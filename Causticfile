script "test" {
    "mkdir -p build"
    "./caustic -q tests/run_tests.cst -o build/caustic-tests"
    "./build/caustic-tests"
}

script "test-aarch64" {
    "mkdir -p build/aarch64"
    "command -v qemu-aarch64 >/dev/null"
    "./caustic -q --target=linux-aarch64 tests/aarch64/scalar_abi.cst -o build/aarch64/scalar_abi"
    "qemu-aarch64 build/aarch64/scalar_abi"
    "./caustic -q --target=linux-aarch64 tests/aarch64/linux_syscalls.cst -o build/aarch64/linux_syscalls"
    "qemu-aarch64 build/aarch64/linux_syscalls"
    "./caustic -q --target=linux-aarch64 tests/threads/t_atomic.cst -o build/aarch64/t_atomic"
    "qemu-aarch64 build/aarch64/t_atomic"
    "./caustic -q --target=linux-aarch64 tests/threads/t_spawn_join.cst -o build/aarch64/t_spawn_join"
    "qemu-aarch64 build/aarch64/t_spawn_join"
    "./caustic -q --target=linux-aarch64 tests/threads/t_sync_full.cst -o build/aarch64/t_sync_full"
    "qemu-aarch64 build/aarch64/t_sync_full"
    "./caustic -q --target=linux-aarch64 tests/aarch64/multi_main.cst tests/aarch64/multi_other.cst -o build/aarch64/multi"
    "qemu-aarch64 build/aarch64/multi"
    "./caustic -q --target=linux-aarch64 --cache build/aarch64/cache src/main.cst -o build/aarch64/caustic"
    "qemu-aarch64 build/aarch64/caustic --version >/dev/null"
    "qemu-aarch64 build/aarch64/caustic -q --target=linux-aarch64 examples/test_sum.cst -o build/aarch64/self-compiled"
    "qemu-aarch64 build/aarch64/self-compiled; test $? -eq 100"
    "./caustic -q --target=linux-aarch64 examples/test_sum.cst"
    "./caustic-as --target=linux-aarch64 examples/test_sum.cst.s"
    "./caustic-ld --target=linux-aarch64 examples/test_sum.cst.s.o -o build/aarch64/manual"
    "qemu-aarch64 build/aarch64/manual; test $? -eq 100"
    "if command -v aarch64-linux-gnu-as >/dev/null && command -v aarch64-linux-gnu-objcopy >/dev/null; then aarch64-linux-gnu-as examples/test_sum.cst.s -o build/aarch64/gnu.o && aarch64-linux-gnu-objcopy -O binary -j .text build/aarch64/gnu.o build/aarch64/gnu.text && aarch64-linux-gnu-objcopy -O binary -j .text examples/test_sum.cst.s.o build/aarch64/internal.text && cmp build/aarch64/gnu.text build/aarch64/internal.text; fi"
}

script "bootstrap" {
    "mkdir -p build"
    "./caustic -O1 src/main.cst -o build/caustic-gen1"
    "./build/caustic-gen1 -O1 src/main.cst -o build/caustic-gen2"
    "./build/caustic-gen2 -O1 src/main.cst -o build/caustic-gen3"
    "cmp -s build/caustic-gen2 build/caustic-gen3 && echo 'bootstrap PASS: gen2 == gen3 (deterministic self-host)' || { echo 'bootstrap FAIL: non-deterministic codegen'; exit 1; }"
}

script "install" {
    "mkdir -p /usr/local/bin /usr/local/lib/caustic/std"
    "cp caustic caustic-as caustic-ld /usr/local/bin/"
    "cp -r std/. /usr/local/lib/caustic/std/"
    "./caustic --shared --allow-unsupported std/libcaustic.cst -o /usr/local/lib/caustic/libcaustic.so"
    "./caustic --target=caustic-x86_64 --mode=compat --shared --allow-unsupported std/libcaustic.cst -o /usr/local/lib/caustic/libcaustic.csl"
    "echo 'caustic installed to /usr/local (std source + libcaustic.so + libcaustic.csl)'"
}

script "uninstall" {
    "rm -f /usr/local/bin/caustic /usr/local/bin/caustic-as /usr/local/bin/caustic-ld"
    "rm -rf /usr/local/lib/caustic"
    "echo 'caustic uninstalled'"
}

script "dist" {
    "mkdir -p caustic-x86_64-linux/bin caustic-x86_64-linux/lib/caustic/std"
    "cp caustic caustic-as caustic-ld caustic-mk caustic-lsp caustic-x86_64-linux/bin/"
    "cp -r std/. caustic-x86_64-linux/lib/caustic/std/"
    "./caustic --shared --allow-unsupported std/libcaustic.cst -o caustic-x86_64-linux/lib/caustic/libcaustic.so"
    "./caustic --target=caustic-x86_64 --mode=compat --shared --allow-unsupported std/libcaustic.cst -o caustic-x86_64-linux/lib/caustic/libcaustic.csl"
    "tar czf caustic-x86_64-linux.tar.gz caustic-x86_64-linux"
    "rm -rf caustic-x86_64-linux"
    "echo 'Created caustic-x86_64-linux.tar.gz (bin + std source + libcaustic.so + libcaustic.csl)'"
}

script "clean" {
    "rm -rf .caustic build"
    "rm -f src/main.cst.s src/main.cst.s.o"
    "rm -f caustic-assembler/main.cst.s caustic-assembler/main.cst.s.o"
    "rm -f caustic-linker/main.cst.s caustic-linker/main.cst.s.o"
    "rm -f caustic-maker/main.cst.s caustic-maker/main.cst.s.o"
}
