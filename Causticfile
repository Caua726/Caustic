name "caustic"
version "0.0.17"
author "Caua"

target "caustic" {
    src "src/main.cst"
    out "caustic"
}

target "caustic-as" {
    src "caustic-assembler/main.cst"
    out "caustic-as"
}

target "caustic-ld" {
    src "caustic-linker/main.cst"
    out "caustic-ld"
}

target "caustic-mk" {
    src "caustic-maker/main.cst"
    out "caustic-mk"
}

target "caustic-lsp" {
    src "lsp/main.cst"
    out "caustic-lsp"
}

// examples

target "hello" {
    src "examples/hello.cst"
    out "build/hello"
}

target "fibonacci" {
    src "examples/fibonacci.cst"
    out "build/fibonacci"
}

target "calculator" {
    src "examples/calculator.cst"
    out "build/calculator"
}

target "structs" {
    src "examples/structs.cst"
    out "build/structs"
}

target "strings" {
    src "examples/strings.cst"
    out "build/strings"
}

target "files" {
    src "examples/files.cst"
    out "build/files"
}

target "enums" {
    src "examples/enums.cst"
    out "build/enums"
}

target "linked_list" {
    src "examples/linked_list.cst"
    out "build/linked_list"
}

target "generics" {
    src "examples/generics.cst"
    out "build/generics"
}

target "ffi" {
    src "examples/ffi.cst"
    out "build/ffi"
}

target "sorting" {
    src "examples/sorting.cst"
    out "build/sorting"
}

target "random" {
    src "examples/random.cst"
    out "build/random"
}

script "test" {
    "./caustic -q tests/run_tests.cst -o /tmp/caustic-tests"
    "/tmp/caustic-tests"
}

script "bootstrap" {
    "./caustic -O1 src/main.cst -o /tmp/caustic-gen1"
    "/tmp/caustic-gen1 -O1 src/main.cst -o /tmp/caustic-gen2"
    "/tmp/caustic-gen2 -O1 src/main.cst -o /tmp/caustic-gen3"
    "cmp -s /tmp/caustic-gen2 /tmp/caustic-gen3 && echo 'bootstrap PASS: gen2 == gen3 (deterministic self-host)' || { echo 'bootstrap FAIL: non-deterministic codegen'; exit 1; }"
}

script "install" {
    "mkdir -p /usr/local/bin /usr/local/lib/caustic/std"
    "cp caustic caustic-as caustic-ld /usr/local/bin/"
    "cp -r std/. /usr/local/lib/caustic/std/"
    "./caustic --shared --allow-unsupported std/libcaustic.cst -o /usr/local/lib/caustic/libcaustic.so"
    "./caustic --target=caustic-x86_64 --mode=compat --shared --allow-unsupported std/libcaustic.cst -o /usr/local/lib/caustic/libcaustic.csl"
    "echo 'caustic installed to /usr/local (std source + libcaustic.so + libcaustic.csl)'"
}

script "uninstall" {
    "rm -f /usr/local/bin/caustic /usr/local/bin/caustic-as /usr/local/bin/caustic-ld"
    "rm -rf /usr/local/lib/caustic"
    "echo 'caustic uninstalled'"
}

script "dist" {
    "mkdir -p caustic-x86_64-linux/bin caustic-x86_64-linux/lib/caustic/std"
    "cp caustic caustic-as caustic-ld caustic-mk caustic-lsp caustic-x86_64-linux/bin/"
    "cp -r std/. caustic-x86_64-linux/lib/caustic/std/"
    "./caustic --shared --allow-unsupported std/libcaustic.cst -o caustic-x86_64-linux/lib/caustic/libcaustic.so"
    "./caustic --target=caustic-x86_64 --mode=compat --shared --allow-unsupported std/libcaustic.cst -o caustic-x86_64-linux/lib/caustic/libcaustic.csl"
    "tar czf caustic-x86_64-linux.tar.gz caustic-x86_64-linux"
    "rm -rf caustic-x86_64-linux"
    "echo 'Created caustic-x86_64-linux.tar.gz (bin + std source + libcaustic.so + libcaustic.csl)'"
}

script "clean" {
    "rm -rf .caustic build"
    "rm -f src/main.cst.s src/main.cst.s.o"
    "rm -f caustic-assembler/main.cst.s caustic-assembler/main.cst.s.o"
    "rm -f caustic-linker/main.cst.s caustic-linker/main.cst.s.o"
    "rm -f caustic-maker/main.cst.s caustic-maker/main.cst.s.o"
}
