use "../../std/mem.cst" as mem;

// === Semantic data structures ===
// All structs live here to avoid cross-module struct issues.
// References to Node/Type from ast.cst use *u8 + cast.

// --- Variable ---
struct Variable {
    name_ptr as *u8;
    name_len as i32;
    ty as *u8;
    flags as i32;
    offset as i32;
    is_global as i32;
    is_extern as i32;
    is_module as i32;
    module_ref as *u8;
    asm_name_ptr as *u8;
    asm_name_len as i32;
    next as *Variable;
}

// --- Scope ---
struct Scope {
    vars as *Variable;
    parent as *Scope;
    is_global as i32;
    next_all as *Scope;
}

// --- Function ---
struct Function {
    name_ptr as *u8;
    name_len as i32;
    return_type as *u8;
    param_types as *u8;
    param_count as i32;
    asm_name_ptr as *u8;
    asm_name_len as i32;
    mod_prefix_ptr as *u8;
    mod_prefix_len as i32;
    is_variadic as i32;
    is_extern as i32;
    next as *Function;
}

// --- Module ---
struct Module {
    name_ptr as *u8;
    name_len as i32;
    scope as *Scope;
    prefix_ptr as *u8;
    prefix_len as i32;
    body as *u8;
    source_dir_ptr as *u8;
    source_dir_len as i32;
    vars_done as i32;
    bodies_done as i32;
    next as *Module;
}

// --- StructDef ---
struct StructDef {
    name_ptr as *u8;
    name_len as i32;
    ty as *u8;
    next as *StructDef;
}

// --- EnumDef ---
struct EnumDef {
    name_ptr as *u8;
    name_len as i32;
    ty as *u8;
    next as *EnumDef;
}

// --- GenericTemplate ---
struct GenericTemplate {
    name_ptr as *u8;
    name_len as i32;
    params as *u8;
    param_count as i32;
    ast as *u8;
    struct_type as *u8;
    is_function as i32;
    mod_prefix_ptr as *u8;
    mod_prefix_len as i32;
    next as *GenericTemplate;
}

// --- GenericInstance ---
struct GenericInstance {
    name_ptr as *u8;
    name_len as i32;
    next as *GenericInstance;
}

// === Constructors ===

fn memzero(p as *u8, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) {
        p[i] = cast(u8, 0);
        i = i + 1;
    }
}

fn new_variable() as *Variable {
    let is *Variable as v = cast(*Variable, mem.galloc(sizeof(Variable)));
    memzero(cast(*u8, v), sizeof(Variable));
    return v;
}

fn new_scope() as *Scope {
    let is *Scope as s = cast(*Scope, mem.galloc(sizeof(Scope)));
    memzero(cast(*u8, s), sizeof(Scope));
    return s;
}

fn new_function() as *Function {
    let is *Function as f = cast(*Function, mem.galloc(sizeof(Function)));
    memzero(cast(*u8, f), sizeof(Function));
    return f;
}

fn new_module() as *Module {
    let is *Module as m = cast(*Module, mem.galloc(sizeof(Module)));
    memzero(cast(*u8, m), sizeof(Module));
    return m;
}

fn new_struct_def() as *StructDef {
    let is *StructDef as s = cast(*StructDef, mem.galloc(sizeof(StructDef)));
    memzero(cast(*u8, s), sizeof(StructDef));
    return s;
}

fn new_enum_def() as *EnumDef {
    let is *EnumDef as e = cast(*EnumDef, mem.galloc(sizeof(EnumDef)));
    memzero(cast(*u8, e), sizeof(EnumDef));
    return e;
}

fn new_generic_template() as *GenericTemplate {
    let is *GenericTemplate as t = cast(*GenericTemplate, mem.galloc(sizeof(GenericTemplate)));
    memzero(cast(*u8, t), sizeof(GenericTemplate));
    return t;
}

fn new_generic_instance() as *GenericInstance {
    let is *GenericInstance as i = cast(*GenericInstance, mem.galloc(sizeof(GenericInstance)));
    memzero(cast(*u8, i), sizeof(GenericInstance));
    return i;
}

// === Packed param_types helpers ===
// param_types: packed array of *u8 (*Type), 8 bytes each

fn pt_alloc(count as i32) as *u8 {
    return mem.galloc(cast(i64, count) * 8);
}

fn pt_set(buf as *u8, idx as i32, ty as *u8) as void {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, idx) * 8);
    *p = cast(i64, ty);
}

fn pt_get(buf as *u8, idx as i32) as *u8 {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, idx) * 8);
    return cast(*u8, *p);
}

// === String helpers ===

fn str_dup(src as *u8, len as i32) as *u8 {
    let is *u8 as dst = mem.galloc(cast(i64, len) + 1);
    mem.memcpy(dst, src, cast(i64, len));
    dst[len] = cast(u8, 0);
    return dst;
}

fn str_eq(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    if (alen != blen) { return 0; }
    if (mem.memcmp(a, b, cast(i64, alen)) != 0) { return 0; }
    return 1;
}

fn str_concat3(a as *u8, alen as i32, b as *u8, blen as i32, c as *u8, clen as i32, out_len as *i32) as *u8 {
    let is i32 as total = alen + blen + clen;
    let is *u8 as buf = mem.galloc(cast(i64, total) + 1);
    mem.memcpy(buf, a, cast(i64, alen));
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, alen)), b, cast(i64, blen));
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, alen) + cast(i64, blen)), c, cast(i64, clen));
    buf[total] = cast(u8, 0);
    *out_len = total;
    return buf;
}
