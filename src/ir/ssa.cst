use "../../std/mem.cst" as mem;
use "defs.cst" as d;
use "cfg.cst" as cfg;
use "dom.cst" as dom;

// === SSA mem2reg pass ===
// Promotes scalar stack variables (accessed via IR_LOAD/IR_STORE with IMM offsets)
// to SSA vregs with phi nodes, then destructs SSA back to conventional form.

let is i32 as MAX_SLOTS with imut = 256;

// === Step 0: Find promotable stack slots ===

struct SlotInfo {
    offset as i64;
    type_ptr as *u8;
    promotable as i32;
    store_count as i32;
    load_count as i32;
}

fn find_promotable(func as *d.IRFunction, slots as *SlotInfo, out_count as *i32) as void {
    let is i32 as count with mut = 0;

    // Pass 1: collect address-taken offsets (IR_ADDR with IMM)
    let is [256]i64 as addr_taken;
    let is i32 as at_count with mut = 0;
    let is *d.IRInst as pre with mut = func.instructions;
    while (cast(i64, pre) != 0) {
        if (pre.is_dead == 0 && pre.op == d.IR_ADDR && pre.src1.op_type == d.OP_IMM) {
            if (at_count < 256) {
                addr_taken[at_count] = pre.src1.imm;
                at_count = at_count + 1;
            }
        }
        pre = pre.next;
    }

    // Pass 2: scan LOAD/STORE with IMM offsets, skip address-taken
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.is_dead == 0) {
            let is i64 as off with mut = 0 - 1;
            let is *u8 as ty with mut = cast(*u8, 0);
            let is i32 as is_store with mut = 0;

            if (inst.op == d.IR_LOAD && inst.src1.op_type == d.OP_IMM) {
                off = inst.src1.imm;
                ty = inst.cast_to;
            }
            if (inst.op == d.IR_STORE && inst.dest.op_type == d.OP_IMM) {
                off = inst.dest.imm;
                ty = inst.cast_to;
                is_store = 1;
            }

            if (off >= 0) {
                // Find or add slot
                let is i32 as idx with mut = cast(i32, 0 - 1);
                let is i32 as si with mut = 0;
                while (si < count) {
                    let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, si) * sizeof(SlotInfo));
                    if (s.offset == off) { idx = si; si = count; }
                    si = si + 1;
                }
                if (idx < 0 && count < MAX_SLOTS) {
                    idx = count;
                    let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, idx) * sizeof(SlotInfo));
                    s.offset = off;
                    s.type_ptr = ty;
                    s.promotable = 1;
                    s.store_count = 0;
                    s.load_count = 0;
                    count = count + 1;
                }
                if (idx >= 0) {
                    let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, idx) * sizeof(SlotInfo));
                    if (is_store == 1) { s.store_count = s.store_count + 1; }
                    else { s.load_count = s.load_count + 1; }
                    if (cast(i64, ty) != 0) { s.type_ptr = ty; }
                }
            }
        }
        inst = inst.next;
    }

    // Mark address-taken slots as non-promotable
    let is i32 as ai with mut = 0;
    while (ai < at_count) {
        let is i64 as addr_off = addr_taken[ai];
        let is i32 as si with mut = 0;
        while (si < count) {
            let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, si) * sizeof(SlotInfo));
            if (s.offset == addr_off) { s.promotable = 0; si = count; }
            si = si + 1;
        }
        ai = ai + 1;
    }

    *out_count = count;
}

// Fast O(1) slot lookup by offset using direct-mapped table
// off_map[off] = slot_index (or -1). Max offset tracked = 8192.
let is i32 as OFF_MAP_MAX with imut = 8192;

fn build_off_map(slots as *SlotInfo, count as i32, off_map as *i32) as void {
    let is i32 as i with mut = 0;
    while (i < OFF_MAP_MAX) {
        let is *i32 as p = cast(*i32, cast(i64, off_map) + cast(i64, i) * 4);
        *p = cast(i32, 0 - 1);
        i = i + 1;
    }
    i = 0;
    while (i < count) {
        let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, i) * sizeof(SlotInfo));
        if (s.promotable == 1 && s.offset >= 0 && s.offset < cast(i64, OFF_MAP_MAX)) {
            let is *i32 as p = cast(*i32, cast(i64, off_map) + cast(i64, s.offset) * 4);
            *p = i;
        }
        i = i + 1;
    }
}

fn fast_slot_index(off_map as *i32, off as i64) as i32 {
    if (off < 0 || off >= cast(i64, OFF_MAP_MAX)) { return cast(i32, 0 - 1); }
    let is *i32 as p = cast(*i32, cast(i64, off_map) + cast(i64, off) * 4);
    return *p;
}

// === Step 4: Insert phi nodes ===
// Returns count of phis inserted. phi_block[i] = block of phi i, phi_slot[i] = slot index,
// phi_vreg[i] = dest vreg of phi, phi_args[i * max_preds + j] = arg vreg from pred j

fn insert_phis(blocks as *cfg.BasicBlock, nblocks as i32,
               slots as *SlotInfo, nslots as i32,
               df_out as *i32, df_starts as *i32, df_counts as *i32,
               func as *d.IRFunction,
               phi_block as *i32, phi_slot as *i32, phi_vreg as *i32,
               phi_args as *i32, max_preds as i32,
               out_nphi as *i32) as void {
    let is i32 as next_vreg with mut = func.vreg_count;
    let is i32 as nphi with mut = 0;

    // For each promotable slot, find def blocks and insert phis at DF
    let is [256]i32 as worklist;
    let is i32 as hp_size = nblocks * nslots + 1;
    let is *i32 as has_phi = cast(*i32, mem.galloc(cast(i64, hp_size) * 4));
    let is i32 as hi with mut = 0;
    while (hi < hp_size) {
        let is *i32 as hpp = cast(*i32, cast(i64, has_phi) + cast(i64, hi) * 4);
        *hpp = 0;
        hi = hi + 1;
    }

    let is i32 as si with mut = 0;
    while (si < nslots) {
        let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, si) * sizeof(SlotInfo));
        if (s.promotable == 1) {
            // Collect def blocks (blocks with IR_STORE to this offset)
            let is i32 as wl_count with mut = 0;
            let is i32 as bi with mut = 0;
            while (bi < nblocks) {
                let is *cfg.BasicBlock as bb = cast(*cfg.BasicBlock, cast(i64, blocks) + cast(i64, bi) * sizeof(cfg.BasicBlock));
                let is *d.IRInst as inst with mut = bb.first;
                let is i32 as found with mut = 0;
                while (cast(i64, inst) != 0 && found == 0) {
                    if (inst.is_dead == 0 && inst.op == d.IR_STORE && inst.dest.op_type == d.OP_IMM) {
                        if (inst.dest.imm == s.offset) { found = 1; }
                    }
                    if (cast(i64, inst) == cast(i64, bb.last)) { inst = cast(*d.IRInst, 0); }
                    else { inst = inst.next; }
                }
                if (found == 1 && wl_count < 256) {
                    worklist[wl_count] = bi;
                    wl_count = wl_count + 1;
                }
                bi = bi + 1;
            }

            // Worklist: for each def block, insert phis at DF
            let is i32 as wi with mut = 0;
            while (wi < wl_count) {
                let is i32 as def_b = worklist[wi];
                let is *i32 as dsp = cast(*i32, cast(i64, df_starts) + cast(i64, def_b) * 4);
                let is *i32 as dcp = cast(*i32, cast(i64, df_counts) + cast(i64, def_b) * 4);
                let is i32 as di with mut = 0;
                while (di < *dcp) {
                    let is *i32 as dfp = cast(*i32, cast(i64, df_out) + cast(i64, *dsp + di) * 4);
                    let is i32 as df_block = *dfp;
                    let is i32 as hp_idx = df_block * nslots + si;
                    let is *i32 as hp_ptr = cast(*i32, cast(i64, has_phi) + cast(i64, hp_idx) * 4);
                    if (*hp_ptr == 0) {
                        *hp_ptr = 1;
                        // Insert phi
                        let is *i32 as pbp = cast(*i32, cast(i64, phi_block) + cast(i64, nphi) * 4);
                        *pbp = df_block;
                        let is *i32 as psp2 = cast(*i32, cast(i64, phi_slot) + cast(i64, nphi) * 4);
                        *psp2 = si;
                        let is *i32 as pvp = cast(*i32, cast(i64, phi_vreg) + cast(i64, nphi) * 4);
                        *pvp = next_vreg;
                        next_vreg = next_vreg + 1;
                        // Init phi args to -1
                        let is i32 as ai with mut = 0;
                        while (ai < max_preds) {
                            let is *i32 as pap = cast(*i32, cast(i64, phi_args) + cast(i64, nphi * max_preds + ai) * 4);
                            *pap = cast(i32, 0 - 1);
                            ai = ai + 1;
                        }
                        nphi = nphi + 1;
                        // Add df_block to worklist if not already a def block
                        if (wl_count < 256) {
                            worklist[wl_count] = df_block;
                            wl_count = wl_count + 1;
                        }
                    }
                    di = di + 1;
                }
                wi = wi + 1;
            }
        }
        si = si + 1;
    }

    func.vreg_count = next_vreg;
    *out_nphi = nphi;
    mem.gfree(cast(*u8, has_phi));
}

// === Step 5: SSA Rename ===
// DFS over dominator tree, maintaining a definition stack per slot

fn ssa_rename(blocks as *cfg.BasicBlock, nblocks as i32,
              slots as *SlotInfo, nslots as i32,
              func as *d.IRFunction,
              phi_block as *i32, phi_slot as *i32, phi_vreg as *i32,
              phi_args as *i32, max_preds as i32, nphi as i32,
              preds as *i32, pred_starts as *i32, pred_counts as *i32) as void {
    // Build fast offset→slot map
    let is *i32 as off_map = cast(*i32, mem.galloc(cast(i64, OFF_MAP_MAX) * 4));
    build_off_map(slots, nslots, off_map);

    // Build per-block phi index: phi_by_block_start[b], phi_by_block_count[b], phi_order[i]
    let is *i32 as pb_count = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as pb_start = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as phi_order = cast(*i32, mem.galloc(cast(i64, nphi + 1) * 4));
    let is i32 as pbi with mut = 0;
    while (pbi < nblocks) {
        let is *i32 as p = cast(*i32, cast(i64, pb_count) + cast(i64, pbi) * 4); *p = 0;
        pbi = pbi + 1;
    }
    pbi = 0;
    while (pbi < nphi) {
        let is *i32 as pbp = cast(*i32, cast(i64, phi_block) + cast(i64, pbi) * 4);
        let is *i32 as pbc = cast(*i32, cast(i64, pb_count) + cast(i64, *pbp) * 4);
        *pbc = *pbc + 1;
        pbi = pbi + 1;
    }
    let is i32 as pb_total with mut = 0;
    pbi = 0;
    while (pbi < nblocks) {
        let is *i32 as ps = cast(*i32, cast(i64, pb_start) + cast(i64, pbi) * 4); *ps = pb_total;
        let is *i32 as pc = cast(*i32, cast(i64, pb_count) + cast(i64, pbi) * 4);
        pb_total = pb_total + *pc;
        *pc = 0;
        pbi = pbi + 1;
    }
    pbi = 0;
    while (pbi < nphi) {
        let is *i32 as pbp = cast(*i32, cast(i64, phi_block) + cast(i64, pbi) * 4);
        let is i32 as blk = *pbp;
        let is *i32 as ps = cast(*i32, cast(i64, pb_start) + cast(i64, blk) * 4);
        let is *i32 as pc = cast(*i32, cast(i64, pb_count) + cast(i64, blk) * 4);
        let is *i32 as op = cast(*i32, cast(i64, phi_order) + cast(i64, *ps + *pc) * 4);
        *op = pbi;
        *pc = *pc + 1;
        pbi = pbi + 1;
    }

    let is i32 as MAX_DEPTH = 512;
    let is *i32 as def_stack = cast(*i32, mem.galloc(cast(i64, nslots * MAX_DEPTH) * 4));
    let is *i32 as def_top = cast(*i32, mem.galloc(cast(i64, nslots) * 4));
    let is i32 as si with mut = 0;
    while (si < nslots) {
        let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, si) * 4);
        *tp = 0;
        si = si + 1;
    }

    // Build dominator tree children list
    let is *i32 as dom_child_start = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as dom_child_count = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as dom_children = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is i32 as bi with mut = 0;
    while (bi < nblocks) {
        let is *i32 as dcp = cast(*i32, cast(i64, dom_child_count) + cast(i64, bi) * 4);
        *dcp = 0;
        bi = bi + 1;
    }
    bi = 1; // skip entry
    while (bi < nblocks) {
        let is *cfg.BasicBlock as bb = cast(*cfg.BasicBlock, cast(i64, blocks) + cast(i64, bi) * sizeof(cfg.BasicBlock));
        if (bb.idom >= 0) {
            let is *i32 as dcp = cast(*i32, cast(i64, dom_child_count) + cast(i64, bb.idom) * 4);
            *dcp = *dcp + 1;
        }
        bi = bi + 1;
    }
    let is i32 as total with mut = 0;
    bi = 0;
    while (bi < nblocks) {
        let is *i32 as dsp = cast(*i32, cast(i64, dom_child_start) + cast(i64, bi) * 4);
        *dsp = total;
        let is *i32 as dcp = cast(*i32, cast(i64, dom_child_count) + cast(i64, bi) * 4);
        total = total + *dcp;
        *dcp = 0;
        bi = bi + 1;
    }
    bi = 1;
    while (bi < nblocks) {
        let is *cfg.BasicBlock as bb = cast(*cfg.BasicBlock, cast(i64, blocks) + cast(i64, bi) * sizeof(cfg.BasicBlock));
        if (bb.idom >= 0) {
            let is i32 as par = bb.idom;
            let is *i32 as dsp = cast(*i32, cast(i64, dom_child_start) + cast(i64, par) * 4);
            let is *i32 as dcp = cast(*i32, cast(i64, dom_child_count) + cast(i64, par) * 4);
            let is *i32 as cp = cast(*i32, cast(i64, dom_children) + cast(i64, *dsp + *dcp) * 4);
            *cp = bi;
            *dcp = *dcp + 1;
        }
        bi = bi + 1;
    }

    // Iterative DFS over dominator tree for renaming
    let is *i32 as rn_stack = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as rn_child_idx = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as rn_save_tops = cast(*i32, mem.galloc(cast(i64, nblocks * nslots) * 4));
    let is i32 as rn_sp with mut = 0;

    // Push entry block
    let is *i32 as rs0 = cast(*i32, cast(i64, rn_stack));
    *rs0 = 0;
    let is *i32 as rc0 = cast(*i32, cast(i64, rn_child_idx));
    *rc0 = 0;
    // Save stack tops
    si = 0;
    while (si < nslots) {
        let is *i32 as sp2 = cast(*i32, cast(i64, rn_save_tops) + cast(i64, si) * 4);
        let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, si) * 4);
        *sp2 = *tp;
        si = si + 1;
    }
    rn_sp = 1;

    while (rn_sp > 0) {
        let is i32 as cur_top = rn_sp - 1;
        let is *i32 as rsp = cast(*i32, cast(i64, rn_stack) + cast(i64, cur_top) * 4);
        let is i32 as b = *rsp;
        let is *i32 as rcp = cast(*i32, cast(i64, rn_child_idx) + cast(i64, cur_top) * 4);

        if (*rcp == 0) {
            // First visit: process this block

            // Process phis in this block via per-block index
            let is *i32 as pbs = cast(*i32, cast(i64, pb_start) + cast(i64, b) * 4);
            let is *i32 as pbc = cast(*i32, cast(i64, pb_count) + cast(i64, b) * 4);
            let is i32 as phi_i with mut = 0;
            while (phi_i < *pbc) {
                let is *i32 as pop = cast(*i32, cast(i64, phi_order) + cast(i64, *pbs + phi_i) * 4);
                let is i32 as pi = *pop;
                let is *i32 as pslp = cast(*i32, cast(i64, phi_slot) + cast(i64, pi) * 4);
                let is i32 as slot = *pslp;
                let is *i32 as pvp = cast(*i32, cast(i64, phi_vreg) + cast(i64, pi) * 4);
                let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, slot) * 4);
                if (*tp < MAX_DEPTH) {
                    let is *i32 as dsp2 = cast(*i32, cast(i64, def_stack) + cast(i64, slot * MAX_DEPTH + *tp) * 4);
                    *dsp2 = *pvp;
                    *tp = *tp + 1;
                }
                phi_i = phi_i + 1;
            }

            // Process instructions in block
            let is *cfg.BasicBlock as bb = cast(*cfg.BasicBlock, cast(i64, blocks) + cast(i64, b) * sizeof(cfg.BasicBlock));
            let is *d.IRInst as inst with mut = bb.first;
            let is i32 as done with mut = 0;
            while (done == 0) {
                if (inst.is_dead == 0) {
                    // Replace LOAD from promotable offset with MOV from current def
                    if (inst.op == d.IR_LOAD && inst.src1.op_type == d.OP_IMM) {
                        let is i32 as sidx = fast_slot_index(off_map, inst.src1.imm);
                        if (sidx >= 0) {
                            let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, sidx) * 4);
                            if (*tp > 0) {
                                let is *i32 as dsp2 = cast(*i32, cast(i64, def_stack) + cast(i64, sidx * MAX_DEPTH + *tp - 1) * 4);
                                let is i32 as cur_def = *dsp2;
                                // Check if we need sign extension (type size < 8)
                                let is i32 as need_cast with mut = 0;
                                if (cast(i64, inst.cast_to) != 0) {
                                    let is *i32 as szp = cast(*i32, cast(i64, inst.cast_to) + 28);
                                    if (*szp < 8) { need_cast = 1; }
                                }
                                if (need_cast == 1) {
                                    // Replace with CAST for sign extension
                                    inst.op = d.IR_CAST;
                                    inst.src1.op_type = d.OP_VREG;
                                    inst.src1.vreg = cur_def;
                                    // cast_to already set, set cast_from = cast_to (same type, triggers truncation+extension)
                                    inst.cast_from = inst.cast_to;
                                } else {
                                    // Replace with MOV
                                    inst.op = d.IR_MOV;
                                    inst.src1.op_type = d.OP_VREG;
                                    inst.src1.vreg = cur_def;
                                }
                            }
                        }
                    }
                    // Replace STORE to promotable offset: mark dead, push value onto def stack
                    if (inst.op == d.IR_STORE && inst.dest.op_type == d.OP_IMM) {
                        let is i32 as sidx = fast_slot_index(off_map, inst.dest.imm);
                        if (sidx >= 0) {
                            if (inst.src1.op_type == d.OP_VREG) {
                                let is i32 as val_vreg = inst.src1.vreg;
                                let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, sidx) * 4);
                                if (*tp < MAX_DEPTH) {
                                    let is *i32 as dsp2 = cast(*i32, cast(i64, def_stack) + cast(i64, sidx * MAX_DEPTH + *tp) * 4);
                                    *dsp2 = val_vreg;
                                    *tp = *tp + 1;
                                }
                            }
                            inst.is_dead = 1;
                        }
                    }
                }
                if (cast(i64, inst) == cast(i64, bb.last)) { done = 1; }
                else { inst = inst.next; }
            }

            // Fill phi args in successors using per-block phi index
            if (bb.succ0 >= 0) {
                let is i32 as s = bb.succ0;
                let is *i32 as psp3 = cast(*i32, cast(i64, pred_starts) + cast(i64, s) * 4);
                let is *i32 as pcp3 = cast(*i32, cast(i64, pred_counts) + cast(i64, s) * 4);
                let is i32 as pred_idx with mut = 0;
                let is i32 as pii with mut = 0;
                while (pii < *pcp3) {
                    let is *i32 as pp2 = cast(*i32, cast(i64, preds) + cast(i64, *psp3 + pii) * 4);
                    if (*pp2 == b) { pred_idx = pii; pii = *pcp3; }
                    pii = pii + 1;
                }
                let is *i32 as spbs = cast(*i32, cast(i64, pb_start) + cast(i64, s) * 4);
                let is *i32 as spbc = cast(*i32, cast(i64, pb_count) + cast(i64, s) * 4);
                let is i32 as spi with mut = 0;
                while (spi < *spbc) {
                    let is *i32 as sop = cast(*i32, cast(i64, phi_order) + cast(i64, *spbs + spi) * 4);
                    let is i32 as pi = *sop;
                    let is *i32 as pslp2 = cast(*i32, cast(i64, phi_slot) + cast(i64, pi) * 4);
                    let is i32 as slot = *pslp2;
                    let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, slot) * 4);
                    if (*tp > 0) {
                        let is *i32 as dsp2 = cast(*i32, cast(i64, def_stack) + cast(i64, slot * MAX_DEPTH + *tp - 1) * 4);
                        let is *i32 as pap = cast(*i32, cast(i64, phi_args) + cast(i64, pi * max_preds + pred_idx) * 4);
                        *pap = *dsp2;
                    }
                    spi = spi + 1;
                }
            }
            if (bb.succ1 >= 0) {
                let is i32 as s = bb.succ1;
                let is *i32 as psp3 = cast(*i32, cast(i64, pred_starts) + cast(i64, s) * 4);
                let is *i32 as pcp3 = cast(*i32, cast(i64, pred_counts) + cast(i64, s) * 4);
                let is i32 as pred_idx with mut = 0;
                let is i32 as pii with mut = 0;
                while (pii < *pcp3) {
                    let is *i32 as pp2 = cast(*i32, cast(i64, preds) + cast(i64, *psp3 + pii) * 4);
                    if (*pp2 == b) { pred_idx = pii; pii = *pcp3; }
                    pii = pii + 1;
                }
                let is *i32 as spbs = cast(*i32, cast(i64, pb_start) + cast(i64, s) * 4);
                let is *i32 as spbc = cast(*i32, cast(i64, pb_count) + cast(i64, s) * 4);
                let is i32 as spi with mut = 0;
                while (spi < *spbc) {
                    let is *i32 as sop = cast(*i32, cast(i64, phi_order) + cast(i64, *spbs + spi) * 4);
                    let is i32 as pi = *sop;
                    let is *i32 as pslp2 = cast(*i32, cast(i64, phi_slot) + cast(i64, pi) * 4);
                    let is i32 as slot = *pslp2;
                    let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, slot) * 4);
                    if (*tp > 0) {
                        let is *i32 as dsp2 = cast(*i32, cast(i64, def_stack) + cast(i64, slot * MAX_DEPTH + *tp - 1) * 4);
                        let is *i32 as pap = cast(*i32, cast(i64, phi_args) + cast(i64, pi * max_preds + pred_idx) * 4);
                        *pap = *dsp2;
                    }
                    spi = spi + 1;
                }
            }
        }

        // Push next dominator tree child or pop
        let is *i32 as dcsp = cast(*i32, cast(i64, dom_child_start) + cast(i64, b) * 4);
        let is *i32 as dccp = cast(*i32, cast(i64, dom_child_count) + cast(i64, b) * 4);
        if (*rcp < *dccp) {
            let is *i32 as child_p = cast(*i32, cast(i64, dom_children) + cast(i64, *dcsp + *rcp) * 4);
            let is i32 as child = *child_p;
            *rcp = *rcp + 1;
            // Save tops for child
            let is *i32 as save_base = cast(*i32, cast(i64, rn_save_tops) + cast(i64, rn_sp * nslots) * 4);
            si = 0;
            while (si < nslots) {
                let is *i32 as sv = cast(*i32, cast(i64, save_base) + cast(i64, si) * 4);
                let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, si) * 4);
                *sv = *tp;
                si = si + 1;
            }
            // Push child
            let is *i32 as nrs = cast(*i32, cast(i64, rn_stack) + cast(i64, rn_sp) * 4);
            *nrs = child;
            let is *i32 as nrc = cast(*i32, cast(i64, rn_child_idx) + cast(i64, rn_sp) * 4);
            *nrc = 0;
            rn_sp = rn_sp + 1;
        } else {
            // Pop: restore def stack tops
            let is *i32 as save_base = cast(*i32, cast(i64, rn_save_tops) + cast(i64, cur_top * nslots) * 4);
            si = 0;
            while (si < nslots) {
                let is *i32 as sv = cast(*i32, cast(i64, save_base) + cast(i64, si) * 4);
                let is *i32 as tp = cast(*i32, cast(i64, def_top) + cast(i64, si) * 4);
                *tp = *sv;
                si = si + 1;
            }
            rn_sp = rn_sp - 1;
        }
    }

    mem.gfree(cast(*u8, def_stack));
    mem.gfree(cast(*u8, def_top));
    mem.gfree(cast(*u8, dom_child_start));
    mem.gfree(cast(*u8, dom_child_count));
    mem.gfree(cast(*u8, dom_children));
    mem.gfree(cast(*u8, rn_stack));
    mem.gfree(cast(*u8, rn_child_idx));
    mem.gfree(cast(*u8, rn_save_tops));
    mem.gfree(cast(*u8, off_map));
    mem.gfree(cast(*u8, pb_count));
    mem.gfree(cast(*u8, pb_start));
    mem.gfree(cast(*u8, phi_order));
}

// === Step 6: SSA Destruction — resolve phis to copies ===

fn destroy_ssa(blocks as *cfg.BasicBlock, nblocks as i32,
               func as *d.IRFunction,
               phi_block as *i32, phi_slot as *i32, phi_vreg as *i32,
               phi_args as *i32, max_preds as i32, nphi as i32,
               preds as *i32, pred_starts as *i32, pred_counts as *i32,
               slots as *SlotInfo, nslots as i32) as void {
    // For each phi, insert MOV at end of each predecessor (before terminator)
    let is i32 as pi with mut = 0;
    while (pi < nphi) {
        let is *i32 as pbp = cast(*i32, cast(i64, phi_block) + cast(i64, pi) * 4);
        let is i32 as b = *pbp;
        let is *i32 as pvp = cast(*i32, cast(i64, phi_vreg) + cast(i64, pi) * 4);
        let is i32 as phi_dst = *pvp;

        let is *i32 as psp = cast(*i32, cast(i64, pred_starts) + cast(i64, b) * 4);
        let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, b) * 4);

        let is i32 as ai with mut = 0;
        while (ai < *pcp) {
            let is *i32 as pap = cast(*i32, cast(i64, phi_args) + cast(i64, pi * max_preds + ai) * 4);
            let is i32 as arg_vreg = *pap;
            if (arg_vreg >= 0) {
                // Insert MOV phi_dst = arg_vreg before terminator of predecessor
                let is *i32 as pp = cast(*i32, cast(i64, preds) + cast(i64, *psp + ai) * 4);
                let is i32 as pred = *pp;
                let is *cfg.BasicBlock as pbb = cast(*cfg.BasicBlock, cast(i64, blocks) + cast(i64, pred) * sizeof(cfg.BasicBlock));

                let is *d.IRInst as mov = d.new_inst(d.IR_MOV);
                mov.dest.op_type = d.OP_VREG;
                mov.dest.vreg = phi_dst;
                mov.src1.op_type = d.OP_VREG;
                mov.src1.vreg = arg_vreg;

                // Annotate with slot type for i32 safety
                let is *i32 as pslp = cast(*i32, cast(i64, phi_slot) + cast(i64, pi) * 4);
                let is i32 as slot_idx = *pslp;
                let is *SlotInfo as slot = cast(*SlotInfo, cast(i64, slots) + cast(i64, slot_idx) * sizeof(SlotInfo));
                if (cast(i64, slot.type_ptr) != 0) {
                    let is *i32 as szp = cast(*i32, cast(i64, slot.type_ptr) + 28);
                    if (*szp < 8) {
                        mov.cast_to = slot.type_ptr;
                        mov.cast_from = slot.type_ptr;
                    }
                }

                // Find instruction before terminator
                let is *d.IRInst as term = pbb.last;
                if (term.op == d.IR_JMP || term.op == d.IR_JZ || term.op == d.IR_JNZ) {
                    // Insert before terminator
                    let is *d.IRInst as prev with mut = pbb.first;
                    if (cast(i64, prev) == cast(i64, term)) {
                        // Block has only the terminator — insert before it
                        mov.next = term;
                        let is *d.IRInst as scan with mut = func.instructions;
                        if (cast(i64, scan) == cast(i64, term)) {
                            func.instructions = mov;
                        } else {
                            while (cast(i64, scan) != 0 && cast(i64, scan.next) != cast(i64, term)) {
                                scan = scan.next;
                            }
                            if (cast(i64, scan) != 0) { scan.next = mov; }
                        }
                        pbb.first = mov;
                    } else {
                        while (cast(i64, prev.next) != cast(i64, term)) { prev = prev.next; }
                        cfg.insert_after(prev, mov);
                    }
                } else {
                    // No terminator branch — insert after last instruction
                    cfg.insert_after(term, mov);
                }
            }
            ai = ai + 1;
        }
        pi = pi + 1;
    }
}

// === Main entry point ===

fn mem2reg(func as *d.IRFunction) as void {
    if (func.vreg_count == 0) { return; }

    // Step 0: find promotable slots
    let is *SlotInfo as slots = cast(*SlotInfo, mem.galloc(cast(i64, MAX_SLOTS) * sizeof(SlotInfo)));
    let is i32 as nslots with mut = 0;
    find_promotable(func, slots, &nslots);

    // Check if any slots are promotable
    let is i32 as any_promo with mut = 0;
    let is i32 as si with mut = 0;
    while (si < nslots) {
        let is *SlotInfo as s = cast(*SlotInfo, cast(i64, slots) + cast(i64, si) * sizeof(SlotInfo));
        if (s.promotable == 1) { any_promo = 1; }
        si = si + 1;
    }
    if (any_promo == 0) { mem.gfree(cast(*u8, slots)); return; }

    // Step 1: build CFG
    let is *cfg.BasicBlock as blocks = cast(*cfg.BasicBlock, mem.galloc(cast(i64, cfg.MAX_BLOCKS) * sizeof(cfg.BasicBlock)));
    let is i32 as lc = func.label_count + 1;
    let is *i32 as label_to_bb = cast(*i32, mem.galloc(cast(i64, lc) * 4));
    let is i32 as li with mut = 0;
    while (li < lc) {
        let is *i32 as p = cast(*i32, cast(i64, label_to_bb) + cast(i64, li) * 4);
        *p = 0;
        li = li + 1;
    }
    let is i32 as nblocks with mut = 0;
    cfg.build_cfg(func, blocks, &nblocks, label_to_bb);
    if (nblocks <= 1) {
        mem.gfree(cast(*u8, slots));
        mem.gfree(cast(*u8, blocks));
        mem.gfree(cast(*u8, label_to_bb));
        return;
    }

    // Build predecessor lists
    let is i32 as max_edges = nblocks * 2 + 4;
    let is *i32 as preds_arr = cast(*i32, mem.galloc(cast(i64, max_edges) * 4));
    let is *i32 as pred_starts = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as pred_counts = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    cfg.build_preds(blocks, nblocks, preds_arr, pred_starts, pred_counts);

    // Step 2: compute RPO + dominance
    let is *i32 as rpo_order = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is i32 as rpo_count with mut = 0;
    cfg.compute_rpo(blocks, nblocks, rpo_order, &rpo_count);
    dom.compute_idom(blocks, nblocks, rpo_order, rpo_count, preds_arr, pred_starts, pred_counts);

    // Step 3: compute dominance frontiers
    let is i32 as max_df with mut = nblocks * nblocks;
    if (max_df > 65536) { max_df = 65536; }
    let is *i32 as df_out = cast(*i32, mem.galloc(cast(i64, max_df) * 4));
    let is *i32 as df_starts = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    let is *i32 as df_counts = cast(*i32, mem.galloc(cast(i64, nblocks) * 4));
    dom.compute_df(blocks, nblocks, preds_arr, pred_starts, pred_counts, df_out, df_starts, df_counts);

    // Step 4: insert phis
    let is i32 as max_preds with mut = 0;
    let is i32 as bi with mut = 0;
    while (bi < nblocks) {
        let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, bi) * 4);
        if (*pcp > max_preds) { max_preds = *pcp; }
        bi = bi + 1;
    }
    if (max_preds < 2) { max_preds = 2; }
    let is i32 as max_phis with mut = nslots * nblocks;
    if (max_phis > 4096) { max_phis = 4096; }
    let is *i32 as phi_block = cast(*i32, mem.galloc(cast(i64, max_phis) * 4));
    let is *i32 as phi_slot = cast(*i32, mem.galloc(cast(i64, max_phis) * 4));
    let is *i32 as phi_vreg = cast(*i32, mem.galloc(cast(i64, max_phis) * 4));
    let is *i32 as phi_args = cast(*i32, mem.galloc(cast(i64, max_phis * max_preds) * 4));
    let is i32 as nphi with mut = 0;
    insert_phis(blocks, nblocks, slots, nslots, df_out, df_starts, df_counts,
                func, phi_block, phi_slot, phi_vreg, phi_args, max_preds, &nphi);

    // Step 5: SSA rename
    ssa_rename(blocks, nblocks, slots, nslots, func,
               phi_block, phi_slot, phi_vreg, phi_args, max_preds, nphi,
               preds_arr, pred_starts, pred_counts);

    // Step 6: SSA destruction (phi → copies)
    if (nphi > 0) {
        destroy_ssa(blocks, nblocks, func,
                    phi_block, phi_slot, phi_vreg, phi_args, max_preds, nphi,
                    preds_arr, pred_starts, pred_counts,
                    slots, nslots);
    }

    // Cleanup
    mem.gfree(cast(*u8, slots));
    mem.gfree(cast(*u8, blocks));
    mem.gfree(cast(*u8, label_to_bb));
    mem.gfree(cast(*u8, preds_arr));
    mem.gfree(cast(*u8, pred_starts));
    mem.gfree(cast(*u8, pred_counts));
    mem.gfree(cast(*u8, rpo_order));
    mem.gfree(cast(*u8, df_out));
    mem.gfree(cast(*u8, df_starts));
    mem.gfree(cast(*u8, df_counts));
    mem.gfree(cast(*u8, phi_block));
    mem.gfree(cast(*u8, phi_slot));
    mem.gfree(cast(*u8, phi_vreg));
    mem.gfree(cast(*u8, phi_args));
}
