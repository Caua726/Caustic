use "defs.cst" as d;
use "opt_unroll.cst" as ur;

// === Auto-vectorizer: integer i64 sum reduction `s += a[i]` ===
//
// -O2 only, run at codegen time (gen_func), like the unroller. SAFE first target:
// a sum reduction only READS the array, so no aliasing analysis is needed, and
// integer add is associative so reassociating into SIMD lanes is exact.
//
// Matches the canonical counted loop `while (i < N) { s = s + a[i]; i = i+1; }`
// with N a small even compile-time constant. Rewrites it (fully unrolled, no
// vector loop) to:
//     vacc = 0 (xmm)
//     for k in 0,2,4,...,N-2:  vacc += movdqu[a + k*8]   (paddq, 2 lanes)
//     s = s_init + (vacc.lane0 + vacc.lane1)
// Only the SCALAR loop is replaced; correctness verified vs the scalar version.

let is i32 as VEC_MAX_TRIP with imut = 64;

fn vec_new_vreg(func as *d.IRFunction) as i32 {
    let is i32 as v = func.vreg_count;
    func.vreg_count = func.vreg_count + 1;
    return v;
}

// append an instruction after `after`, return the new inst (becomes next `after`).
fn vec_emit(after as *d.IRInst, ni as *d.IRInst) as *d.IRInst {
    ni.next = after.next;
    after.next = ni;
    return ni;
}
// resolve through single-def MOV copies AND no-op CASTs (i32->i32, same type).
// i32 reductions are full of `CAST vN = vM (i32->i32)` no-ops that the MOV-only
// ur.ur_resolve can't see past; following them lets the recurrence match.
fn vec_resolve(def_inst as *i64, def_count as *i32, vc as i32, v as i32) as i32 {
    let is i32 as cur with mut = v;
    let is i32 as guard with mut = 0;
    while (guard < 64) {
        if (cur < 0 || cur >= vc) { return cur; }
        let is *i32 as dcp = cast(*i32, cast(i64, def_count) + cast(i64, cur) * 4);
        if (*dcp != 1) { return cur; }
        let is *i64 as dip = cast(*i64, cast(i64, def_inst) + cast(i64, cur) * 8);
        let is *d.IRInst as di = cast(*d.IRInst, *dip);
        if (cast(i64, di) == 0) { return cur; }
        if (di.op == d.IR_MOV && di.src1.op_type == d.OP_VREG) { cur = di.src1.vreg; }
        else if (di.op == d.IR_CAST && di.src1.op_type == d.OP_VREG && cast(i64, di.cast_to) == cast(i64, di.cast_from)) { cur = di.src1.vreg; }
        else { return cur; }
        guard = guard + 1;
    }
    return cur;
}
fn vec_const(def_inst as *i64, def_count as *i32, vc as i32, v as i32, out as *i64) as i32 {
    let is i32 as cur with mut = v;
    let is i32 as guard with mut = 0;
    while (guard < 64) {
        if (cur < 0 || cur >= vc) { return 0; }
        let is *i32 as dcp = cast(*i32, cast(i64, def_count) + cast(i64, cur) * 4);
        if (*dcp != 1) { return 0; }
        let is *i64 as dip = cast(*i64, cast(i64, def_inst) + cast(i64, cur) * 8);
        let is *d.IRInst as di = cast(*d.IRInst, *dip);
        if (cast(i64, di) == 0) { return 0; }
        if (di.op == d.IR_IMM && di.src1.op_type == d.OP_IMM) { *out = di.src1.imm; return 1; }
        if (di.op == d.IR_MOV && di.src1.op_type == d.OP_VREG) { cur = di.src1.vreg; guard = guard + 1; }
        else if (di.op == d.IR_CAST && di.src1.op_type == d.OP_VREG && cast(i64, di.cast_to) == cast(i64, di.cast_from)) { cur = di.src1.vreg; guard = guard + 1; }
        else { return 0; }
    }
    return 0;
}
fn vec_val_const(def_inst as *i64, def_count as *i32, vc as i32, op_type as i32, vreg as i32, imm as i64, out as *i64) as i32 {
    if (op_type == d.OP_IMM) { *out = imm; return 1; }
    if (op_type == d.OP_VREG) { return vec_const(def_inst, def_count, vc, vreg, out); }
    return 0;
}
fn vec_add_is_iv_plus1(add as *d.IRInst, def_inst as *i64, def_count as *i32, vc as i32, iv as i32) as i32 {
    if (cast(i64, add) == 0 || add.op != d.IR_ADD) { return 0; }
    let is i64 as cv with mut = 0;
    if (add.src1.op_type == d.OP_VREG && vec_resolve(def_inst, def_count, vc, add.src1.vreg) == iv
        && vec_val_const(def_inst, def_count, vc, cast(i32, add.src2.op_type), add.src2.vreg, add.src2.imm, &cv) == 1 && cv == 1) { return 1; }
    if (add.src2.op_type == d.OP_VREG && vec_resolve(def_inst, def_count, vc, add.src2.vreg) == iv
        && vec_val_const(def_inst, def_count, vc, cast(i32, add.src1.op_type), add.src1.vreg, add.src1.imm, &cv) == 1 && cv == 1) { return 1; }
    return 0;
}

fn pass_vectorize(func as *d.IRFunction) as i32 {
    let is i32 as vc = func.vreg_count;
    if (vc <= 0) { return 0; }
    let is *i32 as def_count = cast(*i32, d.opt_alloc(cast(i64, vc) * 4));
    let is *i64 as def_inst = cast(*i64, d.opt_alloc(cast(i64, vc) * 8));
    let is i32 as i with mut = 0;
    while (i < vc) {
        let is *i32 as p = cast(*i32, cast(i64, def_count) + cast(i64, i) * 4); *p = 0;
        let is *i64 as q = cast(*i64, cast(i64, def_inst) + cast(i64, i) * 8); *q = 0;
        i = i + 1;
    }
    let is *d.IRInst as w with mut = func.instructions;
    while (cast(i64, w) != 0) {
        if (w.is_dead == 0 && w.dest.op_type == d.OP_VREG && w.op != d.IR_STORE && w.op != d.IR_COPY
            && w.dest.vreg >= 0 && w.dest.vreg < vc) {
            let is *i32 as p = cast(*i32, cast(i64, def_count) + cast(i64, w.dest.vreg) * 4); *p = *p + 1;
            let is *i64 as q = cast(*i64, cast(i64, def_inst) + cast(i64, w.dest.vreg) * 8); *q = cast(i64, w);
        }
        w = w.next;
    }
    // Spill safety: vector vregs are 128-bit but spill slots are 8 bytes, so a
    // spilled vector vreg would corrupt (movsd drops the upper lane). We add <=2
    // live vector vregs; to guarantee they get a register (never spill), bail if
    // the function already has high XMM pressure. Count float-producing insts
    // (the only things besides our vectors that take xmm regs); if there are more
    // than a handful, don't vectorize. Float-free functions (typical integer
    // reductions) trivially pass; pure float reductions have ~2-3 and pass.
    let is i32 as nfloat with mut = 0;
    let is *d.IRInst as fchk with mut = func.instructions;
    while (cast(i64, fchk) != 0) {
        if (fchk.is_dead == 0) {
            let is i32 as fop = fchk.op;
            if (fop == d.IR_FADD || fop == d.IR_FSUB || fop == d.IR_FMUL || fop == d.IR_FDIV
                || fop == d.IR_FNEG || fop == d.IR_FSQRT) { nfloat = nfloat + 1; }
            else if (fop == d.IR_LOAD && cast(i64, fchk.cast_to) != 0 && d._ty_is_float(fchk.cast_to) == 1) { nfloat = nfloat + 1; }
        }
        fchk = fchk.next;
    }
    if (nfloat > 6) { d.opt_free(cast(*u8, def_inst)); d.opt_free(cast(*u8, def_count)); return 0; }

    let is i32 as did with mut = 0;
    let is *d.IRInst as prev with mut = cast(*d.IRInst, 0);
    let is *d.IRInst as hdr with mut = func.instructions;
    while (cast(i64, hdr) != 0 && did == 0) {
        if (hdr.is_dead == 0 && hdr.op == d.IR_LABEL) {
            did = vec_try(func, hdr, prev, def_inst, def_count, vc);
            if (did == 0) { did = vec_try_map(func, hdr, prev, def_inst, def_count, vc); }
        }
        prev = hdr;
        hdr = hdr.next;
    }
    d.opt_free(cast(*u8, def_inst));
    d.opt_free(cast(*u8, def_count));
    return did;
}

// is vreg `v` used as a src by some live body inst strictly before `stop`?
fn vec_used_before(body_first as *d.IRInst, stop as *d.IRInst, v as i32) as i32 {
    let is *d.IRInst as p with mut = body_first;
    while (cast(i64, p) != 0 && cast(i64, p) != cast(i64, stop)) {
        if (p.is_dead == 0) {
            if (p.src1.op_type == d.OP_VREG && p.src1.vreg == v) { return 1; }
            if (p.src2.op_type == d.OP_VREG && p.src2.vreg == v) { return 1; }
        }
        p = p.next;
    }
    return 0;
}

fn vec_try(func as *d.IRFunction, hdr as *d.IRInst, prev as *d.IRInst,
           def_inst as *i64, def_count as *i32, vc as i32) as i32 {
    if (cast(i64, prev) == 0) { return 0; }
    // pass_vectorize runs to a fixpoint; the runtime path keeps the scalar loop as
    // a remainder, so mark a vectorized header (is_extern_call is unused on LABELs)
    // to stop the next pass re-wrapping it.
    if (hdr.is_extern_call == 1) { return 0; }
    let is i32 as hlabel = hdr.dest.label;

    // --- loop skeleton (mirror unroll's counted-loop detection) ---
    let is *d.IRInst as c with mut = ur.ur_next_live(hdr);
    let is *d.IRInst as jz with mut = cast(*d.IRInst, 0);
    let is i32 as sg with mut = 0;
    while (cast(i64, c) != 0 && sg < VEC_MAX_TRIP) {
        if (c.op == d.IR_JZ) { jz = c; c = cast(*d.IRInst, 0); }
        else if (ur.ur_is_barrier(c.op) == 1) { return 0; }
        else { c = ur.ur_next_live(c); sg = sg + 1; }
    }
    if (cast(i64, jz) == 0 || jz.src1.op_type != d.OP_VREG || jz.dest.op_type != d.OP_LABEL) { return 0; }
    if (jz.src1.vreg < 0 || jz.src1.vreg >= vc) { return 0; }
    let is *i64 as cdp = cast(*i64, cast(i64, def_inst) + cast(i64, jz.src1.vreg) * 8);
    let is *d.IRInst as ltd = cast(*d.IRInst, *cdp);
    if (cast(i64, ltd) == 0 || ltd.op != d.IR_LT || ltd.src1.op_type != d.OP_VREG) { return 0; }
    // bound N: const (fold) -> unroll path; runtime vreg -> vector-loop + scalar remainder
    let is i64 as nbound with mut = 0;
    let is i32 as nbound_is_const with mut = 0;
    let is i32 as nbound_vreg with mut = cast(i32, 0 - 1);
    if (vec_val_const(def_inst, def_count, vc, cast(i32, ltd.src2.op_type), ltd.src2.vreg, ltd.src2.imm, &nbound) == 1) { nbound_is_const = 1; }
    else if (ltd.src2.op_type == d.OP_VREG && ltd.src2.vreg >= 0 && ltd.src2.vreg < vc) {
        // resolve through MOV/CAST copies to the loop-invariant source (e.g. the
        // param vreg) — it must be live BEFORE the loop, where the vector loop sits.
        nbound_vreg = vec_resolve(def_inst, def_count, vc, ltd.src2.vreg);
        if (nbound_vreg < 0 || nbound_vreg >= vc) { return 0; }
    }
    else { return 0; }
    let is i32 as iv = vec_resolve(def_inst, def_count, vc, ltd.src1.vreg);
    if (iv < 0 || iv >= vc) { return 0; }

    // body up to back-edge; straight-line; NO stores (reduction reads only)
    let is *d.IRInst as body_first with mut = ur.ur_next_live(jz);
    if (cast(i64, body_first) == 0) { return 0; }
    let is *d.IRInst as backedge with mut = cast(*d.IRInst, 0);
    let is *d.IRInst as b with mut = body_first;
    let is i32 as bsize with mut = 0;
    while (cast(i64, b) != 0 && bsize <= VEC_MAX_TRIP) {
        if (b.op == d.IR_JMP) { if (b.dest.op_type == d.OP_LABEL && b.dest.label == hlabel) { backedge = b; b = cast(*d.IRInst, 0); } else { return 0; } }
        else if (b.op == d.IR_STORE || b.op == d.IR_COPY) { return 0; }   // a store -> not a pure reduction
        else if (ur.ur_is_barrier(b.op) == 1) { return 0; }
        else { bsize = bsize + 1; b = ur.ur_next_live(b); }
    }
    if (cast(i64, backedge) == 0 || bsize == 0) { return 0; }

    // --- find the carried vars (read-before-write in body): expect exactly {iv, s} ---
    let is i32 as s_acc with mut = cast(i32, 0 - 1);
    let is *d.IRInst as s_write with mut = cast(*d.IRInst, 0);
    let is i32 as iv_seen with mut = 0;
    let is i32 as carried_extra with mut = 0;
    b = body_first;
    while (cast(i64, b) != 0 && cast(i64, b) != cast(i64, backedge)) {
        if (b.is_dead == 0 && b.op == d.IR_MOV && b.dest.op_type == d.OP_VREG && b.src1.op_type == d.OP_VREG) {
            let is i32 as cd = b.dest.vreg;
            if (vec_used_before(body_first, b, cd) == 1) {       // carried update
                if (cd == iv) { iv_seen = 1; }
                else if (s_acc < 0) { s_acc = cd; s_write = b; }
                else { carried_extra = 1; }
            }
        }
        b = b.next;
    }
    if (iv_seen == 0 || s_acc < 0 || carried_extra == 1) { return 0; }

    // --- verify s_write: s = (s + LOAD[base + iv*8]) ---
    // s_write: MOV s = vt;  vt = ADD(p,q) with one operand resolving to s, other = x;
    // x = LOAD[addr];  addr = LEA8(base, iv').
    let is i32 as vt = s_write.src1.vreg;
    if (vt < 0 || vt >= vc) { return 0; }
    let is *i64 as vtp = cast(*i64, cast(i64, def_inst) + cast(i64, vt) * 8);
    let is *d.IRInst as add = cast(*d.IRInst, *vtp);
    if (cast(i64, add) == 0 || add.src1.op_type != d.OP_VREG || add.src2.op_type != d.OP_VREG) { return 0; }
    // IR_ADD -> integer reduction; IR_FADD -> f64 reduction (FP reassoc OK at -O2)
    let is i32 as is_float with mut = 0;
    if (add.op == d.IR_FADD) { is_float = 1; }
    else if (add.op != d.IR_ADD) { return 0; }
    // which operand is the accumulator (resolves to s), which is the loaded value x
    let is i32 as a1 = vec_resolve(def_inst, def_count, vc, add.src1.vreg);
    let is i32 as a2 = vec_resolve(def_inst, def_count, vc, add.src2.vreg);
    let is i32 as xv with mut = cast(i32, 0 - 1);
    if (a1 == s_acc) { xv = add.src2.vreg; }
    else if (a2 == s_acc) { xv = add.src1.vreg; }
    else { return 0; }
    // x = LOAD[addr]
    if (xv < 0 || xv >= vc) { return 0; }
    let is *i64 as xp = cast(*i64, cast(i64, def_inst) + cast(i64, xv) * 8);
    let is *d.IRInst as ld = cast(*d.IRInst, *xp);
    if (cast(i64, ld) == 0 || ld.op != d.IR_LOAD || ld.src1.op_type != d.OP_VREG) { return 0; }
    // the load's element type must match the reduction kind (float<->float, int<->int)
    let is i32 as ld_is_float with mut = 0;
    if (cast(i64, ld.cast_to) != 0 && d._ty_is_float(ld.cast_to) == 1) { ld_is_float = 1; }
    if (ld_is_float != is_float) { return 0; }
    // addr = LEA8(base, iv')  (scale 8 = i64 stride)
    let is i32 as addrv = ld.src1.vreg;
    if (addrv < 0 || addrv >= vc) { return 0; }
    let is *i64 as ap = cast(*i64, cast(i64, def_inst) + cast(i64, addrv) * 8);
    let is *d.IRInst as lea = cast(*d.IRInst, *ap);
    if (cast(i64, lea) == 0 || lea.src1.op_type != d.OP_VREG || lea.src2.op_type != d.OP_VREG) { return 0; }
    // element width from the LEA scale: LEA8 -> i64 (2-wide), LEA4 -> i32 (4-wide)
    let is i32 as elem with mut = 0;
    let is i32 as wide with mut = 0;
    let is i32 as vadd_op with mut = 0;
    let is i32 as vred_op with mut = 0;
    if (is_float == 1) {
        // f64: 8-byte stride (LEA8), 2 lanes, addpd + f64 horizontal reduce.
        if (lea.op != d.IR_LEA8) { return 0; }
        elem = 8; wide = 2; vadd_op = d.IR_VADDPD; vred_op = d.IR_VREDUCEPD;
    } else if (lea.op == d.IR_LEA8) { elem = 8; wide = 2; vadd_op = d.IR_VADDQ; vred_op = d.IR_VREDUCEQ; }
    else if (lea.op == d.IR_LEA4) { elem = 4; wide = 4; vadd_op = d.IR_VADDD; vred_op = d.IR_VREDUCED; }
    else { return 0; }
    // one LEA operand resolves to iv (the index), the other to base (loop-invariant)
    let is i32 as l1 = vec_resolve(def_inst, def_count, vc, lea.src1.vreg);
    let is i32 as l2 = vec_resolve(def_inst, def_count, vc, lea.src2.vreg);
    let is i32 as base with mut = cast(i32, 0 - 1);
    if (l1 == iv) { base = l2; }
    else if (l2 == iv) { base = l1; }
    else { return 0; }
    if (base < 0 || base >= vc) { return 0; }

    // --- iv step +1 and init constant (mirror unroll) ---
    let is i32 as iv_writes with mut = 0;
    let is i32 as step_ok with mut = 0;
    b = body_first;
    while (cast(i64, b) != 0 && cast(i64, b) != cast(i64, backedge)) {
        if (b.is_dead == 0 && b.dest.op_type == d.OP_VREG && b.dest.vreg == iv && b.op != d.IR_STORE) {
            iv_writes = iv_writes + 1;
            if (b.op == d.IR_MOV && b.src1.op_type == d.OP_VREG) {
                let is *i64 as vtd = cast(*i64, cast(i64, def_inst) + cast(i64, b.src1.vreg) * 8);
                if (vec_add_is_iv_plus1(cast(*d.IRInst, *vtd), def_inst, def_count, vc, iv) == 1) { step_ok = 1; }
            } else if (vec_add_is_iv_plus1(b, def_inst, def_count, vc, iv) == 1) { step_ok = 1; }
        }
        b = b.next;
    }
    if (iv_writes != 1 || step_ok != 1) { return 0; }
    let is i64 as init with mut = 0;
    let is i32 as init_ok with mut = 0;
    let is *d.IRInst as s2 with mut = func.instructions;
    while (cast(i64, s2) != 0 && cast(i64, s2) != cast(i64, hdr)) {
        if (s2.is_dead == 0 && s2.dest.op_type == d.OP_VREG && s2.dest.vreg == iv && s2.op != d.IR_STORE && s2.op != d.IR_COPY) {
            if (s2.op == d.IR_IMM && s2.src1.op_type == d.OP_IMM) { init = s2.src1.imm; init_ok = 1; }
            else if (s2.op == d.IR_MOV && s2.src1.op_type == d.OP_VREG) { let is i64 as cv with mut = 0; if (vec_const(def_inst, def_count, vc, s2.src1.vreg, &cv) == 1) { init = cv; init_ok = 1; } else { init_ok = 0; } }
            else { init_ok = 0; }
        }
        s2 = s2.next;
    }
    // (init / init_ok above are required only for the const-unroll path A)

    // s_init: the pre-loop value of s (the vreg feeding s before the loop).
    let is i32 as s_init_vreg with mut = cast(i32, 0 - 1);
    s2 = func.instructions;
    while (cast(i64, s2) != 0 && cast(i64, s2) != cast(i64, hdr)) {
        if (s2.is_dead == 0 && s2.dest.op_type == d.OP_VREG && s2.dest.vreg == s_acc
            && s2.op == d.IR_MOV && s2.src1.op_type == d.OP_VREG) { s_init_vreg = s2.src1.vreg; }
        s2 = s2.next;
    }
    if (s_init_vreg < 0) { return 0; }
    let is i32 as fin_op with mut = d.IR_ADD;
    if (is_float == 1) { fin_op = d.IR_FADD; }
    let is i32 as lea_op with mut = d.IR_LEA8;
    if (elem == 4) { lea_op = d.IR_LEA4; }

    // ===== PATH A: const, small, multiple-of-wide trip -> fully unrolled (no loop) =====
    if (nbound_is_const == 1 && init_ok == 1) {
        let is i64 as trip = nbound - init;
        if (trip >= 2 && trip <= cast(i64, VEC_MAX_TRIP) && (trip % cast(i64, wide)) == 0) {
            let is i64 as init_byte = init * cast(i64, elem);
            let is *d.IRInst as ip with mut = prev;
            let is i32 as vacc = vec_new_vreg(func);
            let is *d.IRInst as vz = d.new_inst(d.IR_VZERO);
            vz.dest.op_type = cast(i8, d.OP_VREG); vz.dest.vreg = vacc; vz.line = hdr.line;
            ip = vec_emit(ip, vz);
            let is i64 as k with mut = 0;
            while (k < trip) {
                let is i64 as off = init_byte + k * cast(i64, elem);
                let is i32 as vld = vec_new_vreg(func);
                let is *d.IRInst as vl = d.new_inst(d.IR_VLOADQ);
                vl.dest.op_type = cast(i8, d.OP_VREG); vl.dest.vreg = vld;
                vl.src1.op_type = cast(i8, d.OP_VREG); vl.src1.vreg = base;
                vl.src2.op_type = cast(i8, d.OP_IMM);  vl.src2.imm = off;
                vl.line = hdr.line;
                ip = vec_emit(ip, vl);
                let is *d.IRInst as va = d.new_inst(vadd_op);
                va.dest.op_type = cast(i8, d.OP_VREG); va.dest.vreg = vacc;
                va.src1.op_type = cast(i8, d.OP_VREG); va.src1.vreg = vacc;
                va.src2.op_type = cast(i8, d.OP_VREG); va.src2.vreg = vld;
                va.line = hdr.line;
                ip = vec_emit(ip, va);
                k = k + cast(i64, wide);
            }
            let is i32 as hv = vec_new_vreg(func);
            let is *d.IRInst as vr = d.new_inst(vred_op);
            vr.dest.op_type = cast(i8, d.OP_VREG); vr.dest.vreg = hv;
            vr.src1.op_type = cast(i8, d.OP_VREG); vr.src1.vreg = vacc;
            vr.line = hdr.line;
            ip = vec_emit(ip, vr);
            let is *d.IRInst as fin = d.new_inst(fin_op);
            fin.dest.op_type = cast(i8, d.OP_VREG); fin.dest.vreg = s_acc;
            fin.src1.op_type = cast(i8, d.OP_VREG); fin.src1.vreg = s_init_vreg;
            fin.src2.op_type = cast(i8, d.OP_VREG); fin.src2.vreg = hv;
            fin.line = hdr.line;
            ip = vec_emit(ip, fin);
            jz.is_dead = 1; backedge.is_dead = 1;
            b = body_first;
            while (cast(i64, b) != 0 && cast(i64, b) != cast(i64, backedge)) { b.is_dead = 1; b = b.next; }
            hdr.is_extern_call = 1;
            return 1;
        }
    }

    // ===== PATH B: runtime / large / non-multiple trip -> vector loop + scalar remainder =====
    // Keep the scalar loop as the remainder; before it, run a vector loop over the
    // largest multiple-of-wide prefix and fold into s. Addresses are computed with a
    // LEA(base, iv) each iteration so the array length can be a runtime value.
    //   vacc = 0; lim = N - (wide-1)          (`iv < lim`  ==  `iv + wide <= N`)
    //   .Lv: if (iv >= lim) goto .Lvend; v = [base + iv*elem]; vacc += v; iv += wide; goto .Lv
    //   .Lvend: s = s_init + reduce(vacc)      then the kept scalar loop runs iv..N onto s
    let is *d.IRInst as ipb with mut = prev;

    // --- AVX2 dispatch: if the CPU has AVX2, run a 256-bit (2x wider) vector loop;
    //     otherwise fall to the SSE2 loop below. Both fold into s, then jump past to
    //     the scalar remainder. iv starts at init for whichever path runs. ---
    let is i32 as wideA = wide * 2;
    let is i32 as vadd256 with mut = d.IR_VADDQ256;
    let is i32 as vred256 with mut = d.IR_VREDUCEQ256;
    if (is_float == 1) { vadd256 = d.IR_VADDPD256; vred256 = d.IR_VREDUCEPD256; }
    else if (elem == 4) { vadd256 = d.IR_VADDD256; vred256 = d.IR_VREDUCED256; }
    let is i32 as flagv = vec_new_vreg(func);
    let is *d.IRInst as hav = d.new_inst(d.IR_HASAVX2);
    hav.dest.op_type = cast(i8, d.OP_VREG); hav.dest.vreg = flagv; hav.line = hdr.line;
    ipb = vec_emit(ipb, hav);
    let is i32 as Lsse = vec_new_label(func);
    let is i32 as Lafter = vec_new_label(func);
    let is *d.IRInst as jzf = d.new_inst(d.IR_JZ);
    jzf.src1.op_type = cast(i8, d.OP_VREG); jzf.src1.vreg = flagv;
    jzf.dest.op_type = cast(i8, d.OP_LABEL); jzf.dest.label = Lsse; jzf.line = hdr.line;
    ipb = vec_emit(ipb, jzf);
    let is i32 as vacc8 = vec_new_vreg(func);
    let is *d.IRInst as vz8 = d.new_inst(d.IR_VZERO256);
    vz8.dest.op_type = cast(i8, d.OP_VREG); vz8.dest.vreg = vacc8; vz8.line = hdr.line;
    ipb = vec_emit(ipb, vz8);
    let is i32 as limA_is_imm with mut = 0;
    let is i64 as limA_imm with mut = 0;
    let is i32 as limA_vreg with mut = cast(i32, 0 - 1);
    if (nbound_is_const == 1) { limA_is_imm = 1; limA_imm = nbound - cast(i64, wideA - 1); }
    else {
        limA_vreg = vec_new_vreg(func);
        let is *d.IRInst as subA = d.new_inst(d.IR_SUB);
        subA.dest.op_type = cast(i8, d.OP_VREG); subA.dest.vreg = limA_vreg;
        subA.src1.op_type = cast(i8, d.OP_VREG); subA.src1.vreg = nbound_vreg;
        subA.src2.op_type = cast(i8, d.OP_IMM);  subA.src2.imm = cast(i64, wideA - 1);
        subA.line = hdr.line;
        ipb = vec_emit(ipb, subA);
    }
    let is i32 as LvA = vec_new_label(func);
    let is i32 as LvendA = vec_new_label(func);
    let is *d.IRInst as lblvA = d.new_inst(d.IR_LABEL);
    lblvA.dest.op_type = cast(i8, d.OP_LABEL); lblvA.dest.label = LvA; lblvA.line = hdr.line;
    ipb = vec_emit(ipb, lblvA);
    let is i32 as vcondA = vec_new_vreg(func);
    let is *d.IRInst as ltA = d.new_inst(d.IR_LT);
    ltA.dest.op_type = cast(i8, d.OP_VREG); ltA.dest.vreg = vcondA;
    ltA.src1.op_type = cast(i8, d.OP_VREG); ltA.src1.vreg = iv;
    if (limA_is_imm == 1) { ltA.src2.op_type = cast(i8, d.OP_IMM); ltA.src2.imm = limA_imm; }
    else { ltA.src2.op_type = cast(i8, d.OP_VREG); ltA.src2.vreg = limA_vreg; }
    ltA.line = hdr.line;
    ipb = vec_emit(ipb, ltA);
    let is *d.IRInst as jzvA = d.new_inst(d.IR_JZ);
    jzvA.src1.op_type = cast(i8, d.OP_VREG); jzvA.src1.vreg = vcondA;
    jzvA.dest.op_type = cast(i8, d.OP_LABEL); jzvA.dest.label = LvendA; jzvA.line = hdr.line;
    ipb = vec_emit(ipb, jzvA);
    let is i32 as addrA = vec_new_vreg(func);
    let is *d.IRInst as leaA = d.new_inst(lea_op);
    leaA.dest.op_type = cast(i8, d.OP_VREG); leaA.dest.vreg = addrA;
    leaA.src1.op_type = cast(i8, d.OP_VREG); leaA.src1.vreg = base;
    leaA.src2.op_type = cast(i8, d.OP_VREG); leaA.src2.vreg = iv;
    leaA.line = hdr.line;
    ipb = vec_emit(ipb, leaA);
    let is i32 as vldA = vec_new_vreg(func);
    let is *d.IRInst as vlA = d.new_inst(d.IR_VLOADQ256);
    vlA.dest.op_type = cast(i8, d.OP_VREG); vlA.dest.vreg = vldA;
    vlA.src1.op_type = cast(i8, d.OP_VREG); vlA.src1.vreg = addrA;
    vlA.src2.op_type = cast(i8, d.OP_IMM);  vlA.src2.imm = 0;
    vlA.line = hdr.line;
    ipb = vec_emit(ipb, vlA);
    let is *d.IRInst as vaA = d.new_inst(vadd256);
    vaA.dest.op_type = cast(i8, d.OP_VREG); vaA.dest.vreg = vacc8;
    vaA.src1.op_type = cast(i8, d.OP_VREG); vaA.src1.vreg = vacc8;
    vaA.src2.op_type = cast(i8, d.OP_VREG); vaA.src2.vreg = vldA;
    vaA.line = hdr.line;
    ipb = vec_emit(ipb, vaA);
    let is *d.IRInst as ivaddA = d.new_inst(d.IR_ADD);
    ivaddA.dest.op_type = cast(i8, d.OP_VREG); ivaddA.dest.vreg = iv;
    ivaddA.src1.op_type = cast(i8, d.OP_VREG); ivaddA.src1.vreg = iv;
    ivaddA.src2.op_type = cast(i8, d.OP_IMM);  ivaddA.src2.imm = cast(i64, wideA);
    ivaddA.line = hdr.line;
    ipb = vec_emit(ipb, ivaddA);
    let is *d.IRInst as jmpvA = d.new_inst(d.IR_JMP);
    jmpvA.dest.op_type = cast(i8, d.OP_LABEL); jmpvA.dest.label = LvA; jmpvA.line = hdr.line;
    ipb = vec_emit(ipb, jmpvA);
    let is *d.IRInst as lblendA = d.new_inst(d.IR_LABEL);
    lblendA.dest.op_type = cast(i8, d.OP_LABEL); lblendA.dest.label = LvendA; lblendA.line = hdr.line;
    ipb = vec_emit(ipb, lblendA);
    let is i32 as hvA = vec_new_vreg(func);
    let is *d.IRInst as vrA = d.new_inst(vred256);
    vrA.dest.op_type = cast(i8, d.OP_VREG); vrA.dest.vreg = hvA;
    vrA.src1.op_type = cast(i8, d.OP_VREG); vrA.src1.vreg = vacc8;
    vrA.line = hdr.line;
    ipb = vec_emit(ipb, vrA);
    let is *d.IRInst as finA = d.new_inst(fin_op);
    finA.dest.op_type = cast(i8, d.OP_VREG); finA.dest.vreg = s_acc;
    finA.src1.op_type = cast(i8, d.OP_VREG); finA.src1.vreg = s_init_vreg;
    finA.src2.op_type = cast(i8, d.OP_VREG); finA.src2.vreg = hvA;
    finA.line = hdr.line;
    ipb = vec_emit(ipb, finA);
    let is *d.IRInst as jmpAf = d.new_inst(d.IR_JMP);
    jmpAf.dest.op_type = cast(i8, d.OP_LABEL); jmpAf.dest.label = Lafter; jmpAf.line = hdr.line;
    ipb = vec_emit(ipb, jmpAf);
    let is *d.IRInst as lblSse = d.new_inst(d.IR_LABEL);
    lblSse.dest.op_type = cast(i8, d.OP_LABEL); lblSse.dest.label = Lsse; lblSse.line = hdr.line;
    ipb = vec_emit(ipb, lblSse);

    // --- SSE2 path (128-bit, the always-available fallback) ---
    let is i32 as vacc with mut = vec_new_vreg(func);
    let is *d.IRInst as vzb = d.new_inst(d.IR_VZERO);
    vzb.dest.op_type = cast(i8, d.OP_VREG); vzb.dest.vreg = vacc; vzb.line = hdr.line;
    ipb = vec_emit(ipb, vzb);
    // lim = N - (wide-1)
    let is i32 as lim_is_imm with mut = 0;
    let is i64 as lim_imm with mut = 0;
    let is i32 as lim_vreg with mut = cast(i32, 0 - 1);
    if (nbound_is_const == 1) { lim_is_imm = 1; lim_imm = nbound - cast(i64, wide - 1); }
    else {
        lim_vreg = vec_new_vreg(func);
        let is *d.IRInst as sub = d.new_inst(d.IR_SUB);
        sub.dest.op_type = cast(i8, d.OP_VREG); sub.dest.vreg = lim_vreg;
        sub.src1.op_type = cast(i8, d.OP_VREG); sub.src1.vreg = nbound_vreg;
        sub.src2.op_type = cast(i8, d.OP_IMM);  sub.src2.imm = cast(i64, wide - 1);
        sub.line = hdr.line;
        ipb = vec_emit(ipb, sub);
    }
    let is i32 as Lv = vec_new_label(func);
    let is i32 as Lvend = vec_new_label(func);
    let is *d.IRInst as lblv = d.new_inst(d.IR_LABEL);
    lblv.dest.op_type = cast(i8, d.OP_LABEL); lblv.dest.label = Lv; lblv.line = hdr.line;
    ipb = vec_emit(ipb, lblv);
    // vcond = iv < lim
    let is i32 as vcond = vec_new_vreg(func);
    let is *d.IRInst as lt = d.new_inst(d.IR_LT);
    lt.dest.op_type = cast(i8, d.OP_VREG); lt.dest.vreg = vcond;
    lt.src1.op_type = cast(i8, d.OP_VREG); lt.src1.vreg = iv;
    if (lim_is_imm == 1) { lt.src2.op_type = cast(i8, d.OP_IMM); lt.src2.imm = lim_imm; }
    else { lt.src2.op_type = cast(i8, d.OP_VREG); lt.src2.vreg = lim_vreg; }
    lt.line = hdr.line;
    ipb = vec_emit(ipb, lt);
    let is *d.IRInst as jzv = d.new_inst(d.IR_JZ);
    jzv.src1.op_type = cast(i8, d.OP_VREG); jzv.src1.vreg = vcond;
    jzv.dest.op_type = cast(i8, d.OP_LABEL); jzv.dest.label = Lvend;
    jzv.line = hdr.line;
    ipb = vec_emit(ipb, jzv);
    // addr = LEA(base, iv); v = VLOADQ(addr, 0); vacc += v; iv += wide; jmp .Lv
    let is i32 as addr = vec_new_vreg(func);
    let is *d.IRInst as lea = d.new_inst(lea_op);
    lea.dest.op_type = cast(i8, d.OP_VREG); lea.dest.vreg = addr;
    lea.src1.op_type = cast(i8, d.OP_VREG); lea.src1.vreg = base;
    lea.src2.op_type = cast(i8, d.OP_VREG); lea.src2.vreg = iv;
    lea.line = hdr.line;
    ipb = vec_emit(ipb, lea);
    let is i32 as vld = vec_new_vreg(func);
    let is *d.IRInst as vl = d.new_inst(d.IR_VLOADQ);
    vl.dest.op_type = cast(i8, d.OP_VREG); vl.dest.vreg = vld;
    vl.src1.op_type = cast(i8, d.OP_VREG); vl.src1.vreg = addr;
    vl.src2.op_type = cast(i8, d.OP_IMM);  vl.src2.imm = 0;
    vl.line = hdr.line;
    ipb = vec_emit(ipb, vl);
    let is *d.IRInst as va = d.new_inst(vadd_op);
    va.dest.op_type = cast(i8, d.OP_VREG); va.dest.vreg = vacc;
    va.src1.op_type = cast(i8, d.OP_VREG); va.src1.vreg = vacc;
    va.src2.op_type = cast(i8, d.OP_VREG); va.src2.vreg = vld;
    va.line = hdr.line;
    ipb = vec_emit(ipb, va);
    let is *d.IRInst as ivadd = d.new_inst(d.IR_ADD);
    ivadd.dest.op_type = cast(i8, d.OP_VREG); ivadd.dest.vreg = iv;
    ivadd.src1.op_type = cast(i8, d.OP_VREG); ivadd.src1.vreg = iv;
    ivadd.src2.op_type = cast(i8, d.OP_IMM);  ivadd.src2.imm = cast(i64, wide);
    ivadd.line = hdr.line;
    ipb = vec_emit(ipb, ivadd);
    let is *d.IRInst as jmpv = d.new_inst(d.IR_JMP);
    jmpv.dest.op_type = cast(i8, d.OP_LABEL); jmpv.dest.label = Lv; jmpv.line = hdr.line;
    ipb = vec_emit(ipb, jmpv);
    // .Lvend: s = s_init + reduce(vacc)
    let is *d.IRInst as lblend = d.new_inst(d.IR_LABEL);
    lblend.dest.op_type = cast(i8, d.OP_LABEL); lblend.dest.label = Lvend; lblend.line = hdr.line;
    ipb = vec_emit(ipb, lblend);
    let is i32 as hvb = vec_new_vreg(func);
    let is *d.IRInst as vrb = d.new_inst(vred_op);
    vrb.dest.op_type = cast(i8, d.OP_VREG); vrb.dest.vreg = hvb;
    vrb.src1.op_type = cast(i8, d.OP_VREG); vrb.src1.vreg = vacc;
    vrb.line = hdr.line;
    ipb = vec_emit(ipb, vrb);
    let is *d.IRInst as finb = d.new_inst(fin_op);
    finb.dest.op_type = cast(i8, d.OP_VREG); finb.dest.vreg = s_acc;
    finb.src1.op_type = cast(i8, d.OP_VREG); finb.src1.vreg = s_init_vreg;
    finb.src2.op_type = cast(i8, d.OP_VREG); finb.src2.vreg = hvb;
    finb.line = hdr.line;
    ipb = vec_emit(ipb, finb);
    // .Lafter: both vector paths converge here, then fall into the scalar remainder.
    let is *d.IRInst as lblAfter = d.new_inst(d.IR_LABEL);
    lblAfter.dest.op_type = cast(i8, d.OP_LABEL); lblAfter.dest.label = Lafter; lblAfter.line = hdr.line;
    ipb = vec_emit(ipb, lblAfter);
    // scalar loop kept intact — runs from iv (post-vector) to N as the remainder.
    hdr.is_extern_call = 1;
    return 1;
}

// === Elementwise map vectorizer: `c[i] = a[i] OP b[i]` ===
//
// Unlike a reduction, a map STORES, so aliasing matters: if c overlaps a or b at
// a shifted offset there's a cross-iteration dependency that SIMD would break.
// We handle it with runtime multiversioning — keep the scalar loop as a fallback
// and, BEFORE it, emit a runtime alias check that branches to a fully-unrolled
// vector version only when c is provably disjoint from a and b:
//
//     if (overlap(c,a) | overlap(c,b)) goto .Lscalar(fallthrough)  else goto .Lvec
//   .Lhdr: <scalar loop, unchanged, exits to .Lexit>
//   .Lvec: <vstore(c) = vload(a) OP vload(b), unrolled>; goto .Lexit
//   .Lexit:
//
// overlap([p,p+sz),[q,q+sz)) == (p < q+sz) & (q < p+sz). sz = nbound*elem (a
// sound superset of the accessed range). First cut: ADD only (paddq/paddd/addpd),
// reusing the reduction's packed ops + a new packed store. Constant trip, multiple
// of the vector width.

fn vec_sdef(def_inst as *i64, def_count as *i32, vc as i32, v as i32) as *d.IRInst {
    if (v < 0 || v >= vc) { return cast(*d.IRInst, 0); }
    let is *i32 as dcp = cast(*i32, cast(i64, def_count) + cast(i64, v) * 4);
    if (*dcp != 1) { return cast(*d.IRInst, 0); }
    let is *i64 as dip = cast(*i64, cast(i64, def_inst) + cast(i64, v) * 8);
    return cast(*d.IRInst, *dip);
}
// LEA(base, iv) -> resolved base vreg + scale; else -1.
fn vec_lea_base(lea as *d.IRInst, def_inst as *i64, def_count as *i32, vc as i32, iv as i32, out_elem as *i32) as i32 {
    if (cast(i64, lea) == 0 || lea.src1.op_type != d.OP_VREG || lea.src2.op_type != d.OP_VREG) { return cast(i32, 0 - 1); }
    let is i32 as e with mut = 0;
    if (lea.op == d.IR_LEA8) { e = 8; } else if (lea.op == d.IR_LEA4) { e = 4; } else { return cast(i32, 0 - 1); }
    let is i32 as l1 = vec_resolve(def_inst, def_count, vc, lea.src1.vreg);
    let is i32 as l2 = vec_resolve(def_inst, def_count, vc, lea.src2.vreg);
    let is i32 as base with mut = cast(i32, 0 - 1);
    if (l1 == iv) { base = l2; } else if (l2 == iv) { base = l1; } else { return cast(i32, 0 - 1); }
    *out_elem = e;
    return base;
}
fn vec_ld_is_float(ld as *d.IRInst) as i32 {
    if (cast(i64, ld.cast_to) != 0 && d._ty_is_float(ld.cast_to) == 1) { return 1; }
    return 0;
}
fn vec_new_label(func as *d.IRFunction) as i32 {
    let is i32 as v = func.label_count;
    func.label_count = func.label_count + 1;
    return v;
}
// emit `out = ADD(av, imm)`; advance and return cursor.
fn vec_emit_addimm(func as *d.IRFunction, ip as *d.IRInst, av as i32, imm as i64, line as i32, out as *i32) as *d.IRInst {
    let is i32 as nv = vec_new_vreg(func);
    let is *d.IRInst as ni = d.new_inst(d.IR_ADD);
    ni.dest.op_type = cast(i8, d.OP_VREG); ni.dest.vreg = nv;
    ni.src1.op_type = cast(i8, d.OP_VREG); ni.src1.vreg = av;
    ni.src2.op_type = cast(i8, d.OP_IMM);  ni.src2.imm = imm;
    ni.line = line;
    *out = nv;
    return vec_emit(ip, ni);
}
// emit `out = op(av, bv)` (vreg,vreg); advance and return cursor.
fn vec_emit_vv(func as *d.IRFunction, ip as *d.IRInst, op as i32, av as i32, bv as i32, line as i32, out as *i32) as *d.IRInst {
    let is i32 as nv = vec_new_vreg(func);
    let is *d.IRInst as ni = d.new_inst(op);
    ni.dest.op_type = cast(i8, d.OP_VREG); ni.dest.vreg = nv;
    ni.src1.op_type = cast(i8, d.OP_VREG); ni.src1.vreg = av;
    ni.src2.op_type = cast(i8, d.OP_VREG); ni.src2.vreg = bv;
    ni.line = line;
    *out = nv;
    return vec_emit(ip, ni);
}
// emit `out = LEA<scale>(base, idx)` (= base + idx*scale); advance and return cursor.
fn vec_emit_lea(func as *d.IRFunction, ip as *d.IRInst, lea_op as i32, base as i32, idx as i32, line as i32, out as *i32) as *d.IRInst {
    let is i32 as nv = vec_new_vreg(func);
    let is *d.IRInst as ni = d.new_inst(lea_op);
    ni.dest.op_type = cast(i8, d.OP_VREG); ni.dest.vreg = nv;
    ni.src1.op_type = cast(i8, d.OP_VREG); ni.src1.vreg = base;
    ni.src2.op_type = cast(i8, d.OP_VREG); ni.src2.vreg = idx;
    ni.line = line;
    *out = nv;
    return vec_emit(ip, ni);
}

fn vec_try_map(func as *d.IRFunction, hdr as *d.IRInst, prev as *d.IRInst,
               def_inst as *i64, def_count as *i32, vc as i32) as i32 {
    if (cast(i64, prev) == 0) { return 0; }
    // skip already-multiversioned loops (the scalar fallback is kept) — same marker
    // the reduction path uses; stops the pass_vectorize fixpoint re-wrapping it.
    if (hdr.is_extern_call == 1) { return 0; }
    let is i32 as hlabel = hdr.dest.label;
    let is i32 as ln = hdr.line;

    // --- counted-loop skeleton (mirror vec_try, but STORE is allowed) ---
    let is *d.IRInst as c with mut = ur.ur_next_live(hdr);
    let is *d.IRInst as jz with mut = cast(*d.IRInst, 0);
    let is i32 as sg with mut = 0;
    while (cast(i64, c) != 0 && sg < VEC_MAX_TRIP) {
        if (c.op == d.IR_JZ) { jz = c; c = cast(*d.IRInst, 0); }
        else if (ur.ur_is_barrier(c.op) == 1) { return 0; }
        else { c = ur.ur_next_live(c); sg = sg + 1; }
    }
    if (cast(i64, jz) == 0 || jz.src1.op_type != d.OP_VREG || jz.dest.op_type != d.OP_LABEL) { return 0; }
    if (jz.src1.vreg < 0 || jz.src1.vreg >= vc) { return 0; }
    let is i32 as exit_label = jz.dest.label;
    let is *i64 as cdp = cast(*i64, cast(i64, def_inst) + cast(i64, jz.src1.vreg) * 8);
    let is *d.IRInst as ltd = cast(*d.IRInst, *cdp);
    if (cast(i64, ltd) == 0 || ltd.op != d.IR_LT || ltd.src1.op_type != d.OP_VREG) { return 0; }
    // bound N: const -> unrolled vector twin; runtime vreg -> vector-loop + remainder
    let is i64 as nbound with mut = 0;
    let is i32 as nbound_is_const with mut = 0;
    let is i32 as nbound_vreg with mut = cast(i32, 0 - 1);
    if (vec_val_const(def_inst, def_count, vc, cast(i32, ltd.src2.op_type), ltd.src2.vreg, ltd.src2.imm, &nbound) == 1) { nbound_is_const = 1; }
    else if (ltd.src2.op_type == d.OP_VREG && ltd.src2.vreg >= 0 && ltd.src2.vreg < vc) {
        nbound_vreg = vec_resolve(def_inst, def_count, vc, ltd.src2.vreg);
        if (nbound_vreg < 0 || nbound_vreg >= vc) { return 0; }
    }
    else { return 0; }
    let is i32 as iv = vec_resolve(def_inst, def_count, vc, ltd.src1.vreg);
    if (iv < 0 || iv >= vc) { return 0; }

    let is *d.IRInst as body_first with mut = ur.ur_next_live(jz);
    if (cast(i64, body_first) == 0) { return 0; }
    let is *d.IRInst as backedge with mut = cast(*d.IRInst, 0);
    let is *d.IRInst as store_inst with mut = cast(*d.IRInst, 0);
    let is i32 as nstores with mut = 0;
    let is *d.IRInst as b with mut = body_first;
    let is i32 as bsize with mut = 0;
    while (cast(i64, b) != 0 && bsize <= VEC_MAX_TRIP) {
        if (b.op == d.IR_JMP) { if (b.dest.op_type == d.OP_LABEL && b.dest.label == hlabel) { backedge = b; b = cast(*d.IRInst, 0); } else { return 0; } }
        else if (b.op == d.IR_COPY) { return 0; }
        else if (ur.ur_is_barrier(b.op) == 1) { return 0; }
        else { if (b.op == d.IR_STORE) { store_inst = b; nstores = nstores + 1; } bsize = bsize + 1; b = ur.ur_next_live(b); }
    }
    if (cast(i64, backedge) == 0 || nstores != 1) { return 0; }

    // --- only carried var may be iv (no accumulator) ---
    let is i32 as iv_seen with mut = 0;
    b = body_first;
    while (cast(i64, b) != 0 && cast(i64, b) != cast(i64, backedge)) {
        if (b.is_dead == 0 && b.op == d.IR_MOV && b.dest.op_type == d.OP_VREG && b.src1.op_type == d.OP_VREG) {
            let is i32 as cd = b.dest.vreg;
            if (vec_used_before(body_first, b, cd) == 1) {
                if (cd == iv) { iv_seen = 1; } else { return 0; }
            }
        }
        b = b.next;
    }
    if (iv_seen == 0) { return 0; }

    // --- store: c[i] = val;  addr_c = LEA(base_c, iv);  val = a[i] OP b[i] ---
    if (store_inst.dest.op_type != d.OP_VREG || store_inst.src1.op_type != d.OP_VREG) { return 0; }
    let is i32 as st_float with mut = 0;
    if (cast(i64, store_inst.cast_to) != 0 && d._ty_is_float(store_inst.cast_to) == 1) { st_float = 1; }
    let is i32 as elem_c with mut = 0;
    let is i32 as base_c = vec_lea_base(vec_sdef(def_inst, def_count, vc, store_inst.dest.vreg), def_inst, def_count, vc, iv, &elem_c);
    if (base_c < 0 || base_c >= vc) { return 0; }

    let is i32 as valr = vec_resolve(def_inst, def_count, vc, store_inst.src1.vreg);
    let is *d.IRInst as valdef = vec_sdef(def_inst, def_count, vc, valr);
    if (cast(i64, valdef) == 0) { return 0; }
    let is i32 as is_float with mut = 0;
    let is i32 as opk with mut = 0;   // 0=add 1=sub 2=mul 3=div  (order preserved: src1 OP src2)
    let is i32 as sop = valdef.op;
    if (sop == d.IR_ADD) { opk = 0; }
    else if (sop == d.IR_SUB) { opk = 1; }
    else if (sop == d.IR_FADD) { is_float = 1; opk = 0; }
    else if (sop == d.IR_FSUB) { is_float = 1; opk = 1; }
    else if (sop == d.IR_FMUL) { is_float = 1; opk = 2; }
    else if (sop == d.IR_FDIV) { is_float = 1; opk = 3; }
    else { return 0; }
    if (is_float != st_float) { return 0; }
    if (valdef.src1.op_type != d.OP_VREG || valdef.src2.op_type != d.OP_VREG) { return 0; }

    // src1 must be the iv-indexed array load a[i].
    let is *d.IRInst as lda = vec_sdef(def_inst, def_count, vc, vec_resolve(def_inst, def_count, vc, valdef.src1.vreg));
    if (cast(i64, lda) == 0 || lda.op != d.IR_LOAD || lda.src1.op_type != d.OP_VREG) { return 0; }
    if (vec_ld_is_float(lda) != is_float) { return 0; }
    let is i32 as elem_a with mut = 0;
    let is i32 as base_a = vec_lea_base(vec_sdef(def_inst, def_count, vc, lda.src1.vreg), def_inst, def_count, vc, iv, &elem_a);
    if (base_a < 0 || base_a >= vc || elem_a != elem_c) { return 0; }
    // src2: iv-indexed array load b[i] (two-array map) OR a loop-invariant f64 scalar
    // k (broadcast map -> c[i] = a[i] OP k, with k splatted to all lanes).
    let is i32 as is_bcast with mut = 0;
    let is i32 as base_b with mut = cast(i32, 0 - 1);
    let is i32 as kvreg with mut = cast(i32, 0 - 1);
    let is i32 as r2 = vec_resolve(def_inst, def_count, vc, valdef.src2.vreg);
    let is *d.IRInst as ldb = vec_sdef(def_inst, def_count, vc, r2);
    let is i32 as ldb_ok with mut = 0;
    if (cast(i64, ldb) != 0 && ldb.op == d.IR_LOAD && ldb.src1.op_type == d.OP_VREG && vec_ld_is_float(ldb) == is_float) {
        let is i32 as elem_b with mut = 0;
        base_b = vec_lea_base(vec_sdef(def_inst, def_count, vc, ldb.src1.vreg), def_inst, def_count, vc, iv, &elem_b);
        if (base_b >= 0 && base_b < vc && elem_b == elem_c) { ldb_ok = 1; }
    }
    if (ldb_ok == 0) {
        // broadcast: src2 = a loop-invariant f64 scalar (not written anywhere in the body)
        if (is_float != 1) { return 0; }            // f64 broadcast only for now
        if (r2 < 0 || r2 >= vc) { return 0; }
        let is i32 as invariant with mut = 1;
        let is *d.IRInst as bb with mut = body_first;
        while (cast(i64, bb) != 0 && cast(i64, bb) != cast(i64, backedge)) {
            if (bb.is_dead == 0 && bb.dest.op_type == d.OP_VREG && bb.dest.vreg == r2) { invariant = 0; }
            bb = bb.next;
        }
        if (invariant == 0) { return 0; }
        is_bcast = 1; kvreg = r2;
    }

    let is i32 as elem = elem_c;
    let is i32 as wide with mut = 0;
    let is i32 as vop with mut = 0;
    if (is_float == 1) {
        if (elem != 8) { return 0; }   // f64 only (f32 packed = *ps, not wired yet)
        wide = 2;
        if (opk == 0) { vop = d.IR_VADDPD; }
        else if (opk == 1) { vop = d.IR_VSUBPD; }
        else if (opk == 2) { vop = d.IR_VMULPD; }
        else { vop = d.IR_VDIVPD; }
    } else {
        // int: add/sub only — SSE2 has no 64-bit packed mul (and i32 pmulld is SSE4.1)
        if (opk != 0 && opk != 1) { return 0; }
        if (elem == 8) { wide = 2; if (opk == 0) { vop = d.IR_VADDQ; } else { vop = d.IR_VSUBQ; } }
        else if (elem == 4) { wide = 4; if (opk == 0) { vop = d.IR_VADDD; } else { vop = d.IR_VSUBD; } }
        else { return 0; }
    }

    // --- iv step +1, init constant, trip = nbound - init (mirror vec_try) ---
    let is i32 as iv_writes with mut = 0;
    let is i32 as step_ok with mut = 0;
    b = body_first;
    while (cast(i64, b) != 0 && cast(i64, b) != cast(i64, backedge)) {
        if (b.is_dead == 0 && b.dest.op_type == d.OP_VREG && b.dest.vreg == iv && b.op != d.IR_STORE) {
            iv_writes = iv_writes + 1;
            if (b.op == d.IR_MOV && b.src1.op_type == d.OP_VREG) {
                let is *i64 as vtd = cast(*i64, cast(i64, def_inst) + cast(i64, b.src1.vreg) * 8);
                if (vec_add_is_iv_plus1(cast(*d.IRInst, *vtd), def_inst, def_count, vc, iv) == 1) { step_ok = 1; }
            } else if (vec_add_is_iv_plus1(b, def_inst, def_count, vc, iv) == 1) { step_ok = 1; }
        }
        b = b.next;
    }
    if (iv_writes != 1 || step_ok != 1) { return 0; }
    let is i64 as init with mut = 0;
    let is i32 as init_ok with mut = 0;
    let is *d.IRInst as s2 with mut = func.instructions;
    while (cast(i64, s2) != 0 && cast(i64, s2) != cast(i64, hdr)) {
        if (s2.is_dead == 0 && s2.dest.op_type == d.OP_VREG && s2.dest.vreg == iv && s2.op != d.IR_STORE && s2.op != d.IR_COPY) {
            if (s2.op == d.IR_IMM && s2.src1.op_type == d.OP_IMM) { init = s2.src1.imm; init_ok = 1; }
            else if (s2.op == d.IR_MOV && s2.src1.op_type == d.OP_VREG) { let is i64 as cv with mut = 0; if (vec_const(def_inst, def_count, vc, s2.src1.vreg, &cv) == 1) { init = cv; init_ok = 1; } else { init_ok = 0; } }
            else { init_ok = 0; }
        }
        s2 = s2.next;
    }
    // init_ok required only for the const fully-unrolled twin.
    let is i32 as lea_op with mut = d.IR_LEA8;
    if (elem == 4) { lea_op = d.IR_LEA4; }
    let is i32 as use_unroll with mut = 0;
    if (nbound_is_const == 1 && init_ok == 1) {
        let is i64 as tripc = nbound - init;
        if (tripc >= 2 && tripc <= cast(i64, VEC_MAX_TRIP) && (tripc % cast(i64, wide)) == 0) { use_unroll = 1; }
    }
    // Only two map shapes are handled: const-small-aligned (fully-unrolled twin) and
    // runtime length (vector loop + scalar-loop remainder). A const-but-large/unaligned
    // trip would need the scalar loop as remainder, which the unroller may flatten
    // (it assumes iv=init) — so skip it rather than risk a jump into unrolled code.
    if (nbound_is_const == 1 && use_unroll == 0) { return 0; }
    // Broadcast maps only take the runtime path (avoids the const-unroll hazard above);
    // a const-length broadcast stays scalar (small fixed arrays — low value).
    if (is_bcast == 1 && nbound_is_const == 1) { return 0; }

    // iv must NOT be live after the loop (conservative; both vector paths leave iv
    // in a path-dependent state otherwise).
    let is *d.IRInst as lo with mut = backedge.next;
    while (cast(i64, lo) != 0) {
        if (lo.is_dead == 0) {
            if (lo.src1.op_type == d.OP_VREG && lo.src1.vreg == iv) { return 0; }
            if (lo.src2.op_type == d.OP_VREG && lo.src2.vreg == iv) { return 0; }
        }
        lo = lo.next;
    }

    // ===== (1) before hdr: alias check, JZ any -> .Lvec. Two-array: any = overlap(c,a)
    // | overlap(c,b). Broadcast (no b array): any = overlap(c,a). overlap([p,p+sz),
    // [q,q+sz)) == p<q+sz & q<p+sz; end = base + N*elem (runtime via LEA).
    let is *d.IRInst as ip with mut = prev;
    let is i32 as a_end with mut = 0;
    let is i32 as c_end with mut = 0;
    let is i32 as anyv with mut = 0;
    if (nbound_is_const == 1) {
        let is i64 as sz_check = nbound * cast(i64, elem);   // superset of the accessed range
        ip = vec_emit_addimm(func, ip, base_a, sz_check, ln, &a_end);
        let is i32 as b_end with mut = 0; ip = vec_emit_addimm(func, ip, base_b, sz_check, ln, &b_end);
        ip = vec_emit_addimm(func, ip, base_c, sz_check, ln, &c_end);
        let is i32 as t1 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_c, a_end, ln, &t1);
        let is i32 as t2 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_a, c_end, ln, &t2);
        let is i32 as ova with mut = 0; ip = vec_emit_vv(func, ip, d.IR_AND, t1, t2, ln, &ova);
        let is i32 as t3 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_c, b_end, ln, &t3);
        let is i32 as t4 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_b, c_end, ln, &t4);
        let is i32 as ovb with mut = 0; ip = vec_emit_vv(func, ip, d.IR_AND, t3, t4, ln, &ovb);
        ip = vec_emit_vv(func, ip, d.IR_OR, ova, ovb, ln, &anyv);
    } else {
        ip = vec_emit_lea(func, ip, lea_op, base_a, nbound_vreg, ln, &a_end);   // a + N*elem
        ip = vec_emit_lea(func, ip, lea_op, base_c, nbound_vreg, ln, &c_end);
        let is i32 as t1 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_c, a_end, ln, &t1);   // c < a_end
        let is i32 as t2 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_a, c_end, ln, &t2);   // a < c_end
        let is i32 as ova with mut = 0; ip = vec_emit_vv(func, ip, d.IR_AND, t1, t2, ln, &ova);
        if (is_bcast == 1) { anyv = ova; }                                       // no b array
        else {
            let is i32 as b_end with mut = 0; ip = vec_emit_lea(func, ip, lea_op, base_b, nbound_vreg, ln, &b_end);
            let is i32 as t3 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_c, b_end, ln, &t3);   // c < b_end
            let is i32 as t4 with mut = 0; ip = vec_emit_vv(func, ip, d.IR_LT, base_b, c_end, ln, &t4);   // b < c_end
            let is i32 as ovb with mut = 0; ip = vec_emit_vv(func, ip, d.IR_AND, t3, t4, ln, &ovb);
            ip = vec_emit_vv(func, ip, d.IR_OR, ova, ovb, ln, &anyv);
        }
    }
    let is i32 as label_vec = vec_new_label(func);
    let is *d.IRInst as jzv = d.new_inst(d.IR_JZ);                        // JZ any -> .Lvec (jump if no overlap)
    jzv.src1.op_type = cast(i8, d.OP_VREG); jzv.src1.vreg = anyv;
    jzv.dest.op_type = cast(i8, d.OP_LABEL); jzv.dest.label = label_vec;
    jzv.line = ln;
    ip = vec_emit(ip, jzv);

    // ===== (2) after backedge: .Lvec (the no-overlap version)
    let is *d.IRInst as ip2 with mut = backedge;
    // Skip-guard JMP to .Lexit before .Lvec — dead while the scalar loop keeps its
    // back-edge, but catches a unroller-flattened fallback falling into .Lvec.
    let is *d.IRInst as jskip = d.new_inst(d.IR_JMP);
    jskip.dest.op_type = cast(i8, d.OP_LABEL); jskip.dest.label = exit_label; jskip.line = ln;
    ip2 = vec_emit(ip2, jskip);
    let is *d.IRInst as lbl = d.new_inst(d.IR_LABEL);
    lbl.dest.op_type = cast(i8, d.OP_LABEL); lbl.dest.label = label_vec; lbl.line = ln;
    ip2 = vec_emit(ip2, lbl);

    if (use_unroll == 1) {
        // const small trip -> fully unrolled twin; c[init+k]=a[..] OP b[..]; JMP .Lexit
        let is i64 as init_byte = init * cast(i64, elem);
        let is i64 as trip = nbound - init;
        let is i64 as k with mut = 0;
        while (k < trip) {
            let is i64 as off = init_byte + k * cast(i64, elem);
            let is i32 as vla = vec_new_vreg(func);
            let is *d.IRInst as la = d.new_inst(d.IR_VLOADQ);
            la.dest.op_type = cast(i8, d.OP_VREG); la.dest.vreg = vla;
            la.src1.op_type = cast(i8, d.OP_VREG); la.src1.vreg = base_a;
            la.src2.op_type = cast(i8, d.OP_IMM);  la.src2.imm = off; la.line = ln;
            ip2 = vec_emit(ip2, la);
            let is i32 as vlb = vec_new_vreg(func);
            let is *d.IRInst as lb = d.new_inst(d.IR_VLOADQ);
            lb.dest.op_type = cast(i8, d.OP_VREG); lb.dest.vreg = vlb;
            lb.src1.op_type = cast(i8, d.OP_VREG); lb.src1.vreg = base_b;
            lb.src2.op_type = cast(i8, d.OP_IMM);  lb.src2.imm = off; lb.line = ln;
            ip2 = vec_emit(ip2, lb);
            let is i32 as vr = vec_new_vreg(func);
            let is *d.IRInst as vo = d.new_inst(vop);
            vo.dest.op_type = cast(i8, d.OP_VREG); vo.dest.vreg = vr;
            vo.src1.op_type = cast(i8, d.OP_VREG); vo.src1.vreg = vla;
            vo.src2.op_type = cast(i8, d.OP_VREG); vo.src2.vreg = vlb; vo.line = ln;
            ip2 = vec_emit(ip2, vo);
            let is *d.IRInst as vs = d.new_inst(d.IR_VSTOREQ);
            vs.src1.op_type = cast(i8, d.OP_VREG); vs.src1.vreg = base_c;
            vs.src2.op_type = cast(i8, d.OP_VREG); vs.src2.vreg = vr;
            vs.dest.op_type = cast(i8, d.OP_IMM);  vs.dest.imm = off; vs.line = ln;
            ip2 = vec_emit(ip2, vs);
            k = k + cast(i64, wide);
        }
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest.op_type = cast(i8, d.OP_LABEL); jmp.dest.label = exit_label; jmp.line = ln;
        ip2 = vec_emit(ip2, jmp);
    } else {
        // runtime / large / non-multiple -> vector LOOP over the aligned prefix, then
        // jump into the kept scalar loop (.Lhdr) which runs iv..N as the remainder.

        // --- AVX2 dispatch: 256-bit map loop (2x wider) when the CPU has AVX2; else
        //     fall to the SSE2 loop below. Both exit to .Lhdr (the scalar remainder).
        //     (Skipped for broadcast maps — AVX2 broadcast not wired yet; SSE2 only.) ---
        if (is_bcast == 0) {
        let is i32 as wideA = wide * 2;
        let is i32 as vop256 with mut = d.IR_VADDQ256;
        if (is_float == 1) {
            if (opk == 1) { vop256 = d.IR_VSUBPD256; } else if (opk == 2) { vop256 = d.IR_VMULPD256; }
            else if (opk == 3) { vop256 = d.IR_VDIVPD256; } else { vop256 = d.IR_VADDPD256; }
        } else if (elem == 8) { if (opk == 1) { vop256 = d.IR_VSUBQ256; } else { vop256 = d.IR_VADDQ256; } }
        else { if (opk == 1) { vop256 = d.IR_VSUBD256; } else { vop256 = d.IR_VADDD256; } }
        let is i32 as flagm = vec_new_vreg(func);
        let is *d.IRInst as havm = d.new_inst(d.IR_HASAVX2);
        havm.dest.op_type = cast(i8, d.OP_VREG); havm.dest.vreg = flagm; havm.line = ln;
        ip2 = vec_emit(ip2, havm);
        let is i32 as LsseM = vec_new_label(func);
        let is *d.IRInst as jzfm = d.new_inst(d.IR_JZ);
        jzfm.src1.op_type = cast(i8, d.OP_VREG); jzfm.src1.vreg = flagm;
        jzfm.dest.op_type = cast(i8, d.OP_LABEL); jzfm.dest.label = LsseM; jzfm.line = ln;
        ip2 = vec_emit(ip2, jzfm);
        let is i32 as limAm_is_imm with mut = 0;
        let is i64 as limAm_imm with mut = 0;
        let is i32 as limAm_vreg with mut = cast(i32, 0 - 1);
        if (nbound_is_const == 1) { limAm_is_imm = 1; limAm_imm = nbound - cast(i64, wideA - 1); }
        else {
            limAm_vreg = vec_new_vreg(func);
            let is *d.IRInst as subAm = d.new_inst(d.IR_SUB);
            subAm.dest.op_type = cast(i8, d.OP_VREG); subAm.dest.vreg = limAm_vreg;
            subAm.src1.op_type = cast(i8, d.OP_VREG); subAm.src1.vreg = nbound_vreg;
            subAm.src2.op_type = cast(i8, d.OP_IMM);  subAm.src2.imm = cast(i64, wideA - 1);
            subAm.line = ln;
            ip2 = vec_emit(ip2, subAm);
        }
        let is i32 as LvAm = vec_new_label(func);
        let is *d.IRInst as lblvAm = d.new_inst(d.IR_LABEL);
        lblvAm.dest.op_type = cast(i8, d.OP_LABEL); lblvAm.dest.label = LvAm; lblvAm.line = ln;
        ip2 = vec_emit(ip2, lblvAm);
        let is i32 as vcondAm = vec_new_vreg(func);
        let is *d.IRInst as ltAm = d.new_inst(d.IR_LT);
        ltAm.dest.op_type = cast(i8, d.OP_VREG); ltAm.dest.vreg = vcondAm;
        ltAm.src1.op_type = cast(i8, d.OP_VREG); ltAm.src1.vreg = iv;
        if (limAm_is_imm == 1) { ltAm.src2.op_type = cast(i8, d.OP_IMM); ltAm.src2.imm = limAm_imm; }
        else { ltAm.src2.op_type = cast(i8, d.OP_VREG); ltAm.src2.vreg = limAm_vreg; }
        ltAm.line = ln;
        ip2 = vec_emit(ip2, ltAm);
        let is *d.IRInst as jzAm = d.new_inst(d.IR_JZ);          // done -> scalar remainder (.Lhdr)
        jzAm.src1.op_type = cast(i8, d.OP_VREG); jzAm.src1.vreg = vcondAm;
        jzAm.dest.op_type = cast(i8, d.OP_LABEL); jzAm.dest.label = hlabel; jzAm.line = ln;
        ip2 = vec_emit(ip2, jzAm);
        let is i32 as aaA with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_a, iv, ln, &aaA);
        let is i32 as vlaA = vec_new_vreg(func);
        let is *d.IRInst as laA = d.new_inst(d.IR_VLOADQ256);
        laA.dest.op_type = cast(i8, d.OP_VREG); laA.dest.vreg = vlaA;
        laA.src1.op_type = cast(i8, d.OP_VREG); laA.src1.vreg = aaA;
        laA.src2.op_type = cast(i8, d.OP_IMM);  laA.src2.imm = 0; laA.line = ln;
        ip2 = vec_emit(ip2, laA);
        let is i32 as abA with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_b, iv, ln, &abA);
        let is i32 as vlbA = vec_new_vreg(func);
        let is *d.IRInst as lbA = d.new_inst(d.IR_VLOADQ256);
        lbA.dest.op_type = cast(i8, d.OP_VREG); lbA.dest.vreg = vlbA;
        lbA.src1.op_type = cast(i8, d.OP_VREG); lbA.src1.vreg = abA;
        lbA.src2.op_type = cast(i8, d.OP_IMM);  lbA.src2.imm = 0; lbA.line = ln;
        ip2 = vec_emit(ip2, lbA);
        let is i32 as vrA = vec_new_vreg(func);
        let is *d.IRInst as voA = d.new_inst(vop256);
        voA.dest.op_type = cast(i8, d.OP_VREG); voA.dest.vreg = vrA;
        voA.src1.op_type = cast(i8, d.OP_VREG); voA.src1.vreg = vlaA;
        voA.src2.op_type = cast(i8, d.OP_VREG); voA.src2.vreg = vlbA; voA.line = ln;
        ip2 = vec_emit(ip2, voA);
        let is i32 as acA with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_c, iv, ln, &acA);
        let is *d.IRInst as vsA = d.new_inst(d.IR_VSTOREQ256);
        vsA.src1.op_type = cast(i8, d.OP_VREG); vsA.src1.vreg = acA;
        vsA.src2.op_type = cast(i8, d.OP_VREG); vsA.src2.vreg = vrA;
        vsA.dest.op_type = cast(i8, d.OP_IMM);  vsA.dest.imm = 0; vsA.line = ln;
        ip2 = vec_emit(ip2, vsA);
        let is *d.IRInst as ivaddAm = d.new_inst(d.IR_ADD);
        ivaddAm.dest.op_type = cast(i8, d.OP_VREG); ivaddAm.dest.vreg = iv;
        ivaddAm.src1.op_type = cast(i8, d.OP_VREG); ivaddAm.src1.vreg = iv;
        ivaddAm.src2.op_type = cast(i8, d.OP_IMM);  ivaddAm.src2.imm = cast(i64, wideA);
        ivaddAm.line = ln;
        ip2 = vec_emit(ip2, ivaddAm);
        let is *d.IRInst as jmpAm = d.new_inst(d.IR_JMP);
        jmpAm.dest.op_type = cast(i8, d.OP_LABEL); jmpAm.dest.label = LvAm; jmpAm.line = ln;
        ip2 = vec_emit(ip2, jmpAm);
        let is *d.IRInst as lblSseM = d.new_inst(d.IR_LABEL);
        lblSseM.dest.op_type = cast(i8, d.OP_LABEL); lblSseM.dest.label = LsseM; lblSseM.line = ln;
        ip2 = vec_emit(ip2, lblSseM);
        }   // end if (is_bcast == 0): AVX2 dispatch block

        // --- SSE2 loop (128-bit; the always-available path / broadcast's only path) ---
        // For broadcast, k is splatted to [k,k] INSIDE the loop (cheap movddup) so the
        // scalar k stays live across the loop — the kept scalar remainder (.Lhdr,
        // reached by the loop's back-edge) reads k, and the linear allocator would
        // otherwise free k's register after a once-before-loop splat.
        // lim = N - (wide-1)  (`iv < lim` == `iv + wide <= N`)
        let is i32 as lim_is_imm with mut = 0;
        let is i64 as lim_imm with mut = 0;
        let is i32 as lim_vreg with mut = cast(i32, 0 - 1);
        if (nbound_is_const == 1) { lim_is_imm = 1; lim_imm = nbound - cast(i64, wide - 1); }
        else {
            lim_vreg = vec_new_vreg(func);
            let is *d.IRInst as sub = d.new_inst(d.IR_SUB);
            sub.dest.op_type = cast(i8, d.OP_VREG); sub.dest.vreg = lim_vreg;
            sub.src1.op_type = cast(i8, d.OP_VREG); sub.src1.vreg = nbound_vreg;
            sub.src2.op_type = cast(i8, d.OP_IMM);  sub.src2.imm = cast(i64, wide - 1);
            sub.line = ln;
            ip2 = vec_emit(ip2, sub);
        }
        let is i32 as Lvl = vec_new_label(func);
        let is *d.IRInst as lblv = d.new_inst(d.IR_LABEL);
        lblv.dest.op_type = cast(i8, d.OP_LABEL); lblv.dest.label = Lvl; lblv.line = ln;
        ip2 = vec_emit(ip2, lblv);
        // vcond = iv < lim ; JZ vcond -> .Lhdr (vector done -> scalar remainder)
        let is i32 as vcond = vec_new_vreg(func);
        let is *d.IRInst as lt = d.new_inst(d.IR_LT);
        lt.dest.op_type = cast(i8, d.OP_VREG); lt.dest.vreg = vcond;
        lt.src1.op_type = cast(i8, d.OP_VREG); lt.src1.vreg = iv;
        if (lim_is_imm == 1) { lt.src2.op_type = cast(i8, d.OP_IMM); lt.src2.imm = lim_imm; }
        else { lt.src2.op_type = cast(i8, d.OP_VREG); lt.src2.vreg = lim_vreg; }
        lt.line = ln;
        ip2 = vec_emit(ip2, lt);
        let is *d.IRInst as jzr = d.new_inst(d.IR_JZ);
        jzr.src1.op_type = cast(i8, d.OP_VREG); jzr.src1.vreg = vcond;
        jzr.dest.op_type = cast(i8, d.OP_LABEL); jzr.dest.label = hlabel;
        jzr.line = ln;
        ip2 = vec_emit(ip2, jzr);
        // aa = LEA(base_a, iv); vla = [aa]
        let is i32 as aa with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_a, iv, ln, &aa);
        let is i32 as vla = vec_new_vreg(func);
        let is *d.IRInst as la = d.new_inst(d.IR_VLOADQ);
        la.dest.op_type = cast(i8, d.OP_VREG); la.dest.vreg = vla;
        la.src1.op_type = cast(i8, d.OP_VREG); la.src1.vreg = aa;
        la.src2.op_type = cast(i8, d.OP_IMM);  la.src2.imm = 0; la.line = ln;
        ip2 = vec_emit(ip2, la);
        let is i32 as vlb with mut = cast(i32, 0 - 1);
        if (is_bcast == 1) {
            // vlb = [k,k] (movddup) — recomputed each iteration, keeping k live
            vlb = vec_new_vreg(func);
            let is *d.IRInst as spl = d.new_inst(d.IR_VSPLATPD);
            spl.dest.op_type = cast(i8, d.OP_VREG); spl.dest.vreg = vlb;
            spl.src1.op_type = cast(i8, d.OP_VREG); spl.src1.vreg = kvreg;
            spl.line = ln;
            ip2 = vec_emit(ip2, spl);
        } else {
            let is i32 as ab with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_b, iv, ln, &ab);
            vlb = vec_new_vreg(func);
            let is *d.IRInst as lb = d.new_inst(d.IR_VLOADQ);
            lb.dest.op_type = cast(i8, d.OP_VREG); lb.dest.vreg = vlb;
            lb.src1.op_type = cast(i8, d.OP_VREG); lb.src1.vreg = ab;
            lb.src2.op_type = cast(i8, d.OP_IMM);  lb.src2.imm = 0; lb.line = ln;
            ip2 = vec_emit(ip2, lb);
        }
        let is i32 as vr = vec_new_vreg(func);
        let is *d.IRInst as vo = d.new_inst(vop);
        vo.dest.op_type = cast(i8, d.OP_VREG); vo.dest.vreg = vr;
        vo.src1.op_type = cast(i8, d.OP_VREG); vo.src1.vreg = vla;
        vo.src2.op_type = cast(i8, d.OP_VREG); vo.src2.vreg = vlb; vo.line = ln;
        ip2 = vec_emit(ip2, vo);
        let is i32 as ac with mut = 0; ip2 = vec_emit_lea(func, ip2, lea_op, base_c, iv, ln, &ac);
        let is *d.IRInst as vs = d.new_inst(d.IR_VSTOREQ);
        vs.src1.op_type = cast(i8, d.OP_VREG); vs.src1.vreg = ac;
        vs.src2.op_type = cast(i8, d.OP_VREG); vs.src2.vreg = vr;
        vs.dest.op_type = cast(i8, d.OP_IMM);  vs.dest.imm = 0; vs.line = ln;
        ip2 = vec_emit(ip2, vs);
        // iv += wide ; JMP .Lvl
        let is *d.IRInst as ivadd = d.new_inst(d.IR_ADD);
        ivadd.dest.op_type = cast(i8, d.OP_VREG); ivadd.dest.vreg = iv;
        ivadd.src1.op_type = cast(i8, d.OP_VREG); ivadd.src1.vreg = iv;
        ivadd.src2.op_type = cast(i8, d.OP_IMM);  ivadd.src2.imm = cast(i64, wide);
        ivadd.line = ln;
        ip2 = vec_emit(ip2, ivadd);
        let is *d.IRInst as jmpb = d.new_inst(d.IR_JMP);
        jmpb.dest.op_type = cast(i8, d.OP_LABEL); jmpb.dest.label = Lvl; jmpb.line = ln;
        ip2 = vec_emit(ip2, jmpb);
    }
    // scalar loop kept intact: alias fallback (overlap path) AND remainder (vector path).
    hdr.is_extern_call = 1;
    return 1;
}
