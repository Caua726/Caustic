use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "defs.cst" as d;

fn pr(s as *u8, len as i64) as void { linux.write(1, s, len); }
fn pr_int(v as i64) as void { io.write_int(1, v); }
fn nl() as void { pr("\n", 1); }

fn op_name(op as i32) as void {
    if (op == 0) { pr("IMM       ", 10); }
    else if (op == 1) { pr("MOV       ", 10); }
    else if (op == 2) { pr("ADD       ", 10); }
    else if (op == 3) { pr("SUB       ", 10); }
    else if (op == 4) { pr("MUL       ", 10); }
    else if (op == 5) { pr("DIV       ", 10); }
    else if (op == 6) { pr("MOD       ", 10); }
    else if (op == 7) { pr("NEG       ", 10); }
    else if (op == 8) { pr("EQ        ", 10); }
    else if (op == 9) { pr("NE        ", 10); }
    else if (op == 10) { pr("LT        ", 10); }
    else if (op == 11) { pr("LE        ", 10); }
    else if (op == 12) { pr("GT        ", 10); }
    else if (op == 13) { pr("GE        ", 10); }
    else if (op == 14) { pr("JMP       ", 10); }
    else if (op == 15) { pr("JZ        ", 10); }
    else if (op == 16) { pr("JNZ       ", 10); }
    else if (op == 17) { pr("LABEL     ", 10); }
    else if (op == 18) { pr("CALL      ", 10); }
    else if (op == 19) { pr("RET       ", 10); }
    else if (op == 20) { pr("LOAD      ", 10); }
    else if (op == 21) { pr("STORE     ", 10); }
    else if (op == 22) { pr("PHI       ", 10); }
    else if (op == 23) { pr("ASM       ", 10); }
    else if (op == 24) { pr("CAST      ", 10); }
    else if (op == 25) { pr("SHL       ", 10); }
    else if (op == 26) { pr("SHR       ", 10); }
    else if (op == 27) { pr("AND       ", 10); }
    else if (op == 28) { pr("OR        ", 10); }
    else if (op == 29) { pr("XOR       ", 10); }
    else if (op == 30) { pr("NOT       ", 10); }
    else if (op == 31) { pr("GET_ARG   ", 10); }
    else if (op == 32) { pr("SET_ARG   ", 10); }
    else if (op == 33) { pr("SET_SARG  ", 10); }
    else if (op == 34) { pr("SYSCALL   ", 10); }
    else if (op == 35) { pr("COPY      ", 10); }
    else if (op == 36) { pr("ADDR      ", 10); }
    else if (op == 37) { pr("ADDR_G    ", 10); }
    else if (op == 38) { pr("ALLOC_A   ", 10); }
    else if (op == 39) { pr("SET_CTX   ", 10); }
    else if (op == 40) { pr("FN_ADDR   ", 10); }
    else if (op == 41) { pr("FADD      ", 10); }
    else if (op == 42) { pr("FSUB      ", 10); }
    else if (op == 43) { pr("FMUL      ", 10); }
    else if (op == 44) { pr("FDIV      ", 10); }
    else if (op == 45) { pr("FNEG      ", 10); }
    else if (op == 46) { pr("VA_START  ", 10); }
    else { pr("???       ", 10); }
}

fn print_op(o as d.Operand) as void {
    if (o.op_type == d.OP_NONE) { return; }
    if (o.op_type == d.OP_VREG) { pr("v", 1); pr_int(cast(i64, o.vreg)); }
    else if (o.op_type == d.OP_IMM) { pr_int(o.imm); }
    else if (o.op_type == d.OP_LABEL) { pr("L", 1); pr_int(cast(i64, o.label)); }
}

fn ir_print(prog as *u8) as void {
    let is *d.IRProgram as p = cast(*d.IRProgram, prog);
    if (cast(i64, p) == 0) { pr("(empty IR)\n", 11); return; }

    pr("=== IR ===\n\n", 12);

    let is *d.IRFunction as func with mut = p.functions;
    while (cast(i64, func) != 0) {
        pr("fn ", 3);
        linux.write(1, func.asm_name_ptr, cast(i64, func.asm_name_len));
        pr("  vregs=", 8);
        pr_int(cast(i64, func.vreg_count));
        pr(" labels=", 8);
        pr_int(cast(i64, func.label_count));
        nl();

        let is i32 as num with mut = 0;
        let is *d.IRInst as inst with mut = func.instructions;
        while (cast(i64, inst) != 0) {
            if (inst.is_dead == 0) {
                pr("  ", 2);
                // pad number
                if (num < 10) { pr("  ", 2); }
                else if (num < 100) { pr(" ", 1); }
                pr_int(cast(i64, num));
                pr(": ", 2);
                op_name(inst.op);

                let is i32 as op = inst.op;

                if (op == d.IR_IMM) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
                } else if (op == d.IR_MOV || op == d.IR_CAST) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
                } else if (op >= d.IR_ADD && op <= d.IR_MOD) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
                } else if (op >= d.IR_FADD && op <= d.IR_FDIV) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
                } else if (op >= d.IR_EQ && op <= d.IR_GE) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
                } else if (op >= d.IR_SHL && op <= d.IR_XOR) {
                    print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
                } else if (op == d.IR_NEG || op == d.IR_NOT || op == d.IR_FNEG) {
                    print_op(inst.dest); pr(" = -", 4); print_op(inst.src1);
                } else if (op == d.IR_RET) {
                    print_op(inst.src1);
                } else if (op == d.IR_LABEL) {
                    pr("L", 1); pr_int(cast(i64, inst.dest.label));
                } else if (op == d.IR_JMP) {
                    pr("L", 1); pr_int(cast(i64, inst.dest.label));
                } else if (op == d.IR_JZ || op == d.IR_JNZ) {
                    pr("L", 1); pr_int(cast(i64, inst.dest.label)); pr(" if ", 4); print_op(inst.src1);
                } else if (op == d.IR_LOAD) {
                    print_op(inst.dest); pr(" = [", 4); print_op(inst.src1); pr("]", 1);
                } else if (op == d.IR_STORE) {
                    pr("[", 1); print_op(inst.dest); pr("] = ", 4); print_op(inst.src1);
                } else if (op == d.IR_CALL) {
                    print_op(inst.dest); pr(" = call ", 8);
                    linux.write(1, inst.call_name_ptr, cast(i64, inst.call_name_len));
                } else if (op == d.IR_SET_ARG || op == d.IR_SET_SYS_ARG) {
                    pr("arg", 3); print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
                } else if (op == d.IR_GET_ARG) {
                    print_op(inst.dest); pr(" = arg", 6); print_op(inst.src1);
                } else if (op == d.IR_ADDR || op == d.IR_ADDR_GLOBAL || op == d.IR_GET_ALLOC_ADDR) {
                    print_op(inst.dest); pr(" = &", 4); print_op(inst.src1);
                } else if (op == d.IR_SET_CTX) {
                    pr("ctx = ", 6); print_op(inst.src1);
                } else if (op == d.IR_COPY) {
                    pr("[", 1); print_op(inst.dest); pr("] <- [", 6); print_op(inst.src1); pr("] sz=", 5); print_op(inst.src2);
                } else if (op == d.IR_ASM) {
                    pr("\"", 1);
                    if (inst.asm_str_len > 0) {
                        linux.write(1, inst.asm_str_ptr, cast(i64, inst.asm_str_len));
                    }
                    pr("\"", 1);
                } else if (op == d.IR_FN_ADDR) {
                    print_op(inst.dest); pr(" = fn_addr", 10);
                } else if (op == d.IR_SYSCALL) {
                    print_op(inst.dest); pr(" = syscall", 10);
                } else if (op == d.IR_VA_START) {
                    print_op(inst.dest); pr(" = va_start", 11);
                } else {
                    print_op(inst.dest); pr(" ", 1); print_op(inst.src1); pr(" ", 1); print_op(inst.src2);
                }

                if (inst.line > 0) { pr("  ; L", 5); pr_int(cast(i64, inst.line)); }
                nl();
            }
            num = num + 1;
            inst = inst.next;
        }
        nl();
        func = func.next;
    }
    pr("==========\n", 11);
}
