use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "defs.cst" as d;
use "../parser/ast.cst" as ast;

let is i32 as dbg_fd with mut = 1;
let is i32 as dbg_show_dead with mut = 0;

fn pr(s as *u8, len as i64) as void { linux.write(cast(i64, dbg_fd), s, len); }
fn pr_int(v as i64) as void { io.write_int(cast(i64, dbg_fd), v); }
fn nl() as void { pr("\n", 1); }

fn pr_str(s as *u8) as void {
    let is i32 as i with mut = 0;
    while (s[i] != cast(u8, 0)) { i = i + 1; }
    pr(s, cast(i64, i));
}

fn pr_type_name(ty_ptr as *u8) as void {
    if (cast(i64, ty_ptr) == 0) { pr("?", 1); return; }
    let is *ast.Type as t = cast(*ast.Type, ty_ptr);
    if (t.kind == ast.TY_VOID) { pr("void", 4); }
    else if (t.kind == ast.TY_I8) { pr("i8", 2); }
    else if (t.kind == ast.TY_I16) { pr("i16", 3); }
    else if (t.kind == ast.TY_I32) { pr("i32", 3); }
    else if (t.kind == ast.TY_I64) { pr("i64", 3); }
    else if (t.kind == ast.TY_U8) { pr("u8", 2); }
    else if (t.kind == ast.TY_U16) { pr("u16", 3); }
    else if (t.kind == ast.TY_U32) { pr("u32", 3); }
    else if (t.kind == ast.TY_U64) { pr("u64", 3); }
    else if (t.kind == ast.TY_F32) { pr("f32", 3); }
    else if (t.kind == ast.TY_F64) { pr("f64", 3); }
    else if (t.kind == ast.TY_BOOL) { pr("bool", 4); }
    else if (t.kind == ast.TY_CHAR) { pr("char", 4); }
    else if (t.kind == ast.TY_STRING) { pr("string", 6); }
    else if (t.kind == ast.TY_PTR) { pr("*", 1); pr_type_name(cast(*u8, t.base)); }
    else if (t.kind == ast.TY_ARRAY) { pr("[]", 2); pr_type_name(cast(*u8, t.base)); }
    else if (t.kind == ast.TY_STRUCT && t.name_len > 0) { pr(t.name_ptr, cast(i64, t.name_len)); }
    else if (t.kind == ast.TY_ENUM && t.name_len > 0) { pr(t.name_ptr, cast(i64, t.name_len)); }
    else { pr("?", 1); }
}

fn pr_pad(n as i64, width as i32) as void {
    let is i32 as digits with mut = 1;
    let is i64 as tmp with mut = n;
    if (tmp < 0) { tmp = 0 - tmp; digits = digits + 1; }
    while (tmp >= 10) { tmp = tmp / 10; digits = digits + 1; }
    let is i32 as pad with mut = width - digits;
    while (pad > 0) { pr(" ", 1); pad = pad - 1; }
    pr_int(n);
}

fn op_name(op as i32) as void {
    if (op == d.IR_IMM) { pr("IMM       ", 10); }
    else if (op == d.IR_MOV) { pr("MOV       ", 10); }
    else if (op == d.IR_ADD) { pr("ADD       ", 10); }
    else if (op == d.IR_SUB) { pr("SUB       ", 10); }
    else if (op == d.IR_MUL) { pr("MUL       ", 10); }
    else if (op == d.IR_DIV) { pr("DIV       ", 10); }
    else if (op == d.IR_MOD) { pr("MOD       ", 10); }
    else if (op == d.IR_NEG) { pr("NEG       ", 10); }
    else if (op == d.IR_EQ) { pr("EQ        ", 10); }
    else if (op == d.IR_NE) { pr("NE        ", 10); }
    else if (op == d.IR_LT) { pr("LT        ", 10); }
    else if (op == d.IR_LE) { pr("LE        ", 10); }
    else if (op == d.IR_GT) { pr("GT        ", 10); }
    else if (op == d.IR_GE) { pr("GE        ", 10); }
    else if (op == d.IR_JMP) { pr("JMP       ", 10); }
    else if (op == d.IR_JZ) { pr("JZ        ", 10); }
    else if (op == d.IR_JNZ) { pr("JNZ       ", 10); }
    else if (op == d.IR_LABEL) { pr("LABEL     ", 10); }
    else if (op == d.IR_CALL) { pr("CALL      ", 10); }
    else if (op == d.IR_RET) { pr("RET       ", 10); }
    else if (op == d.IR_LOAD) { pr("LOAD      ", 10); }
    else if (op == d.IR_STORE) { pr("STORE     ", 10); }
    else if (op == d.IR_PHI) { pr("PHI       ", 10); }
    else if (op == d.IR_ASM) { pr("ASM       ", 10); }
    else if (op == d.IR_CAST) { pr("CAST      ", 10); }
    else if (op == d.IR_SHL) { pr("SHL       ", 10); }
    else if (op == d.IR_SHR) { pr("SHR       ", 10); }
    else if (op == d.IR_AND) { pr("AND       ", 10); }
    else if (op == d.IR_OR) { pr("OR        ", 10); }
    else if (op == d.IR_XOR) { pr("XOR       ", 10); }
    else if (op == d.IR_NOT) { pr("NOT       ", 10); }
    else if (op == d.IR_GET_ARG) { pr("GET_ARG   ", 10); }
    else if (op == d.IR_SET_ARG) { pr("SET_ARG   ", 10); }
    else if (op == d.IR_SET_SYS_ARG) { pr("SET_SARG  ", 10); }
    else if (op == d.IR_SYSCALL) { pr("SYSCALL   ", 10); }
    else if (op == d.IR_COPY) { pr("COPY      ", 10); }
    else if (op == d.IR_ADDR) { pr("ADDR      ", 10); }
    else if (op == d.IR_ADDR_GLOBAL) { pr("ADDR_G    ", 10); }
    else if (op == d.IR_GET_ALLOC_ADDR) { pr("ALLOC_A   ", 10); }
    else if (op == d.IR_SET_CTX) { pr("SET_CTX   ", 10); }
    else if (op == d.IR_FN_ADDR) { pr("FN_ADDR   ", 10); }
    else if (op == d.IR_FADD) { pr("FADD      ", 10); }
    else if (op == d.IR_FSUB) { pr("FSUB      ", 10); }
    else if (op == d.IR_FMUL) { pr("FMUL      ", 10); }
    else if (op == d.IR_FDIV) { pr("FDIV      ", 10); }
    else if (op == d.IR_FNEG) { pr("FNEG      ", 10); }
    else if (op == d.IR_VA_START) { pr("VA_START  ", 10); }
    else { pr("OP", 2); pr_int(cast(i64, op)); pr("      ", 6); }
}

fn print_op(o as d.Operand) as void {
    if (o.op_type == d.OP_NONE) { pr("_", 1); return; }
    if (o.op_type == d.OP_VREG) { pr("v", 1); pr_int(cast(i64, o.vreg)); }
    else if (o.op_type == d.OP_IMM) { pr_int(o.imm); }
    else if (o.op_type == d.OP_LABEL) { pr("L", 1); pr_int(cast(i64, o.label)); }
}

fn print_inst(inst as *d.IRInst, num as i32) as void {
    let is i32 as op = inst.op;

    if (inst.is_dead == 1) {
        if (dbg_show_dead == 0) { return; }
        pr("  DEAD ", 7);
    } else {
        pr("  ", 2);
    }

    pr_pad(cast(i64, num), 4);
    pr(": ", 2);

    // Labels get special prefix
    if (op == d.IR_LABEL) {
        pr("L", 1); pr_int(cast(i64, inst.dest.label)); pr(":", 1); nl();
        return;
    }

    op_name(op);

    if (op == d.IR_IMM) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
    } else if (op == d.IR_MOV) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
    } else if (op == d.IR_CAST) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
        pr(" (", 2);
        pr_type_name(inst.cast_from);
        pr("->", 2);
        pr_type_name(inst.cast_to);
        pr(")", 1);
    } else if (op == d.IR_PHI) {
        print_op(inst.dest); pr(" = phi(", 7); print_op(inst.src1); pr(", ", 2); print_op(inst.src2); pr(")", 1);
    } else if (op >= d.IR_ADD && op <= d.IR_MOD) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
    } else if (op >= d.IR_FADD && op <= d.IR_FDIV) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
    } else if (op >= d.IR_EQ && op <= d.IR_GE) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
    } else if (op >= d.IR_SHL && op <= d.IR_XOR) {
        print_op(inst.dest); pr(" = ", 3); print_op(inst.src1); pr(", ", 2); print_op(inst.src2);
    } else if (op == d.IR_NEG || op == d.IR_NOT || op == d.IR_FNEG) {
        print_op(inst.dest); pr(" = -", 4); print_op(inst.src1);
    } else if (op == d.IR_RET) {
        print_op(inst.src1);
    } else if (op == d.IR_JMP) {
        pr("-> L", 4); pr_int(cast(i64, inst.dest.label));
    } else if (op == d.IR_JZ) {
        pr("L", 1); pr_int(cast(i64, inst.dest.label)); pr(" if !", 5); print_op(inst.src1);
    } else if (op == d.IR_JNZ) {
        pr("L", 1); pr_int(cast(i64, inst.dest.label)); pr(" if ", 4); print_op(inst.src1);
    } else if (op == d.IR_LOAD) {
        print_op(inst.dest); pr(" = [", 4); print_op(inst.src1); pr("]", 1);
    } else if (op == d.IR_STORE) {
        pr("[", 1); print_op(inst.dest); pr("] = ", 4); print_op(inst.src1);
    } else if (op == d.IR_CALL) {
        print_op(inst.dest); pr(" = call ", 8);
        linux.write(cast(i64, dbg_fd), inst.call_name_ptr, cast(i64, inst.call_name_len));
    } else if (op == d.IR_SET_ARG || op == d.IR_SET_SYS_ARG) {
        pr("arg", 3); print_op(inst.dest); pr(" = ", 3); print_op(inst.src1);
    } else if (op == d.IR_GET_ARG) {
        print_op(inst.dest); pr(" = arg", 6); print_op(inst.src1);
    } else if (op == d.IR_ADDR) {
        print_op(inst.dest); pr(" = &[rbp-", 9); pr_int(inst.src1.imm); pr("]", 1);
    } else if (op == d.IR_ADDR_GLOBAL) {
        print_op(inst.dest); pr(" = &global ", 11);
        if (inst.global_name_len > 0) {
            linux.write(cast(i64, dbg_fd), inst.global_name_ptr, cast(i64, inst.global_name_len));
        }
    } else if (op == d.IR_GET_ALLOC_ADDR) {
        print_op(inst.dest); pr(" = &alloc[rbp-", 14); pr_int(inst.src1.imm); pr("]", 1);
    } else if (op == d.IR_SET_CTX) {
        pr("ctx[", 4); print_op(inst.dest); pr("] = ", 4); print_op(inst.src1);
    } else if (op == d.IR_COPY) {
        pr("[", 1); print_op(inst.dest); pr("] <- [", 6); print_op(inst.src1); pr("] sz=", 5); print_op(inst.src2);
    } else if (op == d.IR_ASM) {
        pr("\"", 1);
        if (inst.asm_str_len > 0) {
            linux.write(cast(i64, dbg_fd), inst.asm_str_ptr, cast(i64, inst.asm_str_len));
        }
        pr("\"", 1);
    } else if (op == d.IR_FN_ADDR) {
        print_op(inst.dest); pr(" = fn_addr ", 11);
        if (inst.call_name_len > 0) {
            linux.write(cast(i64, dbg_fd), inst.call_name_ptr, cast(i64, inst.call_name_len));
        }
    } else if (op == d.IR_SYSCALL) {
        print_op(inst.dest); pr(" = syscall", 10);
    } else if (op == d.IR_VA_START) {
        print_op(inst.dest); pr(" = va_start", 11);
    } else {
        print_op(inst.dest); pr(" ", 1); print_op(inst.src1); pr(" ", 1); print_op(inst.src2);
    }

    if (inst.line > 0) { pr("  ; L", 5); pr_int(cast(i64, inst.line)); }
    nl();
}

fn ir_print_func(func as *d.IRFunction) as void {
    if (func.is_reachable == 0) { return; }
    pr("fn ", 3);
    linux.write(cast(i64, dbg_fd), func.asm_name_ptr, cast(i64, func.asm_name_len));
    pr("  (vregs=", 9);
    pr_int(cast(i64, func.vreg_count));
    pr(", labels=", 9);
    pr_int(cast(i64, func.label_count));
    pr(", args=", 7);
    pr_int(cast(i64, func.num_args));
    pr(", stack=", 8);
    pr_int(cast(i64, func.stack_size));
    pr(")", 1);
    nl();

    let is i32 as num with mut = 0;
    let is i32 as live with mut = 0;
    let is i32 as dead with mut = 0;
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        print_inst(inst, num);
        if (inst.is_dead == 1) { dead = dead + 1; }
        else { live = live + 1; }
        num = num + 1;
        inst = inst.next;
    }
    pr("  ; ", 4); pr_int(cast(i64, live)); pr(" live", 5);
    if (dead > 0) { pr(", ", 2); pr_int(cast(i64, dead)); pr(" dead", 5); }
    nl(); nl();
}

fn ir_print(prog as *u8) as void {
    let is *d.IRProgram as p = cast(*d.IRProgram, prog);
    if (cast(i64, p) == 0) { pr("(empty IR)\n", 11); return; }

    // Print globals
    let is *d.IRGlobal as g with mut = p.globals;
    if (cast(i64, g) != 0) {
        pr("=== Globals ===\n", 16);
        while (cast(i64, g) != 0) {
            if (g.is_reachable == 1) {
                pr("  ", 2);
                linux.write(cast(i64, dbg_fd), g.name_ptr, cast(i64, g.name_len));
                pr("  size=", 7); pr_int(cast(i64, g.size));
                if (g.is_initialized == 1) { pr(" init=", 6); pr_int(g.init_value); }
                nl();
            }
            g = g.next;
        }
        nl();
    }

    // Print strings
    let is *d.StringEntry as s with mut = p.strings;
    if (cast(i64, s) != 0) {
        pr("=== Strings ===\n", 16);
        while (cast(i64, s) != 0) {
            pr("  .str", 6); pr_int(cast(i64, s.id));
            pr(" = \"", 4);
            // Print up to 60 chars
            let is i32 as slen with mut = s.len;
            if (slen > 60) { slen = 60; }
            linux.write(cast(i64, dbg_fd), s.ptr, cast(i64, slen));
            if (s.len > 60) { pr("...", 3); }
            pr("\" (", 3); pr_int(cast(i64, s.len)); pr("b)", 2);
            nl();
            s = s.next;
        }
        nl();
    }

    pr("=== IR Functions ===\n\n", 22);

    let is *d.IRFunction as func with mut = p.functions;
    while (cast(i64, func) != 0) {
        ir_print_func(func);
        func = func.next;
    }
}

// Print IR for a single phase (used for before/after optimization)
fn ir_print_phase(prog as *u8, phase as *u8) as void {
    let is *d.IRProgram as p = cast(*d.IRProgram, prog);
    if (cast(i64, p) == 0) { return; }
    pr("=== IR (", 8); pr_str(phase); pr(") ===\n\n", 7);
    let is *d.IRFunction as func with mut = p.functions;
    while (cast(i64, func) != 0) {
        ir_print_func(func);
        func = func.next;
    }
}
