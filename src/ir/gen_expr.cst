use "../../std/mem.cst" as mem;
use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "../parser/ast.cst" as ast;
use "defs.cst" as d;
use "gen.cst" as g;

fn emit_deferred_calls() as void {
    let is i32 as i with mut = g.defer_count - 1;
    while (i >= 0) {
        let is *ast.Node as nd = cast(*ast.Node, g.get_defer(i));
        gen_expr(nd);
        i = i - 1;
    }
}

fn gen_addr(node as *ast.Node) as i32 {
    let is i32 as k = node.kind;
    let is i32 as line = g.tok_line(node.tok_idx);

    if (k == ast.NK_IDENT) {
        let is i32 as dest = g.new_vreg();
        if (node.is_global == 1) {
            let is *d.IRInst as i = d.new_inst(d.IR_ADDR_GLOBAL);
            i.dest = d.op_vreg(dest);
            if (node.asm_name_len > 0) {
                i.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                i.global_name_len = node.asm_name_len;
            } else {
                i.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
                i.global_name_len = node.name_len;
            }
            i.is_extern_global = node.is_extern;
            i.line = line;
            g.emit(i);
        } else {
            let is *d.IRInst as i = d.new_inst(d.IR_ADDR);
            i.dest = d.op_vreg(dest);
            i.src1 = d.op_imm(cast(i64, node.var_offset));
            i.line = line;
            g.emit(i);
        }
        return dest;
    }

    if (k == ast.NK_DEREF) {
        return gen_expr(node.expr);
    }

    if (k == ast.NK_INDEX) {
        let is *ast.Type as lty = node.lhs.ty;
        let is i32 as base with mut;
        if (lty.kind == ast.TY_PTR) {
            base = gen_expr(node.lhs);
        } else {
            base = gen_addr(node.lhs);
        }
        let is i32 as index = gen_expr(node.rhs);
        let is *ast.Type as ety = node.ty;
        let is i32 as sz = ety.size;
        let is i32 as off_reg with mut;
        if (sz == 1) { off_reg = index; }
        else if (sz == 2) { off_reg = g.emit_binary(d.IR_SHL, index, g.emit_imm(1, line), line); }
        else if (sz == 4) { off_reg = g.emit_binary(d.IR_SHL, index, g.emit_imm(2, line), line); }
        else if (sz == 8) { off_reg = g.emit_binary(d.IR_SHL, index, g.emit_imm(3, line), line); }
        else { off_reg = g.emit_binary(d.IR_MUL, index, g.emit_imm(cast(i64, sz), line), line); }
        return g.emit_binary(d.IR_ADD, base, off_reg, line);
    }

    if (k == ast.NK_MEMBER) {
        let is *ast.Type as lty = node.lhs.ty;
        let is i32 as base with mut;
        if (lty.kind == ast.TY_PTR) {
            base = gen_expr(node.lhs);
        } else {
            base = gen_addr(node.lhs);
        }
        if (node.var_offset == 0) { return base; }
        let is i32 as off_reg = g.emit_imm(cast(i64, node.var_offset), line);
        return g.emit_binary(d.IR_ADD, base, off_reg, line);
    }

    io.write_str(linux.STDERR, "ir: gen_addr: unsupported node kind\n");
    linux.exit(1);
    return 0;
}

// === Extracted helpers for gen_expr ===

fn emit_load_from_addr(addr as i32, ty_ptr as *u8, line as i32) as i32 {
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    if (ty.size > 8) { return addr; }
    let is i32 as dest = g.new_vreg();
    let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
    i.dest = d.op_vreg(dest);
    i.src1 = d.op_vreg(addr);
    i.cast_to = ty_ptr;
    i.line = line;
    g.emit(i);
    return dest;
}

fn gen_cmp(node as *ast.Node, op as i32, line as i32, need_cast as i32) as i32 {
    let is i32 as lhs = gen_expr(node.lhs);
    let is i32 as rhs = gen_expr(node.rhs);
    let is i32 as r = g.emit_binary(op, lhs, rhs, line);
    if (need_cast == 1) {
        g.ctx_tail.cast_to = cast(*u8, node.lhs.ty);
    }
    return r;
}

fn gen_bitwise(node as *ast.Node, op as i32, line as i32, need_cast as i32) as i32 {
    let is i32 as lhs = gen_expr(node.lhs);
    let is i32 as rhs = gen_expr(node.rhs);
    let is i32 as r = g.emit_binary(op, lhs, rhs, line);
    if (need_cast == 1) {
        g.ctx_tail.cast_to = cast(*u8, node.ty);
    }
    return r;
}

fn gen_fncall(node as *ast.Node, ty as *ast.Type, line as i32) as i32 {
    let is i32 as arg_count with mut = 0;
    let is *ast.Node as a with mut = node.args;
    while (cast(i64, a) != 0) { arg_count = arg_count + 1; a = a.next; }

    // SRET for large struct return
    let is i32 as use_sret with mut = 0;
    if (ty.size > 8) { use_sret = 1; }

    let is i32 as sret_addr with mut = cast(i32, 0 - 1);
    if (use_sret == 1) {
        g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + ty.size;
        if (g.ctx_func.alloc_stack_size % 16 != 0) {
            g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + 16 - (g.ctx_func.alloc_stack_size % 16);
        }
        let is i32 as offset = g.ctx_func.alloc_stack_size;
        sret_addr = g.new_vreg();
        let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
        ga.dest = d.op_vreg(sret_addr);
        ga.src1 = d.op_imm(cast(i64, offset));
        ga.line = line;
        g.emit(ga);
        arg_count = arg_count + 1;
    }

    // Generate args - max 32 args
    let is [256]u8 as arg_vregs;
    let is [64]u8 as arg_is_flt;
    let is [64]i64 as arg_types;
    let is i32 as ai with mut = 0;
    if (sret_addr != cast(i32, 0 - 1)) {
        let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, ai) * 4);
        *av = sret_addr;
        arg_is_flt[ai] = 0;
        arg_types[ai] = 0;
        ai = ai + 1;
    }
    a = node.args;
    while (cast(i64, a) != 0 && ai < 64) {
        let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, ai) * 4);
        *av = gen_expr(a);
        if (g.is_float_kind(a.ty.kind) == 1) { arg_is_flt[ai] = 1; }
        else { arg_is_flt[ai] = 0; }
        arg_types[ai] = cast(i64, a.ty);
        ai = ai + 1;
        a = a.next;
    }

    let is i32 as stack_args with mut = 0;
    let is i32 as padding with mut = 0;
    let is i32 as j with mut = 0;
    let is i32 as xmm_total with mut = 0;

    if (node.is_extern == 1) {
        // System V ABI: floats → xmm0-xmm7, ints → rdi/rsi/rdx/rcx/r8/r9
        let is i32 as gpr_total with mut = 0;
        j = 0;
        while (j < arg_count) {
            if (arg_is_flt[j] == 1) { xmm_total = xmm_total + 1; }
            else { gpr_total = gpr_total + 1; }
            j = j + 1;
        }
        let is i32 as stack_gpr with mut = 0;
        let is i32 as stack_xmm with mut = 0;
        if (gpr_total > 6) { stack_gpr = gpr_total - 6; }
        if (xmm_total > 8) { stack_xmm = xmm_total - 8; }
        stack_args = stack_gpr + stack_xmm;
        if (stack_args % 2 != 0) { padding = 1; }
        if (padding == 1) {
            let is *d.IRInst as pa = d.new_inst(d.IR_ASM);
            pa.asm_str_ptr = d.str_dup("sub rsp, 8", 10);
            pa.asm_str_len = 10;
            pa.line = line;
            g.emit(pa);
        }
        // Classify each arg: on_stack or register
        let is [64]u8 as arg_on_stk;
        let is i32 as gi with mut = 0;
        let is i32 as xi with mut = 0;
        j = 0;
        while (j < arg_count) {
            if (arg_is_flt[j] == 1) {
                if (xi < 8) { arg_on_stk[j] = 0; } else { arg_on_stk[j] = 1; }
                xi = xi + 1;
            } else {
                if (gi < 6) { arg_on_stk[j] = 0; } else { arg_on_stk[j] = 1; }
                gi = gi + 1;
            }
            j = j + 1;
        }
        // Push stack overflow args in reverse
        j = arg_count - 1;
        while (j >= 0) {
            if (arg_on_stk[j] == 1) {
                let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
                g.emit_set_arg(6, *av, cast(*u8, 0), line);
            }
            j = j - 1;
        }
        // Set register args with separate GPR/XMM indices
        gi = 0;
        xi = 0;
        j = 0;
        while (j < arg_count) {
            if (arg_on_stk[j] == 0) {
                let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
                if (arg_is_flt[j] == 1) {
                    g.emit_set_arg(xi, *av, cast(*u8, arg_types[j]), line);
                    xi = xi + 1;
                } else {
                    g.emit_set_arg(gi, *av, cast(*u8, 0), line);
                    gi = gi + 1;
                }
            } else {
                if (arg_is_flt[j] == 1) { xi = xi + 1; }
                else { gi = gi + 1; }
            }
            j = j + 1;
        }
    } else {
        // Internal Caustic ABI: all args in GPRs
        if (arg_count > 6) { stack_args = arg_count - 6; }
        if (stack_args % 2 != 0) { padding = 1; }
        if (padding == 1) {
            let is *d.IRInst as pa = d.new_inst(d.IR_ASM);
            pa.asm_str_ptr = d.str_dup("sub rsp, 8", 10);
            pa.asm_str_len = 10;
            pa.line = line;
            g.emit(pa);
        }
        // Stack args in reverse
        j = arg_count - 1;
        while (j >= 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            g.emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j - 1;
        }
        // Register args
        j = 0;
        while (j < arg_count && j < 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            g.emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j + 1;
        }
    }

    // Use asm_name if available (for mangled names)
    let is *u8 as cname with mut = node.name_ptr;
    let is i32 as clen with mut = node.name_len;
    if (node.asm_name_len > 0) {
        cname = node.asm_name_ptr;
        clen = node.asm_name_len;
    }
    let is i32 as ret_reg = g.emit_call(cname, clen, node.is_variadic, node.is_extern, cast(*u8, ty), xmm_total, line);

    if (stack_args > 0) {
        let is i32 as pad2 with mut = 0;
        if (stack_args % 2 != 0) { pad2 = 1; }
        let is i32 as cleanup_bytes = (stack_args + pad2) * 8;
        // Build "add rsp, N" string
        let is [32]u8 as cbuf;
        mem.memcpy(cast(*u8, &cbuf), "add rsp, ", 9);
        let is i32 as cpos with mut = 9;
        let is i32 as cv with mut = cleanup_bytes;
        let is [10]u8 as nbuf;
        let is i32 as ni with mut = 0;
        while (cv > 0) {
            nbuf[ni] = cast(u8, (cv % 10) + 48);
            cv = cv / 10;
            ni = ni + 1;
        }
        let is i32 as nj with mut = ni - 1;
        while (nj >= 0) {
            cbuf[cpos] = nbuf[nj];
            cpos = cpos + 1;
            nj = nj - 1;
        }
        let is *d.IRInst as cl = d.new_inst(d.IR_ASM);
        cl.asm_str_ptr = d.str_dup(cast(*u8, &cbuf), cpos);
        cl.asm_str_len = cpos;
        cl.line = line;
        g.emit(cl);
    }

    if (sret_addr != cast(i32, 0 - 1)) { return sret_addr; }
    return ret_reg;
}

fn gen_syscall(node as *ast.Node, line as i32) as i32 {
    let is i32 as arg_count with mut = 0;
    let is [56]u8 as arg_vregs;
    let is *ast.Node as a with mut = node.args;
    while (cast(i64, a) != 0) {
        let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, arg_count) * 4);
        *av = gen_expr(a);
        arg_count = arg_count + 1;
        a = a.next;
    }
    let is i32 as si with mut = 0;
    while (si < arg_count) {
        let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, si) * 4);
        let is *d.IRInst as sa = d.new_inst(d.IR_SET_SYS_ARG);
        sa.dest = d.op_imm(cast(i64, si));
        sa.src1 = d.op_vreg(*av);
        sa.line = line;
        g.emit(sa);
        si = si + 1;
    }
    let is i32 as dest = g.new_vreg();
    let is *d.IRInst as sc = d.new_inst(d.IR_SYSCALL);
    sc.dest = d.op_vreg(dest);
    sc.line = line;
    g.emit(sc);
    return dest;
}

fn gen_enum_lit(node as *ast.Node, ty as *ast.Type, line as i32) as i32 {
    let is i32 as disc = node.discriminant;
    // Simple enum (no payload, small)
    if (cast(i64, node.payload_args) == 0 && ty.size <= 4) {
        return g.emit_imm(cast(i64, disc), line);
    }
    // Tagged union with no payload but needs full allocation
    if (cast(i64, node.payload_args) == 0 && ty.size > 4) {
        let is i32 as total_size = ty.size;
        g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + total_size;
        if (g.ctx_func.alloc_stack_size % 16 != 0) {
            g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + 16 - (g.ctx_func.alloc_stack_size % 16);
        }
        let is i32 as offset = g.ctx_func.alloc_stack_size;
        let is i32 as base_addr = g.new_vreg();
        let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
        ga.dest = d.op_vreg(base_addr); ga.src1 = d.op_imm(cast(i64, offset)); ga.line = line; g.emit(ga);
        let is i32 as disc_reg = g.emit_imm(cast(i64, disc), line);
        let is *d.IRInst as st = d.new_inst(d.IR_STORE);
        st.dest = d.op_vreg(base_addr); st.src1 = d.op_vreg(disc_reg);
        st.cast_to = cast(*u8, ast.type_i32); st.line = line; g.emit(st);
        return base_addr;
    }
    // Tagged union with payload
    let is i32 as total_size = ty.size;
    g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + total_size;
    if (g.ctx_func.alloc_stack_size % 16 != 0) {
        g.ctx_func.alloc_stack_size = g.ctx_func.alloc_stack_size + 16 - (g.ctx_func.alloc_stack_size % 16);
    }
    let is i32 as offset = g.ctx_func.alloc_stack_size;
    let is i32 as base_addr = g.new_vreg();
    let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
    ga.dest = d.op_vreg(base_addr); ga.src1 = d.op_imm(cast(i64, offset)); ga.line = line; g.emit(ga);
    // Store discriminant
    let is i32 as disc_reg = g.emit_imm(cast(i64, disc), line);
    let is *d.IRInst as st = d.new_inst(d.IR_STORE);
    st.dest = d.op_vreg(base_addr); st.src1 = d.op_vreg(disc_reg);
    st.cast_to = cast(*u8, ast.type_i32); st.line = line; g.emit(st);
    // Store payload
    let is i32 as payload_off = ty.payload_offset;
    let is i32 as payload_addr with mut = base_addr;
    if (payload_off > 0) {
        let is i32 as ofreg = g.emit_imm(cast(i64, payload_off), line);
        payload_addr = g.emit_binary(d.IR_ADD, base_addr, ofreg, line);
    }
    // Store each payload arg sequentially
    let is *ast.Node as arg with mut = node.payload_args;
    while (cast(i64, arg) != 0) {
        let is i32 as val = gen_expr(arg);
        let is *ast.Type as arg_ty = arg.ty;
        if (arg_ty.size > 8) {
            let is *d.IRInst as cp = d.new_inst(d.IR_COPY);
            cp.dest = d.op_vreg(payload_addr); cp.src1 = d.op_vreg(val);
            cp.src2 = d.op_imm(cast(i64, arg_ty.size)); cp.line = line; g.emit(cp);
        } else {
            let is *d.IRInst as sv = d.new_inst(d.IR_STORE);
            sv.dest = d.op_vreg(payload_addr); sv.src1 = d.op_vreg(val);
            sv.cast_to = cast(*u8, arg_ty); sv.line = line; g.emit(sv);
        }
        arg = arg.next;
    }
    return base_addr;
}

// === gen_expr ===

fn gen_expr(node as *ast.Node) as i32 {
    if (cast(i64, node) == 0) {
        io.write_str(linux.STDERR, "ir: null expression node\n");
        linux.exit(1);
    }

    let is i32 as k = node.kind;
    let is i32 as line = g.tok_line(node.tok_idx);
    let is *ast.Type as ty = node.ty;

    // NK_ADDR
    if (k == ast.NK_ADDR) { return gen_addr(node.expr); }

    // NK_DEREF
    if (k == ast.NK_DEREF) {
        let is i32 as addr = gen_expr(node.expr);
        return emit_load_from_addr(addr, cast(*u8, ty), line);
    }

    // NK_INDEX
    if (k == ast.NK_INDEX) {
        let is i32 as addr = gen_addr(node);
        return emit_load_from_addr(addr, cast(*u8, ty), line);
    }

    // NK_MEMBER
    if (k == ast.NK_MEMBER) {
        let is i32 as addr = gen_addr(node);
        return emit_load_from_addr(addr, cast(*u8, ty), line);
    }

    // NK_ASSIGN
    if (k == ast.NK_ASSIGN) {
        let is i32 as lhs_addr = gen_addr(node.lhs);
        let is i32 as rhs_kind = node.rhs.kind;
        if (rhs_kind == ast.NK_FNCALL || rhs_kind == ast.NK_SYSCALL) {
            let is *d.IRInst as ctx_inst = d.new_inst(d.IR_SET_CTX);
            // Only pass lhs_addr as context for struct return (size > 8)
            // For scalar types, clear context to avoid corrupting r10
            if (ty.size > 8) {
                ctx_inst.src1 = d.op_vreg(lhs_addr);
            } else {
                ctx_inst.src1 = d.op_imm(0);
            }
            ctx_inst.line = line;
            g.emit(ctx_inst);
        }
        let is i32 as rhs_val = gen_expr(node.rhs);
        if (ty.size > 8) {
            let is *d.IRInst as i = d.new_inst(d.IR_COPY);
            i.dest = d.op_vreg(lhs_addr);
            i.src1 = d.op_vreg(rhs_val);
            i.src2 = d.op_imm(cast(i64, ty.size));
            i.line = line;
            g.emit(i);
            return lhs_addr;
        }
        let is *d.IRInst as i = d.new_inst(d.IR_STORE);
        i.dest = d.op_vreg(lhs_addr);
        i.src1 = d.op_vreg(rhs_val);
        i.cast_to = cast(*u8, ty);
        i.line = line;
        g.emit(i);
        return rhs_val;
    }

    // NK_NUM
    if (k == ast.NK_NUM) {
        if (g.is_float_kind(node.ty.kind) == 1) {
            return g.emit_imm(ast.f64_to_i64(node.fval), line);
        }
        return g.emit_imm(node.val, line);
    }

    // NK_STRING
    if (k == ast.NK_STRING) {
        let is i32 as sid = g.register_string(node.name_ptr, node.name_len);
        let is i32 as dest = g.new_vreg();
        // Build label name ".LCN"
        let is [16]u8 as lbuf;
        lbuf[0] = 46; // '.'
        lbuf[1] = 76; // 'L'
        lbuf[2] = 67; // 'C'
        let is i32 as llen with mut = 3;
        // Write integer id
        let is i32 as tmp_id with mut = sid;
        if (tmp_id == 0) {
            lbuf[llen] = 48;
            llen = llen + 1;
        } else {
            let is [10]u8 as dbuf;
            let is i32 as di with mut = 0;
            while (tmp_id > 0) {
                dbuf[di] = cast(u8, (tmp_id % 10) + 48);
                tmp_id = tmp_id / 10;
                di = di + 1;
            }
            let is i32 as dj with mut = di - 1;
            while (dj >= 0) {
                lbuf[llen] = dbuf[dj];
                llen = llen + 1;
                dj = dj - 1;
            }
        }
        let is *d.IRInst as i = d.new_inst(d.IR_ADDR_GLOBAL);
        i.dest = d.op_vreg(dest);
        i.global_name_ptr = d.str_dup(cast(*u8, &lbuf), llen);
        i.global_name_len = llen;
        i.line = line;
        g.emit(i);
        return dest;
    }

    // NK_SIZEOF
    if (k == ast.NK_SIZEOF) {
        return g.emit_imm(node.val, line);
    }

    // NK_IDENT
    if (k == ast.NK_IDENT) {
        let is i32 as reg = g.new_vreg();
        if (node.is_global == 1) {
            let is i32 as addr = g.new_vreg();
            let is *d.IRInst as ai = d.new_inst(d.IR_ADDR_GLOBAL);
            ai.dest = d.op_vreg(addr);
            if (node.asm_name_len > 0) {
                ai.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                ai.global_name_len = node.asm_name_len;
            } else {
                ai.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
                ai.global_name_len = node.name_len;
            }
            ai.is_extern_global = node.is_extern;
            ai.line = line;
            g.emit(ai);
            if (ty.size > 8) { return addr; }
            if (node.is_string_const == 1) { return addr; }
            let is *d.IRInst as li = d.new_inst(d.IR_LOAD);
            li.dest = d.op_vreg(reg);
            li.src1 = d.op_vreg(addr);
            li.cast_to = cast(*u8, ty);
            li.line = line;
            g.emit(li);
        } else {
            if (ty.size > 8) {
                let is *d.IRInst as i = d.new_inst(d.IR_ADDR);
                i.dest = d.op_vreg(reg);
                i.src1 = d.op_imm(cast(i64, node.var_offset));
                i.line = line;
                g.emit(i);
                return reg;
            }
            let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
            i.dest = d.op_vreg(reg);
            i.src1 = d.op_imm(cast(i64, node.var_offset));
            i.cast_to = cast(*u8, ty);
            i.line = line;
            g.emit(i);
        }
        return reg;
    }

    // NK_CAST
    if (k == ast.NK_CAST) {
        let is i32 as src = gen_expr(node.expr);
        return g.emit_cast_from(src, cast(*u8, node.expr.ty), cast(*u8, ty), line);
    }

    // NK_FN_PTR
    if (k == ast.NK_FN_PTR) {
        let is i32 as dest = g.new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_FN_ADDR);
        i.dest = d.op_vreg(dest);
        if (node.asm_name_len > 0) {
            i.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
            i.global_name_len = node.asm_name_len;
        } else {
            i.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
            i.global_name_len = node.name_len;
        }
        i.line = line;
        g.emit(i);
        return dest;
    }

    // Binary ops: ADD, SUB, MUL, DIV, MOD
    if (k == ast.NK_ADD) {
        // Constant fold
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return g.emit_imm(node.lhs.val + node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        // Pointer arithmetic: ptr + int
        let is *ast.Type as lty = node.lhs.ty;
        let is *ast.Type as rty = node.rhs.ty;
        if (lty.kind == ast.TY_PTR) {
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = g.emit_imm(cast(i64, sz), line);
                rhs = g.emit_binary(d.IR_MUL, rhs, sr, line);
            }
            return g.emit_binary(d.IR_ADD, lhs, rhs, line);
        }
        if (rty.kind == ast.TY_PTR) {
            let is i32 as sz = rty.base.size;
            if (sz > 1) {
                let is i32 as sr = g.emit_imm(cast(i64, sz), line);
                lhs = g.emit_binary(d.IR_MUL, lhs, sr, line);
            }
            return g.emit_binary(d.IR_ADD, lhs, rhs, line);
        }
        if (cast(i64, lty) != cast(i64, ty)) { lhs = g.emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, rty) != cast(i64, ty)) { rhs = g.emit_cast(rhs, cast(*u8, ty), line); }
        if (g.is_float_kind(ty.kind) == 1) { return g.emit_binary(d.IR_FADD, lhs, rhs, line); }
        return g.emit_binary(d.IR_ADD, lhs, rhs, line);
    }

    if (k == ast.NK_SUB) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return g.emit_imm(node.lhs.val - node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        let is *ast.Type as lty = node.lhs.ty;
        let is *ast.Type as rty = node.rhs.ty;
        // ptr - int
        if (lty.kind == ast.TY_PTR && rty.kind != ast.TY_PTR) {
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = g.emit_imm(cast(i64, sz), line);
                rhs = g.emit_binary(d.IR_MUL, rhs, sr, line);
            }
            return g.emit_binary(d.IR_SUB, lhs, rhs, line);
        }
        // ptr - ptr
        if (lty.kind == ast.TY_PTR && rty.kind == ast.TY_PTR) {
            let is i32 as diff = g.emit_binary(d.IR_SUB, lhs, rhs, line);
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = g.emit_imm(cast(i64, sz), line);
                return g.emit_binary(d.IR_DIV, diff, sr, line);
            }
            return diff;
        }
        if (cast(i64, lty) != cast(i64, ty)) { lhs = g.emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, rty) != cast(i64, ty)) { rhs = g.emit_cast(rhs, cast(*u8, ty), line); }
        if (g.is_float_kind(ty.kind) == 1) { return g.emit_binary(d.IR_FSUB, lhs, rhs, line); }
        return g.emit_binary(d.IR_SUB, lhs, rhs, line);
    }

    if (k == ast.NK_MUL) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return g.emit_imm(node.lhs.val * node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = g.emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = g.emit_cast(rhs, cast(*u8, ty), line); }
        if (g.is_float_kind(ty.kind) == 1) { return g.emit_binary(d.IR_FMUL, lhs, rhs, line); }
        return g.emit_binary(d.IR_MUL, lhs, rhs, line);
    }

    if (k == ast.NK_DIV) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM && g.is_float_kind(ty.kind) == 0) {
            return g.emit_imm(node.lhs.val / node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = g.emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = g.emit_cast(rhs, cast(*u8, ty), line); }
        if (g.is_float_kind(ty.kind) == 1) { return g.emit_binary(d.IR_FDIV, lhs, rhs, line); }
        let is i32 as dv = g.emit_binary(d.IR_DIV, lhs, rhs, line);
        g.ctx_tail.cast_to = cast(*u8, ty);
        return dv;
    }

    if (k == ast.NK_MOD) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return g.emit_imm(node.lhs.val % node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = g.emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = g.emit_cast(rhs, cast(*u8, ty), line); }
        let is i32 as md = g.emit_binary(d.IR_MOD, lhs, rhs, line);
        g.ctx_tail.cast_to = cast(*u8, ty);
        return md;
    }

    // Comparison ops
    if (k == ast.NK_EQ) { return gen_cmp(node, d.IR_EQ, line, 0); }
    if (k == ast.NK_NE) { return gen_cmp(node, d.IR_NE, line, 0); }
    if (k == ast.NK_LT) { return gen_cmp(node, d.IR_LT, line, 1); }
    if (k == ast.NK_LE) { return gen_cmp(node, d.IR_LE, line, 1); }
    if (k == ast.NK_GT) { return gen_cmp(node, d.IR_GT, line, 1); }
    if (k == ast.NK_GE) { return gen_cmp(node, d.IR_GE, line, 1); }

    // Bitwise ops
    if (k == ast.NK_SHL) { return gen_bitwise(node, d.IR_SHL, line, 0); }
    if (k == ast.NK_SHR) { return gen_bitwise(node, d.IR_SHR, line, 1); }
    if (k == ast.NK_BAND) { return gen_bitwise(node, d.IR_AND, line, 0); }
    if (k == ast.NK_BOR) { return gen_bitwise(node, d.IR_OR, line, 0); }
    if (k == ast.NK_BXOR) { return gen_bitwise(node, d.IR_XOR, line, 0); }

    // Unary ops
    if (k == ast.NK_BNOT) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as dest = g.new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_NOT);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(src);
        i.line = line;
        g.emit(i);
        return dest;
    }
    if (k == ast.NK_LNOT) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as zero = g.emit_imm(0, line);
        return g.emit_binary(d.IR_EQ, src, zero, line);
    }
    if (k == ast.NK_NEG) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as dest = g.new_vreg();
        let is i32 as neg_op with mut = d.IR_NEG;
        if (g.is_float_kind(ty.kind) == 1) { neg_op = d.IR_FNEG; }
        let is *d.IRInst as i = d.new_inst(neg_op);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(src);
        i.line = line;
        g.emit(i);
        return dest;
    }

    // Logical AND (multi-def dest — blocks const prop but is correct)
    if (k == ast.NK_LAND) {
        let is i32 as false_l = g.new_label();
        let is i32 as end_l = g.new_label();
        let is i32 as dest = g.new_vreg();
        let is i32 as lhs = gen_expr(node.lhs);
        let is *d.IRInst as jz1 = d.new_inst(d.IR_JZ);
        jz1.src1 = d.op_vreg(lhs); jz1.dest = d.op_label(false_l); jz1.line = line; g.emit(jz1);
        let is i32 as rhs = gen_expr(node.rhs);
        let is *d.IRInst as jz2 = d.new_inst(d.IR_JZ);
        jz2.src1 = d.op_vreg(rhs); jz2.dest = d.op_label(false_l); jz2.line = line; g.emit(jz2);
        let is *d.IRInst as mt = d.new_inst(d.IR_IMM);
        mt.dest = d.op_vreg(dest); mt.src1 = d.op_imm(1); g.emit(mt);
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); g.emit(jmp);
        let is *d.IRInst as fl = d.new_inst(d.IR_LABEL);
        fl.dest = d.op_label(false_l); g.emit(fl);
        let is *d.IRInst as mf = d.new_inst(d.IR_IMM);
        mf.dest = d.op_vreg(dest); mf.src1 = d.op_imm(0); g.emit(mf);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); g.emit(el);
        return dest;
    }

    // Logical OR (multi-def dest — blocks const prop but is correct)
    if (k == ast.NK_LOR) {
        let is i32 as true_l = g.new_label();
        let is i32 as end_l = g.new_label();
        let is i32 as dest = g.new_vreg();
        let is i32 as lhs = gen_expr(node.lhs);
        let is *d.IRInst as jnz1 = d.new_inst(d.IR_JNZ);
        jnz1.src1 = d.op_vreg(lhs); jnz1.dest = d.op_label(true_l); jnz1.line = line; g.emit(jnz1);
        let is i32 as rhs = gen_expr(node.rhs);
        let is *d.IRInst as jnz2 = d.new_inst(d.IR_JNZ);
        jnz2.src1 = d.op_vreg(rhs); jnz2.dest = d.op_label(true_l); jnz2.line = line; g.emit(jnz2);
        let is *d.IRInst as mf = d.new_inst(d.IR_IMM);
        mf.dest = d.op_vreg(dest); mf.src1 = d.op_imm(0); g.emit(mf);
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); g.emit(jmp);
        let is *d.IRInst as tl = d.new_inst(d.IR_LABEL);
        tl.dest = d.op_label(true_l); g.emit(tl);
        let is *d.IRInst as mt = d.new_inst(d.IR_IMM);
        mt.dest = d.op_vreg(dest); mt.src1 = d.op_imm(1); g.emit(mt);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); g.emit(el);
        return dest;
    }

    // NK_FNCALL
    if (k == ast.NK_FNCALL) { return gen_fncall(node, ty, line); }

    // NK_CALL_INDIRECT: call(fn_ptr, args...)
    if (k == ast.NK_CALL_INDIRECT) {
        let is i32 as fn_ptr_vreg = gen_expr(node.expr);
        let is i32 as arg_count with mut = 0;
        let is *ast.Node as a with mut = node.args;
        while (cast(i64, a) != 0) { arg_count = arg_count + 1; a = a.next; }

        let is [256]u8 as arg_vregs;
        let is i32 as ai with mut = 0;
        a = node.args;
        while (cast(i64, a) != 0 && ai < 64) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, ai) * 4);
            *av = gen_expr(a);
            ai = ai + 1;
            a = a.next;
        }

        // Stack args in reverse (internal ABI: all GPR)
        let is i32 as stack_args with mut = 0;
        let is i32 as padding with mut = 0;
        if (arg_count > 6) { stack_args = arg_count - 6; }
        if (stack_args % 2 != 0) { padding = 1; }
        if (padding == 1) {
            let is *d.IRInst as pa = d.new_inst(d.IR_ASM);
            pa.asm_str_ptr = d.str_dup("sub rsp, 8", 10);
            pa.asm_str_len = 10;
            pa.line = line;
            g.emit(pa);
        }
        let is i32 as j with mut = arg_count - 1;
        while (j >= 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            g.emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j - 1;
        }
        j = 0;
        while (j < arg_count && j < 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            g.emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j + 1;
        }

        let is i32 as ret_reg = g.emit_call_indirect(fn_ptr_vreg, line);
        // Attach return type for float handling in codegen
        if (cast(i64, ty) != 0) { g.ctx_tail.cast_to = cast(*u8, ty); }

        if (stack_args > 0) {
            let is i32 as pad2 with mut = 0;
            if (stack_args % 2 != 0) { pad2 = 1; }
            let is i32 as cleanup_bytes = (stack_args + pad2) * 8;
            let is [32]u8 as cbuf;
            mem.memcpy(cast(*u8, &cbuf), "add rsp, ", 9);
            let is i32 as cpos with mut = 9;
            let is i32 as cv with mut = cleanup_bytes;
            let is [10]u8 as nbuf;
            let is i32 as ni with mut = 0;
            while (cv > 0) {
                nbuf[ni] = cast(u8, (cv % 10) + 48);
                cv = cv / 10;
                ni = ni + 1;
            }
            let is i32 as nj with mut = ni - 1;
            while (nj >= 0) {
                cbuf[cpos] = nbuf[nj];
                cpos = cpos + 1;
                nj = nj - 1;
            }
            let is *d.IRInst as cl = d.new_inst(d.IR_ASM);
            cl.asm_str_ptr = d.str_dup(cast(*u8, &cbuf), cpos);
            cl.asm_str_len = cpos;
            cl.line = line;
            g.emit(cl);
        }

        return ret_reg;
    }

    // NK_SYSCALL
    if (k == ast.NK_SYSCALL) { return gen_syscall(node, line); }

    // NK_ENUM_LIT
    if (k == ast.NK_ENUM_LIT) { return gen_enum_lit(node, ty, line); }

    // NK_VA_START
    if (k == ast.NK_VA_START) {
        let is i32 as va_addr = gen_expr(node.expr);
        let is *d.IRInst as vai = d.new_inst(d.IR_VA_START);
        vai.src1 = d.op_vreg(va_addr);
        vai.src2 = d.op_imm(cast(i64, g.ctx_func.num_args));
        vai.line = line;
        g.emit(vai);
        return va_addr;
    }

    io.write_str(linux.STDERR, "ir: unsupported expression kind: ");
    io.write_int(linux.STDERR, cast(i64, k));
    io.write_str(linux.STDERR, "\n");
    linux.exit(1);
    return 0;
}

// === gen_stmt ===
