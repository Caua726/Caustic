use "../../std/mem.cst" as mem;
use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "../parser/ast.cst" as ast;
use "../lexer/tokens.cst" as tok;
use "defs.cst" as d;

// === Debug info: token list for line number resolution ===
let is *u8 as ir_tl with mut;

fn tok_line(tidx as i32) as i32 {
    if (cast(i64, ir_tl) == 0 || tidx <= 0) { return 0; }
    let is *tok.TokenList as tl = cast(*tok.TokenList, ir_tl);
    let is *tok.Token as t = tok.tl_get(tl, tidx);
    return t.line;
}

// === Context ===
let is *d.IRFunction as ctx_func with mut;
let is *d.IRInst as ctx_head with mut;
let is *d.IRInst as ctx_tail with mut;
let is i32 as ctx_vreg with mut;
let is i32 as ctx_label with mut;
let is i32 as ctx_loop_depth with mut;
let is i32 as ctx_has_sret with mut;
let is i32 as ctx_sret_vreg with mut;
let is i32 as ctx_has_returned with mut;
// Loop stack: 3 i32 per entry (start, end, continue), max 32 = 384 bytes
let is [384]u8 as loop_stack with mut;
// Defer stack: *Node pointers (8 bytes each), max 64 = 512 bytes
let is [512]u8 as defer_stack with mut;
let is i32 as defer_count with mut;
// String registry
let is *d.StringEntry as string_head with mut;
let is i32 as string_id_count with mut;
// gen_ir recursion depth
let is i32 as ir_depth with mut;
// Module dedup: track already-processed bodies (max 256 modules)
let is [2048]u8 as ir_done_bodies with mut;
let is i32 as ir_done_count with mut;

fn ir_reset() as void {
    ir_tl = cast(*u8, 0);
    ctx_func = cast(*d.IRFunction, 0);
    ctx_head = cast(*d.IRInst, 0);
    ctx_tail = cast(*d.IRInst, 0);
    ctx_vreg = 0;
    ctx_label = 0;
    ctx_loop_depth = 0;
    ctx_has_sret = 0;
    ctx_sret_vreg = 0;
    ctx_has_returned = 0;
    defer_count = 0;
    string_head = cast(*d.StringEntry, 0);
    string_id_count = 0;
    ir_depth = 0;
    ir_done_count = 0;
}

fn is_float_kind(kind as i32) as i32 {
    if (kind == ast.TY_F32 || kind == ast.TY_F64) { return 1; }
    return 0;
}

// === Emit helpers ===

fn emit(inst as *d.IRInst) as void {
    if (cast(i64, ctx_head) == 0) {
        ctx_head = inst;
        ctx_tail = inst;
    } else {
        ctx_tail.next = inst;
        ctx_tail = inst;
    }
}

fn new_vreg() as i32 {
    let is i32 as v = ctx_vreg;
    ctx_vreg = ctx_vreg + 1;
    return v;
}

fn new_label() as i32 {
    let is i32 as l = ctx_label;
    ctx_label = ctx_label + 1;
    return l;
}

fn emit_imm(val as i64, line as i32) as i32 {
    let is i32 as dest = new_vreg();
    let is *d.IRInst as i = d.new_inst(d.IR_IMM);
    i.dest = d.op_vreg(dest);
    i.src1 = d.op_imm(val);
    i.line = line;
    emit(i);
    return dest;
}

fn emit_binary(op as i32, lhs as i32, rhs as i32, line as i32) as i32 {
    let is i32 as dest = new_vreg();
    let is *d.IRInst as i = d.new_inst(op);
    i.dest = d.op_vreg(dest);
    i.src1 = d.op_vreg(lhs);
    i.src2 = d.op_vreg(rhs);
    i.line = line;
    emit(i);
    return dest;
}

fn emit_cast_from(src as i32, from_ty as *u8, to_ty as *u8, line as i32) as i32 {
    let is i32 as dest = new_vreg();
    let is *d.IRInst as i = d.new_inst(d.IR_CAST);
    i.dest = d.op_vreg(dest);
    i.src1 = d.op_vreg(src);
    i.cast_to = to_ty;
    i.cast_from = from_ty;
    i.line = line;
    emit(i);
    return dest;
}

fn emit_cast(src as i32, to_ty as *u8, line as i32) as i32 {
    return emit_cast_from(src, cast(*u8, 0), to_ty, line);
}

fn emit_call(name_ptr as *u8, name_len as i32, is_variadic as i32, ret_type as *u8, line as i32) as i32 {
    let is i32 as dest = new_vreg();
    let is *d.IRInst as i = d.new_inst(d.IR_CALL);
    i.dest = d.op_vreg(dest);
    i.call_name_ptr = d.str_dup(name_ptr, name_len);
    i.call_name_len = name_len;
    i.is_variadic_call = is_variadic;
    i.cast_to = ret_type;
    i.line = line;
    emit(i);
    return dest;
}

fn emit_set_arg(idx as i32, src as i32, arg_type as *u8, line as i32) as void {
    let is *d.IRInst as i = d.new_inst(d.IR_SET_ARG);
    i.dest = d.op_imm(cast(i64, idx));
    i.src1 = d.op_vreg(src);
    i.cast_to = arg_type;
    i.line = line;
    emit(i);
}

fn emit_get_arg(idx as i32, line as i32) as i32 {
    let is i32 as dest = new_vreg();
    let is *d.IRInst as i = d.new_inst(d.IR_GET_ARG);
    i.dest = d.op_vreg(dest);
    i.src1 = d.op_imm(cast(i64, idx));
    i.line = line;
    emit(i);
    return dest;
}

fn emit_return(src as i32, line as i32) as void {
    let is *d.IRInst as i = d.new_inst(d.IR_RET);
    if (src != cast(i32, 0 - 1)) {
        i.src1 = d.op_vreg(src);
    }
    i.line = line;
    emit(i);
}

fn push_loop(start as i32, end_l as i32, cont as i32) as void {
    if (ctx_loop_depth >= 32) { return; }
    let is i64 as off = cast(i64, ctx_loop_depth) * 12;
    let is *i32 as p = cast(*i32, cast(i64, &loop_stack) + off);
    *p = start;
    let is *i32 as p2 = cast(*i32, cast(i64, &loop_stack) + off + 4);
    *p2 = end_l;
    let is *i32 as p3 = cast(*i32, cast(i64, &loop_stack) + off + 8);
    *p3 = cont;
    ctx_loop_depth = ctx_loop_depth + 1;
}

fn pop_loop() as void {
    if (ctx_loop_depth > 0) { ctx_loop_depth = ctx_loop_depth - 1; }
}

fn get_loop_end() as i32 {
    let is i64 as off = cast(i64, ctx_loop_depth - 1) * 12 + 4;
    let is *i32 as p = cast(*i32, cast(i64, &loop_stack) + off);
    return *p;
}

fn get_loop_continue() as i32 {
    let is i64 as off = cast(i64, ctx_loop_depth - 1) * 12 + 8;
    let is *i32 as p = cast(*i32, cast(i64, &loop_stack) + off);
    return *p;
}

fn push_defer(node as *u8) as void {
    if (defer_count >= 64) { return; }
    let is i64 as off = cast(i64, defer_count) * 8;
    let is *i64 as p = cast(*i64, cast(i64, &defer_stack) + off);
    *p = cast(i64, node);
    defer_count = defer_count + 1;
}

fn get_defer(idx as i32) as *u8 {
    let is i64 as off = cast(i64, idx) * 8;
    let is *i64 as p = cast(*i64, cast(i64, &defer_stack) + off);
    return cast(*u8, *p);
}

fn register_string(ptr as *u8, len as i32) as i32 {
    let is i32 as id = string_id_count;
    let is *d.StringEntry as s = d.new_string_entry();
    s.id = id;
    s.ptr = d.str_dup(ptr, len);
    s.len = len;
    s.next = string_head;
    string_head = s;
    string_id_count = string_id_count + 1;
    return id;
}

fn emit_deferred_calls() as void {
    let is i32 as i with mut = defer_count - 1;
    while (i >= 0) {
        let is *ast.Node as nd = cast(*ast.Node, get_defer(i));
        gen_expr(nd);
        i = i - 1;
    }
}

// === gen_addr ===

fn gen_addr(node as *ast.Node) as i32 {
    let is i32 as k = node.kind;
    let is i32 as line = tok_line(node.tok_idx);

    if (k == ast.NK_IDENT) {
        let is i32 as dest = new_vreg();
        if (node.is_global == 1) {
            let is *d.IRInst as i = d.new_inst(d.IR_ADDR_GLOBAL);
            i.dest = d.op_vreg(dest);
            if (node.asm_name_len > 0) {
                i.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                i.global_name_len = node.asm_name_len;
            } else {
                i.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
                i.global_name_len = node.name_len;
            }
            i.is_extern_global = node.is_extern;
            i.line = line;
            emit(i);
        } else {
            let is *d.IRInst as i = d.new_inst(d.IR_ADDR);
            i.dest = d.op_vreg(dest);
            i.src1 = d.op_imm(cast(i64, node.var_offset));
            i.line = line;
            emit(i);
        }
        return dest;
    }

    if (k == ast.NK_DEREF) {
        return gen_expr(node.expr);
    }

    if (k == ast.NK_INDEX) {
        let is *ast.Type as lty = node.lhs.ty;
        let is i32 as base with mut;
        if (lty.kind == ast.TY_PTR) {
            base = gen_expr(node.lhs);
        } else {
            base = gen_addr(node.lhs);
        }
        let is i32 as index = gen_expr(node.rhs);
        let is *ast.Type as ety = node.ty;
        let is i32 as sz = ety.size;
        let is i32 as off_reg with mut;
        if (sz == 1) {
            off_reg = index;
        } else {
            let is i32 as sr = emit_imm(cast(i64, sz), line);
            off_reg = emit_binary(d.IR_MUL, index, sr, line);
        }
        return emit_binary(d.IR_ADD, base, off_reg, line);
    }

    if (k == ast.NK_MEMBER) {
        let is *ast.Type as lty = node.lhs.ty;
        let is i32 as base with mut;
        if (lty.kind == ast.TY_PTR) {
            base = gen_expr(node.lhs);
        } else {
            base = gen_addr(node.lhs);
        }
        if (node.var_offset == 0) { return base; }
        let is i32 as off_reg = emit_imm(cast(i64, node.var_offset), line);
        return emit_binary(d.IR_ADD, base, off_reg, line);
    }

    io.write_str(linux.STDERR, "ir: gen_addr: unsupported node kind\n");
    linux.exit(1);
    return 0;
}

// === gen_expr ===

fn gen_expr(node as *ast.Node) as i32 {
    if (cast(i64, node) == 0) {
        io.write_str(linux.STDERR, "ir: null expression node\n");
        linux.exit(1);
    }

    let is i32 as k = node.kind;
    let is i32 as line = tok_line(node.tok_idx);
    let is *ast.Type as ty = node.ty;

    // NK_ADDR
    if (k == ast.NK_ADDR) { return gen_addr(node.expr); }

    // NK_DEREF
    if (k == ast.NK_DEREF) {
        let is i32 as addr = gen_expr(node.expr);
        if (ty.size > 8) { return addr; }
        let is i32 as dest = new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(addr);
        i.cast_to = cast(*u8, ty);
        i.line = line;
        emit(i);
        return dest;
    }

    // NK_INDEX
    if (k == ast.NK_INDEX) {
        let is i32 as addr = gen_addr(node);
        if (ty.size > 8) { return addr; }
        let is i32 as dest = new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(addr);
        i.cast_to = cast(*u8, ty);
        i.line = line;
        emit(i);
        return dest;
    }

    // NK_MEMBER
    if (k == ast.NK_MEMBER) {
        let is i32 as addr = gen_addr(node);
        if (ty.size > 8) { return addr; }
        let is i32 as dest = new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(addr);
        i.cast_to = cast(*u8, ty);
        i.line = line;
        emit(i);
        return dest;
    }

    // NK_ASSIGN
    if (k == ast.NK_ASSIGN) {
        let is i32 as lhs_addr = gen_addr(node.lhs);
        let is i32 as rhs_kind = node.rhs.kind;
        if (rhs_kind == ast.NK_FNCALL || rhs_kind == ast.NK_SYSCALL) {
            let is *d.IRInst as ctx_inst = d.new_inst(d.IR_SET_CTX);
            ctx_inst.src1 = d.op_vreg(lhs_addr);
            ctx_inst.line = line;
            emit(ctx_inst);
        }
        let is i32 as rhs_val = gen_expr(node.rhs);
        if (ty.size > 8) {
            let is *d.IRInst as i = d.new_inst(d.IR_COPY);
            i.dest = d.op_vreg(lhs_addr);
            i.src1 = d.op_vreg(rhs_val);
            i.src2 = d.op_imm(cast(i64, ty.size));
            i.line = line;
            emit(i);
            return lhs_addr;
        }
        let is *d.IRInst as i = d.new_inst(d.IR_STORE);
        i.dest = d.op_vreg(lhs_addr);
        i.src1 = d.op_vreg(rhs_val);
        i.cast_to = cast(*u8, ty);
        i.line = line;
        emit(i);
        return rhs_val;
    }

    // NK_NUM
    if (k == ast.NK_NUM) {
        if (is_float_kind(node.ty.kind) == 1) {
            return emit_imm(ast.f64_to_i64(node.fval), line);
        }
        return emit_imm(node.val, line);
    }

    // NK_STRING
    if (k == ast.NK_STRING) {
        let is i32 as sid = register_string(node.name_ptr, node.name_len);
        let is i32 as dest = new_vreg();
        // Build label name ".LCN"
        let is [16]u8 as lbuf;
        lbuf[0] = 46; // '.'
        lbuf[1] = 76; // 'L'
        lbuf[2] = 67; // 'C'
        let is i32 as llen with mut = 3;
        // Write integer id
        let is i32 as tmp_id with mut = sid;
        if (tmp_id == 0) {
            lbuf[llen] = 48;
            llen = llen + 1;
        } else {
            let is [10]u8 as dbuf;
            let is i32 as di with mut = 0;
            while (tmp_id > 0) {
                dbuf[di] = cast(u8, (tmp_id % 10) + 48);
                tmp_id = tmp_id / 10;
                di = di + 1;
            }
            let is i32 as dj with mut = di - 1;
            while (dj >= 0) {
                lbuf[llen] = dbuf[dj];
                llen = llen + 1;
                dj = dj - 1;
            }
        }
        let is *d.IRInst as i = d.new_inst(d.IR_ADDR_GLOBAL);
        i.dest = d.op_vreg(dest);
        i.global_name_ptr = d.str_dup(cast(*u8, &lbuf), llen);
        i.global_name_len = llen;
        i.line = line;
        emit(i);
        return dest;
    }

    // NK_SIZEOF
    if (k == ast.NK_SIZEOF) {
        return emit_imm(node.val, line);
    }

    // NK_IDENT
    if (k == ast.NK_IDENT) {
        let is i32 as reg = new_vreg();
        if (node.is_global == 1) {
            let is i32 as addr = new_vreg();
            let is *d.IRInst as ai = d.new_inst(d.IR_ADDR_GLOBAL);
            ai.dest = d.op_vreg(addr);
            if (node.asm_name_len > 0) {
                ai.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                ai.global_name_len = node.asm_name_len;
            } else {
                ai.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
                ai.global_name_len = node.name_len;
            }
            ai.is_extern_global = node.is_extern;
            ai.line = line;
            emit(ai);
            if (ty.size > 8) { return addr; }
            let is *d.IRInst as li = d.new_inst(d.IR_LOAD);
            li.dest = d.op_vreg(reg);
            li.src1 = d.op_vreg(addr);
            li.cast_to = cast(*u8, ty);
            li.line = line;
            emit(li);
        } else {
            if (ty.size > 8) {
                let is *d.IRInst as i = d.new_inst(d.IR_ADDR);
                i.dest = d.op_vreg(reg);
                i.src1 = d.op_imm(cast(i64, node.var_offset));
                i.line = line;
                emit(i);
                return reg;
            }
            let is *d.IRInst as i = d.new_inst(d.IR_LOAD);
            i.dest = d.op_vreg(reg);
            i.src1 = d.op_imm(cast(i64, node.var_offset));
            i.cast_to = cast(*u8, ty);
            i.line = line;
            emit(i);
        }
        return reg;
    }

    // NK_CAST
    if (k == ast.NK_CAST) {
        let is i32 as src = gen_expr(node.expr);
        return emit_cast_from(src, cast(*u8, node.expr.ty), cast(*u8, ty), line);
    }

    // NK_FN_PTR
    if (k == ast.NK_FN_PTR) {
        let is i32 as dest = new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_FN_ADDR);
        i.dest = d.op_vreg(dest);
        if (node.asm_name_len > 0) {
            i.global_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
            i.global_name_len = node.asm_name_len;
        } else {
            i.global_name_ptr = d.str_dup(node.name_ptr, node.name_len);
            i.global_name_len = node.name_len;
        }
        i.line = line;
        emit(i);
        return dest;
    }

    // Binary ops: ADD, SUB, MUL, DIV, MOD
    if (k == ast.NK_ADD) {
        // Constant fold
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return emit_imm(node.lhs.val + node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        // Pointer arithmetic: ptr + int
        let is *ast.Type as lty = node.lhs.ty;
        let is *ast.Type as rty = node.rhs.ty;
        if (lty.kind == ast.TY_PTR) {
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = emit_imm(cast(i64, sz), line);
                rhs = emit_binary(d.IR_MUL, rhs, sr, line);
            }
            return emit_binary(d.IR_ADD, lhs, rhs, line);
        }
        if (rty.kind == ast.TY_PTR) {
            let is i32 as sz = rty.base.size;
            if (sz > 1) {
                let is i32 as sr = emit_imm(cast(i64, sz), line);
                lhs = emit_binary(d.IR_MUL, lhs, sr, line);
            }
            return emit_binary(d.IR_ADD, lhs, rhs, line);
        }
        if (cast(i64, lty) != cast(i64, ty)) { lhs = emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, rty) != cast(i64, ty)) { rhs = emit_cast(rhs, cast(*u8, ty), line); }
        if (is_float_kind(ty.kind) == 1) { return emit_binary(d.IR_FADD, lhs, rhs, line); }
        return emit_binary(d.IR_ADD, lhs, rhs, line);
    }

    if (k == ast.NK_SUB) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return emit_imm(node.lhs.val - node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        let is *ast.Type as lty = node.lhs.ty;
        let is *ast.Type as rty = node.rhs.ty;
        // ptr - int
        if (lty.kind == ast.TY_PTR && rty.kind != ast.TY_PTR) {
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = emit_imm(cast(i64, sz), line);
                rhs = emit_binary(d.IR_MUL, rhs, sr, line);
            }
            return emit_binary(d.IR_SUB, lhs, rhs, line);
        }
        // ptr - ptr
        if (lty.kind == ast.TY_PTR && rty.kind == ast.TY_PTR) {
            let is i32 as diff = emit_binary(d.IR_SUB, lhs, rhs, line);
            let is i32 as sz = lty.base.size;
            if (sz > 1) {
                let is i32 as sr = emit_imm(cast(i64, sz), line);
                return emit_binary(d.IR_DIV, diff, sr, line);
            }
            return diff;
        }
        if (cast(i64, lty) != cast(i64, ty)) { lhs = emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, rty) != cast(i64, ty)) { rhs = emit_cast(rhs, cast(*u8, ty), line); }
        if (is_float_kind(ty.kind) == 1) { return emit_binary(d.IR_FSUB, lhs, rhs, line); }
        return emit_binary(d.IR_SUB, lhs, rhs, line);
    }

    if (k == ast.NK_MUL) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return emit_imm(node.lhs.val * node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = emit_cast(rhs, cast(*u8, ty), line); }
        if (is_float_kind(ty.kind) == 1) { return emit_binary(d.IR_FMUL, lhs, rhs, line); }
        return emit_binary(d.IR_MUL, lhs, rhs, line);
    }

    if (k == ast.NK_DIV) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM && is_float_kind(ty.kind) == 0) {
            return emit_imm(node.lhs.val / node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = emit_cast(rhs, cast(*u8, ty), line); }
        if (is_float_kind(ty.kind) == 1) { return emit_binary(d.IR_FDIV, lhs, rhs, line); }
        let is i32 as dv = emit_binary(d.IR_DIV, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, ty);
        return dv;
    }

    if (k == ast.NK_MOD) {
        if (node.lhs.kind == ast.NK_NUM && node.rhs.kind == ast.NK_NUM) {
            return emit_imm(node.lhs.val % node.rhs.val, line);
        }
        let is i32 as lhs with mut = gen_expr(node.lhs);
        let is i32 as rhs with mut = gen_expr(node.rhs);
        if (cast(i64, node.lhs.ty) != cast(i64, ty)) { lhs = emit_cast(lhs, cast(*u8, ty), line); }
        if (cast(i64, node.rhs.ty) != cast(i64, ty)) { rhs = emit_cast(rhs, cast(*u8, ty), line); }
        let is i32 as md = emit_binary(d.IR_MOD, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, ty);
        return md;
    }

    // Comparison ops
    if (k == ast.NK_EQ) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_EQ, lhs, rhs, line);
    }
    if (k == ast.NK_NE) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_NE, lhs, rhs, line);
    }
    if (k == ast.NK_LT) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        let is i32 as r = emit_binary(d.IR_LT, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, node.lhs.ty);
        return r;
    }
    if (k == ast.NK_LE) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        let is i32 as r = emit_binary(d.IR_LE, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, node.lhs.ty);
        return r;
    }
    if (k == ast.NK_GT) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        let is i32 as r = emit_binary(d.IR_GT, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, node.lhs.ty);
        return r;
    }
    if (k == ast.NK_GE) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        let is i32 as r = emit_binary(d.IR_GE, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, node.lhs.ty);
        return r;
    }

    // Bitwise ops
    if (k == ast.NK_SHL) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_SHL, lhs, rhs, line);
    }
    if (k == ast.NK_SHR) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        let is i32 as r = emit_binary(d.IR_SHR, lhs, rhs, line);
        ctx_tail.cast_to = cast(*u8, node.ty);
        return r;
    }
    if (k == ast.NK_BAND) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_AND, lhs, rhs, line);
    }
    if (k == ast.NK_BOR) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_OR, lhs, rhs, line);
    }
    if (k == ast.NK_BXOR) {
        let is i32 as lhs = gen_expr(node.lhs);
        let is i32 as rhs = gen_expr(node.rhs);
        return emit_binary(d.IR_XOR, lhs, rhs, line);
    }

    // Unary ops
    if (k == ast.NK_BNOT) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as dest = new_vreg();
        let is *d.IRInst as i = d.new_inst(d.IR_NOT);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(src);
        i.line = line;
        emit(i);
        return dest;
    }
    if (k == ast.NK_LNOT) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as zero = emit_imm(0, line);
        return emit_binary(d.IR_EQ, src, zero, line);
    }
    if (k == ast.NK_NEG) {
        let is i32 as src = gen_expr(node.expr);
        let is i32 as dest = new_vreg();
        let is i32 as neg_op with mut = d.IR_NEG;
        if (is_float_kind(ty.kind) == 1) { neg_op = d.IR_FNEG; }
        let is *d.IRInst as i = d.new_inst(neg_op);
        i.dest = d.op_vreg(dest);
        i.src1 = d.op_vreg(src);
        i.line = line;
        emit(i);
        return dest;
    }

    // Logical AND
    if (k == ast.NK_LAND) {
        let is i32 as false_l = new_label();
        let is i32 as end_l = new_label();
        let is i32 as dest = new_vreg();
        let is i32 as lhs = gen_expr(node.lhs);
        let is *d.IRInst as jz1 = d.new_inst(d.IR_JZ);
        jz1.src1 = d.op_vreg(lhs); jz1.dest = d.op_label(false_l); jz1.line = line; emit(jz1);
        let is i32 as rhs = gen_expr(node.rhs);
        let is *d.IRInst as jz2 = d.new_inst(d.IR_JZ);
        jz2.src1 = d.op_vreg(rhs); jz2.dest = d.op_label(false_l); jz2.line = line; emit(jz2);
        // true
        let is *d.IRInst as mt = d.new_inst(d.IR_IMM);
        mt.dest = d.op_vreg(dest); mt.src1 = d.op_imm(1); emit(mt);
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); emit(jmp);
        // false
        let is *d.IRInst as fl = d.new_inst(d.IR_LABEL);
        fl.dest = d.op_label(false_l); emit(fl);
        let is *d.IRInst as mf = d.new_inst(d.IR_IMM);
        mf.dest = d.op_vreg(dest); mf.src1 = d.op_imm(0); emit(mf);
        // end
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        return dest;
    }

    // Logical OR
    if (k == ast.NK_LOR) {
        let is i32 as true_l = new_label();
        let is i32 as end_l = new_label();
        let is i32 as dest = new_vreg();
        let is i32 as lhs = gen_expr(node.lhs);
        let is *d.IRInst as jnz1 = d.new_inst(d.IR_JNZ);
        jnz1.src1 = d.op_vreg(lhs); jnz1.dest = d.op_label(true_l); jnz1.line = line; emit(jnz1);
        let is i32 as rhs = gen_expr(node.rhs);
        let is *d.IRInst as jnz2 = d.new_inst(d.IR_JNZ);
        jnz2.src1 = d.op_vreg(rhs); jnz2.dest = d.op_label(true_l); jnz2.line = line; emit(jnz2);
        // false
        let is *d.IRInst as mf = d.new_inst(d.IR_IMM);
        mf.dest = d.op_vreg(dest); mf.src1 = d.op_imm(0); emit(mf);
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); emit(jmp);
        // true
        let is *d.IRInst as tl = d.new_inst(d.IR_LABEL);
        tl.dest = d.op_label(true_l); emit(tl);
        let is *d.IRInst as mt = d.new_inst(d.IR_IMM);
        mt.dest = d.op_vreg(dest); mt.src1 = d.op_imm(1); emit(mt);
        // end
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        return dest;
    }

    // NK_FNCALL
    if (k == ast.NK_FNCALL) {
        let is i32 as arg_count with mut = 0;
        let is *ast.Node as a with mut = node.args;
        while (cast(i64, a) != 0) { arg_count = arg_count + 1; a = a.next; }

        // SRET for large struct return
        let is i32 as use_sret with mut = 0;
        if (ty.size > 8) { use_sret = 1; }

        let is i32 as sret_addr with mut = cast(i32, 0 - 1);
        if (use_sret == 1) {
            ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + ty.size;
            let is i32 as offset = ctx_func.alloc_stack_size;
            // align 16
            if (ctx_func.alloc_stack_size % 16 != 0) {
                ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + 16 - (ctx_func.alloc_stack_size % 16);
            }
            sret_addr = new_vreg();
            let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
            ga.dest = d.op_vreg(sret_addr);
            ga.src1 = d.op_imm(cast(i64, offset));
            ga.line = line;
            emit(ga);
            arg_count = arg_count + 1;
        }

        // Generate args - max 32 args
        let is [256]u8 as arg_vregs;
        let is i32 as ai with mut = 0;
        if (sret_addr != cast(i32, 0 - 1)) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, ai) * 4);
            *av = sret_addr;
            ai = ai + 1;
        }
        a = node.args;
        while (cast(i64, a) != 0) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, ai) * 4);
            *av = gen_expr(a);
            ai = ai + 1;
            a = a.next;
        }

        // Internal Caustic ABI: all args in GPRs
        let is i32 as stack_args with mut = 0;
        if (arg_count > 6) { stack_args = arg_count - 6; }
        let is i32 as padding with mut = 0;
        if (stack_args % 2 != 0) { padding = 1; }
        if (padding == 1) {
            let is *d.IRInst as al = d.new_inst(d.IR_ASM);
            al.asm_str_ptr = d.str_dup("sub rsp, 8", 10);
            al.asm_str_len = 10;
            al.line = line;
            emit(al);
        }
        // Stack args in reverse
        let is i32 as j with mut = arg_count - 1;
        while (j >= 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j - 1;
        }
        // Register args
        j = 0;
        while (j < arg_count && j < 6) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, j) * 4);
            emit_set_arg(j, *av, cast(*u8, 0), line);
            j = j + 1;
        }

        // Use asm_name if available (for mangled names)
        let is *u8 as cname with mut = node.name_ptr;
        let is i32 as clen with mut = node.name_len;
        if (node.asm_name_len > 0) {
            cname = node.asm_name_ptr;
            clen = node.asm_name_len;
        }
        let is i32 as ret_reg = emit_call(cname, clen, node.is_variadic, cast(*u8, ty), line);

        if (stack_args > 0) {
            let is i32 as pad2 with mut = 0;
            if (stack_args % 2 != 0) { pad2 = 1; }
            let is i32 as cleanup_bytes = (stack_args + pad2) * 8;
            // Build "add rsp, N" string
            let is [32]u8 as cbuf;
            mem.memcpy(cast(*u8, &cbuf), "add rsp, ", 9);
            let is i32 as cpos with mut = 9;
            let is i32 as cv with mut = cleanup_bytes;
            let is [10]u8 as nbuf;
            let is i32 as ni with mut = 0;
            while (cv > 0) {
                nbuf[ni] = cast(u8, (cv % 10) + 48);
                cv = cv / 10;
                ni = ni + 1;
            }
            let is i32 as nj with mut = ni - 1;
            while (nj >= 0) {
                cbuf[cpos] = nbuf[nj];
                cpos = cpos + 1;
                nj = nj - 1;
            }
            let is *d.IRInst as cl = d.new_inst(d.IR_ASM);
            cl.asm_str_ptr = d.str_dup(cast(*u8, &cbuf), cpos);
            cl.asm_str_len = cpos;
            cl.line = line;
            emit(cl);
        }

        if (sret_addr != cast(i32, 0 - 1)) { return sret_addr; }
        return ret_reg;
    }

    // NK_SYSCALL
    if (k == ast.NK_SYSCALL) {
        let is i32 as arg_count with mut = 0;
        let is [56]u8 as arg_vregs;
        let is *ast.Node as a with mut = node.args;
        while (cast(i64, a) != 0) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, arg_count) * 4);
            *av = gen_expr(a);
            arg_count = arg_count + 1;
            a = a.next;
        }
        let is i32 as si with mut = 0;
        while (si < arg_count) {
            let is *i32 as av = cast(*i32, cast(i64, &arg_vregs) + cast(i64, si) * 4);
            let is *d.IRInst as sa = d.new_inst(d.IR_SET_SYS_ARG);
            sa.dest = d.op_imm(cast(i64, si));
            sa.src1 = d.op_vreg(*av);
            sa.line = line;
            emit(sa);
            si = si + 1;
        }
        let is i32 as dest = new_vreg();
        let is *d.IRInst as sc = d.new_inst(d.IR_SYSCALL);
        sc.dest = d.op_vreg(dest);
        sc.line = line;
        emit(sc);
        return dest;
    }

    // NK_ENUM_LIT
    if (k == ast.NK_ENUM_LIT) {
        let is i32 as disc = node.discriminant;
        // Simple enum (no payload, small)
        if (cast(i64, node.payload_args) == 0 && ty.size <= 4) {
            return emit_imm(cast(i64, disc), line);
        }
        // Tagged union with no payload but needs full allocation
        if (cast(i64, node.payload_args) == 0 && ty.size > 4) {
            let is i32 as total_size = ty.size;
            ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + total_size;
            if (ctx_func.alloc_stack_size % 16 != 0) {
                ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + 16 - (ctx_func.alloc_stack_size % 16);
            }
            let is i32 as offset = ctx_func.alloc_stack_size;
            let is i32 as base_addr = new_vreg();
            let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
            ga.dest = d.op_vreg(base_addr); ga.src1 = d.op_imm(cast(i64, offset)); ga.line = line; emit(ga);
            let is i32 as disc_reg = emit_imm(cast(i64, disc), line);
            let is *d.IRInst as st = d.new_inst(d.IR_STORE);
            st.dest = d.op_vreg(base_addr); st.src1 = d.op_vreg(disc_reg);
            st.cast_to = cast(*u8, ast.type_i32); st.line = line; emit(st);
            return base_addr;
        }
        // Tagged union with payload
        let is i32 as total_size = ty.size;
        ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + total_size;
        if (ctx_func.alloc_stack_size % 16 != 0) {
            ctx_func.alloc_stack_size = ctx_func.alloc_stack_size + 16 - (ctx_func.alloc_stack_size % 16);
        }
        let is i32 as offset = ctx_func.alloc_stack_size;
        let is i32 as base_addr = new_vreg();
        let is *d.IRInst as ga = d.new_inst(d.IR_GET_ALLOC_ADDR);
        ga.dest = d.op_vreg(base_addr); ga.src1 = d.op_imm(cast(i64, offset)); ga.line = line; emit(ga);
        // Store discriminant
        let is i32 as disc_reg = emit_imm(cast(i64, disc), line);
        let is *d.IRInst as st = d.new_inst(d.IR_STORE);
        st.dest = d.op_vreg(base_addr); st.src1 = d.op_vreg(disc_reg);
        st.cast_to = cast(*u8, ast.type_i32); st.line = line; emit(st);
        // Store payload
        let is i32 as payload_off = ty.payload_offset;
        let is i32 as payload_addr with mut = base_addr;
        if (payload_off > 0) {
            let is i32 as ofreg = emit_imm(cast(i64, payload_off), line);
            payload_addr = emit_binary(d.IR_ADD, base_addr, ofreg, line);
        }
        // Store each payload arg sequentially
        let is *ast.Node as arg with mut = node.payload_args;
        while (cast(i64, arg) != 0) {
            let is i32 as val = gen_expr(arg);
            let is *ast.Type as arg_ty = arg.ty;
            if (arg_ty.size > 8) {
                let is *d.IRInst as cp = d.new_inst(d.IR_COPY);
                cp.dest = d.op_vreg(payload_addr); cp.src1 = d.op_vreg(val);
                cp.src2 = d.op_imm(cast(i64, arg_ty.size)); cp.line = line; emit(cp);
            } else {
                let is *d.IRInst as sv = d.new_inst(d.IR_STORE);
                sv.dest = d.op_vreg(payload_addr); sv.src1 = d.op_vreg(val);
                sv.cast_to = cast(*u8, arg_ty); sv.line = line; emit(sv);
            }
            arg = arg.next;
        }
        return base_addr;
    }

    // NK_VA_START
    if (k == ast.NK_VA_START) {
        let is i32 as va_addr = gen_expr(node.expr);
        let is *d.IRInst as vai = d.new_inst(d.IR_VA_START);
        vai.src1 = d.op_vreg(va_addr);
        vai.src2 = d.op_imm(cast(i64, ctx_func.num_args));
        vai.line = line;
        emit(vai);
        return va_addr;
    }

    io.write_str(linux.STDERR, "ir: unsupported expression kind: ");
    io.write_int(linux.STDERR, cast(i64, k));
    io.write_str(linux.STDERR, "\n");
    linux.exit(1);
    return 0;
}

// === gen_stmt ===

fn gen_stmt(node as *ast.Node) as void {
    let is *ast.Node as n with mut = node;
    while (cast(i64, n) != 0) {
        if (ctx_has_returned == 0) {
            gen_stmt_single(n);
        }
        n = n.next;
    }
}

fn gen_stmt_single(node as *ast.Node) as void {
    if (cast(i64, node) == 0) { return; }
    let is i32 as k = node.kind;
    let is i32 as line = tok_line(node.tok_idx);

    // RETURN
    if (k == ast.NK_RETURN) {
        if (cast(i64, node.expr) != 0) {
            let is i32 as result = gen_expr(node.expr);
            emit_deferred_calls();
            if (ctx_has_sret == 1) {
                let is *d.IRInst as cp = d.new_inst(d.IR_COPY);
                cp.dest = d.op_vreg(ctx_sret_vreg);
                cp.src1 = d.op_vreg(result);
                cp.src2 = d.op_imm(cast(i64, node.expr.ty.size));
                cp.line = line;
                emit(cp);
                emit_return(ctx_sret_vreg, line);
            } else {
                emit_return(result, line);
            }
        } else {
            emit_deferred_calls();
            emit_return(cast(i32, 0 - 1), line);
        }
        ctx_has_returned = 1;
        return;
    }

    // EXPR_STMT
    if (k == ast.NK_EXPR_STMT) {
        gen_expr(node.expr);
        return;
    }

    // LET (local)
    if (k == ast.NK_LET) {
        if (cast(i64, node.init_expr) != 0) {
            let is i32 as init_kind = node.init_expr.kind;
            if (init_kind == ast.NK_FNCALL || init_kind == ast.NK_SYSCALL) {
                let is *d.IRInst as ctx_inst = d.new_inst(d.IR_SET_CTX);
                ctx_inst.src1 = d.op_imm(0);
                ctx_inst.line = line;
                emit(ctx_inst);
            }
            let is i32 as val = gen_expr(node.init_expr);
            let is *ast.Type as ty = node.ty;
            if (ty.size > 8) {
                let is i32 as dest_addr = new_vreg();
                let is *d.IRInst as ai = d.new_inst(d.IR_ADDR);
                ai.dest = d.op_vreg(dest_addr);
                ai.src1 = d.op_imm(cast(i64, node.var_offset));
                ai.line = line;
                emit(ai);
                let is *d.IRInst as cp = d.new_inst(d.IR_COPY);
                cp.dest = d.op_vreg(dest_addr);
                cp.src1 = d.op_vreg(val);
                cp.src2 = d.op_imm(cast(i64, ty.size));
                cp.line = line;
                emit(cp);
            } else {
                let is *d.IRInst as si = d.new_inst(d.IR_STORE);
                si.dest = d.op_imm(cast(i64, node.var_offset));
                si.src1 = d.op_vreg(val);
                si.cast_to = cast(*u8, ty);
                si.line = line;
                emit(si);
            }
        }
        return;
    }

    // BLOCK
    if (k == ast.NK_BLOCK) {
        gen_stmt(node.stmts);
        return;
    }

    // IF
    if (k == ast.NK_IF) {
        let is i32 as saved_ret = ctx_has_returned;
        let is i32 as saved_defer = defer_count;
        let is i32 as else_l = new_label();
        let is i32 as end_l = new_label();
        let is i32 as cond_reg = gen_expr(node.cond);
        let is *d.IRInst as jz = d.new_inst(d.IR_JZ);
        jz.src1 = d.op_vreg(cond_reg); jz.dest = d.op_label(else_l); jz.line = line; emit(jz);
        gen_stmt(node.then_b);
        let is i32 as then_ret = ctx_has_returned;
        ctx_has_returned = saved_ret;
        defer_count = saved_defer;
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); jmp.line = line; emit(jmp);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(else_l); emit(el);
        let is i32 as else_ret with mut = 0;
        if (cast(i64, node.else_b) != 0) {
            gen_stmt(node.else_b);
            else_ret = ctx_has_returned;
        }
        let is *d.IRInst as endl = d.new_inst(d.IR_LABEL);
        endl.dest = d.op_label(end_l); emit(endl);
        if (then_ret == 1 && else_ret == 1) {
            ctx_has_returned = 1;
        } else {
            ctx_has_returned = saved_ret;
        }
        defer_count = saved_defer;
        return;
    }

    // ASM
    if (k == ast.NK_ASM) {
        let is *d.IRInst as i = d.new_inst(d.IR_ASM);
        i.asm_str_ptr = d.str_dup(node.name_ptr, node.name_len);
        i.asm_str_len = node.name_len;
        i.line = line;
        emit(i);
        ctx_has_returned = 1;
        return;
    }

    // WHILE
    if (k == ast.NK_WHILE) {
        let is i32 as saved_ret = ctx_has_returned;
        let is i32 as saved_defer = defer_count;
        let is i32 as start_l = new_label();
        let is i32 as end_l = new_label();
        push_loop(start_l, end_l, start_l);
        let is *d.IRInst as sl = d.new_inst(d.IR_LABEL);
        sl.dest = d.op_label(start_l); emit(sl);
        let is i32 as cond_reg = gen_expr(node.cond);
        let is *d.IRInst as jz = d.new_inst(d.IR_JZ);
        jz.src1 = d.op_vreg(cond_reg); jz.dest = d.op_label(end_l); jz.line = line; emit(jz);
        gen_stmt_single(node.body);
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(start_l); jmp.line = line; emit(jmp);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        pop_loop();
        ctx_has_returned = saved_ret;
        defer_count = saved_defer;
        return;
    }

    // DO_WHILE
    if (k == ast.NK_DO_WHILE) {
        let is i32 as saved_ret = ctx_has_returned;
        let is i32 as saved_defer = defer_count;
        let is i32 as start_l = new_label();
        let is i32 as end_l = new_label();
        let is i32 as cond_l = new_label();
        push_loop(start_l, end_l, cond_l);
        let is *d.IRInst as sl = d.new_inst(d.IR_LABEL);
        sl.dest = d.op_label(start_l); emit(sl);
        gen_stmt_single(node.body);
        let is *d.IRInst as cl = d.new_inst(d.IR_LABEL);
        cl.dest = d.op_label(cond_l); emit(cl);
        let is i32 as cond_reg = gen_expr(node.cond);
        let is *d.IRInst as jnz = d.new_inst(d.IR_JNZ);
        jnz.src1 = d.op_vreg(cond_reg); jnz.dest = d.op_label(start_l); jnz.line = line; emit(jnz);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        pop_loop();
        ctx_has_returned = saved_ret;
        defer_count = saved_defer;
        return;
    }

    // FOR
    if (k == ast.NK_FOR) {
        let is i32 as saved_defer = defer_count;
        let is i32 as start_l = new_label();
        let is i32 as end_l = new_label();
        let is i32 as step_l = new_label();
        // Init
        if (cast(i64, node.for_init) != 0) {
            if (node.for_init.kind == ast.NK_LET) {
                gen_stmt_single(node.for_init);
            } else {
                gen_expr(node.for_init);
            }
        }
        push_loop(start_l, end_l, step_l);
        let is *d.IRInst as sl = d.new_inst(d.IR_LABEL);
        sl.dest = d.op_label(start_l); emit(sl);
        // Cond
        if (cast(i64, node.cond) != 0) {
            let is i32 as cond_reg = gen_expr(node.cond);
            let is *d.IRInst as jz = d.new_inst(d.IR_JZ);
            jz.src1 = d.op_vreg(cond_reg); jz.dest = d.op_label(end_l); jz.line = line; emit(jz);
        }
        gen_stmt_single(node.body);
        let is *d.IRInst as stl = d.new_inst(d.IR_LABEL);
        stl.dest = d.op_label(step_l); emit(stl);
        // Step
        if (cast(i64, node.for_step) != 0) {
            gen_expr(node.for_step);
        }
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(start_l); jmp.line = line; emit(jmp);
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        pop_loop();
        defer_count = saved_defer;
        return;
    }

    // BREAK
    if (k == ast.NK_BREAK) {
        if (ctx_loop_depth == 0) { return; }
        let is i32 as end_l = get_loop_end();
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(end_l); jmp.line = line; emit(jmp);
        return;
    }

    // CONTINUE
    if (k == ast.NK_CONTINUE) {
        if (ctx_loop_depth == 0) { return; }
        let is i32 as cont_l = get_loop_continue();
        let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
        jmp.dest = d.op_label(cont_l); jmp.line = line; emit(jmp);
        return;
    }

    // ASSIGN (as statement)
    if (k == ast.NK_ASSIGN) {
        gen_expr(node);
        return;
    }

    // DEFER
    if (k == ast.NK_DEFER) {
        push_defer(cast(*u8, node.expr));
        return;
    }

    // MATCH
    if (k == ast.NK_MATCH) {
        let is i32 as saved_ret = ctx_has_returned;
        let is i32 as saved_defer = defer_count;
        let is i32 as end_l = new_label();
        let is i32 as expr_reg = gen_expr(node.expr);
        let is *ast.Type as mt = node.match_type;
        let is i32 as is_tagged with mut = 0;
        if (mt.payload_offset > 0) { is_tagged = 1; }
        // Load discriminant
        let is i32 as disc_reg with mut;
        if (is_tagged == 1) {
            disc_reg = new_vreg();
            let is *d.IRInst as ld = d.new_inst(d.IR_LOAD);
            ld.dest = d.op_vreg(disc_reg); ld.src1 = d.op_vreg(expr_reg);
            ld.cast_to = cast(*u8, ast.type_i32); ld.line = line; emit(ld);
        } else {
            disc_reg = expr_reg;
        }
        let is i32 as all_returned with mut = 1;
        let is *ast.Node as c with mut = node.cases;
        while (cast(i64, c) != 0) {
            let is i32 as next_l = new_label();
            let is i32 as case_disc = cast(i32, c.val);
            let is i32 as imm_reg = emit_imm(cast(i64, case_disc), line);
            let is i32 as cmp = emit_binary(d.IR_EQ, disc_reg, imm_reg, line);
            let is *d.IRInst as jz = d.new_inst(d.IR_JZ);
            jz.src1 = d.op_vreg(cmp); jz.dest = d.op_label(next_l); jz.line = line; emit(jz);

            // Payload bindings
            if (cast(i64, c.params) != 0 && is_tagged == 1) {
                let is i32 as poff = mt.payload_offset;
                let is i32 as paddr with mut = expr_reg;
                if (poff > 0) {
                    let is i32 as ofreg = emit_imm(cast(i64, poff), line);
                    paddr = emit_binary(d.IR_ADD, expr_reg, ofreg, line);
                }
                // Bind single or first payload to binding var
                let is *ast.Node as binding = c.params;
                if (cast(i64, binding) != 0) {
                    let is *ast.Type as bty = binding.ty;
                    let is i32 as val with mut;
                    if (bty.size > 8) {
                        val = paddr;
                    } else {
                        val = new_vreg();
                        let is *d.IRInst as ld2 = d.new_inst(d.IR_LOAD);
                        ld2.dest = d.op_vreg(val); ld2.src1 = d.op_vreg(paddr);
                        ld2.cast_to = cast(*u8, bty); ld2.line = line; emit(ld2);
                    }
                    if (bty.size > 8) {
                        let is i32 as da = new_vreg();
                        let is *d.IRInst as ai = d.new_inst(d.IR_ADDR);
                        ai.dest = d.op_vreg(da); ai.src1 = d.op_imm(cast(i64, binding.var_offset));
                        ai.line = line; emit(ai);
                        let is *d.IRInst as cp = d.new_inst(d.IR_COPY);
                        cp.dest = d.op_vreg(da); cp.src1 = d.op_vreg(val);
                        cp.src2 = d.op_imm(cast(i64, bty.size)); cp.line = line; emit(cp);
                    } else {
                        let is *d.IRInst as sv = d.new_inst(d.IR_STORE);
                        sv.dest = d.op_imm(cast(i64, binding.var_offset));
                        sv.src1 = d.op_vreg(val);
                        sv.cast_to = cast(*u8, bty); sv.line = line; emit(sv);
                    }
                }
            }

            ctx_has_returned = saved_ret;
            defer_count = saved_defer;
            gen_stmt(c.body);
            if (ctx_has_returned == 0) { all_returned = 0; }
            let is *d.IRInst as jmp = d.new_inst(d.IR_JMP);
            jmp.dest = d.op_label(end_l); jmp.line = line; emit(jmp);
            let is *d.IRInst as nl = d.new_inst(d.IR_LABEL);
            nl.dest = d.op_label(next_l); emit(nl);
            c = c.next;
        }
        // Else block
        if (cast(i64, node.else_b) != 0) {
            ctx_has_returned = saved_ret;
            gen_stmt(node.else_b);
            if (ctx_has_returned == 0) { all_returned = 0; }
        } else {
            all_returned = 0;
        }
        let is *d.IRInst as el = d.new_inst(d.IR_LABEL);
        el.dest = d.op_label(end_l); emit(el);
        if (all_returned == 1) { ctx_has_returned = 1; } else { ctx_has_returned = saved_ret; }
        defer_count = saved_defer;
        return;
    }

    io.write_str(linux.STDERR, "ir: unsupported statement kind: ");
    io.write_int(linux.STDERR, cast(i64, k));
    io.write_str(linux.STDERR, "\n");
    linux.exit(1);
}

// === eval_const_expr ===

fn eval_const_expr(node as *ast.Node) as i64 {
    if (node.kind == ast.NK_NUM) { return node.val; }
    if (node.kind == ast.NK_ADD) { return eval_const_expr(node.lhs) + eval_const_expr(node.rhs); }
    if (node.kind == ast.NK_SUB) { return eval_const_expr(node.lhs) - eval_const_expr(node.rhs); }
    if (node.kind == ast.NK_MUL) { return eval_const_expr(node.lhs) * eval_const_expr(node.rhs); }
    if (node.kind == ast.NK_DIV) { return eval_const_expr(node.lhs) / eval_const_expr(node.rhs); }
    io.write_str(linux.STDERR, "ir: non-constant expr in global init\n");
    linux.exit(1);
    return 0;
}

// === mark_reachable ===

fn mark_reachable(prog as *d.IRProgram, func as *d.IRFunction) as void {
    if (cast(i64, func) == 0) { return; }
    if (func.is_reachable == 1) { return; }
    func.is_reachable = 1;
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.op == d.IR_CALL && inst.call_name_len > 0) {
            let is *d.IRFunction as f with mut = prog.functions;
            while (cast(i64, f) != 0) {
                let is *u8 as fname with mut = f.name_ptr;
                let is i32 as flen with mut = f.name_len;
                if (f.asm_name_len > 0) { fname = f.asm_name_ptr; flen = f.asm_name_len; }
                if (d.str_eq(fname, flen, inst.call_name_ptr, inst.call_name_len) == 1) {
                    mark_reachable(prog, f);
                }
                f = f.next;
            }
        }
        if (inst.op == d.IR_FN_ADDR && inst.global_name_len > 0) {
            let is *d.IRFunction as f with mut = prog.functions;
            while (cast(i64, f) != 0) {
                let is *u8 as fname with mut = f.name_ptr;
                let is i32 as flen with mut = f.name_len;
                if (f.asm_name_len > 0) { fname = f.asm_name_ptr; flen = f.asm_name_len; }
                if (d.str_eq(fname, flen, inst.global_name_ptr, inst.global_name_len) == 1) {
                    mark_reachable(prog, f);
                }
                f = f.next;
            }
        }
        if (inst.op == d.IR_ADDR_GLOBAL && inst.global_name_len > 0) {
            let is *d.IRGlobal as g with mut = prog.globals;
            while (cast(i64, g) != 0) {
                if (d.str_eq(g.name_ptr, g.name_len, inst.global_name_ptr, inst.global_name_len) == 1) {
                    g.is_reachable = 1;
                }
                g = g.next;
            }
        }
        inst = inst.next;
    }
}

// === gen_ir entry ===

fn gen_ir(root as *u8, no_main as i32) as *d.IRProgram {
    ir_depth = ir_depth + 1;
    let is *d.IRProgram as prog = d.new_irprog();
    let is *d.IRFunction as func_tail with mut = cast(*d.IRFunction, 0);
    let is *d.IRGlobal as glob_tail with mut = cast(*d.IRGlobal, 0);

    let is *ast.Node as node with mut = cast(*ast.Node, root);
    while (cast(i64, node) != 0) {
        let is i32 as nk = node.kind;

        // Global LET
        if (nk == ast.NK_LET && node.is_global == 1) {
            if (node.is_extern == 1) { node = node.next; }
            else {
                let is *d.IRGlobal as glob = d.new_irglobal();
                if (node.asm_name_len > 0) {
                    glob.name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                    glob.name_len = node.asm_name_len;
                } else {
                    glob.name_ptr = d.str_dup(node.name_ptr, node.name_len);
                    glob.name_len = node.name_len;
                }
                glob.size = node.ty.size;
                if (cast(i64, node.init_expr) != 0) {
                    glob.init_value = eval_const_expr(node.init_expr);
                    glob.is_initialized = 1;
                }
                if (cast(i64, glob_tail) == 0) {
                    prog.globals = glob;
                } else {
                    glob_tail.next = glob;
                }
                glob_tail = glob;
                node = node.next;
            }
        }
        // NK_FN
        else if (nk == ast.NK_FN) {
            // Skip generic templates
            if (node.generic_param_count > 0) { node = node.next; }
            // Skip extern / no body
            else if (cast(i64, node.body) == 0) { node = node.next; }
            else {
                // Reset context
                ctx_head = cast(*d.IRInst, 0);
                ctx_tail = cast(*d.IRInst, 0);
                ctx_vreg = 0;
                ctx_loop_depth = 0;
                ctx_has_sret = 0;
                ctx_has_returned = 0;
                defer_count = 0;

                let is *d.IRFunction as func = d.new_irfunc();
                if (node.asm_name_len > 0) {
                    func.name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                    func.name_len = node.asm_name_len;
                    func.asm_name_ptr = d.str_dup(node.asm_name_ptr, node.asm_name_len);
                    func.asm_name_len = node.asm_name_len;
                } else {
                    func.name_ptr = d.str_dup(node.name_ptr, node.name_len);
                    func.name_len = node.name_len;
                    func.asm_name_ptr = d.str_dup(node.name_ptr, node.name_len);
                    func.asm_name_len = node.name_len;
                }
                func.is_variadic = node.is_variadic;

                let is i32 as param_count with mut = 0;
                let is *ast.Node as p with mut = node.params;
                while (cast(i64, p) != 0) { param_count = param_count + 1; p = p.next; }
                func.num_args = param_count;

                ctx_func = func;

                if (node.body.kind == ast.NK_BLOCK) {
                    let is i32 as arg_idx with mut = 0;
                    // SRET check
                    if (cast(i64, node.return_type) != 0 && node.return_type.size > 8) {
                        ctx_has_sret = 1;
                        ctx_sret_vreg = emit_get_arg(arg_idx, tok_line(node.tok_idx));
                        arg_idx = arg_idx + 1;
                    }
                    // Get args and store to local vars
                    p = node.params;
                    while (cast(i64, p) != 0) {
                        let is i32 as av = emit_get_arg(arg_idx, p.tok_idx);
                        let is *d.IRInst as si = d.new_inst(d.IR_STORE);
                        si.dest = d.op_imm(cast(i64, p.var_offset));
                        si.src1 = d.op_vreg(av);
                        si.cast_to = cast(*u8, p.ty);
                        si.line = p.tok_idx;
                        emit(si);
                        arg_idx = arg_idx + 1;
                        p = p.next;
                    }
                    gen_stmt(node.body.stmts);
                    emit_deferred_calls();
                    // Implicit return
                    let is i32 as zero = emit_imm(0, 0);
                    emit_return(zero, 0);
                }

                func.instructions = ctx_head;
                func.vreg_count = ctx_vreg;
                func.label_count = ctx_label;
                func.stack_size = node.stack_size;

                if (cast(i64, func_tail) == 0) {
                    prog.functions = func;
                } else {
                    func_tail.next = func;
                }
                func_tail = func;

                // Check if main
                if (d.str_eq(func.name_ptr, func.name_len, "main", 4) == 1) {
                    prog.main_func = func;
                }
                node = node.next;
            }
        }
        // NK_USE — recurse
        else if (nk == ast.NK_USE) {
            if (cast(i64, node.body) != 0) {
                // Check if this body was already processed
                let is i64 as body_ptr = cast(i64, node.body);
                let is i32 as already with mut = 0;
                let is i32 as di with mut = 0;
                while (di < ir_done_count) {
                    let is *i64 as dp = cast(*i64, cast(i64, &ir_done_bodies) + cast(i64, di) * 8);
                    if (*dp == body_ptr) { already = 1; }
                    di = di + 1;
                }
                if (already == 0) {
                    // Mark as done
                    let is *i64 as dp2 = cast(*i64, cast(i64, &ir_done_bodies) + cast(i64, ir_done_count) * 8);
                    *dp2 = body_ptr;
                    ir_done_count = ir_done_count + 1;
                    let is *d.IRProgram as mod_prog = gen_ir(cast(*u8, node.body), 1);
                    // Merge functions
                    if (cast(i64, mod_prog.functions) != 0) {
                        if (cast(i64, func_tail) == 0) {
                            prog.functions = mod_prog.functions;
                        } else {
                            func_tail.next = mod_prog.functions;
                        }
                        // Find new tail
                        let is *d.IRFunction as ft with mut = mod_prog.functions;
                        while (cast(i64, ft.next) != 0) { ft = ft.next; }
                        func_tail = ft;
                    }
                    // Merge globals
                    if (cast(i64, mod_prog.globals) != 0) {
                        if (cast(i64, glob_tail) == 0) {
                            prog.globals = mod_prog.globals;
                        } else {
                            glob_tail.next = mod_prog.globals;
                        }
                        let is *d.IRGlobal as gt with mut = mod_prog.globals;
                        while (cast(i64, gt.next) != 0) { gt = gt.next; }
                        glob_tail = gt;
                    }
                }
            }
            node = node.next;
        }
        else {
            node = node.next;
        }
    }

    // Search main after all merges (only at top level)
    if (ir_depth == 1 && cast(i64, prog.main_func) == 0) {
        let is *d.IRFunction as f with mut = prog.functions;
        while (cast(i64, f) != 0) {
            if (d.str_eq(f.name_ptr, f.name_len, "main", 4) == 1) {
                prog.main_func = f;
            }
            f = f.next;
        }
    }

    if (ir_depth == 1 && cast(i64, prog.main_func) == 0 && no_main == 0) {
        io.write_str(linux.STDERR, "ir: function main not found\n");
        linux.exit(1);
    }

    prog.strings = string_head;

    if (cast(i64, prog.main_func) != 0) {
        mark_reachable(prog, prog.main_func);
    } else if (no_main == 1) {
        let is *d.IRFunction as f with mut = prog.functions;
        while (cast(i64, f) != 0) { f.is_reachable = 1; f = f.next; }
        let is *d.IRGlobal as g with mut = prog.globals;
        while (cast(i64, g) != 0) { g.is_reachable = 1; g = g.next; }
    }

    ir_depth = ir_depth - 1;
    return prog;
}
