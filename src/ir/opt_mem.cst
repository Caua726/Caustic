use "../../std/mem/bins.cst" as bins;
use "../../std/mem/core.cst" as core;

let is bins.Bins as _opt_bins with mut;
let is i32 as _opt_ready with mut = 0;

// Header: 16 bytes before user pointer
// byte 0: 0=bins, 1=mmap
// bytes 8-15: size (for mmap munmap)
let is i64 as HDR with imut = 16;

fn opt_bins_init() as void {
    if (_opt_ready == 0) {
        _opt_bins = bins.bins_new(131072);
        _opt_ready = 1;
    }
}

fn opt_bins_destroy() as void {
    if (_opt_ready == 1) {
        bins.bins_destroy(&_opt_bins);
        _opt_ready = 0;
    }
}

fn opt_alloc(size as i64) as *u8 {
    if (_opt_ready == 0) { opt_bins_init(); }
    if (size > 65520) {
        // mmap path: alloc size + HDR, store tag + size
        let is i64 as total = size + HDR;
        let is *u8 as raw = core.mmap_anon(total);
        if (cast(i64, raw) < 0) { return cast(*u8, 0); }
        let is *i64 as tag = cast(*i64, raw);
        *tag = 1;
        let is *i64 as sp = cast(*i64, cast(i64, raw) + 8);
        *sp = total;
        return cast(*u8, cast(i64, raw) + HDR);
    }
    // bins path
    let is *u8 as raw = bins.bins_alloc(&_opt_bins, size + HDR);
    if (cast(i64, raw) == 0) { return cast(*u8, 0); }
    let is *i64 as tag = cast(*i64, raw);
    *tag = 0;
    return cast(*u8, cast(i64, raw) + HDR);
}

fn opt_free(ptr as *u8) as void {
    if (cast(i64, ptr) == 0) { return; }
    let is *u8 as raw = cast(*u8, cast(i64, ptr) - HDR);
    let is *i64 as tag = cast(*i64, raw);
    if (*tag == 1) {
        let is *i64 as sp = cast(*i64, cast(i64, raw) + 8);
        core.munmap(raw, *sp);
    } else {
        bins.bins_free(&_opt_bins, raw);
    }
}

fn opt_mmap(size as i64) as *u8 {
    return core.mmap_anon(size);
}

fn opt_munmap(ptr as *u8, size as i64) as void {
    core.munmap(ptr, size);
}
