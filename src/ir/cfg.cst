use "defs.cst" as d;

// === CFG construction: basic blocks, predecessors, reverse postorder ===

let is i32 as MAX_BLOCKS with imut = 4096;

struct BasicBlock {
    first as *d.IRInst;
    last as *d.IRInst;
    succ0 as i32;       // fallthrough (-1 = none)
    succ1 as i32;       // branch target (-1 = none)
    idom as i32;
    rpo as i32;          // reverse postorder number
    df_start as i32;
    df_count as i32;
    pred_start as i32;
    pred_count as i32;
}

// === Helper: insert instruction after target in linked list ===
fn insert_after(target as *d.IRInst, newinst as *d.IRInst) as void {
    newinst.next = target.next;
    target.next = newinst;
}

// === Helper: insert instruction before target (need prev) ===
fn insert_before(prev as *d.IRInst, target as *d.IRInst, newinst as *d.IRInst) as void {
    newinst.next = target;
    prev.next = newinst;
}

fn build_cfg(func as *d.IRFunction, blocks as *BasicBlock, out_nblocks as *i32,
             label_to_bb as *i32) as void {
    // First pass: identify block starts (label targets + after branches)
    let is i32 as nblocks with mut = 0;
    let is i32 as lc = func.label_count + 1;

    // Mark which positions start new blocks
    // Use instruction index → block mapping
    let is i32 as inst_count with mut = 0;
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) { inst_count = inst_count + 1; inst = inst.next; }

    let is *i32 as inst_is_leader = cast(*i32, d.opt_alloc(cast(i64, inst_count + 1) * 4));
    let is i32 as ii with mut = 0;
    while (ii <= inst_count) {
        let is *i32 as p = cast(*i32, cast(i64, inst_is_leader) + cast(i64, ii) * 4);
        *p = 0;
        ii = ii + 1;
    }

    // First instruction is always a leader
    let is *i32 as p0 = cast(*i32, cast(i64, inst_is_leader));
    *p0 = 1;

    // Labels are leaders; instructions after branches are leaders
    ii = 0;
    inst = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.op == d.IR_LABEL) {
            let is *i32 as p = cast(*i32, cast(i64, inst_is_leader) + cast(i64, ii) * 4);
            *p = 1;
        }
        if (inst.op == d.IR_JMP || inst.op == d.IR_JZ || inst.op == d.IR_JNZ || inst.op == d.IR_RET) {
            if (ii + 1 < inst_count) {
                let is *i32 as p = cast(*i32, cast(i64, inst_is_leader) + cast(i64, ii + 1) * 4);
                *p = 1;
            }
        }
        ii = ii + 1;
        inst = inst.next;
    }

    // Build block array
    let is *i32 as inst_to_bb = cast(*i32, d.opt_alloc(cast(i64, inst_count) * 4));
    ii = 0;
    inst = func.instructions;
    let is i32 as cur_block with mut = cast(i32, 0 - 1);
    while (cast(i64, inst) != 0) {
        let is *i32 as lp = cast(*i32, cast(i64, inst_is_leader) + cast(i64, ii) * 4);
        if (*lp == 1) {
            cur_block = cur_block + 1;
            if (cur_block < MAX_BLOCKS) {
                let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, cur_block) * sizeof(BasicBlock));
                bb.first = inst;
                bb.last = inst;
                bb.succ0 = cast(i32, 0 - 1);
                bb.succ1 = cast(i32, 0 - 1);
                bb.idom = cast(i32, 0 - 1);
                bb.rpo = cast(i32, 0 - 1);
                bb.df_start = 0;
                bb.df_count = 0;
                bb.pred_start = 0;
                bb.pred_count = 0;
            }
        }
        if (cur_block >= 0 && cur_block < MAX_BLOCKS) {
            let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, cur_block) * sizeof(BasicBlock));
            bb.last = inst;
            // Map label → block
            if (inst.op == d.IR_LABEL) {
                let is i32 as lid = inst.dest.label;
                if (lid < lc) {
                    let is *i32 as lbp = cast(*i32, cast(i64, label_to_bb) + cast(i64, lid) * 4);
                    *lbp = cur_block;
                }
            }
        }
        let is *i32 as ibp = cast(*i32, cast(i64, inst_to_bb) + cast(i64, ii) * 4);
        *ibp = cur_block;
        ii = ii + 1;
        inst = inst.next;
    }
    nblocks = cur_block + 1;

    // Set successors from terminators
    ii = 0;
    while (ii < nblocks) {
        let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, ii) * sizeof(BasicBlock));
        let is *d.IRInst as last = bb.last;
        if (last.op == d.IR_JMP) {
            let is *i32 as lbp = cast(*i32, cast(i64, label_to_bb) + cast(i64, last.dest.label) * 4);
            bb.succ0 = *lbp;
        } else if (last.op == d.IR_JZ || last.op == d.IR_JNZ) {
            // Fallthrough
            if (ii + 1 < nblocks) { bb.succ0 = ii + 1; }
            // Branch target
            let is *i32 as lbp = cast(*i32, cast(i64, label_to_bb) + cast(i64, last.dest.label) * 4);
            bb.succ1 = *lbp;
        } else if (last.op == d.IR_RET) {
            // No successors
        } else {
            // Fallthrough
            if (ii + 1 < nblocks) { bb.succ0 = ii + 1; }
        }
        ii = ii + 1;
    }

    d.opt_free(cast(*u8, inst_is_leader));
    d.opt_free(cast(*u8, inst_to_bb));
    *out_nblocks = nblocks;
}

fn build_preds(blocks as *BasicBlock, nblocks as i32,
               preds as *i32, pred_starts as *i32, pred_counts as *i32) as void {
    // Count predecessors
    let is i32 as bi with mut = 0;
    while (bi < nblocks) {
        let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, bi) * 4);
        *pcp = 0;
        bi = bi + 1;
    }
    bi = 0;
    while (bi < nblocks) {
        let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, bi) * sizeof(BasicBlock));
        if (bb.succ0 >= 0) {
            let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, bb.succ0) * 4);
            *pcp = *pcp + 1;
        }
        if (bb.succ1 >= 0) {
            let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, bb.succ1) * 4);
            *pcp = *pcp + 1;
        }
        bi = bi + 1;
    }
    // Compute starts
    let is i32 as total with mut = 0;
    bi = 0;
    while (bi < nblocks) {
        let is *i32 as psp = cast(*i32, cast(i64, pred_starts) + cast(i64, bi) * 4);
        *psp = total;
        let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, bi) * 4);
        total = total + *pcp;
        *pcp = 0; // reset for fill pass
        bi = bi + 1;
    }
    // Fill
    bi = 0;
    while (bi < nblocks) {
        let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, bi) * sizeof(BasicBlock));
        if (bb.succ0 >= 0) {
            let is i32 as s = bb.succ0;
            let is *i32 as psp = cast(*i32, cast(i64, pred_starts) + cast(i64, s) * 4);
            let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, s) * 4);
            let is *i32 as pp = cast(*i32, cast(i64, preds) + cast(i64, *psp + *pcp) * 4);
            *pp = bi;
            *pcp = *pcp + 1;
        }
        if (bb.succ1 >= 0) {
            let is i32 as s = bb.succ1;
            let is *i32 as psp = cast(*i32, cast(i64, pred_starts) + cast(i64, s) * 4);
            let is *i32 as pcp = cast(*i32, cast(i64, pred_counts) + cast(i64, s) * 4);
            let is *i32 as pp = cast(*i32, cast(i64, preds) + cast(i64, *psp + *pcp) * 4);
            *pp = bi;
            *pcp = *pcp + 1;
        }
        bi = bi + 1;
    }
}

// === Step 2: Compute reverse postorder ===

fn compute_rpo(blocks as *BasicBlock, nblocks as i32, rpo_order as *i32, out_rpo_count as *i32) as void {
    // Iterative DFS to compute reverse postorder
    let is *i32 as visited = cast(*i32, d.opt_alloc(cast(i64, nblocks) * 4));
    let is *i32 as stack = cast(*i32, d.opt_alloc(cast(i64, nblocks * 2 + 4) * 4));
    let is *i32 as stack_state = cast(*i32, d.opt_alloc(cast(i64, nblocks * 2 + 4) * 4));
    let is i32 as bi with mut = 0;
    while (bi < nblocks) {
        let is *i32 as vp = cast(*i32, cast(i64, visited) + cast(i64, bi) * 4);
        *vp = 0;
        bi = bi + 1;
    }

    let is i32 as sp with mut = 0;
    let is i32 as rpo_idx with mut = nblocks;

    // Push entry block
    let is *i32 as sp0 = cast(*i32, cast(i64, stack));
    *sp0 = 0;
    let is *i32 as ss0 = cast(*i32, cast(i64, stack_state));
    *ss0 = 0;
    let is *i32 as v0 = cast(*i32, cast(i64, visited));
    *v0 = 1;
    sp = 1;

    while (sp > 0) {
        let is i32 as top = sp - 1;
        let is *i32 as stp = cast(*i32, cast(i64, stack) + cast(i64, top) * 4);
        let is i32 as b = *stp;
        let is *i32 as ssp = cast(*i32, cast(i64, stack_state) + cast(i64, top) * 4);
        let is i32 as state = *ssp;

        let is *BasicBlock as bb = cast(*BasicBlock, cast(i64, blocks) + cast(i64, b) * sizeof(BasicBlock));

        if (state == 0) {
            // Push successors
            *ssp = 1;
            if (bb.succ1 >= 0) {
                let is *i32 as vp = cast(*i32, cast(i64, visited) + cast(i64, bb.succ1) * 4);
                if (*vp == 0) {
                    *vp = 1;
                    let is *i32 as nsp = cast(*i32, cast(i64, stack) + cast(i64, sp) * 4);
                    *nsp = bb.succ1;
                    let is *i32 as nss = cast(*i32, cast(i64, stack_state) + cast(i64, sp) * 4);
                    *nss = 0;
                    sp = sp + 1;
                }
            }
            if (bb.succ0 >= 0) {
                let is *i32 as vp = cast(*i32, cast(i64, visited) + cast(i64, bb.succ0) * 4);
                if (*vp == 0) {
                    *vp = 1;
                    let is *i32 as nsp = cast(*i32, cast(i64, stack) + cast(i64, sp) * 4);
                    *nsp = bb.succ0;
                    let is *i32 as nss = cast(*i32, cast(i64, stack_state) + cast(i64, sp) * 4);
                    *nss = 0;
                    sp = sp + 1;
                }
            }
        } else {
            // Post-visit: assign RPO number
            rpo_idx = rpo_idx - 1;
            bb.rpo = rpo_idx;
            let is *i32 as rp = cast(*i32, cast(i64, rpo_order) + cast(i64, rpo_idx) * 4);
            *rp = b;
            sp = sp - 1;
        }
    }

    *out_rpo_count = nblocks - rpo_idx;
    // Shift rpo_order to start at 0 if needed
    if (rpo_idx > 0) {
        let is i32 as ri with mut = 0;
        while (ri < nblocks - rpo_idx) {
            let is *i32 as dst = cast(*i32, cast(i64, rpo_order) + cast(i64, ri) * 4);
            let is *i32 as src = cast(*i32, cast(i64, rpo_order) + cast(i64, ri + rpo_idx) * 4);
            *dst = *src;
            ri = ri + 1;
        }
    }

    d.opt_free(cast(*u8, visited));
    d.opt_free(cast(*u8, stack));
    d.opt_free(cast(*u8, stack_state));
}
