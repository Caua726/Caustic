use "../../std/linux.cst" as linux;
use "../../std/mem.cst" as mem;
use "defs.cst" as d;
use "../parser/ast.cst" as ast;

// === Binary IR cache format ===
//
// Header (28 bytes):
//   magic(i32) version(i32) func_count(i32) global_count(i32)
//   string_count(i32) hash_lo(i32) hash_hi(i32)
//
// String pool: pool_size(i32) + pool_data(pool_size bytes)
//
// Globals: global_count * 28 bytes each
// String literals: string_count * 12 bytes each
// Functions: variable size (44-byte header + inst_count(i32) + insts)
// Instructions: 120 bytes each

let is i32 as CACHE_MAGIC   with imut = 1129337155; // 0x43495250 = "CIRP"
let is i32 as CACHE_VERSION with imut = 1;

// Per-instruction serialized size:
//   op(4) + 3*operand(20 each = 60) + line(4) + is_dead(4)
//   + asm(4+4) + call(4+4+4) + global(4+4+4) + cast(4+4+4+4) = 120
let is i32 as INST_SIZE with imut = 120;

// ===================================================================
// Write helpers
// ===================================================================

fn write_i32(buf as *u8, off as i32, val as i32) as void {
    let is *i32 as p = cast(*i32, cast(i64, buf) + cast(i64, off));
    *p = val;
}

fn write_i64(buf as *u8, off as i32, val as i64) as void {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, off));
    *p = val;
}

fn read_i32(buf as *u8, off as i32) as i32 {
    let is *i32 as p = cast(*i32, cast(i64, buf) + cast(i64, off));
    return *p;
}

fn read_i64(buf as *u8, off as i32) as i64 {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, off));
    return *p;
}

// ===================================================================
// String pool builder
// ===================================================================

fn add_to_pool(pool as *u8, pool_pos as *i32, str_ptr as *u8, str_len as i32) as i32 {
    if (str_len <= 0 || cast(i64, str_ptr) == 0) {
        return 0;
    }
    let is i32 as pos = *pool_pos;
    mem.memcpy(cast(*u8, cast(i64, pool) + cast(i64, pos)), str_ptr, cast(i64, str_len));
    *pool_pos = pos + str_len;
    return pos;
}

// ===================================================================
// Count pass: count functions, globals, strings, total pool size
// ===================================================================

fn count_pool_str(total as *i32, ptr as *u8, len as i32) as void {
    if (len > 0 && cast(i64, ptr) != 0) {
        *total = *total + len;
    }
}

fn count_all(prog as *d.IRProgram, out_fc as *i32, out_gc as *i32, out_sc as *i32, out_pool as *i32) as void {
    let is i32 as fc with mut = 0;
    let is i32 as gc with mut = 0;
    let is i32 as sc with mut = 0;
    let is i32 as pool with mut = 0;

    // Count functions and instruction strings
    let is *d.IRFunction as f with mut = prog.functions;
    while (cast(i64, f) != 0) {
        fc = fc + 1;
        count_pool_str(&pool, f.name_ptr, f.name_len);
        count_pool_str(&pool, f.asm_name_ptr, f.asm_name_len);

        let is *d.IRInst as inst with mut = f.instructions;
        while (cast(i64, inst) != 0) {
            count_pool_str(&pool, inst.asm_str_ptr, inst.asm_str_len);
            count_pool_str(&pool, inst.call_name_ptr, inst.call_name_len);
            count_pool_str(&pool, inst.global_name_ptr, inst.global_name_len);
            inst = inst.next;
        }
        f = f.next;
    }

    // Count globals
    let is *d.IRGlobal as g with mut = prog.globals;
    while (cast(i64, g) != 0) {
        gc = gc + 1;
        count_pool_str(&pool, g.name_ptr, g.name_len);
        g = g.next;
    }

    // Count string literals
    let is *d.StringEntry as s with mut = prog.strings;
    while (cast(i64, s) != 0) {
        sc = sc + 1;
        count_pool_str(&pool, s.ptr, s.len);
        s = s.next;
    }

    *out_fc = fc;
    *out_gc = gc;
    *out_sc = sc;
    *out_pool = pool;
}

// ===================================================================
// Count instructions in a function
// ===================================================================

fn count_insts(f as *d.IRFunction) as i32 {
    let is i32 as n with mut = 0;
    let is *d.IRInst as inst with mut = f.instructions;
    while (cast(i64, inst) != 0) {
        n = n + 1;
        inst = inst.next;
    }
    return n;
}

// ===================================================================
// Serialize operand (20 bytes) into buffer at offset
// ===================================================================

fn write_operand(buf as *u8, off as i32, op as *d.Operand) as void {
    write_i32(buf, off, op.op_type);
    write_i32(buf, off + 4, op.vreg);
    write_i64(buf, off + 8, op.imm);
    write_i32(buf, off + 16, op.label);
}

// ===================================================================
// write_ir_cache
// ===================================================================

fn write_ir_cache(path as *u8, prog_ptr as *u8, source_hash as i64) as i32 {
    let is *d.IRProgram as prog = cast(*d.IRProgram, prog_ptr);

    // Count everything
    let is i32 as func_count with mut = 0;
    let is i32 as global_count with mut = 0;
    let is i32 as string_count with mut = 0;
    let is i32 as pool_size with mut = 0;
    count_all(prog, &func_count, &global_count, &string_count, &pool_size);

    // Count total instructions for buffer sizing
    let is i32 as total_insts with mut = 0;
    let is *d.IRFunction as ff with mut = prog.functions;
    while (cast(i64, ff) != 0) {
        total_insts = total_insts + count_insts(ff);
        ff = ff.next;
    }

    // Calculate total buffer size
    let is i64 as buf_size =
        28                                              // header
        + 4                                             // pool_size field
        + cast(i64, pool_size)                          // pool data
        + cast(i64, global_count) * 28                  // globals
        + cast(i64, string_count) * 12                  // string literals
        + cast(i64, func_count) * 48                    // func headers (44) + inst_count (4)
        + cast(i64, total_insts) * cast(i64, INST_SIZE); // instructions

    let is *u8 as buf = mem.galloc(buf_size);
    let is i32 as pos with mut = 0;

    // --- Header (28 bytes) ---
    let is i64 as mask32 = cast(i64, 65535) * 65536 + 65535; // 0xFFFFFFFF
    let is i32 as hash_lo = cast(i32, source_hash & mask32);
    let is i32 as hash_hi = cast(i32, ((source_hash >> 16) >> 16) & mask32);

    write_i32(buf, 0, CACHE_MAGIC);
    write_i32(buf, 4, CACHE_VERSION);
    write_i32(buf, 8, func_count);
    write_i32(buf, 12, global_count);
    write_i32(buf, 16, string_count);
    write_i32(buf, 20, hash_lo);
    write_i32(buf, 24, hash_hi);
    pos = 28;

    // --- String pool ---
    write_i32(buf, pos, pool_size);
    pos = pos + 4;
    let is i32 as pool_start = pos;
    let is i32 as pool_pos with mut = 0;
    let is *u8 as pool_buf = cast(*u8, cast(i64, buf) + cast(i64, pool_start));

    // We will fill pool_buf incrementally as we write sections.
    // Advance pos past the pool region.
    pos = pos + pool_size;

    // --- Globals (28 bytes each) ---
    let is *d.IRGlobal as g with mut = prog.globals;
    while (cast(i64, g) != 0) {
        let is i32 as name_off = add_to_pool(pool_buf, &pool_pos, g.name_ptr, g.name_len);
        write_i32(buf, pos, name_off);
        write_i32(buf, pos + 4, g.name_len);
        write_i32(buf, pos + 8, g.size);
        write_i64(buf, pos + 12, g.init_value);
        write_i32(buf, pos + 20, g.is_initialized);
        write_i32(buf, pos + 24, g.is_reachable);
        pos = pos + 28;
        g = g.next;
    }

    // --- String literals (12 bytes each) ---
    let is *d.StringEntry as se with mut = prog.strings;
    while (cast(i64, se) != 0) {
        let is i32 as data_off = add_to_pool(pool_buf, &pool_pos, se.ptr, se.len);
        write_i32(buf, pos, se.id);
        write_i32(buf, pos + 4, data_off);
        write_i32(buf, pos + 8, se.len);
        pos = pos + 12;
        se = se.next;
    }

    // --- Functions ---
    let is *d.IRFunction as func with mut = prog.functions;
    while (cast(i64, func) != 0) {
        // Function header (44 bytes)
        let is i32 as fn_name_off = add_to_pool(pool_buf, &pool_pos, func.name_ptr, func.name_len);
        let is i32 as fn_asm_off = add_to_pool(pool_buf, &pool_pos, func.asm_name_ptr, func.asm_name_len);

        write_i32(buf, pos, fn_name_off);
        write_i32(buf, pos + 4, func.name_len);
        write_i32(buf, pos + 8, fn_asm_off);
        write_i32(buf, pos + 12, func.asm_name_len);
        write_i32(buf, pos + 16, func.vreg_count);
        write_i32(buf, pos + 20, func.label_count);
        write_i32(buf, pos + 24, func.is_reachable);
        write_i32(buf, pos + 28, func.alloc_stack_size);
        write_i32(buf, pos + 32, func.stack_size);
        write_i32(buf, pos + 36, func.num_args);
        write_i32(buf, pos + 40, func.is_variadic);
        pos = pos + 44;

        // Instruction count
        let is i32 as ic = count_insts(func);
        write_i32(buf, pos, ic);
        pos = pos + 4;

        // Instructions (120 bytes each)
        let is *d.IRInst as inst with mut = func.instructions;
        while (cast(i64, inst) != 0) {
            let is i32 as ip with mut = pos;

            write_i32(buf, ip, inst.op);
            ip = ip + 4;

            // dest operand (20 bytes)
            write_operand(buf, ip, &inst.dest);
            ip = ip + 20;

            // src1 operand (20 bytes)
            write_operand(buf, ip, &inst.src1);
            ip = ip + 20;

            // src2 operand (20 bytes)
            write_operand(buf, ip, &inst.src2);
            ip = ip + 20;

            // line, is_dead
            write_i32(buf, ip, inst.line);
            write_i32(buf, ip + 4, inst.is_dead);
            ip = ip + 8;

            // asm_str
            let is i32 as asm_off = add_to_pool(pool_buf, &pool_pos, inst.asm_str_ptr, inst.asm_str_len);
            write_i32(buf, ip, asm_off);
            write_i32(buf, ip + 4, inst.asm_str_len);
            ip = ip + 8;

            // call_name
            let is i32 as call_off = add_to_pool(pool_buf, &pool_pos, inst.call_name_ptr, inst.call_name_len);
            write_i32(buf, ip, call_off);
            write_i32(buf, ip + 4, inst.call_name_len);
            write_i32(buf, ip + 8, inst.is_variadic_call);
            ip = ip + 12;

            // global_name
            let is i32 as gn_off = add_to_pool(pool_buf, &pool_pos, inst.global_name_ptr, inst.global_name_len);
            write_i32(buf, ip, gn_off);
            write_i32(buf, ip + 4, inst.global_name_len);
            write_i32(buf, ip + 8, inst.is_extern_global);
            ip = ip + 12;

            // cast_to: serialize kind and size from *Type
            if (cast(i64, inst.cast_to) != 0) {
                let is *ast.Type as ct = cast(*ast.Type, inst.cast_to);
                write_i32(buf, ip, ct.kind);
                write_i32(buf, ip + 4, ct.size);
            } else {
                write_i32(buf, ip, 0);
                write_i32(buf, ip + 4, 0);
            }
            ip = ip + 8;

            // cast_from: serialize kind and size from *Type
            if (cast(i64, inst.cast_from) != 0) {
                let is *ast.Type as cf = cast(*ast.Type, inst.cast_from);
                write_i32(buf, ip, cf.kind);
                write_i32(buf, ip + 4, cf.size);
            } else {
                write_i32(buf, ip, 0);
                write_i32(buf, ip + 4, 0);
            }
            ip = ip + 8;

            pos = pos + INST_SIZE;
            inst = inst.next;
        }
        func = func.next;
    }

    // Write file
    let is i64 as fd = linux.open(path, linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC, 438);
    if (fd < 0) {
        mem.gfree(buf);
        return 1;
    }
    linux.write(fd, buf, cast(i64, pos));
    linux.close(fd);
    mem.gfree(buf);
    return 0;
}

// ===================================================================
// read_ir_cache
// ===================================================================

fn read_operand(buf as *u8, off as i32, out as *d.Operand) as void {
    out.op_type = read_i32(buf, off);
    out.vreg = read_i32(buf, off + 4);
    out.imm = read_i64(buf, off + 8);
    out.label = read_i32(buf, off + 16);
}

fn read_ir_cache(path as *u8, expected_hash as i64) as *u8 {
    // Open and read entire file
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    if (fd < 0) {
        return cast(*u8, 0);
    }

    let is i64 as file_size = linux.lseek(fd, 0, linux.SEEK_END);
    if (file_size < 28) {
        linux.close(fd);
        return cast(*u8, 0);
    }
    linux.lseek(fd, 0, linux.SEEK_SET);

    let is *u8 as buf = mem.galloc(file_size);
    let is i64 as nread = linux.read(fd, buf, file_size);
    linux.close(fd);

    if (nread != file_size) {
        mem.gfree(buf);
        return cast(*u8, 0);
    }

    // Verify header
    let is i32 as magic = read_i32(buf, 0);
    let is i32 as version = read_i32(buf, 4);
    if (magic != CACHE_MAGIC || version != CACHE_VERSION) {
        mem.gfree(buf);
        return cast(*u8, 0);
    }

    let is i32 as func_count = read_i32(buf, 8);
    let is i32 as global_count = read_i32(buf, 12);
    let is i32 as string_count = read_i32(buf, 16);
    let is i32 as hash_lo = read_i32(buf, 20);
    let is i32 as hash_hi = read_i32(buf, 24);

    // Reconstruct and verify hash (mask to avoid sign extension)
    let is i64 as lo_mask = cast(i64, 65535) * 65536 + 65535; // 0xFFFFFFFF
    let is i64 as stored_hash = (cast(i64, hash_lo) & lo_mask) + ((cast(i64, hash_hi) & lo_mask) << 32);
    if (stored_hash != expected_hash) {
        mem.gfree(buf);
        return cast(*u8, 0);
    }

    let is i32 as pos with mut = 28;

    // String pool
    let is i32 as pool_size = read_i32(buf, pos);
    pos = pos + 4;
    let is *u8 as pool = cast(*u8, cast(i64, buf) + cast(i64, pos));
    pos = pos + pool_size;

    // Allocate program
    let is *d.IRProgram as prog = d.new_irprog();

    // --- Read globals ---
    let is *d.IRGlobal as g_head with mut = cast(*d.IRGlobal, 0);
    let is *d.IRGlobal as g_tail with mut = cast(*d.IRGlobal, 0);
    let is i32 as gi with mut = 0;
    while (gi < global_count) {
        let is *d.IRGlobal as g = d.new_irglobal();

        let is i32 as name_off = read_i32(buf, pos);
        let is i32 as name_len = read_i32(buf, pos + 4);
        g.name_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, name_off)), name_len);
        g.name_len = name_len;
        g.size = read_i32(buf, pos + 8);
        g.init_value = read_i64(buf, pos + 12);
        g.is_initialized = read_i32(buf, pos + 20);
        g.is_reachable = read_i32(buf, pos + 24);
        pos = pos + 28;

        if (cast(i64, g_head) == 0) {
            g_head = g;
            g_tail = g;
        } else {
            g_tail.next = g;
            g_tail = g;
        }
        gi = gi + 1;
    }
    prog.globals = g_head;

    // --- Read string literals ---
    let is *d.StringEntry as s_head with mut = cast(*d.StringEntry, 0);
    let is *d.StringEntry as s_tail with mut = cast(*d.StringEntry, 0);
    let is i32 as si with mut = 0;
    while (si < string_count) {
        let is *d.StringEntry as se = d.new_string_entry();

        se.id = read_i32(buf, pos);
        let is i32 as data_off = read_i32(buf, pos + 4);
        let is i32 as data_len = read_i32(buf, pos + 8);
        se.ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, data_off)), data_len);
        se.len = data_len;
        pos = pos + 12;

        if (cast(i64, s_head) == 0) {
            s_head = se;
            s_tail = se;
        } else {
            s_tail.next = se;
            s_tail = se;
        }
        si = si + 1;
    }
    prog.strings = s_head;

    // --- Read functions ---
    let is *d.IRFunction as f_head with mut = cast(*d.IRFunction, 0);
    let is *d.IRFunction as f_tail with mut = cast(*d.IRFunction, 0);
    let is i32 as fi with mut = 0;
    while (fi < func_count) {
        let is *d.IRFunction as f = d.new_irfunc();

        // Function header (44 bytes)
        let is i32 as fn_name_off = read_i32(buf, pos);
        let is i32 as fn_name_len = read_i32(buf, pos + 4);
        f.name_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, fn_name_off)), fn_name_len);
        f.name_len = fn_name_len;

        let is i32 as fn_asm_off = read_i32(buf, pos + 8);
        let is i32 as fn_asm_len = read_i32(buf, pos + 12);
        f.asm_name_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, fn_asm_off)), fn_asm_len);
        f.asm_name_len = fn_asm_len;

        f.vreg_count = read_i32(buf, pos + 16);
        f.label_count = read_i32(buf, pos + 20);
        f.is_reachable = read_i32(buf, pos + 24);
        f.alloc_stack_size = read_i32(buf, pos + 28);
        f.stack_size = read_i32(buf, pos + 32);
        f.num_args = read_i32(buf, pos + 36);
        f.is_variadic = read_i32(buf, pos + 40);
        pos = pos + 44;

        // Instruction count
        let is i32 as ic = read_i32(buf, pos);
        pos = pos + 4;

        // Read instructions
        let is *d.IRInst as i_head with mut = cast(*d.IRInst, 0);
        let is *d.IRInst as i_tail with mut = cast(*d.IRInst, 0);
        let is i32 as ii with mut = 0;
        while (ii < ic) {
            let is i32 as ip with mut = pos;

            let is i32 as op = read_i32(buf, ip);
            let is *d.IRInst as inst = d.new_inst(op);
            ip = ip + 4;

            // dest
            read_operand(buf, ip, &inst.dest);
            ip = ip + 20;

            // src1
            read_operand(buf, ip, &inst.src1);
            ip = ip + 20;

            // src2
            read_operand(buf, ip, &inst.src2);
            ip = ip + 20;

            // line, is_dead
            inst.line = read_i32(buf, ip);
            inst.is_dead = read_i32(buf, ip + 4);
            ip = ip + 8;

            // asm_str
            let is i32 as asm_off = read_i32(buf, ip);
            let is i32 as asm_len = read_i32(buf, ip + 4);
            if (asm_len > 0) {
                inst.asm_str_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, asm_off)), asm_len);
                inst.asm_str_len = asm_len;
            }
            ip = ip + 8;

            // call_name
            let is i32 as cn_off = read_i32(buf, ip);
            let is i32 as cn_len = read_i32(buf, ip + 4);
            inst.is_variadic_call = read_i32(buf, ip + 8);
            if (cn_len > 0) {
                inst.call_name_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, cn_off)), cn_len);
                inst.call_name_len = cn_len;
            }
            ip = ip + 12;

            // global_name
            let is i32 as gn_off = read_i32(buf, ip);
            let is i32 as gn_len = read_i32(buf, ip + 4);
            inst.is_extern_global = read_i32(buf, ip + 8);
            if (gn_len > 0) {
                inst.global_name_ptr = d.str_dup(cast(*u8, cast(i64, pool) + cast(i64, gn_off)), gn_len);
                inst.global_name_len = gn_len;
            }
            ip = ip + 12;

            // cast_to
            let is i32 as ct_kind = read_i32(buf, ip);
            let is i32 as ct_size = read_i32(buf, ip + 4);
            if (ct_kind != 0 || ct_size != 0) {
                let is *ast.Type as ct = ast.new_type(ct_kind);
                ct.size = ct_size;
                inst.cast_to = cast(*u8, ct);
            }
            ip = ip + 8;

            // cast_from
            let is i32 as cf_kind = read_i32(buf, ip);
            let is i32 as cf_size = read_i32(buf, ip + 4);
            if (cf_kind != 0 || cf_size != 0) {
                let is *ast.Type as cf = ast.new_type(cf_kind);
                cf.size = cf_size;
                inst.cast_from = cast(*u8, cf);
            }
            ip = ip + 8;

            // Link instruction
            if (cast(i64, i_head) == 0) {
                i_head = inst;
                i_tail = inst;
            } else {
                i_tail.next = inst;
                i_tail = inst;
            }

            pos = pos + INST_SIZE;
            ii = ii + 1;
        }

        f.instructions = i_head;

        // Link function
        if (cast(i64, f_head) == 0) {
            f_head = f;
            f_tail = f;
        } else {
            f_tail.next = f;
            f_tail = f;
        }
        fi = fi + 1;
    }
    prog.functions = f_head;

    // Find main_func by scanning for name "main"
    let is *d.IRFunction as mf with mut = prog.functions;
    while (cast(i64, mf) != 0) {
        if (d.str_eq(mf.name_ptr, mf.name_len, "main", 4) == 1) {
            prog.main_func = mf;
        }
        mf = mf.next;
    }

    mem.gfree(buf);
    return cast(*u8, prog);
}
