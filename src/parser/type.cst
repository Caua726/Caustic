use "../../std/mem.cst" as mem;
use "../lexer/tokens.cst" as tok;
use "ast.cst" as ast;
use "util.cst" as pu;

fn try_primitive(ptr as *u8, len as i32) as *ast.Type {
    if (tok.streq_lit(ptr, len, "i8") == 1)     { return ast.type_i8; }
    if (tok.streq_lit(ptr, len, "i16") == 1)    { return ast.type_i16; }
    if (tok.streq_lit(ptr, len, "i32") == 1)    { return ast.type_i32; }
    if (tok.streq_lit(ptr, len, "i64") == 1)    { return ast.type_i64; }
    if (tok.streq_lit(ptr, len, "u8") == 1)     { return ast.type_u8; }
    if (tok.streq_lit(ptr, len, "u16") == 1)    { return ast.type_u16; }
    if (tok.streq_lit(ptr, len, "u32") == 1)    { return ast.type_u32; }
    if (tok.streq_lit(ptr, len, "u64") == 1)    { return ast.type_u64; }
    if (tok.streq_lit(ptr, len, "f32") == 1)    { return ast.type_f32; }
    if (tok.streq_lit(ptr, len, "f64") == 1)    { return ast.type_f64; }
    if (tok.streq_lit(ptr, len, "bool") == 1)   { return ast.type_bool; }
    if (tok.streq_lit(ptr, len, "char") == 1)   { return ast.type_char; }
    if (tok.streq_lit(ptr, len, "string") == 1) { return ast.type_string; }
    if (tok.streq_lit(ptr, len, "void") == 1)   { return ast.type_void; }
    return cast(*ast.Type, 0);
}

fn is_primitive(ptr as *u8, len as i32) as i32 {
    if (tok.streq_lit(ptr, len, "i8") == 1)     { return 1; }
    if (tok.streq_lit(ptr, len, "i16") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "i32") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "i64") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "u8") == 1)     { return 1; }
    if (tok.streq_lit(ptr, len, "u16") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "u32") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "u64") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "f32") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "f64") == 1)    { return 1; }
    if (tok.streq_lit(ptr, len, "bool") == 1)   { return 1; }
    if (tok.streq_lit(ptr, len, "char") == 1)   { return 1; }
    if (tok.streq_lit(ptr, len, "void") == 1)   { return 1; }
    return 0;
}

fn parse_type() as *ast.Type {
    if (pu.p_panic_mode == 1) { return ast.type_void; }
    // Array: [N]T
    if (pu.cur().kind == tok.TK_LBRACKET) {
        pu.advance();
        let is i64 as len = pu.cur().int_val;
        pu.advance();
        pu.expect(tok.TK_RBRACKET);
        let is *ast.Type as base = parse_type();
        let is *ast.Type as ty = ast.new_type(ast.TY_ARRAY);
        ty.base = base;
        ty.array_len = cast(i32, len);
        ty.size = cast(i32, len) * base.size;
        return ty;
    }

    // Pointer: *T
    if (pu.cur().kind == tok.TK_STAR) {
        pu.advance();
        let is *ast.Type as base = parse_type();
        let is *ast.Type as ty = ast.new_type(ast.TY_PTR);
        ty.base = base;
        ty.size = 8;
        return ty;
    }

    // Function type: fn(T1, T2, ...) as RetType
    if (pu.cur().kind == tok.TK_FN) {
        pu.advance();
        pu.expect(tok.TK_LPAREN);
        let is *ast.Type as fty = ast.new_type(ast.TY_FN);
        fty.size = 8;
        let is i32 as pcap with mut = 8;
        let is *u8 as pbuf with mut = ast.ga_alloc(pcap);
        let is i32 as pcount with mut = 0;
        if (pu.cur().kind != tok.TK_RPAREN) {
            while (1) {
                let is *ast.Type as pt = parse_type();
                if (pcount >= pcap) {
                    let is i32 as nc = pcap * 2;
                    let is *u8 as nb = ast.ga_alloc(nc);
                    mem.memcpy(nb, pbuf, cast(i64, pcount) * 8);
                    pbuf = nb; pcap = nc;
                }
                ast.ga_set(pbuf, pcount, pt);
                pcount = pcount + 1;
                if (pu.cur().kind == tok.TK_COMMA) { pu.advance(); }
                else { break; }
            }
        }
        pu.expect(tok.TK_RPAREN);
        fty.fields = pbuf;
        fty.field_count = pcount;
        if (pu.cur().kind == tok.TK_AS) {
            pu.advance();
            fty.base = parse_type();
        } else {
            fty.base = ast.type_void;
        }
        return fty;
    }

    if (pu.cur().kind != tok.TK_IDENT) {
        pu.error_expected("expected type name");
    }

    let is *u8 as name with mut = pu.cur().ptr;
    let is i32 as nlen with mut = pu.cur().len;
    let is *ast.Type as ty with mut = cast(*ast.Type, 0);

    // Module-qualified type: mod.Type (only if name is not a primitive)
    if (pu.peek().kind == tok.TK_DOT && is_primitive(name, nlen) == 0) {
        pu.advance(); // module name
        pu.advance(); // dot
        let is *u8 as tname = pu.cur().ptr;
        let is i32 as tlen = pu.cur().len;
        // Build "module.Type" string
        let is i32 as total = nlen + 1 + tlen;
        let is *u8 as full = ast.ast_alloc(cast(i64, total) + 1);
        mem.memcpy(full, name, cast(i64, nlen));
        full[nlen] = 46; // '.'
        mem.memcpy(cast(*u8, cast(i64, full) + cast(i64, nlen) + 1), tname, cast(i64, tlen));
        full[total] = cast(u8, 0);
        ty = ast.new_type(ast.TY_STRUCT);
        ty.name_ptr = full;
        ty.name_len = total;
        // Update name/nlen for generic mangling below
        name = full;
        nlen = total;
        pu.advance(); // type name
    }

    // Primitives
    if (cast(i64, ty) == 0) {
        if (tok.streq_lit(name, nlen, "i8") == 1)          { ty = ast.type_i8; }
        else if (tok.streq_lit(name, nlen, "i16") == 1)    { ty = ast.type_i16; }
        else if (tok.streq_lit(name, nlen, "i32") == 1)    { ty = ast.type_i32; }
        else if (tok.streq_lit(name, nlen, "i64") == 1)    { ty = ast.type_i64; }
        else if (tok.streq_lit(name, nlen, "u8") == 1)     { ty = ast.type_u8; }
        else if (tok.streq_lit(name, nlen, "u16") == 1)    { ty = ast.type_u16; }
        else if (tok.streq_lit(name, nlen, "u32") == 1)    { ty = ast.type_u32; }
        else if (tok.streq_lit(name, nlen, "u64") == 1)    { ty = ast.type_u64; }
        else if (tok.streq_lit(name, nlen, "f32") == 1)    { ty = ast.type_f32; }
        else if (tok.streq_lit(name, nlen, "f64") == 1)    { ty = ast.type_f64; }
        else if (tok.streq_lit(name, nlen, "bool") == 1)   { ty = ast.type_bool; }
        else if (tok.streq_lit(name, nlen, "char") == 1)   { ty = ast.type_char; }
        else if (tok.streq_lit(name, nlen, "string") == 1) { ty = ast.type_string; }
        else if (tok.streq_lit(name, nlen, "void") == 1)   { ty = ast.type_void; }
        else {
            ty = ast.new_type(ast.TY_STRUCT);
            ty.name_ptr = pu.str_dup(name, nlen);
            ty.name_len = nlen;
        }
        pu.advance();
    }

    // Generic args: Type gen i32, i64
    if (ty.kind == ast.TY_STRUCT && pu.cur().kind == tok.TK_GEN) {
        pu.advance();
        let is i32 as ga_cap with mut = 4;
        let is *u8 as ga_buf with mut = ast.ga_alloc(ga_cap);
        let is i32 as ga_count with mut = 0;
        while (1 == 1) {
            let is *ast.Type as arg = parse_type();
            if (ga_count >= ga_cap) {
                let is i32 as new_cap = ga_cap * 2;
                let is *u8 as new_buf = ast.ga_alloc(new_cap);
                mem.memcpy(new_buf, ga_buf, cast(i64, ga_count) * 8);
                ga_buf = new_buf;
                ga_cap = new_cap;
            }
            ast.ga_set(ga_buf, ga_count, arg);
            ga_count = ga_count + 1;
            if (pu.is_param_boundary() == 1) { break; }
            if (pu.eat(tok.TK_COMMA) == 0) { break; }
        }
        ty.base_name_ptr = pu.str_dup(name, nlen);
        ty.base_name_len = nlen;
        ty.gen_args = ga_buf;
        ty.gen_arg_count = ga_count;
        let is *u8 as mangled = pu.mangle_name(name, nlen, ga_buf, ga_count);
        ty.name_ptr = mangled;
        ty.name_len = pu.str_len(mangled);
    }

    return ty;
}
