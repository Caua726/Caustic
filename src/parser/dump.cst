use "../../std/linux.cst" as linux;
use "../io.cst" as io;
use "ast.cst" as ast;

fn print_str(s as *u8) as void { io.write_str(linux.STDOUT, s); }
fn write_n(s as *u8, n as i64) as void { io.write_n(linux.STDOUT, s, n); }
fn print_int(n as i64) as void { io.write_int(linux.STDOUT, n); }

fn nk_name(kind as i32) as *u8 {
    if (kind == ast.NK_NUM)       { return "NUM"; }
    if (kind == ast.NK_IDENT)     { return "IDENT"; }
    if (kind == ast.NK_STRING)    { return "STRING"; }
    if (kind == ast.NK_ADD)       { return "ADD"; }
    if (kind == ast.NK_SUB)       { return "SUB"; }
    if (kind == ast.NK_MUL)       { return "MUL"; }
    if (kind == ast.NK_DIV)       { return "DIV"; }
    if (kind == ast.NK_MOD)       { return "MOD"; }
    if (kind == ast.NK_EQ)        { return "EQ"; }
    if (kind == ast.NK_NE)        { return "NE"; }
    if (kind == ast.NK_LT)        { return "LT"; }
    if (kind == ast.NK_LE)        { return "LE"; }
    if (kind == ast.NK_GT)        { return "GT"; }
    if (kind == ast.NK_GE)        { return "GE"; }
    if (kind == ast.NK_ASSIGN)    { return "ASSIGN"; }
    if (kind == ast.NK_EXPR_STMT) { return "EXPR_STMT"; }
    if (kind == ast.NK_RETURN)    { return "RETURN"; }
    if (kind == ast.NK_FN)        { return "FN"; }
    if (kind == ast.NK_FNCALL)    { return "FNCALL"; }
    if (kind == ast.NK_BLOCK)     { return "BLOCK"; }
    if (kind == ast.NK_LET)       { return "LET"; }
    if (kind == ast.NK_IF)        { return "IF"; }
    if (kind == ast.NK_ASM)       { return "ASM"; }
    if (kind == ast.NK_WHILE)     { return "WHILE"; }
    if (kind == ast.NK_CAST)      { return "CAST"; }
    if (kind == ast.NK_ADDR)      { return "ADDR"; }
    if (kind == ast.NK_DEREF)     { return "DEREF"; }
    if (kind == ast.NK_INDEX)     { return "INDEX"; }
    if (kind == ast.NK_SYSCALL)   { return "SYSCALL"; }
    if (kind == ast.NK_MEMBER)    { return "MEMBER"; }
    if (kind == ast.NK_LAND)      { return "LAND"; }
    if (kind == ast.NK_LOR)       { return "LOR"; }
    if (kind == ast.NK_BREAK)     { return "BREAK"; }
    if (kind == ast.NK_CONTINUE)  { return "CONTINUE"; }
    if (kind == ast.NK_SHL)       { return "SHL"; }
    if (kind == ast.NK_SHR)       { return "SHR"; }
    if (kind == ast.NK_BAND)      { return "BAND"; }
    if (kind == ast.NK_BOR)       { return "BOR"; }
    if (kind == ast.NK_SIZEOF)    { return "SIZEOF"; }
    if (kind == ast.NK_USE)       { return "USE"; }
    if (kind == ast.NK_FOR)       { return "FOR"; }
    if (kind == ast.NK_DO_WHILE)  { return "DO_WHILE"; }
    if (kind == ast.NK_BXOR)      { return "BXOR"; }
    if (kind == ast.NK_BNOT)      { return "BNOT"; }
    if (kind == ast.NK_LNOT)      { return "LNOT"; }
    if (kind == ast.NK_NEG)       { return "NEG"; }
    if (kind == ast.NK_ENUM_LIT)  { return "ENUM_LIT"; }
    if (kind == ast.NK_MATCH)     { return "MATCH"; }
    if (kind == ast.NK_DEFER)     { return "DEFER"; }
    if (kind == ast.NK_FN_PTR)    { return "FN_PTR"; }
    if (kind == ast.NK_VA_START)  { return "VA_START"; }
    return "UNKNOWN";
}

fn print_type(t as *ast.Type) as void {
    if (cast(i64, t) == 0) { print_str("?"); return; }
    if (t.kind == ast.TY_VOID)   { print_str("void"); return; }
    if (t.kind == ast.TY_I8)     { print_str("i8"); return; }
    if (t.kind == ast.TY_I16)    { print_str("i16"); return; }
    if (t.kind == ast.TY_I32)    { print_str("i32"); return; }
    if (t.kind == ast.TY_I64)    { print_str("i64"); return; }
    if (t.kind == ast.TY_U8)     { print_str("u8"); return; }
    if (t.kind == ast.TY_U16)    { print_str("u16"); return; }
    if (t.kind == ast.TY_U32)    { print_str("u32"); return; }
    if (t.kind == ast.TY_U64)    { print_str("u64"); return; }
    if (t.kind == ast.TY_F32)    { print_str("f32"); return; }
    if (t.kind == ast.TY_F64)    { print_str("f64"); return; }
    if (t.kind == ast.TY_BOOL)   { print_str("bool"); return; }
    if (t.kind == ast.TY_CHAR)   { print_str("char"); return; }
    if (t.kind == ast.TY_STRING) { print_str("string"); return; }
    if (t.kind == ast.TY_PTR)    { print_str("*"); print_type(t.base); return; }
    if (t.kind == ast.TY_ARRAY) {
        print_str("["); print_int(cast(i64, t.array_len)); print_str("]");
        print_type(t.base); return;
    }
    if (t.kind == ast.TY_STRUCT && t.name_len > 0) { write_n(t.name_ptr, cast(i64, t.name_len)); return; }
    if (t.kind == ast.TY_ENUM && t.name_len > 0)   { write_n(t.name_ptr, cast(i64, t.name_len)); return; }
    print_str("?type");
}

fn print_gen_params(node as *ast.Node) as void {
    if (node.generic_param_count <= 0) { return; }
    print_str(" gen<");
    let is i32 as i with mut = 0;
    while (i < node.generic_param_count) {
        if (i > 0) { print_str(", "); }
        let is *u8 as p = ast.gp_ptr(node.generic_params, i);
        let is i32 as l = ast.gp_len(node.generic_params, i);
        write_n(p, cast(i64, l));
        i = i + 1;
    }
    print_str(">");
}

fn print_indent(depth as i32) as void {
    let is i32 as i with mut = 0;
    while (i < depth) { print_str("  "); i = i + 1; }
}

fn dump_ast(node as *ast.Node, depth as i32) as void {
    if (cast(i64, node) == 0) { return; }
    let is i32 as k = node.kind;
    print_indent(depth);
    print_str(nk_name(k));

    if (k == ast.NK_NUM) {
        if (cast(i64, node.ty) == cast(i64, ast.type_f64)) { print_str(" <float>"); }
        else { print_str(" "); print_int(node.val); }
    }
    else if (k == ast.NK_IDENT) {
        print_str(" '"); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("'");
    }
    else if (k == ast.NK_STRING) {
        print_str(" \""); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("\"");
    }
    else if (k == ast.NK_FN) {
        print_str(" '"); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("'");
        if (cast(i64, node.return_type) != 0) { print_str(" -> "); print_type(node.return_type); }
        if (node.is_extern == 1) { print_str(" extern"); }
        print_gen_params(node);
    }
    else if (k == ast.NK_FNCALL) {
        if (cast(i64, node.lhs) != 0 && cast(i64, node.lhs.name_ptr) != 0) {
            print_str(" '"); write_n(node.lhs.name_ptr, cast(i64, node.lhs.name_len)); print_str("'");
        }
    }
    else if (k == ast.NK_LET) {
        print_str(" '"); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("'");
        if (cast(i64, node.ty) != 0) { print_str(" : "); print_type(node.ty); }
        if (node.flags == ast.VF_MUT)  { print_str(" mut"); }
        if (node.flags == ast.VF_IMUT) { print_str(" imut"); }
    }
    else if (k == ast.NK_MEMBER) {
        print_str(" ."); write_n(node.member_ptr, cast(i64, node.member_len));
    }
    else if (k == ast.NK_USE) {
        print_str(" \""); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("\"");
        if (cast(i64, node.member_ptr) != 0) {
            print_str(" as "); write_n(node.member_ptr, cast(i64, node.member_len));
        }
    }
    else if (k == ast.NK_CAST)   { if (cast(i64, node.ty) != 0) { print_str(" -> "); print_type(node.ty); } }
    else if (k == ast.NK_SIZEOF) { if (cast(i64, node.ty) != 0) { print_str(" "); print_type(node.ty); } }
    else if (k == ast.NK_ASM)    { print_str(" \"...\""); }
    else if (k == ast.NK_FN_PTR) {
        if (cast(i64, node.name_ptr) != 0) {
            print_str(" '"); write_n(node.name_ptr, cast(i64, node.name_len)); print_str("'");
        }
    }
    else if (k == ast.NK_BLOCK) {
        if (cast(i64, node.ty) != 0 && node.ty.kind == ast.TY_STRUCT) {
            print_str(" struct '"); write_n(node.ty.name_ptr, cast(i64, node.ty.name_len)); print_str("'");
            print_gen_params(node);
        }
        else if (cast(i64, node.ty) != 0 && node.ty.kind == ast.TY_ENUM) {
            print_str(" enum '"); write_n(node.ty.name_ptr, cast(i64, node.ty.name_len)); print_str("'");
            print_gen_params(node);
        }
    }
    else if (k == ast.NK_MATCH) {
        print_str(" "); print_type(node.match_type);
    }
    print_str("\n");

    let is i32 as d1 = depth + 1;
    if (k == ast.NK_ADD || k == ast.NK_SUB || k == ast.NK_MUL || k == ast.NK_DIV
        || k == ast.NK_MOD || k == ast.NK_EQ || k == ast.NK_NE || k == ast.NK_LT
        || k == ast.NK_LE || k == ast.NK_GT || k == ast.NK_GE || k == ast.NK_ASSIGN
        || k == ast.NK_LAND || k == ast.NK_LOR || k == ast.NK_SHL || k == ast.NK_SHR
        || k == ast.NK_BAND || k == ast.NK_BOR || k == ast.NK_BXOR || k == ast.NK_INDEX) {
        dump_ast(node.lhs, d1); dump_ast(node.rhs, d1);
    }
    else if (k == ast.NK_ADDR || k == ast.NK_DEREF || k == ast.NK_NEG
             || k == ast.NK_LNOT || k == ast.NK_BNOT) {
        dump_ast(node.expr, d1);
    }
    else if (k == ast.NK_CAST || k == ast.NK_RETURN || k == ast.NK_EXPR_STMT || k == ast.NK_DEFER || k == ast.NK_VA_START) {
        dump_ast(node.expr, d1);
    }
    else if (k == ast.NK_LET) { dump_ast(node.init_expr, d1); }
    else if (k == ast.NK_FN) {
        let is *ast.Node as p with mut = node.params;
        while (cast(i64, p) != 0) {
            print_indent(d1); print_str("param '");
            write_n(p.name_ptr, cast(i64, p.name_len));
            print_str("' : "); print_type(p.ty); print_str("\n");
            p = p.next;
        }
        dump_ast(node.body, d1);
    }
    else if (k == ast.NK_FNCALL || k == ast.NK_SYSCALL) {
        let is *ast.Node as a with mut = node.args;
        while (cast(i64, a) != 0) { dump_ast(a, d1); a = a.next; }
    }
    else if (k == ast.NK_BLOCK) {
        let is *ast.Node as s with mut = node.stmts;
        while (cast(i64, s) != 0) { dump_ast(s, d1); s = s.next; }
    }
    else if (k == ast.NK_IF) {
        dump_ast(node.cond, d1); dump_ast(node.then_b, d1);
        if (cast(i64, node.else_b) != 0) { dump_ast(node.else_b, d1); }
    }
    else if (k == ast.NK_WHILE) { dump_ast(node.cond, d1); dump_ast(node.body, d1); }
    else if (k == ast.NK_FOR) {
        if (cast(i64, node.for_init) != 0) { dump_ast(node.for_init, d1); }
        dump_ast(node.cond, d1); dump_ast(node.for_step, d1); dump_ast(node.body, d1);
    }
    else if (k == ast.NK_DO_WHILE) { dump_ast(node.body, d1); dump_ast(node.cond, d1); }
    else if (k == ast.NK_MATCH) {
        dump_ast(node.expr, d1);
        let is *ast.Node as c with mut = node.cases;
        while (cast(i64, c) != 0) {
            print_indent(d1); print_str("case '");
            write_n(c.name_ptr, cast(i64, c.name_len));
            print_str("'");
            if (cast(i64, c.params) != 0) {
                print_str("(");
                let is *ast.Node as b with mut = c.params;
                while (cast(i64, b) != 0) {
                    write_n(b.name_ptr, cast(i64, b.name_len));
                    b = b.next;
                    if (cast(i64, b) != 0) { print_str(", "); }
                }
                print_str(")");
            }
            print_str("\n");
            dump_ast(c.body, depth + 2);
            c = c.next;
        }
        if (cast(i64, node.else_b) != 0) {
            print_indent(d1); print_str("else\n"); dump_ast(node.else_b, depth + 2);
        }
    }
    else if (k == ast.NK_MEMBER) { dump_ast(node.lhs, d1); }
}
