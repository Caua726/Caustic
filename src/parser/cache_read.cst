use "../../std/io.cst" as io;
use "../../std/mem.cst" as mem;
use "ast.cst" as ast;

// ============================================================
// Binary AST cache: serialize/deserialize the parsed AST
// Format: header + string_table + type_table + node_table
// ============================================================

let is i32 as MAGIC   with imut = 1128354883; // 0x43415354 = "CAST"
let is i32 as MAGIC_CSTI with imut = 1230263107; // 0x49545343 = "CSTI" (interface image)
let is i32 as VERSION with imut = 5;

// Serialized sizes per entry (v3 adds generic side-tables + is_imut/base_name;
// v4 adds only_start/only_count for `use ... only ...` submodule filters)
let is i32 as SER_TYPE_SIZE with imut = 64;  // 12 i32 (v2) + base_name_off/len + gp_start/ga_start
let is i32 as SER_NODE_SIZE with imut = 192; // 184 (v3) + only_start + only_count
let is i32 as HEADER_SIZE   with imut = 48;  // 32 (v2) + gp_count + ga_count + 2 reserved

// Max capacity for collection pass
let is i32 as MAX_NODES with imut = 65536;
let is i32 as MAX_TYPES with imut = 16384;

// ============================================================
// Collection state: arrays of pointers for index mapping
// ============================================================

let is *u8 as node_ptrs with mut;  // array of *Node (i64 each)
let is i32 as node_count with mut;

let is *u8 as type_ptrs with mut;  // array of *Type (i64 each)
let is i32 as type_count with mut;

// String table buffer
let is *u8 as str_buf with mut;
let is i32 as str_len with mut;
let is i32 as str_cap with mut;


fn write_i32(buf as *u8, off as i32, val as i32) as void {
    let is *i32 as p = cast(*i32, cast(i64, buf) + cast(i64, off));
    *p = val;
}

fn write_i64(buf as *u8, off as i32, val as i64) as void {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, off));
    *p = val;
}

fn read_i32(buf as *u8, off as i32) as i32 {
    let is *i32 as p = cast(*i32, cast(i64, buf) + cast(i64, off));
    return *p;
}

fn read_i64(buf as *u8, off as i32) as i64 {
    let is *i64 as p = cast(*i64, cast(i64, buf) + cast(i64, off));
    return *p;
}

fn idx_to_node(nodes as *u8, idx as i32) as *ast.Node {
    if (idx < 0) { return cast(*ast.Node, 0); }
    return cast(*ast.Node, cast(i64, nodes) + cast(i64, idx) * cast(i64, sizeof(ast.Node)));
}

fn idx_to_type(types as *u8, idx as i32) as *ast.Type {
    if (idx < 0) { return cast(*ast.Type, 0); }
    return cast(*ast.Type, cast(i64, types) + cast(i64, idx) * cast(i64, sizeof(ast.Type)));
}

fn str_tab_ptr(strtab as *u8, off as i32, slen as i32) as *u8 {
    if (slen <= 0) { return cast(*u8, 0); }
    return cast(*u8, cast(i64, strtab) + cast(i64, off));
}

// ============================================================
// Deserialize a single Type from the binary buffer
// ============================================================

fn deserialize_type(src as *u8, off as i32, t as *ast.Type, strtab as *u8, types_base as *u8) as void {
    let is i64 as base = cast(i64, src) + cast(i64, off);
    let is *u8 as b = cast(*u8, base);

    t.kind         = read_i32(b, 0);
    let is i32 as base_idx = read_i32(b, 4);
    t.base         = idx_to_type(types_base, base_idx);
    t.array_len    = read_i32(b, 8);
    let is i32 as noff = read_i32(b, 12);
    t.name_len     = read_i32(b, 16);
    t.name_ptr     = str_tab_ptr(strtab, noff, t.name_len);
    t.size         = read_i32(b, 20);
    // fields_idx handled in second pass (needs nodes)
    t.field_count  = read_i32(b, 28);
    t.variant_count = read_i32(b, 32);
    t.gen_param_count = read_i32(b, 36);
    t.gen_arg_count = read_i32(b, 40);
    t.payload_offset = read_i32(b, 44);

    // v3: base_name (for generic type refs)
    let is i32 as bnoff = read_i32(b, 48);
    t.base_name_len = read_i32(b, 52);
    t.base_name_ptr = str_tab_ptr(strtab, bnoff, t.base_name_len);

    // Cleared here; restored in second passes that need nodes / GP / GA tables.
    t.fields       = cast(*u8, 0);
    t.gen_params   = cast(*u8, 0);
    t.gen_args     = cast(*u8, 0);
    t.max_payload  = 0;
}

// ============================================================
// Deserialize a single Node from the binary buffer
// ============================================================

fn deserialize_node(src as *u8, off as i32, n as *ast.Node, strtab as *u8,
                    nodes_base as *u8, types_base as *u8) as void {
    let is i64 as base = cast(i64, src) + cast(i64, off);
    let is *u8 as b = cast(*u8, base);

    n.kind       = read_i32(b, 0);
    n.next       = idx_to_node(nodes_base, read_i32(b, 4));
    n.ty         = idx_to_type(types_base, read_i32(b, 8));
    n.tok_idx    = read_i32(b, 12);
    n.lhs        = idx_to_node(nodes_base, read_i32(b, 16));
    n.rhs        = idx_to_node(nodes_base, read_i32(b, 20));
    n.val        = read_i64(b, 24);

    // Restore fval from bitcast i64
    let is i64 as fval_bits = read_i64(b, 32);
    let is [8]u8 as fbc;
    let is *i64 as fip = cast(*i64, &fbc);
    *fip = fval_bits;
    let is *f64 as ffp = cast(*f64, &fbc);
    n.fval = *ffp;

    n.expr       = idx_to_node(nodes_base, read_i32(b, 40));
    n.init_expr  = idx_to_node(nodes_base, read_i32(b, 44));

    let is i32 as noff = read_i32(b, 48);
    n.name_len   = read_i32(b, 52);
    n.name_ptr   = str_tab_ptr(strtab, noff, n.name_len);

    let is i32 as moff = read_i32(b, 56);
    n.member_len = read_i32(b, 60);
    n.member_ptr = str_tab_ptr(strtab, moff, n.member_len);

    n.return_type = idx_to_type(types_base, read_i32(b, 64));
    n.flags      = read_i32(b, 68);
    n.body       = idx_to_node(nodes_base, read_i32(b, 72));
    n.params     = idx_to_node(nodes_base, read_i32(b, 76));
    n.is_variadic = read_i32(b, 80);
    n.is_extern  = read_i32(b, 84);

    let is i32 as ioff = read_i32(b, 88);
    let is i32 as ilen = read_i32(b, 92);
    if (ilen != 0) {
        let is *ast.Node_Extra as ie = ast.node_ensure_extra(n);
        ie.impl_len = ilen;
        ie.impl_ptr = str_tab_ptr(strtab, ioff, ilen);
    }

    n.args       = idx_to_node(nodes_base, read_i32(b, 96));
    n.generic_param_count = read_i32(b, 100);
    n.generic_arg_count   = read_i32(b, 104);
    n.stmts      = idx_to_node(nodes_base, read_i32(b, 108));
    n.cond       = idx_to_node(nodes_base, read_i32(b, 112));
    n.then_b     = idx_to_node(nodes_base, read_i32(b, 116));
    n.else_b     = idx_to_node(nodes_base, read_i32(b, 120));
    n.for_init   = idx_to_node(nodes_base, read_i32(b, 124));
    n.for_step   = idx_to_node(nodes_base, read_i32(b, 128));
    n.match_type = idx_to_type(types_base, read_i32(b, 132));
    n.cases      = idx_to_node(nodes_base, read_i32(b, 136));
    n.discriminant = read_i32(b, 140);
    n.payload_args = idx_to_node(nodes_base, read_i32(b, 144));
    n.var_offset = read_i32(b, 148);
    n.stack_size = read_i32(b, 152);
    n.is_global  = read_i32(b, 156);

    let is i32 as aoff = read_i32(b, 160);
    n.asm_name_len = read_i32(b, 164);
    n.asm_name_ptr = str_tab_ptr(strtab, aoff, n.asm_name_len);

    // v3: is_imut (separate field). generic_params/generic_args restored in the
    // second pass (they need the GP/GA side-tables + types_base).
    // v5: bit 0 = is_imut, bit 1 = is_naked.
    let is i32 as imv = read_i32(b, 168);
    if ((imv & 1) != 0) { ast.node_ensure_extra(n).is_imut = 1; }
    if ((imv & 2) != 0) { ast.node_ensure_extra(n).is_naked = 1; }
    n.generic_params = cast(*u8, 0);
    n.generic_args   = cast(*u8, 0);
    // v4: only_count (use ... only ...). only_names rebuilt in the second pass.
    let is i32 as ocv = read_i32(b, 184);
    if (ocv != 0) { ast.node_ensure_extra(n).only_count = ocv; }
}

// ============================================================
// Second pass: fixup type.fields pointers (need nodes array)
// ============================================================

fn fixup_type_fields(type_src as *u8, types_base as *u8, nodes_base as *u8,
                     tc as i32) as void {
    let is i32 as i with mut = 0;
    while (i < tc) {
        let is i32 as foff = i * SER_TYPE_SIZE + 24;
        let is i32 as fields_idx = read_i32(type_src, foff);
        let is *ast.Type as t = idx_to_type(types_base, i);
        if (fields_idx >= 0) {
            t.fields = cast(*u8, idx_to_node(nodes_base, fields_idx));
        } else {
            t.fields = cast(*u8, 0);
        }
        i = i + 1;
    }
}

// ============================================================
// Second pass (v3): rebuild the packed generic arrays from the GP/GA side-tables.
//   GP table: {str_off:i32, str_len:i32} entries (param NAMES).
//   GA table: i32 entries (type indices).
// node.generic_params / type.gen_params <- GP[start .. start+count]
// node.generic_args   / type.gen_args   <- GA[start .. start+count]
// ============================================================
fn fixup_generics(type_src as *u8, node_src as *u8, gp_base as *u8, ga_base as *u8,
                  types_base as *u8, nodes_base as *u8, strtab as *u8,
                  tc as i32, nc as i32) as void {
    // Nodes
    let is i32 as ni with mut = 0;
    while (ni < nc) {
        let is *ast.Node as n = idx_to_node(nodes_base, ni);
        let is i32 as n_gpc = read_i32(node_src, ni * SER_NODE_SIZE + 100);
        let is i32 as n_gps = read_i32(node_src, ni * SER_NODE_SIZE + 172);
        if (n_gpc > 0 && n_gps >= 0) {
            let is *u8 as n_gpbuf = ast.gp_alloc(n_gpc);
            let is i32 as nj with mut = 0;
            while (nj < n_gpc) {
                let is i32 as soff = read_i32(gp_base, (n_gps + nj) * 8);
                let is i32 as slen = read_i32(gp_base, (n_gps + nj) * 8 + 4);
                ast.gp_set(n_gpbuf, nj, str_tab_ptr(strtab, soff, slen), slen);
                nj = nj + 1;
            }
            n.generic_params = n_gpbuf;
        }
        let is i32 as n_gac = read_i32(node_src, ni * SER_NODE_SIZE + 104);
        let is i32 as n_gas = read_i32(node_src, ni * SER_NODE_SIZE + 176);
        if (n_gac > 0 && n_gas >= 0) {
            let is *u8 as n_gabuf = ast.ga_alloc(n_gac);
            let is i32 as nk with mut = 0;
            while (nk < n_gac) {
                let is i32 as tidx = read_i32(ga_base, (n_gas + nk) * 4);
                ast.ga_set(n_gabuf, nk, ast.canon_type(idx_to_type(types_base, tidx)));
                nk = nk + 1;
            }
            n.generic_args = n_gabuf;
        }
        // v4: only_names (same {ptr,len}×N layout as generic params → reuse gp_*).
        let is i32 as n_oc = read_i32(node_src, ni * SER_NODE_SIZE + 184);
        let is i32 as n_os = read_i32(node_src, ni * SER_NODE_SIZE + 180);
        if (n_oc > 0 && n_os >= 0) {
            let is *u8 as n_obuf = ast.gp_alloc(n_oc);
            let is i32 as nm with mut = 0;
            while (nm < n_oc) {
                let is i32 as osoff = read_i32(gp_base, (n_os + nm) * 8);
                let is i32 as oslen = read_i32(gp_base, (n_os + nm) * 8 + 4);
                ast.gp_set(n_obuf, nm, str_tab_ptr(strtab, osoff, oslen), oslen);
                nm = nm + 1;
            }
            ast.node_ensure_extra(n).only_names = n_obuf;
        }
        ni = ni + 1;
    }
    // Types
    let is i32 as tti with mut = 0;
    while (tti < tc) {
        let is *ast.Type as t = idx_to_type(types_base, tti);
        let is i32 as t_gpc = read_i32(type_src, tti * SER_TYPE_SIZE + 36);
        let is i32 as t_gps = read_i32(type_src, tti * SER_TYPE_SIZE + 56);
        if (t_gpc > 0 && t_gps >= 0) {
            let is *u8 as t_gpbuf = ast.gp_alloc(t_gpc);
            let is i32 as tj with mut = 0;
            while (tj < t_gpc) {
                let is i32 as soff2 = read_i32(gp_base, (t_gps + tj) * 8);
                let is i32 as slen2 = read_i32(gp_base, (t_gps + tj) * 8 + 4);
                ast.gp_set(t_gpbuf, tj, str_tab_ptr(strtab, soff2, slen2), slen2);
                tj = tj + 1;
            }
            t.gen_params = t_gpbuf;
        }
        let is i32 as t_gac = read_i32(type_src, tti * SER_TYPE_SIZE + 40);
        let is i32 as t_gas = read_i32(type_src, tti * SER_TYPE_SIZE + 60);
        if (t_gac > 0 && t_gas >= 0) {
            let is *u8 as t_gabuf = ast.ga_alloc(t_gac);
            let is i32 as tk with mut = 0;
            while (tk < t_gac) {
                let is i32 as tidx2 = read_i32(ga_base, (t_gas + tk) * 4);
                ast.ga_set(t_gabuf, tk, ast.canon_type(idx_to_type(types_base, tidx2)));
                tk = tk + 1;
            }
            t.gen_args = t_gabuf;
        }
        tti = tti + 1;
    }
}

// ============================================================
// read_ast_cache: deserialize AST from file
// Returns root node pointer or null on error/mismatch
// ============================================================

fn read_ast_cache(path as *u8, expected_hash as i64) as *ast.Node {
    return read_image(path, expected_hash, MAGIC, 1);
}

// read_csti_nocheck: load a per-module interface image (magic "CSTI") whose
// freshness is already guaranteed externally (load_module's mtime check), so the
// embedded source hash is not verified.
fn read_csti_nocheck(path as *u8) as *ast.Node {
    return read_image(path, 0, MAGIC_CSTI, 0);
}

// read_image: shared deserializer for both the AST cache (CAST) and interface
// images (CSTI). `check_hash` gates the embedded source-hash verification.
fn read_image(path as *u8, expected_hash as i64, expect_magic as i32, check_hash as i32) as *ast.Node {
    // Open file
    let is i64 as fd = io._open_read(path);
    if (fd < 0) { return cast(*ast.Node, 0); }

    // Get file size
    let is i64 as file_size = io._lseek(fd, 0, io._SEEK_END);
    if (file_size < cast(i64, HEADER_SIZE)) {
        io._close_fd(fd);
        return cast(*ast.Node, 0);
    }
    io._lseek(fd, 0, io._SEEK_SET);

    // Read entire file
    let is *u8 as data = ast.ast_alloc(file_size);
    let is i64 as nread = io._read_fd(fd, data, file_size);
    io._close_fd(fd);

    if (nread != file_size) { return cast(*ast.Node, 0); }

    // Validate header
    let is i32 as magic = read_i32(data, 0);
    if (magic != expect_magic) { return cast(*ast.Node, 0); }

    let is i32 as version = read_i32(data, 4);
    if (version != VERSION) { return cast(*ast.Node, 0); }

    let is i32 as nc = read_i32(data, 8);
    let is i32 as tc = read_i32(data, 12);
    let is i32 as stab_size = read_i32(data, 16);
    let is i32 as root_idx = read_i32(data, 20);
    let is i32 as hash_lo = read_i32(data, 24);
    let is i32 as hash_hi = read_i32(data, 28);
    let is i32 as gp_cnt = read_i32(data, 32);
    let is i32 as ga_cnt = read_i32(data, 36);

    // Reconstruct and verify hash (mask to avoid sign extension)
    let is i64 as hmask = cast(i64, 65535) * 65536 + 65535; // 0xFFFFFFFF
    let is i64 as stored_hash = (cast(i64, hash_lo) & hmask) + ((cast(i64, hash_hi) & hmask) << 32);
    if (check_hash == 1 && stored_hash != expected_hash) { return cast(*ast.Node, 0); }

    // Verify file size matches expected (incl. GP/GA side-tables)
    let is i64 as expected_size = cast(i64, HEADER_SIZE) + cast(i64, stab_size)
        + cast(i64, tc) * cast(i64, SER_TYPE_SIZE)
        + cast(i64, nc) * cast(i64, SER_NODE_SIZE)
        + cast(i64, gp_cnt) * 8 + cast(i64, ga_cnt) * 4;
    if (file_size != expected_size) { return cast(*ast.Node, 0); }

    // Pointers into the data buffer
    let is *u8 as strtab = cast(*u8, cast(i64, data) + cast(i64, HEADER_SIZE));
    let is *u8 as type_src = cast(*u8, cast(i64, strtab) + cast(i64, stab_size));
    let is *u8 as node_src = cast(*u8, cast(i64, type_src) + cast(i64, tc) * cast(i64, SER_TYPE_SIZE));
    let is *u8 as gp_base = cast(*u8, cast(i64, node_src) + cast(i64, nc) * cast(i64, SER_NODE_SIZE));
    let is *u8 as ga_base = cast(*u8, cast(i64, gp_base) + cast(i64, gp_cnt) * 8);

    // Allocate contiguous arrays for types and nodes
    let is *u8 as types_base = ast.ast_alloc(cast(i64, tc) * sizeof(ast.Type));
    let is *u8 as nodes_base = ast.ast_alloc(cast(i64, nc) * sizeof(ast.Node));

    // Zero-fill
    mem.memset(types_base, 0, cast(i64, tc) * sizeof(ast.Type));
    mem.memset(nodes_base, 0, cast(i64, nc) * sizeof(ast.Node));

    // Deserialize types (first pass: everything except fields)
    let is i32 as ti with mut = 0;
    while (ti < tc) {
        let is *ast.Type as t = idx_to_type(types_base, ti);
        deserialize_type(type_src, ti * SER_TYPE_SIZE, t, strtab, types_base);
        ti = ti + 1;
    }

    // Deserialize nodes
    let is i32 as ni with mut = 0;
    while (ni < nc) {
        let is *ast.Node as n = idx_to_node(nodes_base, ni);
        deserialize_node(node_src, ni * SER_NODE_SIZE, n, strtab, nodes_base, types_base);
        ni = ni + 1;
    }

    // Canonicalize primitive type references to the singletons. The rebuilt
    // pool holds fresh copies of primitive types, but the type system compares
    // primitives by pointer identity, so every Type reference that resolves to
    // a primitive must be folded to ast.type_<k> or semantic checks (return
    // type, void compare, implicit convert) spuriously fail.
    let is i32 as cti with mut = 0;
    while (cti < tc) {
        let is *ast.Type as ct = idx_to_type(types_base, cti);
        ct.base = ast.canon_type(ct.base);
        cti = cti + 1;
    }
    let is i32 as cni with mut = 0;
    while (cni < nc) {
        let is *ast.Node as cn = idx_to_node(nodes_base, cni);
        cn.ty = ast.canon_type(cn.ty);
        cn.return_type = ast.canon_type(cn.return_type);
        cn.match_type = ast.canon_type(cn.match_type);
        cni = cni + 1;
    }

    // Second pass: fixup type.fields pointers (needs nodes)
    fixup_type_fields(type_src, types_base, nodes_base, tc);

    // Second pass (v3): rebuild packed generic arrays from the GP/GA side-tables.
    fixup_generics(type_src, node_src, gp_base, ga_base, types_base, nodes_base, strtab, tc, nc);

    // Validate root index
    if (root_idx < 0 || root_idx >= nc) { return cast(*ast.Node, 0); }

    return idx_to_node(nodes_base, root_idx);
}

// ============================================================
// Simple hash for source file content
// ============================================================

fn hash_bytes(data as *u8, len as i64) as i64 {
    let is i64 as h with mut = 5381;
    let is i64 as i with mut = 0;
    while (i < len) {
        h = ((h << 5) + h) + cast(i64, data[i]);
        i = i + 1;
    }
    // Keep positive by masking off sign bit
    return h & cast(i64, 4611686018427387903);
}
