use "../../std/linux.cst" as linux;
use "../../std/mem.cst" as mem;
use "../lexer/tokens.cst" as tok;
use "../lexer/lexer.cst" as lex;
use "ast.cst" as ast;

let is *tok.TokenList as p_tl with mut;
let is i32 as p_pos with mut;
let is *u8 as p_src with mut;
let is i64 as p_src_len with mut;
let is *u8 as p_filename with mut;
let is i32 as p_in_params with mut;
let is i32 as p_had_error with mut;
let is i32 as p_panic_mode with mut;

fn cur() as *tok.Token { return tok.tl_get(p_tl, p_pos); }
fn peek() as *tok.Token { return tok.tl_get(p_tl, p_pos + 1); }
fn peek_n(n as i32) as *tok.Token { return tok.tl_get(p_tl, p_pos + n); }
fn advance() as void { p_pos = p_pos + 1; }

fn tok_desc(t as *tok.Token) as *u8 {
    if (t.kind == tok.TK_EOF)       { return "end of file"; }
    if (t.kind == tok.TK_INTEGER)   { return "integer"; }
    if (t.kind == tok.TK_FLOAT)     { return "float"; }
    if (t.kind == tok.TK_STRING)    { return "string literal"; }
    if (t.kind == tok.TK_CHAR)      { return "character"; }
    if (t.kind == tok.TK_SEMICOLON) { return "';'"; }
    if (t.kind == tok.TK_LPAREN)    { return "'('"; }
    if (t.kind == tok.TK_RPAREN)    { return "')'"; }
    if (t.kind == tok.TK_LBRACE)    { return "'{'"; }
    if (t.kind == tok.TK_RBRACE)    { return "'}'"; }
    if (t.kind == tok.TK_LBRACKET)  { return "'['"; }
    if (t.kind == tok.TK_RBRACKET)  { return "']'"; }
    if (t.kind == tok.TK_COMMA)     { return "','"; }
    if (t.kind == tok.TK_DOT)       { return "'.'"; }
    if (t.kind == tok.TK_EQ)        { return "'='"; }
    if (t.kind == tok.TK_ASSIGN)    { return "':='"; }
    if (t.kind == tok.TK_STAR)      { return "'*'"; }
    if (t.kind == tok.TK_PLUS)      { return "'+'"; }
    if (t.kind == tok.TK_MINUS)     { return "'-'"; }
    if (t.kind == tok.TK_AND)       { return "'&'"; }
    if (t.kind == tok.TK_FN)        { return "'fn'"; }
    if (t.kind == tok.TK_LET)       { return "'let'"; }
    if (t.kind == tok.TK_AS)        { return "'as'"; }
    if (t.kind == tok.TK_IS)        { return "'is'"; }
    if (t.kind == tok.TK_RETURN)    { return "'return'"; }
    if (t.kind == tok.TK_IF)        { return "'if'"; }
    if (t.kind == tok.TK_ELSE)      { return "'else'"; }
    if (t.kind == tok.TK_WHILE)     { return "'while'"; }
    if (t.kind == tok.TK_FOR)       { return "'for'"; }
    if (t.kind == tok.TK_STRUCT)    { return "'struct'"; }
    if (t.kind == tok.TK_ENUM)      { return "'enum'"; }
    if (t.kind == tok.TK_IMPL)      { return "'impl'"; }
    if (t.kind == tok.TK_USE)       { return "'use'"; }
    if (t.kind == tok.TK_EXTERN)    { return "'extern'"; }
    if (t.kind == tok.TK_GEN)       { return "'gen'"; }
    if (t.kind == tok.TK_MATCH)     { return "'match'"; }
    if (t.kind == tok.TK_CASE)      { return "'case'"; }
    if (t.kind == tok.TK_PLUS_EQ)   { return "'+='"; }
    if (t.kind == tok.TK_MINUS_EQ)  { return "'-='"; }
    if (t.kind == tok.TK_STAR_EQ)   { return "'*='"; }
    if (t.kind == tok.TK_SLASH_EQ)  { return "'/='"; }
    if (t.kind == tok.TK_PERCENT_EQ) { return "'%='"; }
    if (t.kind == tok.TK_SHL_EQ)    { return "'<<='"; }
    if (t.kind == tok.TK_SHR_EQ)    { return "'>>='"; }
    if (t.kind == tok.TK_AND_EQ)    { return "'&='"; }
    if (t.kind == tok.TK_OR_EQ)     { return "'|='"; }
    if (t.kind == tok.TK_XOR_EQ)    { return "'^='"; }
    if (t.kind == tok.TK_IDENT && t.len > 0) { return str_dup(t.ptr, t.len); }
    return "token";
}

// Build "expected X, found Y" message
fn err_msg(expected as *u8, found as *u8) as *u8 {
    let is i32 as elen with mut = 0;
    while (expected[elen] != 0) { elen = elen + 1; }
    let is i32 as flen with mut = 0;
    while (found[flen] != 0) { flen = flen + 1; }
    let is i32 as total = elen + 8 + flen;
    let is *u8 as buf = ast.ast_alloc(cast(i64, total) + 1);
    mem.memcpy(buf, expected, cast(i64, elen));
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, elen)), ", found ", 8);
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, elen) + 8), found, cast(i64, flen));
    buf[total] = cast(u8, 0);
    return buf;
}

fn error_tok(msg as *u8) as void {
    if (p_panic_mode == 1) { return; }
    p_panic_mode = 1;
    p_had_error = 1;
    let is *tok.Token as t = cur();
    lex.error_at_report(p_src, p_src_len, p_filename, t.line, t.col, msg);
}

fn error_expected(expected as *u8) as void {
    let is *u8 as msg = err_msg(expected, tok_desc(cur()));
    error_tok(msg);
}

fn sync_stmt() as void {
    p_panic_mode = 0;
    while (cur().kind != tok.TK_EOF) {
        if (cur().kind == tok.TK_SEMICOLON) { advance(); return; }
        if (cur().kind == tok.TK_RBRACE) { return; }
        advance();
    }
}

fn sync_toplevel() as void {
    p_panic_mode = 0;
    while (cur().kind != tok.TK_EOF) {
        if (cur().kind == tok.TK_FN) { return; }
        if (cur().kind == tok.TK_STRUCT) { return; }
        if (cur().kind == tok.TK_ENUM) { return; }
        if (cur().kind == tok.TK_LET) { return; }
        if (cur().kind == tok.TK_USE) { return; }
        if (cur().kind == tok.TK_IMPL) { return; }
        if (cur().kind == tok.TK_EXTERN) { return; }
        advance();
    }
}

fn expect(kind as i32) as void {
    if (cur().kind != kind) {
        if (kind == tok.TK_SEMICOLON)  { error_expected("expected ';'"); }
        else if (kind == tok.TK_LPAREN)   { error_expected("expected '('"); }
        else if (kind == tok.TK_RPAREN)   { error_expected("expected ')'"); }
        else if (kind == tok.TK_LBRACE)   { error_expected("expected '{'"); }
        else if (kind == tok.TK_RBRACE)   { error_expected("expected '}'"); }
        else if (kind == tok.TK_LBRACKET) { error_expected("expected '['"); }
        else if (kind == tok.TK_RBRACKET) { error_expected("expected ']'"); }
        else if (kind == tok.TK_COMMA)    { error_expected("expected ','"); }
        else if (kind == tok.TK_AS)       { error_expected("expected 'as'"); }
        else if (kind == tok.TK_IS)       { error_expected("expected 'is'"); }
        else if (kind == tok.TK_LET)      { error_expected("expected 'let'"); }
        else if (kind == tok.TK_FN)       { error_expected("expected 'fn'"); }
        else if (kind == tok.TK_EQ)       { error_expected("expected '='"); }
        else { error_expected("unexpected"); }
        return;
    }
    advance();
}

fn eat(kind as i32) as i32 {
    if (cur().kind == kind) { advance(); return 1; }
    return 0;
}

fn str_dup(ptr as *u8, len as i32) as *u8 {
    let is *u8 as buf = ast.ast_alloc(cast(i64, len) + 1);
    mem.memcpy(buf, ptr, cast(i64, len));
    buf[len] = cast(u8, 0);
    return buf;
}

fn str_len(s as *u8) as i32 {
    let is i32 as i with mut = 0;
    while (s[i] != 0) { i = i + 1; }
    return i;
}

fn type_name_str(t as *ast.Type) as *u8 {
    if (t.kind == ast.TY_I8)     { return "i8"; }
    if (t.kind == ast.TY_I16)    { return "i16"; }
    if (t.kind == ast.TY_I32)    { return "i32"; }
    if (t.kind == ast.TY_I64)    { return "i64"; }
    if (t.kind == ast.TY_U8)     { return "u8"; }
    if (t.kind == ast.TY_U16)    { return "u16"; }
    if (t.kind == ast.TY_U32)    { return "u32"; }
    if (t.kind == ast.TY_U64)    { return "u64"; }
    if (t.kind == ast.TY_F32)    { return "f32"; }
    if (t.kind == ast.TY_F64)    { return "f64"; }
    if (t.kind == ast.TY_BOOL)   { return "bool"; }
    if (t.kind == ast.TY_CHAR)   { return "char"; }
    if (t.kind == ast.TY_STRING) { return "string"; }
    if (t.kind == ast.TY_VOID)   { return "void"; }
    if (t.kind == ast.TY_PTR)    { return "ptr"; }
    if (t.kind == ast.TY_STRUCT && t.name_len > 0) { return t.name_ptr; }
    return "unknown";
}

fn mangle_name(base_ptr as *u8, base_len as i32, args as *u8, arg_count as i32) as *u8 {
    let is i32 as total with mut = base_len;
    let is i32 as i with mut = 0;
    while (i < arg_count) {
        let is *u8 as tn = type_name_str(ast.ga_get(args, i));
        total = total + 1 + str_len(tn);
        i = i + 1;
    }
    let is *u8 as buf = ast.ast_alloc(cast(i64, total) + 1);
    mem.memcpy(buf, base_ptr, cast(i64, base_len));
    let is i32 as pos with mut = base_len;
    i = 0;
    while (i < arg_count) {
        buf[pos] = 95;
        pos = pos + 1;
        let is *u8 as tn = type_name_str(ast.ga_get(args, i));
        let is i32 as tl = str_len(tn);
        mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, pos)), tn, cast(i64, tl));
        pos = pos + tl;
        i = i + 1;
    }
    buf[pos] = cast(u8, 0);
    return buf;
}

fn concat_underscore(a as *u8, alen as i32, b as *u8, blen as i32) as *u8 {
    let is i32 as total = alen + 1 + blen;
    let is *u8 as buf = ast.ast_alloc(cast(i64, total) + 1);
    mem.memcpy(buf, a, cast(i64, alen));
    buf[alen] = 95;
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, alen) + 1), b, cast(i64, blen));
    buf[total] = cast(u8, 0);
    return buf;
}

fn is_param_boundary() as i32 {
    if (p_in_params == 0) { return 0; }
    if (cur().kind != tok.TK_COMMA) { return 0; }
    if (peek().kind == tok.TK_IDENT && peek_n(2).kind == tok.TK_AS) { return 1; }
    return 0;
}

// Process string literal: strip quotes and resolve escape sequences.
// Input: ptr points to opening quote, len includes both quotes.
// Returns new buffer with processed content, sets *out_len to content length.
fn process_string(ptr as *u8, len as i32, out_len as *i32) as *u8 {
    let is *u8 as buf = ast.ast_alloc(cast(i64, len));
    let is i32 as j with mut = 0;
    let is i32 as i with mut = 1;
    let is i32 as end = len - 1;
    while (i < end) {
        if (ptr[i] == 92) {
            i = i + 1;
            if (i < end) {
                let is u8 as ec = ptr[i];
                if (ec == 110)     { buf[j] = 10; }
                else if (ec == 116) { buf[j] = 9; }
                else if (ec == 114) { buf[j] = 13; }
                else if (ec == 48)  { buf[j] = 0; }
                else if (ec == 92)  { buf[j] = 92; }
                else if (ec == 34)  { buf[j] = 34; }
                else if (ec == 39)  { buf[j] = 39; }
                else if (ec == 120) { // \xNN hex escape
                    let is u8 as hval with mut = 0;
                    let is i32 as hfound with mut = 0;
                    if (i + 1 < end) {
                        let is u8 as h1 = ptr[i + 1];
                        if (h1 >= 48 && h1 <= 57) { hval = h1 - 48; i = i + 1; hfound = 1; }
                        else if (h1 >= 97 && h1 <= 102) { hval = h1 - 87; i = i + 1; hfound = 1; }
                        else if (h1 >= 65 && h1 <= 70) { hval = h1 - 55; i = i + 1; hfound = 1; }
                    }
                    if (hfound == 1 && i + 1 < end) {
                        let is u8 as h2 = ptr[i + 1];
                        if (h2 >= 48 && h2 <= 57) { hval = hval * 16 + (h2 - 48); i = i + 1; }
                        else if (h2 >= 97 && h2 <= 102) { hval = hval * 16 + (h2 - 87); i = i + 1; }
                        else if (h2 >= 65 && h2 <= 70) { hval = hval * 16 + (h2 - 55); i = i + 1; }
                    }
                    buf[j] = hval;
                }
                else { buf[j] = ec; }
                j = j + 1;
            }
        } else {
            buf[j] = ptr[i];
            j = j + 1;
        }
        i = i + 1;
    }
    buf[j] = cast(u8, 0);
    *out_len = j;
    return buf;
}

fn is_compound_assign(kind as i32) as i32 {
    if (kind == tok.TK_PLUS_EQ) { return 1; }
    if (kind == tok.TK_MINUS_EQ) { return 1; }
    if (kind == tok.TK_STAR_EQ) { return 1; }
    if (kind == tok.TK_SLASH_EQ) { return 1; }
    if (kind == tok.TK_PERCENT_EQ) { return 1; }
    if (kind == tok.TK_SHL_EQ) { return 1; }
    if (kind == tok.TK_SHR_EQ) { return 1; }
    if (kind == tok.TK_AND_EQ) { return 1; }
    if (kind == tok.TK_OR_EQ) { return 1; }
    if (kind == tok.TK_XOR_EQ) { return 1; }
    return 0;
}

fn compound_to_binop(kind as i32) as i32 {
    if (kind == tok.TK_PLUS_EQ) { return ast.NK_ADD; }
    if (kind == tok.TK_MINUS_EQ) { return ast.NK_SUB; }
    if (kind == tok.TK_STAR_EQ) { return ast.NK_MUL; }
    if (kind == tok.TK_SLASH_EQ) { return ast.NK_DIV; }
    if (kind == tok.TK_PERCENT_EQ) { return ast.NK_MOD; }
    if (kind == tok.TK_SHL_EQ) { return ast.NK_SHL; }
    if (kind == tok.TK_SHR_EQ) { return ast.NK_SHR; }
    if (kind == tok.TK_AND_EQ) { return ast.NK_BAND; }
    if (kind == tok.TK_OR_EQ) { return ast.NK_BOR; }
    if (kind == tok.TK_XOR_EQ) { return ast.NK_BXOR; }
    return ast.NK_ADD;
}
