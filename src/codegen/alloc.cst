use "../../std/mem.cst" as mem;
use "../ir/defs.cst" as d;

// === Register allocator structs ===

struct LiveInterval {
    vreg as i32;
    start as i32;
    end_pos as i32;
    reg as i32;
    spill_loc as i32;
    use_count as i32;
    spill_cost as i32;
}

struct AllocCtx {
    intervals as *LiveInterval;
    count as i32;
    vreg_to_loc as *i32;
    stack_slots as i32;
    next_spill as i32;
    is_leaf as i32;
    arg_spill_base as i32;
    aligned_stack_size as i32;
    func as *u8;
    va_save_offset as i32;
}

let is i32 as INT_MAX with imut = 2147483647;

fn memzero(p as *u8, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) { p[i] = cast(u8, 0); i = i + 1; }
}

fn new_alloc_ctx() as *AllocCtx {
    let is *AllocCtx as c = cast(*AllocCtx, mem.galloc(sizeof(AllocCtx)));
    memzero(cast(*u8, c), sizeof(AllocCtx));
    return c;
}

// === build_intervals ===

fn build_intervals(func as *d.IRFunction, ctx as *AllocCtx) as void {
    let is i32 as vc = func.vreg_count;
    ctx.intervals = cast(*LiveInterval, mem.galloc(cast(i64, vc) * sizeof(LiveInterval)));
    ctx.count = vc;
    let is i32 as i with mut = 0;
    while (i < vc) {
        let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, i) * sizeof(LiveInterval));
        iv.vreg = i;
        iv.start = INT_MAX;
        iv.end_pos = cast(i32, 0 - 1);
        iv.reg = cast(i32, 0 - 1);
        iv.spill_loc = cast(i32, 0 - 1);
        iv.use_count = 0;
        iv.spill_cost = 0;
        i = i + 1;
    }
    // Map labels to positions
    let is i32 as lc = func.label_count + 1;
    let is *i32 as label_pos = cast(*i32, mem.galloc(cast(i64, lc) * 4));
    memzero(cast(*u8, label_pos), cast(i64, lc) * 4);
    let is i32 as pos with mut = 0;
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.op == d.IR_LABEL) {
            let is *i32 as lp = cast(*i32, cast(i64, label_pos) + cast(i64, inst.dest.label) * 4);
            *lp = pos;
        }
        pos = pos + 1;
        inst = inst.next;
    }
    // Scan instructions
    pos = 0;
    inst = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.src1.op_type == d.OP_VREG) {
            let is i32 as v = inst.src1.vreg;
            let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, v) * sizeof(LiveInterval));
            if (iv.start > pos) { iv.start = pos; }
            iv.end_pos = pos;
            iv.use_count = iv.use_count + 1;
            iv.spill_cost = iv.spill_cost + 10;
        }
        if (inst.src2.op_type == d.OP_VREG) {
            let is i32 as v = inst.src2.vreg;
            let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, v) * sizeof(LiveInterval));
            if (iv.start > pos) { iv.start = pos; }
            iv.end_pos = pos;
            iv.use_count = iv.use_count + 1;
            iv.spill_cost = iv.spill_cost + 10;
        }
        if (inst.dest.op_type == d.OP_VREG) {
            let is i32 as v = inst.dest.vreg;
            let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, v) * sizeof(LiveInterval));
            if (iv.start > pos) { iv.start = pos; }
            iv.end_pos = pos;
            iv.spill_cost = iv.spill_cost + 1;
        }
        // Extend intervals for backward jumps (loops)
        if (inst.op == d.IR_JMP || inst.op == d.IR_JZ || inst.op == d.IR_JNZ) {
            let is *i32 as lp = cast(*i32, cast(i64, label_pos) + cast(i64, inst.dest.label) * 4);
            let is i32 as target_pos = *lp;
            if (target_pos <= pos) {
                let is i32 as v with mut = 0;
                while (v < vc) {
                    let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, v) * sizeof(LiveInterval));
                    if (iv.start != INT_MAX && iv.start < pos && iv.end_pos >= target_pos) {
                        if (iv.start > target_pos) { iv.start = target_pos; }
                        if (iv.end_pos < pos) { iv.end_pos = pos; }
                    }
                    v = v + 1;
                }
            }
        }
        pos = pos + 1;
        inst = inst.next;
    }
    // Compute spill costs
    i = 0;
    while (i < vc) {
        let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, i) * sizeof(LiveInterval));
        if (iv.use_count > 0) {
            let is i32 as span = iv.end_pos - iv.start + 1;
            if (span > 0) {
                iv.spill_cost = iv.spill_cost * 100 / span;
            }
        }
        i = i + 1;
    }
    // Insertion sort by start position
    i = 1;
    while (i < vc) {
        let is LiveInterval as key;
        mem.memcpy(cast(*u8, &key), cast(*u8, cast(i64, ctx.intervals) + cast(i64, i) * sizeof(LiveInterval)), sizeof(LiveInterval));
        let is i32 as j with mut = i - 1;
        let is i32 as sort_done with mut = 0;
        while (j >= 0 && sort_done == 0) {
            let is *LiveInterval as jv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, j) * sizeof(LiveInterval));
            if (jv.start > key.start || (jv.start == key.start && jv.end_pos > key.end_pos)) {
                // Move j to j+1
                let is *LiveInterval as jv1 = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, j + 1) * sizeof(LiveInterval));
                mem.memcpy(cast(*u8, jv1), cast(*u8, jv), sizeof(LiveInterval));
                j = j - 1;
            } else {
                sort_done = 1;
            }
        }
        let is i32 as ins_pos = j + 1;
        let is *LiveInterval as dst = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, ins_pos) * sizeof(LiveInterval));
        mem.memcpy(cast(*u8, dst), cast(*u8, &key), sizeof(LiveInterval));
        i = i + 1;
    }
}

// === linear_scan_alloc ===
// Callee-saved regs for allocation: rbx(3), r12(10), r13(11)
// r14 and r15 reserved as scratch

fn find_free_reg(ctx as *AllocCtx, pos as i32) as i32 {
    // Try rbx(3), r12(10), r13(11)
    let is [3]i32 as allowed;
    allowed[0] = 3;
    allowed[1] = 10;
    allowed[2] = 11;
    let is i32 as ki with mut = 0;
    while (ki < 3) {
        let is i32 as ri = allowed[ki];
        // Check if reg is free: vreg_to_loc has no one mapped to ri currently alive
        // We use a simpler approach: scan active intervals
        let is i32 as in_use with mut = 0;
        let is i32 as ii with mut = 0;
        while (ii < ctx.count) {
            let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, ii) * sizeof(LiveInterval));
            if (iv.reg == ri && iv.end_pos >= pos && iv.start <= pos) {
                in_use = 1;
            }
            ii = ii + 1;
        }
        if (in_use == 0) { return ri; }
        ki = ki + 1;
    }
    return cast(i32, 0 - 1);
}

fn spill_register(ctx as *AllocCtx, pos as i32) as i32 {
    // Find interval in rbx/r12/r13 with latest end_pos to spill
    let is i32 as victim_reg with mut = cast(i32, 0 - 1);
    let is i32 as victim_idx with mut = cast(i32, 0 - 1);
    let is i32 as max_end with mut = cast(i32, 0 - 1);
    let is [3]i32 as allowed;
    allowed[0] = 3;
    allowed[1] = 10;
    allowed[2] = 11;
    let is i32 as ki with mut = 0;
    while (ki < 3) {
        let is i32 as ri = allowed[ki];
        let is i32 as ii with mut = 0;
        while (ii < ctx.count) {
            let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, ii) * sizeof(LiveInterval));
            if (iv.reg == ri && iv.end_pos >= pos) {
                if (iv.end_pos > max_end) {
                    max_end = iv.end_pos;
                    victim_reg = ri;
                    victim_idx = ii;
                }
            }
            ii = ii + 1;
        }
        ki = ki + 1;
    }
    if (victim_idx >= 0) {
        let is *LiveInterval as viv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, victim_idx) * sizeof(LiveInterval));
        let is i32 as v = viv.vreg;
        let is i32 as spill = ctx.next_spill;
        ctx.next_spill = ctx.next_spill + 1;
        let is *i32 as vp = cast(*i32, cast(i64, ctx.vreg_to_loc) + cast(i64, v) * 4);
        *vp = 0 - spill;
        viv.reg = cast(i32, 0 - 1);
        return victim_reg;
    }
    return cast(i32, 0 - 1);
}

fn linear_scan_alloc(func as *d.IRFunction, ctx as *AllocCtx) as void {
    let is i32 as vc = func.vreg_count;
    ctx.vreg_to_loc = cast(*i32, mem.galloc(cast(i64, vc) * 4));
    let is i32 as i with mut = 0;
    while (i < vc) {
        let is *i32 as vp = cast(*i32, cast(i64, ctx.vreg_to_loc) + cast(i64, i) * 4);
        *vp = cast(i32, 0 - 1000);
        i = i + 1;
    }
    i = 0;
    while (i < ctx.count) {
        let is *LiveInterval as iv = cast(*LiveInterval, cast(i64, ctx.intervals) + cast(i64, i) * sizeof(LiveInterval));
        if (iv.start == INT_MAX) { i = i + 1; }
        else {
            let is i32 as reg with mut = find_free_reg(ctx, iv.start);
            if (reg == cast(i32, 0 - 1)) {
                reg = spill_register(ctx, iv.start);
            }
            if (reg != cast(i32, 0 - 1)) {
                iv.reg = reg;
                let is *i32 as vp = cast(*i32, cast(i64, ctx.vreg_to_loc) + cast(i64, iv.vreg) * 4);
                *vp = reg;
            } else {
                let is i32 as spill = ctx.next_spill;
                ctx.next_spill = ctx.next_spill + 1;
                let is *i32 as vp = cast(*i32, cast(i64, ctx.vreg_to_loc) + cast(i64, iv.vreg) * 4);
                *vp = 0 - spill;
                iv.spill_loc = spill;
            }
            i = i + 1;
        }
    }
    ctx.stack_slots = ctx.next_spill - 1;
}

// === get_operand_loc ===
// Returns: >= 0 = register index, < 0 = memory (offset = -loc * 8)

fn get_loc(vreg as i32, ctx as *AllocCtx) as i32 {
    let is *i32 as vp = cast(*i32, cast(i64, ctx.vreg_to_loc) + cast(i64, vreg) * 4);
    return *vp;
}

fn is_mem(vreg as i32, ctx as *AllocCtx) as i32 {
    if (get_loc(vreg, ctx) < 0) { return 1; }
    return 0;
}
