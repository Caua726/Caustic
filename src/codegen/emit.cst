use "../../std/mem.cst" as mem;
use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "../parser/ast.cst" as ast;
use "../ir/defs.cst" as d;
use "alloc.cst" as al;

// === Output buffer ===
let is *u8 as out_buf with mut;
let is i64 as out_len with mut;
let is i64 as out_cap with mut;
let is i32 as out_fd with mut;

// === Debug info ===
let is *u8 as cg_filename with mut;
let is i32 as cg_filename_len with mut;

// === Register cache: track which phys reg holds which spilled vreg ===
// rc_vreg[reg_idx] = vreg currently cached in that register (99999 = empty)
// Only tracks SPILLED vregs (register-allocated vregs don't need caching).
let is [16]i32 as rc_vreg with mut;

fn rc_init() as void {
    let is i32 as i with mut = 0;
    while (i < 16) { rc_vreg[i] = 99999; i = i + 1; }
}

fn ph_invalidate() as void {
    let is i32 as i with mut = 0;
    while (i < 16) { rc_vreg[i] = 99999; i = i + 1; }
}

// Invalidate a specific register (e.g., when it's overwritten)
fn rc_invalidate_reg(idx as i32) as void {
    if (idx >= 0 && idx < 16) { rc_vreg[idx] = 99999; }
}

// Record that phys reg idx now holds spilled vreg
fn rc_set(idx as i32, vreg as i32) as void {
    if (idx >= 0 && idx < 16) { rc_vreg[idx] = vreg; }
}

// Find which register holds a given vreg. Returns reg idx or -1.
fn rc_find(vreg as i32) as i32 {
    let is i32 as i with mut = 0;
    while (i < 16) {
        if (rc_vreg[i] == vreg) { return i; }
        i = i + 1;
    }
    return cast(i32, 0 - 1);
}

// Invalidate all entries for a vreg (when it's redefined)
fn rc_invalidate_vreg(vreg as i32) as void {
    let is i32 as i with mut = 0;
    while (i < 16) {
        if (rc_vreg[i] == vreg) { rc_vreg[i] = 99999; }
        i = i + 1;
    }
}

fn reg_name_to_idx(name as *u8) as i32 {
    if (name[0] == 114) {
        // r...
        if (name[1] == 97) { return 0; } // rax
        if (name[1] == 99) { return 1; } // rcx
        if (name[1] == 100 && name[2] == 105) { return 5; } // rdi (check before rdx!)
        if (name[1] == 100) { return 2; } // rdx
        if (name[1] == 98) { return 3; } // rbx
        if (name[1] == 115) { return 4; } // rsi
        if (name[1] == 49 && name[2] == 53) { return 15; } // r15
        if (name[1] == 49 && name[2] == 52) { return 12; } // r14 → idx 12
        if (name[1] == 49 && name[2] == 51) { return 11; } // r13 → idx 11
        if (name[1] == 49 && name[2] == 50) { return 10; } // r12 → idx 10
        if (name[1] == 49 && name[2] == 49) { return 9; } // r11 → idx 9
        if (name[1] == 49 && name[2] == 48) { return 8; } // r10 → idx 8
        if (name[1] == 56) { return 6; }  // r8 → idx 6
        if (name[1] == 57) { return 7; }  // r9 → idx 7
    }
    return 99999;
}

// === Per-function profiling ===
// Each entry: name_ptr(8) + name_len(4) + vregs(4) + time_us(8) = 24 bytes
let is i64 as cg_prof_buf with mut = 0;   // ptr to buffer
let is i32 as cg_prof_count with mut = 0;
let is i32 as cg_prof_max with mut = 0;
let is i32 as cg_prof_enabled with mut = 0;

fn cg_prof_init(max_entries as i32) as void {
    cg_prof_buf = cast(i64, mem.galloc(cast(i64, max_entries) * 24));
    cg_prof_count = 0;
    cg_prof_max = max_entries;
    cg_prof_enabled = 1;
}

fn cg_prof_get_time_us() as i64 {
    let is [2]i64 as ts;
    syscall(228, 1, &ts);
    return ts[0] * 1000000 + ts[1] / 1000;
}

fn cg_prof_record(name_ptr as *u8, name_len as i32, vregs as i32, time_us as i64) as void {
    if (cg_prof_count >= cg_prof_max) { return; }
    let is i64 as off = cast(i64, cg_prof_count) * 24;
    let is *i64 as p0 = cast(*i64, cg_prof_buf + off);
    *p0 = cast(i64, name_ptr);
    let is *i32 as p1 = cast(*i32, cg_prof_buf + off + 8);
    *p1 = name_len;
    let is *i32 as p2 = cast(*i32, cg_prof_buf + off + 12);
    *p2 = vregs;
    let is *i64 as p3 = cast(*i64, cg_prof_buf + off + 16);
    *p3 = time_us;
    cg_prof_count = cg_prof_count + 1;
}

fn out_init(fd as i32) as void {
    out_cap = 4194304; // 4MB
    out_buf = mem.galloc(out_cap);
    out_len = 0;
    out_fd = fd;
}

fn out_flush() as void {
    if (out_len > 0) {
        linux.write(cast(i64, out_fd), out_buf, out_len);
        out_len = 0;
    }
}

fn out_ensure(n as i64) as void {
    if (out_len + n >= out_cap) {
        out_flush();
    }
}

fn out_char(c as u8) as void {
    out_ensure(1);
    out_buf[out_len] = c;
    out_len = out_len + 1;
}

fn out_str(s as *u8, n as i32) as void {
    out_ensure(cast(i64, n));
    mem.memcpy(cast(*u8, cast(i64, out_buf) + out_len), s, cast(i64, n));
    out_len = out_len + cast(i64, n);
}

fn out_cstr(s as *u8) as void {
    let is i32 as i with mut = 0;
    while (s[i] != 0) { i = i + 1; }
    out_str(s, i);
}

fn out_int(n as i64) as void {
    if (n == 0) { out_char(48); return; }
    let is i64 as val with mut = n;
    let is i32 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is [24]u8 as buf;
    let is i32 as pos with mut = 23;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    if (neg == 1) { buf[pos] = 45; pos = pos - 1; }
    out_str(cast(*u8, cast(i64, &buf) + cast(i64, pos) + 1), 23 - pos);
}

fn out_line(s as *u8) as void {
    out_cstr("  ");
    out_cstr(s);
    out_char(10);
}

fn out_line2(a as *u8, b as *u8) as void {
    out_cstr("  ");
    out_cstr(a);
    out_cstr(b);
    out_char(10);
}

fn out_line3(a as *u8, b as *u8, c as *u8) as void {
    out_cstr("  ");
    out_cstr(a);
    out_cstr(b);
    out_cstr(c);
    out_char(10);
}

// === Register name tables ===
// regs[0..11] = rax,rcx,rdx,rbx,rsi,rdi,r8,r9,r10,r11,r12,r13

fn reg64(idx as i32) as *u8 {
    if (idx == 0) { return "rax"; }
    if (idx == 1) { return "rcx"; }
    if (idx == 2) { return "rdx"; }
    if (idx == 3) { return "rbx"; }
    if (idx == 4) { return "rsi"; }
    if (idx == 5) { return "rdi"; }
    if (idx == 6) { return "r8"; }
    if (idx == 7) { return "r9"; }
    if (idx == 8) { return "r10"; }
    if (idx == 9) { return "r11"; }
    if (idx == 10) { return "r12"; }
    if (idx == 11) { return "r13"; }
    if (idx == 12) { return "r14"; }
    if (idx == 15) { return "r15"; }
    return "rax";
}

fn reg32(idx as i32) as *u8 {
    if (idx == 0) { return "eax"; }
    if (idx == 1) { return "ecx"; }
    if (idx == 2) { return "edx"; }
    if (idx == 3) { return "ebx"; }
    if (idx == 4) { return "esi"; }
    if (idx == 5) { return "edi"; }
    if (idx == 6) { return "r8d"; }
    if (idx == 7) { return "r9d"; }
    if (idx == 8) { return "r10d"; }
    if (idx == 9) { return "r11d"; }
    if (idx == 10) { return "r12d"; }
    if (idx == 11) { return "r13d"; }
    if (idx == 12) { return "r14d"; }
    if (idx == 15) { return "r15d"; }
    return "eax";
}

fn reg16(idx as i32) as *u8 {
    if (idx == 0) { return "ax"; }
    if (idx == 1) { return "cx"; }
    if (idx == 2) { return "dx"; }
    if (idx == 3) { return "bx"; }
    if (idx == 4) { return "si"; }
    if (idx == 5) { return "di"; }
    if (idx == 6) { return "r8w"; }
    if (idx == 7) { return "r9w"; }
    if (idx == 8) { return "r10w"; }
    if (idx == 9) { return "r11w"; }
    if (idx == 10) { return "r12w"; }
    if (idx == 11) { return "r13w"; }
    if (idx == 12) { return "r14w"; }
    if (idx == 15) { return "r15w"; }
    return "ax";
}

fn reg8(idx as i32) as *u8 {
    if (idx == 0) { return "al"; }
    if (idx == 1) { return "cl"; }
    if (idx == 2) { return "dl"; }
    if (idx == 3) { return "bl"; }
    if (idx == 4) { return "sil"; }
    if (idx == 5) { return "dil"; }
    if (idx == 6) { return "r8b"; }
    if (idx == 7) { return "r9b"; }
    if (idx == 8) { return "r10b"; }
    if (idx == 9) { return "r11b"; }
    if (idx == 10) { return "r12b"; }
    if (idx == 11) { return "r13b"; }
    if (idx == 12) { return "r14b"; }
    if (idx == 15) { return "r15b"; }
    return "al";
}

fn arg_reg64(idx as i32) as *u8 {
    if (idx == 0) { return "rdi"; }
    if (idx == 1) { return "rsi"; }
    if (idx == 2) { return "rdx"; }
    if (idx == 3) { return "rcx"; }
    if (idx == 4) { return "r8"; }
    if (idx == 5) { return "r9"; }
    return "rax";
}

fn syscall_reg(idx as i32) as *u8 {
    if (idx == 0) { return "rax"; }
    if (idx == 1) { return "rdi"; }
    if (idx == 2) { return "rsi"; }
    if (idx == 3) { return "rdx"; }
    if (idx == 4) { return "r10"; }
    if (idx == 5) { return "r8"; }
    if (idx == 6) { return "r9"; }
    return "rax";
}

// === Operand helpers ===

// get_scratch: if dest vreg is in a register, return that register name.
// If dest is spilled, return "rax" as scratch (caller must store_op after).
fn get_scratch(vreg as i32, ctx as *al.AllocCtx) as *u8 {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) { return reg64(loc); }
    return "rax";
}

// Returns register index for scratch: dest's phys reg, or 0 (rax) if spilled.
fn get_scratch_idx(vreg as i32, ctx as *al.AllocCtx) as i32 {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) { return loc; }
    return 0;
}

// load vreg value into target register

fn load_op(vreg as i32, ctx as *al.AllocCtx, target as *u8) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        let is *u8 as rn = reg64(loc);
        if (cast(i64, rn) != cast(i64, target)) {
            out_cstr("  mov ");
            out_cstr(target);
            out_cstr(", ");
            out_cstr(rn);
            out_char(10);
        }
        if (al.al_opt_level >= 1) {
            rc_invalidate_reg(reg_name_to_idx(target));
        }
    } else {
        if (al.al_opt_level >= 1) {
            // Spilled vreg: check register cache
            let is i32 as tidx = reg_name_to_idx(target);
            let is i32 as cached = rc_find(vreg);
            if (cached >= 0) {
                if (cached == tidx) { return; }
                out_cstr("  mov ");
                out_cstr(target);
                out_cstr(", ");
                out_cstr(reg64(cached));
                out_char(10);
                rc_set(tidx, vreg);
                return;
            }
            let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
            out_cstr("  mov ");
            out_cstr(target);
            out_cstr(", QWORD PTR [rbp-");
            out_int(off);
            out_cstr("]\n");
            rc_set(tidx, vreg);
        } else {
            let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
            out_cstr("  mov ");
            out_cstr(target);
            out_cstr(", QWORD PTR [rbp-");
            out_int(off);
            out_cstr("]\n");
        }
    }
}

fn store_op(vreg as i32, ctx as *al.AllocCtx, source as *u8) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        let is *u8 as rn = reg64(loc);
        if (cast(i64, rn) != cast(i64, source)) {
            out_cstr("  mov ");
            out_cstr(rn);
            out_cstr(", ");
            out_cstr(source);
            out_char(10);
        }
        if (al.al_opt_level >= 1) {
            let is i32 as sidx = reg_name_to_idx(source);
            rc_invalidate_reg(sidx);
            rc_invalidate_reg(loc);
        }
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        out_cstr("  mov QWORD PTR [rbp-");
        out_int(off);
        out_cstr("], ");
        out_cstr(source);
        out_char(10);
        if (al.al_opt_level >= 1) {
            rc_invalidate_vreg(vreg);
            rc_set(reg_name_to_idx(source), vreg);
        }
    }
}

// Emit operand inline: register name or QWORD PTR [rbp-offset]
fn emit_op(vreg as i32, ctx as *al.AllocCtx) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        out_cstr(reg64(loc));
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        out_cstr("QWORD PTR [rbp-");
        out_int(off);
        out_cstr("]");
    }
}

// Emit src2 operand: either immediate or register/memory
fn emit_src2(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    if (inst.src2.op_type == d.OP_IMM) {
        out_int(inst.src2.imm);
    } else {
        emit_op(inst.src2.vreg, ctx);
    }
}

// Emit "  mov DST_LOC, IMM" handling 64-bit large immediates
fn emit_mov_imm(vreg as i32, ctx as *al.AllocCtx, val as i64) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    let is i32 as is_large with mut = 0;
    if (val > 2147483647 || val < 0 - 2147483647) { is_large = 1; }
    if (loc >= 0) {
        if (is_large == 1) {
            out_cstr("  mov ");
            out_cstr(reg64(loc));
            out_cstr(", ");
            out_int(val);
            out_char(10);
        } else {
            out_cstr("  mov ");
            out_cstr(reg64(loc));
            out_cstr(", ");
            out_int(val);
            out_char(10);
        }
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        if (is_large == 1) {
            out_cstr("  mov rax, ");
            out_int(val);
            out_char(10);
            out_cstr("  mov QWORD PTR [rbp-");
            out_int(off);
            out_cstr("], rax\n");
        } else {
            out_cstr("  mov QWORD PTR [rbp-");
            out_int(off);
            out_cstr("], ");
            out_int(val);
            out_char(10);
        }
    }
}

fn get_type_size(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 8; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    return ty.size;
}

fn is_signed_type(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 1; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    let is i32 as k = ty.kind;
    if (k == ast.TY_I8 || k == ast.TY_I16 || k == ast.TY_I32 || k == ast.TY_I64) { return 1; }
    if (k == ast.TY_CHAR) { return 0; }
    return 0;
}

fn is_float_type(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 0; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    if (ty.kind == ast.TY_F32 || ty.kind == ast.TY_F64) { return 1; }
    return 0;
}

// Helper: emit binary op using dest register directly when possible
fn gen_binop(inst as *d.IRInst, ctx as *al.AllocCtx, op_name as *u8) as void {
    let is i32 as dest_loc = al.get_loc(inst.dest.vreg, ctx);
    if (dest_loc >= 0) {
        let is i32 as conflict with mut = 0;
        if (inst.src2.op_type == d.OP_VREG) {
            if (al.get_loc(inst.src2.vreg, ctx) == dest_loc) { conflict = 1; }
        }
        if (conflict == 0) {
            let is *u8 as dr = reg64(dest_loc);
            load_op(inst.src1.vreg, ctx, dr);
            out_cstr("  ");
            out_cstr(op_name);
            out_cstr(" ");
            out_cstr(dr);
            out_cstr(", ");
            emit_src2(inst, ctx);
            out_char(10);
            // The op just clobbered dr — clear any stale cache entry
            // (load_op may have set rc_set(dest_loc, src1.vreg) above)
            if (al.al_opt_level >= 1) { rc_invalidate_reg(dest_loc); }
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            out_cstr("  ");
            out_cstr(op_name);
            out_cstr(" rax, ");
            out_cstr(reg64(dest_loc));
            out_char(10);
            store_op(inst.dest.vreg, ctx, "rax");
        }
    } else {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        out_cstr("  ");
        out_cstr(op_name);
        out_cstr(" ");
        out_cstr(scr);
        out_cstr(", ");
        emit_src2(inst, ctx);
        out_char(10);
        store_op(inst.dest.vreg, ctx, scr);
    }
}

// === gen_inst: IMM, MOV ===

fn gen_inst_imm_mov(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_IMM) {
        emit_mov_imm(inst.dest.vreg, ctx, inst.src1.imm);
        return;
    }
    // IR_MOV
    let is i32 as dloc = al.get_loc(inst.dest.vreg, ctx);
    if (dloc >= 0) {
        load_op(inst.src1.vreg, ctx, reg64(dloc));
    } else {
        let is i32 as sloc = al.get_loc(inst.src1.vreg, ctx);
        if (sloc >= 0) {
            store_op(inst.dest.vreg, ctx, reg64(sloc));
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            store_op(inst.dest.vreg, ctx, "rax");
        }
    }
}

// === gen_inst: ADD, SUB, MUL, DIV, MOD, NEG ===

fn gen_inst_arith(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADD) { gen_binop(inst, ctx, "add"); return; }
    if (op == d.IR_SUB) { gen_binop(inst, ctx, "sub"); return; }
    if (op == d.IR_MUL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        if (inst.src2.op_type == d.OP_IMM) {
            load_op(inst.src1.vreg, ctx, scr);
            out_cstr("  mov rcx, ");
            out_int(inst.src2.imm);
            out_char(10);
            out_cstr("  imul "); out_cstr(scr); out_cstr(", rcx\n");
        } else if (al.is_mem(inst.src2.vreg, ctx) == 1) {
            load_op(inst.src1.vreg, ctx, scr);
            load_op(inst.src2.vreg, ctx, "rcx");
            out_cstr("  imul "); out_cstr(scr); out_cstr(", rcx\n");
        } else {
            load_op(inst.src1.vreg, ctx, scr);
            out_cstr("  imul "); out_cstr(scr); out_cstr(", ");
            emit_op(inst.src2.vreg, ctx);
            out_char(10);
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_DIV) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            load_op(inst.src1.vreg, ctx, scr);
            let is i64 as shift with mut = 0;
            let is i64 as tmp with mut = inst.src2.imm;
            while (tmp > 1) { tmp = tmp >> 1; shift = shift + 1; }
            if (is_signed_type(inst.cast_to) == 1) {
                if (shift == 1) {
                    out_cstr("  mov rcx, "); out_cstr(scr); out_char(10);
                    out_line("shr rcx, 63");
                    out_cstr("  add "); out_cstr(scr); out_cstr(", rcx\n");
                    out_cstr("  sar "); out_cstr(scr); out_cstr(", 1\n");
                } else {
                    out_cstr("  mov rcx, "); out_cstr(scr); out_char(10);
                    out_line("sar rcx, 63");
                    out_cstr("  shr rcx, "); out_int(64 - shift); out_char(10);
                    out_cstr("  add "); out_cstr(scr); out_cstr(", rcx\n");
                    out_cstr("  sar "); out_cstr(scr); out_cstr(", "); out_int(shift); out_char(10);
                }
            } else {
                out_cstr("  shr "); out_cstr(scr); out_cstr(", "); out_int(shift); out_char(10);
            }
            store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            out_cstr("  mov rcx, "); out_int(inst.src2.imm); out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
        }
        out_line("push rdx");
        if (is_signed_type(inst.cast_to) == 1) {
            out_line("cqo");
            out_line("idiv rcx");
        } else {
            out_line("xor rdx, rdx");
            out_line("div rcx");
        }
        out_line("pop rdx");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_MOD) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            load_op(inst.src1.vreg, ctx, scr);
            let is i64 as mask = inst.src2.imm - 1;
            if (is_signed_type(inst.cast_to) == 1) {
                out_cstr("  mov rcx, "); out_cstr(scr); out_char(10);
                out_cstr("  sar "); out_cstr(scr); out_cstr(", 63\n");
                out_cstr("  and "); out_cstr(scr); out_cstr(", "); out_int(mask); out_char(10);
                out_cstr("  add rcx, "); out_cstr(scr); out_char(10);
                out_cstr("  and rcx, "); out_int(mask); out_char(10);
                out_cstr("  sub rcx, "); out_cstr(scr); out_char(10);
                out_cstr("  mov "); out_cstr(scr); out_cstr(", rcx\n");
            } else {
                out_cstr("  and "); out_cstr(scr); out_cstr(", "); out_int(mask); out_char(10);
            }
            store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            out_cstr("  mov rcx, "); out_int(inst.src2.imm); out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
        }
        out_line("push rdx");
        if (is_signed_type(inst.cast_to) == 1) {
            out_line("cqo");
            out_line("idiv rcx");
        } else {
            out_line("xor rdx, rdx");
            out_line("div rcx");
        }
        out_line("mov rax, rdx");
        out_line("pop rdx");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_NEG
    let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
    load_op(inst.src1.vreg, ctx, scr);
    out_cstr("  neg "); out_cstr(scr); out_char(10);
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: FADD, FSUB, FMUL, FDIV, FNEG ===

fn gen_inst_float(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_FNEG) {
        load_op(inst.src1.vreg, ctx, "rax");
        out_line("movq xmm0, rax");
        out_line("mov rcx, 0x8000000000000000");
        out_line("movq xmm1, rcx");
        out_line("xorpd xmm0, xmm1");
        out_line("movq rax, xmm0");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // FADD, FSUB, FMUL, FDIV
    load_op(inst.src1.vreg, ctx, "rax");
    load_op(inst.src2.vreg, ctx, "rcx");
    out_line("movq xmm0, rax");
    out_line("movq xmm1, rcx");
    if (op == d.IR_FADD) { out_line("addsd xmm0, xmm1"); }
    if (op == d.IR_FSUB) { out_line("subsd xmm0, xmm1"); }
    if (op == d.IR_FMUL) { out_line("mulsd xmm0, xmm1"); }
    if (op == d.IR_FDIV) { out_line("divsd xmm0, xmm1"); }
    out_line("movq rax, xmm0");
    store_op(inst.dest.vreg, ctx, "rax");
}

// === gen_inst: EQ, NE, LT, LE, GT, GE (with branch fusion) ===

fn gen_inst_compare(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    let is i32 as fused with mut = 0;
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) != 0 && nx.is_dead != 1) {
        let is i32 as nx_op = nx.op;
        if ((nx_op == d.IR_JZ || nx_op == d.IR_JNZ) && nx.src1.vreg == inst.dest.vreg) {
            load_op(inst.src1.vreg, ctx, "rax");
            if (inst.src2.op_type == d.OP_IMM && inst.src2.imm == 0) {
                out_cstr("  test rax, rax\n");
            } else {
                out_cstr("  cmp rax, ");
                emit_src2(inst, ctx);
                out_char(10);
            }
            let is i32 as sgn = is_signed_type(inst.cast_to);
            if (nx_op == d.IR_JZ) {
                if (op == d.IR_EQ) { out_cstr("  jne .L"); }
                else if (op == d.IR_NE) { out_cstr("  je .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { out_cstr("  jge .L"); } else { out_cstr("  jae .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { out_cstr("  jg .L"); } else { out_cstr("  ja .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { out_cstr("  jle .L"); } else { out_cstr("  jbe .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { out_cstr("  jl .L"); } else { out_cstr("  jb .L"); } }
            } else {
                if (op == d.IR_EQ) { out_cstr("  je .L"); }
                else if (op == d.IR_NE) { out_cstr("  jne .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { out_cstr("  jl .L"); } else { out_cstr("  jb .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { out_cstr("  jle .L"); } else { out_cstr("  jbe .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { out_cstr("  jg .L"); } else { out_cstr("  ja .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { out_cstr("  jge .L"); } else { out_cstr("  jae .L"); } }
            }
            out_int(cast(i64, nx.dest.label));
            out_char(10);
            nx.is_dead = 1;
            fused = 1;
        }
    }
    if (fused == 0) {
        load_op(inst.src1.vreg, ctx, "rcx");
        out_line("xor eax, eax");
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm == 0) {
            out_cstr("  test rcx, rcx\n");
        } else {
            out_cstr("  cmp rcx, ");
            emit_src2(inst, ctx);
            out_char(10);
        }
        if (op == d.IR_EQ) { out_line("sete al"); }
        if (op == d.IR_NE) { out_line("setne al"); }
        let is i32 as sgn2 = is_signed_type(inst.cast_to);
        if (op == d.IR_LT) { if (sgn2 == 1) { out_line("setl al"); } else { out_line("setb al"); } }
        if (op == d.IR_LE) { if (sgn2 == 1) { out_line("setle al"); } else { out_line("setbe al"); } }
        if (op == d.IR_GT) { if (sgn2 == 1) { out_line("setg al"); } else { out_line("seta al"); } }
        if (op == d.IR_GE) { if (sgn2 == 1) { out_line("setge al"); } else { out_line("setae al"); } }
        store_op(inst.dest.vreg, ctx, "rax");
    }
}

// === gen_inst: SHL, SHR, AND, OR, XOR, NOT ===

fn gen_inst_shift_bitwise(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SHL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            out_cstr("  shl ");
            out_cstr(scr);
            out_cstr(", ");
            out_int(inst.src2.imm);
            out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
            out_cstr("  shl ");
            out_cstr(scr);
            out_cstr(", cl\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SHR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            if (is_signed_type(inst.cast_to) == 1) {
                out_cstr("  sar ");
            } else {
                out_cstr("  shr ");
            }
            out_cstr(scr);
            out_cstr(", ");
            out_int(inst.src2.imm);
            out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
            if (is_signed_type(inst.cast_to) == 1) {
                out_cstr("  sar ");
            } else {
                out_cstr("  shr ");
            }
            out_cstr(scr);
            out_cstr(", cl\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_AND) { gen_binop(inst, ctx, "and"); return; }
    if (op == d.IR_OR) { gen_binop(inst, ctx, "or"); return; }
    if (op == d.IR_XOR) { gen_binop(inst, ctx, "xor"); return; }
    // IR_NOT
    let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
    load_op(inst.src1.vreg, ctx, scr);
    out_cstr("  not ");
    out_cstr(scr);
    out_char(10);
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: RET, LABEL, JMP, JZ, JNZ ===

fn gen_inst_control(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_RET) {
        if (inst.src1.op_type != d.OP_NONE) {
            load_op(inst.src1.vreg, ctx, "rax");
        }
        if (ctx.aligned_stack_size > 0) {
            out_cstr("  add rsp, ");
            out_int(cast(i64, ctx.aligned_stack_size));
            out_char(10);
        }
        if (ctx.used_callee_mask & 16) { out_line("pop r15"); }
        if (ctx.used_callee_mask & 8) { out_line("pop r14"); }
        if (ctx.used_callee_mask & 4) { out_line("pop r13"); }
        if (ctx.used_callee_mask & 2) { out_line("pop r12"); }
        if (ctx.used_callee_mask & 1) { out_line("pop rbx"); }
        out_line("pop rbp");
        out_line("ret");
        return;
    }
    if (op == d.IR_LABEL) {
        if (al.al_opt_level >= 1) { ph_invalidate(); }
        out_cstr(".L");
        out_int(cast(i64, inst.dest.label));
        out_cstr(":\n");
        return;
    }
    if (op == d.IR_JMP) {
        if (al.al_opt_level >= 1) { ph_invalidate(); }
        out_cstr("  jmp .L");
        out_int(cast(i64, inst.dest.label));
        out_char(10);
        return;
    }
    if (op == d.IR_JZ) {
        load_op(inst.src1.vreg, ctx, "rax");
        out_line("test rax, rax");
        out_cstr("  jz .L");
        out_int(cast(i64, inst.dest.label));
        out_char(10);
        return;
    }
    // IR_JNZ
    load_op(inst.src1.vreg, ctx, "rax");
    out_line("test rax, rax");
    out_cstr("  jnz .L");
    out_int(cast(i64, inst.dest.label));
    out_char(10);
}

// === gen_inst: ADDR, ADDR_GLOBAL, FN_ADDR, GET_ALLOC_ADDR, LOAD, STORE, COPY, ASM, CAST ===

fn gen_inst_memory(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADDR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        out_cstr("  lea ");
        out_cstr(scr);
        out_cstr(", [rbp-");
        out_int(inst.src1.imm);
        out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_ADDR_GLOBAL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        if (inst.is_extern_global == 1) {
            out_cstr("  mov ");
            out_cstr(scr);
            out_cstr(", QWORD PTR [rip+");
            out_str(inst.global_name_ptr, inst.global_name_len);
            out_cstr("]\n");
        } else {
            out_cstr("  lea ");
            out_cstr(scr);
            out_cstr(", [rip+");
            out_str(inst.global_name_ptr, inst.global_name_len);
            out_cstr("]\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_FN_ADDR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        out_cstr("  lea ");
        out_cstr(scr);
        out_cstr(", [rip+");
        out_str(inst.global_name_ptr, inst.global_name_len);
        out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_GET_ALLOC_ADDR) {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, ctx.stack_slots) * 8 + inst.src1.imm;
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        out_cstr("  lea ");
        out_cstr(scr);
        out_cstr(", [rbp-");
        out_int(off);
        out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SET_CTX) {
        if (inst.src1.op_type == d.OP_IMM) {
            out_line("xor r10, r10");
            if (al.al_opt_level >= 1) { rc_invalidate_reg(8); }
        } else {
            load_op(inst.src1.vreg, ctx, "r10");
        }
        return;
    }
    if (op == d.IR_LOAD) {
        let is i32 as sz = get_type_size(inst.cast_to);
        let is i32 as sgn = is_signed_type(inst.cast_to);
        let is i32 as si = get_scratch_idx(inst.dest.vreg, ctx);
        let is *u8 as scr = reg64(si);
        let is *u8 as scr32 = reg32(si);
        if (inst.src1.op_type == d.OP_VREG) {
            let is AddrMode as am with mut;
            am.matched = 0;
            if (al.al_opt_level >= 1) {
                am = try_match_addr(inst.src1.vreg, ctx);
            }
            if (am.matched == 1) {
                // Emit: mov/movsx scr, SIZE PTR [rax + rcx * scale]
                // Both base and index are spilled (checked in try_match_addr)
                load_op(am.base_vreg, ctx, "rax");
                load_op(am.index_vreg, ctx, "rcx");
                if (sz == 8) {
                    out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR [rax + rcx * "); out_int(cast(i64, am.scale)); out_cstr("]\n");
                } else if (sz == 4) {
                    if (sgn == 1) { out_cstr("  movsxd "); out_cstr(scr); } else { out_cstr("  mov "); out_cstr(scr32); }
                    out_cstr(", DWORD PTR [rax + rcx * "); out_int(cast(i64, am.scale)); out_cstr("]\n");
                } else if (sz == 2) {
                    if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                    out_cstr(scr); out_cstr(", WORD PTR [rax + rcx * "); out_int(cast(i64, am.scale)); out_cstr("]\n");
                } else if (sz == 1) {
                    if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                    out_cstr(scr); out_cstr(", BYTE PTR [rax + rcx * "); out_int(cast(i64, am.scale)); out_cstr("]\n");
                } else {
                    out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR [rax + rcx * "); out_int(cast(i64, am.scale)); out_cstr("]\n");
                }
                store_op(inst.dest.vreg, ctx, scr);
            } else {
            load_op(inst.src1.vreg, ctx, scr);
            if (sz == 8) {
                out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR ["); out_cstr(scr); out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) { out_cstr("  movsxd "); out_cstr(scr); out_cstr(", DWORD PTR ["); out_cstr(scr); out_cstr("]\n"); }
                else { out_cstr("  mov "); out_cstr(scr32); out_cstr(", DWORD PTR ["); out_cstr(scr); out_cstr("]\n"); }
            } else if (sz == 2) {
                if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                out_cstr(scr); out_cstr(", WORD PTR ["); out_cstr(scr); out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                out_cstr(scr); out_cstr(", BYTE PTR ["); out_cstr(scr); out_cstr("]\n");
            } else {
                out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR ["); out_cstr(scr); out_cstr("]\n");
            }
            store_op(inst.dest.vreg, ctx, scr);
            }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR [rbp-");
                out_int(inst.src1.imm); out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) {
                    out_cstr("  movsxd "); out_cstr(scr);
                } else {
                    out_cstr("  mov "); out_cstr(scr32);
                }
                out_cstr(", DWORD PTR [rbp-"); out_int(inst.src1.imm); out_cstr("]\n");
            } else if (sz == 2) {
                if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                out_cstr(scr); out_cstr(", WORD PTR [rbp-"); out_int(inst.src1.imm); out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
                out_cstr(scr); out_cstr(", BYTE PTR [rbp-"); out_int(inst.src1.imm); out_cstr("]\n");
            } else {
                out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR [rbp-");
                out_int(inst.src1.imm); out_cstr("]\n");
            }
            store_op(inst.dest.vreg, ctx, scr);
        }
        return;
    }
    if (op == d.IR_STORE) {
        let is i32 as sz = get_type_size(inst.cast_to);
        load_op(inst.src1.vreg, ctx, "rax");
        if (inst.dest.op_type == d.OP_VREG) {
            load_op(inst.dest.vreg, ctx, "rcx");
            if (sz == 8) { out_line("mov QWORD PTR [rcx], rax"); }
            else if (sz == 4) { out_line("mov DWORD PTR [rcx], eax"); }
            else if (sz == 2) { out_line("mov WORD PTR [rcx], ax"); }
            else if (sz == 1) { out_line("mov BYTE PTR [rcx], al"); }
            else { out_line("mov QWORD PTR [rcx], rax"); }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                out_cstr("  mov QWORD PTR [rbp-");
                out_int(inst.dest.imm);
                out_cstr("], rax\n");
            } else if (sz == 4) {
                out_cstr("  mov DWORD PTR [rbp-");
                out_int(inst.dest.imm);
                out_cstr("], eax\n");
            } else if (sz == 2) {
                out_cstr("  mov WORD PTR [rbp-");
                out_int(inst.dest.imm);
                out_cstr("], ax\n");
            } else if (sz == 1) {
                out_cstr("  mov BYTE PTR [rbp-");
                out_int(inst.dest.imm);
                out_cstr("], al\n");
            } else {
                // Struct > 8 bytes: rax is a pointer to the struct data.
                // Copy from [rax] to [rbp-dest] using rcx as scratch.
                out_line("mov rcx, rax");
                let is i32 as soff with mut = 0;
                while (soff + 8 <= sz) {
                    out_cstr("  mov rax, QWORD PTR [rcx+");
                    out_int(cast(i64, soff));
                    out_cstr("]\n");
                    out_cstr("  mov QWORD PTR [rbp-");
                    out_int(inst.dest.imm - cast(i64, soff));
                    out_cstr("], rax\n");
                    soff = soff + 8;
                }
                if (soff + 4 <= sz) {
                    out_cstr("  mov eax, DWORD PTR [rcx+");
                    out_int(cast(i64, soff));
                    out_cstr("]\n");
                    out_cstr("  mov DWORD PTR [rbp-");
                    out_int(inst.dest.imm - cast(i64, soff));
                    out_cstr("], eax\n");
                    soff = soff + 4;
                }
                if (soff + 2 <= sz) {
                    out_cstr("  movzx eax, WORD PTR [rcx+");
                    out_int(cast(i64, soff));
                    out_cstr("]\n");
                    out_cstr("  mov WORD PTR [rbp-");
                    out_int(inst.dest.imm - cast(i64, soff));
                    out_cstr("], ax\n");
                    soff = soff + 2;
                }
                if (soff < sz) {
                    out_cstr("  movzx eax, BYTE PTR [rcx+");
                    out_int(cast(i64, soff));
                    out_cstr("]\n");
                    out_cstr("  mov BYTE PTR [rbp-");
                    out_int(inst.dest.imm - cast(i64, soff));
                    out_cstr("], al\n");
                }
            }
        }
        return;
    }
    if (op == d.IR_COPY) {
        load_op(inst.dest.vreg, ctx, "rdi");
        load_op(inst.src1.vreg, ctx, "rsi");
        out_cstr("  mov rcx, ");
        out_int(inst.src2.imm);
        out_char(10);
        out_line("cld");
        out_line("rep movsb");
        // rep movsb clobbers rdi, rsi, rcx
        if (al.al_opt_level >= 1) {
            rc_invalidate_reg(5);
            rc_invalidate_reg(4);
            rc_invalidate_reg(1);
        }
        return;
    }
    if (op == d.IR_ASM) {
        out_cstr("  ");
        out_str(inst.asm_str_ptr, inst.asm_str_len);
        out_char(10);
        if (al.al_opt_level >= 1) { ph_invalidate(); }
        return;
    }
    // IR_CAST
    let is i32 as to_flt = is_float_type(inst.cast_to);
    let is i32 as from_flt = is_float_type(inst.cast_from);
    let is i32 as si = get_scratch_idx(inst.dest.vreg, ctx);
    let is *u8 as scr = reg64(si);
    load_op(inst.src1.vreg, ctx, scr);
    if (from_flt == 1 && to_flt == 0) {
        out_cstr("  movq xmm0, "); out_cstr(scr); out_char(10);
        out_cstr("  cvttsd2si "); out_cstr(scr); out_cstr(", xmm0\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (from_flt == 0 && to_flt == 1) {
        out_cstr("  cvtsi2sd xmm0, "); out_cstr(scr); out_char(10);
        out_cstr("  movq "); out_cstr(scr); out_cstr(", xmm0\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    let is i32 as to_sz = get_type_size(inst.cast_to);
    let is i32 as sgn = is_signed_type(inst.cast_to);
    if (to_sz == 4) {
        if (sgn == 1) { out_cstr("  movsxd "); out_cstr(scr); out_cstr(", "); out_cstr(reg32(si)); out_char(10); }
        else { out_cstr("  mov "); out_cstr(reg32(si)); out_cstr(", "); out_cstr(reg32(si)); out_char(10); }
    } else if (to_sz == 2) {
        if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
        out_cstr(scr); out_cstr(", "); out_cstr(reg16(si)); out_char(10);
    } else if (to_sz == 1) {
        if (sgn == 1) { out_cstr("  movsx "); } else { out_cstr("  movzx "); }
        out_cstr(scr); out_cstr(", "); out_cstr(reg8(si)); out_char(10);
    }
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: SET_ARG, GET_ARG, SET_SYS_ARG, SYSCALL, CALL, VA_START ===

fn gen_inst_calls(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SET_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        if (idx < 6) {
            load_op(inst.src1.vreg, ctx, arg_reg64(idx));
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            out_line("push rax");
        }
        return;
    }
    if (op == d.IR_GET_ARG) {
        let is i32 as idx = cast(i32, inst.src1.imm);
        if (idx < 6) {
            store_op(inst.dest.vreg, ctx, arg_reg64(idx));
        } else {
            let is i64 as off = 16 + cast(i64, idx - 6) * 8;
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            out_cstr("  mov "); out_cstr(scr); out_cstr(", QWORD PTR [rbp+");
            out_int(off);
            out_cstr("]\n");
            store_op(inst.dest.vreg, ctx, scr);
        }
        return;
    }
    if (op == d.IR_SET_SYS_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        load_op(inst.src1.vreg, ctx, syscall_reg(idx));
        return;
    }
    if (op == d.IR_SYSCALL) {
        out_line("syscall");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_CALL) {
        out_cstr("  call ");
        out_str(inst.call_name_ptr, inst.call_name_len);
        out_char(10);
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_VA_START
    let is i32 as num_args = cast(i32, inst.src2.imm);
    load_op(inst.src1.vreg, ctx, "rcx");
    out_cstr("  mov DWORD PTR [rcx], ");
    out_int(cast(i64, num_args) * 8);
    out_char(10);
    out_line("mov DWORD PTR [rcx+4], 48");
    let is i64 as overflow_off with mut = 16;
    if (num_args > 6) {
        overflow_off = 16 + cast(i64, num_args - 6) * 8;
    }
    out_cstr("  lea rax, [rbp+");
    out_int(overflow_off);
    out_cstr("]\n");
    out_line("mov QWORD PTR [rcx+8], rax");
    out_cstr("  lea rax, [rbp-");
    out_int(cast(i64, ctx.va_save_offset));
    out_cstr("]\n");
    out_line("mov QWORD PTR [rcx+16], rax");
}

// === Instruction selection: use counts + pattern matching on IR ===
// vreg_uses[v] = number of times v appears as src1, src2, or STORE/COPY dest
let is *i32 as isel_uses with mut;
let is i32 as isel_vc with mut = 0;

fn isel_init(func as *d.IRFunction) as void {
    isel_vc = func.vreg_count;
    isel_uses = cast(*i32, mem.galloc(cast(i64, isel_vc) * 4));
    let is i32 as i with mut = 0;
    while (i < isel_vc) {
        let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, i) * 4);
        *p = 0;
        i = i + 1;
    }
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.is_dead == 0) {
            if (inst.src1.op_type == d.OP_VREG && inst.src1.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.src1.vreg) * 4);
                *p = *p + 1;
            }
            if (inst.src2.op_type == d.OP_VREG && inst.src2.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.src2.vreg) * 4);
                *p = *p + 1;
            }
            if ((inst.op == d.IR_STORE || inst.op == d.IR_COPY) && inst.dest.op_type == d.OP_VREG && inst.dest.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.dest.vreg) * 4);
                *p = *p + 1;
            }
        }
        inst = inst.next;
    }
}

fn isel_get_uses(vreg as i32) as i32 {
    if (vreg < 0 || vreg >= isel_vc) { return 99; }
    let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, vreg) * 4);
    return *p;
}

// vreg_def[v] = pointer to the IRInst that defines vreg v (0 = unknown)
let is *i64 as isel_defs with mut;

fn isel_init_defs(func as *d.IRFunction) as void {
    isel_defs = cast(*i64, mem.galloc(cast(i64, isel_vc) * 8));
    let is i32 as i with mut = 0;
    while (i < isel_vc) {
        let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, i) * 8);
        *p = 0;
        i = i + 1;
    }
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.is_dead == 0 && inst.dest.op_type == d.OP_VREG) {
            let is i32 as dv = inst.dest.vreg;
            if (dv >= 0 && dv < isel_vc) {
                let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, dv) * 8);
                *p = cast(i64, inst);
            }
        }
        inst = inst.next;
    }
}

fn isel_get_def(vreg as i32) as *d.IRInst {
    if (vreg < 0 || vreg >= isel_vc) { return cast(*d.IRInst, 0); }
    let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, vreg) * 8);
    return cast(*d.IRInst, *p);
}

// Addressing mode result: [base_reg + index_reg * scale]
// scale: 1, 2, 4, or 8. If scale=0, no index.
struct AddrMode {
    base_vreg as i32;
    index_vreg as i32;
    scale as i32;
    matched as i32;
}

// Try to match addr = ADD(base, SHL(index, log2(scale))) where scale is 1/2/4/8
// Returns matched=1 if successful, 0 otherwise.
fn try_match_addr(addr_vreg as i32, ctx as *al.AllocCtx) as AddrMode {
    let is AddrMode as r;
    r.matched = 0;
    r.base_vreg = addr_vreg;
    r.index_vreg = 0;
    r.scale = 0;
    let is *d.IRInst as def = isel_get_def(addr_vreg);
    if (cast(i64, def) == 0) { return r; }
    if (def.op != d.IR_ADD) { return r; }
    if (def.src1.op_type != d.OP_VREG || def.src2.op_type != d.OP_VREG) { return r; }
    // Only fuse if the ADD result has exactly 1 use (this LOAD/STORE)
    if (isel_get_uses(addr_vreg) != 1) { return r; }
    // Check if src2 is SHL(index, shift) where shift is 0/1/2/3
    let is *d.IRInst as shl_def = isel_get_def(def.src2.vreg);
    if (cast(i64, shl_def) == 0) { return r; }
    if (shl_def.op != d.IR_SHL) { return r; }
    if (shl_def.src2.op_type != d.OP_IMM) { return r; }
    let is i64 as shift = shl_def.src2.imm;
    if (shift < 0 || shift > 3) { return r; }
    // Only fuse if SHL result has exactly 1 use (the ADD)
    if (isel_get_uses(def.src2.vreg) != 1) { return r; }
    r.base_vreg = def.src1.vreg;
    r.index_vreg = shl_def.src1.vreg;
    // Safety: base and index must be spilled (not register-allocated) because
    // the register allocator may have reused their physical registers for the
    // ADD/SHL results by this point. Spilled values are always available.
    if (al.is_mem(r.base_vreg, ctx) == 0 || al.is_mem(r.index_vreg, ctx) == 0) { return r; }
    if (shift == 0) { r.scale = 1; }
    else if (shift == 1) { r.scale = 2; }
    else if (shift == 2) { r.scale = 4; }
    else { r.scale = 8; }
    r.matched = 1;
    return r;
}

fn size_name(sz as i32) as *u8 {
    if (sz == 8) { return "QWORD PTR"; }
    if (sz == 4) { return "DWORD PTR"; }
    if (sz == 2) { return "WORD PTR"; }
    if (sz == 1) { return "BYTE PTR"; }
    return "QWORD PTR";
}

fn size_reg(idx as i32, sz as i32) as *u8 {
    if (sz == 8) { return reg64(idx); }
    if (sz == 4) { return reg32(idx); }
    if (sz == 2) { return reg16(idx); }
    if (sz == 1) { return reg8(idx); }
    return reg64(idx);
}

// Pattern: IR_IMM v=const + IR_STORE [addr]=v → mov PTR [addr], const
// Only when addr is a vreg (indirect store) and imm fits 32-bit
fn try_fuse_imm_store(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_STORE) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    // Safety: only fuse if the IMM vreg has exactly 1 use (the STORE)
    if (isel_get_uses(inst.dest.vreg) != 1) { return 0; }
    if (nx.dest.op_type != d.OP_VREG) { return 0; }
    let is i64 as val = inst.src1.imm;
    if (val > 2147483647 || val < 0 - 2147483647) { return 0; }
    let is i32 as sz = get_type_size(nx.cast_to);
    if (sz > 8) { return 0; }
    // Emit: mov SIZE PTR [addr_reg], imm
    load_op(nx.dest.vreg, ctx, "rcx");
    out_cstr("  mov ");
    out_cstr(size_name(sz));
    out_cstr(" [rcx], ");
    out_int(val);
    out_char(10);
    nx.is_dead = 1;
    return 1;
}

// Pattern: IR_IMM v=const + IR_STORE dest=IMM(offset), src1=v → mov PTR [rbp-off], const
// Store immediate to stack without loading into register first
fn try_fuse_imm_store_stack(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_STORE) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    if (isel_get_uses(inst.dest.vreg) != 1) { return 0; }
    if (nx.dest.op_type != d.OP_IMM) { return 0; }
    let is i64 as val = inst.src1.imm;
    if (val > 2147483647 || val < 0 - 2147483647) { return 0; }
    let is i32 as sz = get_type_size(nx.cast_to);
    if (sz > 8) { return 0; }
    // Emit: mov SIZE PTR [rbp-off], imm
    out_cstr("  mov ");
    out_cstr(size_name(sz));
    out_cstr(" [rbp-");
    out_int(nx.dest.imm);
    out_cstr("], ");
    out_int(val);
    out_char(10);
    nx.is_dead = 1;
    return 1;
}

// Pattern: IR_LOAD v1=[rbp-X] + IR_ADD/SUB v2=v1,imm + IR_STORE [rbp-X]=v2
// → add/sub SIZE PTR [rbp-X], imm
fn try_fuse_inc_stack(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    if (inst.src1.op_type != d.OP_IMM) { return 0; }
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_ADD && nx.op != d.IR_SUB) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    if (nx.src2.op_type != d.OP_IMM) { return 0; }
    let is i64 as addval = nx.src2.imm;
    if (addval > 2147483647 || addval < 0 - 2147483647) { return 0; }
    let is *d.IRInst as nx2 = nx.next;
    if (cast(i64, nx2) == 0 || nx2.is_dead == 1) { return 0; }
    if (nx2.op != d.IR_STORE) { return 0; }
    if (nx2.dest.op_type != d.OP_IMM) { return 0; }
    if (nx2.dest.imm != inst.src1.imm) { return 0; }
    if (nx2.src1.op_type != d.OP_VREG || nx2.src1.vreg != nx.dest.vreg) { return 0; }
    let is i32 as sz = get_type_size(inst.cast_to);
    if (sz > 8) { return 0; }
    // Emit: add/sub SIZE PTR [rbp-X], imm
    if (nx.op == d.IR_ADD) { out_cstr("  add "); }
    else { out_cstr("  sub "); }
    out_cstr(size_name(sz));
    out_cstr(" [rbp-");
    out_int(inst.src1.imm);
    out_cstr("], ");
    out_int(addval);
    out_char(10);
    // Mark consumed instructions dead but keep them for vreg tracking
    nx.is_dead = 1;
    nx2.is_dead = 1;
    // The LOAD result (inst.dest) may still be needed if it has other uses
    // For safety, still emit the load normally
    return 0;
}

// === gen_inst: thin dispatcher ===

fn gen_inst(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;

    if (al.al_opt_level >= 1) {
        // Invalidate scratch registers (rax=0, rcx=1, rdx=2)
        rc_invalidate_reg(0);
        rc_invalidate_reg(1);
        rc_invalidate_reg(2);

        // Invalidate dest register — it will be overwritten by this instruction
        if (inst.dest.op_type == d.OP_VREG && op != d.IR_STORE && op != d.IR_COPY) {
            let is i32 as dest_loc = al.get_loc(inst.dest.vreg, ctx);
            if (dest_loc >= 0) {
                rc_invalidate_reg(dest_loc);
            }
            // Also invalidate any cached entry for this vreg (it's being redefined)
            rc_invalidate_vreg(inst.dest.vreg);
        }

        // Invalidate arg registers written by SET_ARG
        if (op == d.IR_SET_ARG) {
            let is i32 as aidx = cast(i32, inst.dest.imm);
            if (aidx == 0) { rc_invalidate_reg(5); }
            if (aidx == 1) { rc_invalidate_reg(4); }
            if (aidx == 2) { rc_invalidate_reg(2); }
            if (aidx == 3) { rc_invalidate_reg(1); }
            if (aidx == 4) { rc_invalidate_reg(6); }
            if (aidx == 5) { rc_invalidate_reg(7); }
        }

        // Full invalidation on calls (all caller-saved regs clobbered)
        if (op == d.IR_CALL || op == d.IR_SYSCALL) { ph_invalidate(); }

        // Instruction selection: try fused patterns before standard emission
        if (op == d.IR_IMM) {
            if (try_fuse_imm_store(inst, ctx) == 1) { return; }
            if (try_fuse_imm_store_stack(inst, ctx) == 1) { return; }
        }
        if (op == d.IR_LOAD) {
            try_fuse_inc_stack(inst, ctx);
            // Note: try_fuse_inc_stack returns 0 always — load still emitted normally
        }
    }

    if (op == d.IR_IMM || op == d.IR_MOV) { gen_inst_imm_mov(inst, ctx); return; }
    if (op == d.IR_ADD || op == d.IR_SUB || op == d.IR_MUL || op == d.IR_DIV || op == d.IR_MOD || op == d.IR_NEG) { gen_inst_arith(inst, ctx); return; }
    if (op == d.IR_FADD || op == d.IR_FSUB || op == d.IR_FMUL || op == d.IR_FDIV || op == d.IR_FNEG) { gen_inst_float(inst, ctx); return; }
    if (op == d.IR_EQ || op == d.IR_NE || op == d.IR_LT || op == d.IR_LE || op == d.IR_GT || op == d.IR_GE) { gen_inst_compare(inst, ctx); return; }
    if (op == d.IR_SHL || op == d.IR_SHR || op == d.IR_AND || op == d.IR_OR || op == d.IR_XOR || op == d.IR_NOT) { gen_inst_shift_bitwise(inst, ctx); return; }
    if (op == d.IR_RET || op == d.IR_LABEL || op == d.IR_JMP || op == d.IR_JZ || op == d.IR_JNZ) { gen_inst_control(inst, ctx); return; }
    if (op == d.IR_SET_ARG || op == d.IR_GET_ARG || op == d.IR_SET_SYS_ARG || op == d.IR_SYSCALL || op == d.IR_CALL || op == d.IR_VA_START) { gen_inst_calls(inst, ctx); return; }
    // Memory, load/store, copy, asm, cast, set_ctx
    gen_inst_memory(inst, ctx);
}

// === gen_func ===

fn gen_func(func as *d.IRFunction) as void {
    // Init register cache, instruction selection use counts, and def table
    rc_init();
    if (al.al_opt_level >= 1) {
        isel_init(func);
        isel_init_defs(func);
    }

    // Build intervals and allocate registers
    let is *al.AllocCtx as ctx = al.new_alloc_ctx();
    ctx.func = cast(*u8, func);
    ctx.next_spill = 1;

    al.build_intervals(func, ctx);
    // GC disabled temporarily for debugging — using linear scan for all
    al.linear_scan_alloc(func, ctx);
    io.write_str(linux.STDERR, "    alloc ok, vregs=");
    io.write_int(linux.STDERR, cast(i64, func.vreg_count));
    io.write_str(linux.STDERR, " spills=");
    io.write_int(linux.STDERR, cast(i64, ctx.stack_slots));
    io.write_str(linux.STDERR, "\n");

    // Set arg_spill_base so spill slots don't overlap with local vars
    ctx.arg_spill_base = func.stack_size;

    // Compute total stack size needed
    let is i32 as local_size = func.stack_size;
    let is i32 as spill_size = ctx.stack_slots * 8;
    let is i32 as alloc_size = func.alloc_stack_size;
    let is i32 as va_size with mut = 0;
    if (func.is_variadic == 1) { va_size = 48; }
    let is i32 as total with mut = local_size + spill_size + alloc_size + va_size;
    // Count callee-saved pushes from mask bits
    let is i32 as mask = ctx.used_callee_mask;
    let is i32 as push_count with mut = 0;
    if (mask & 1) { push_count = push_count + 1; }
    if (mask & 2) { push_count = push_count + 1; }
    if (mask & 4) { push_count = push_count + 1; }
    if (mask & 8) { push_count = push_count + 1; }
    if (mask & 16) { push_count = push_count + 1; }
    // Align to 16: call(8) + push rbp(8) + push_count*8 + total must be 16-aligned
    let is i32 as frame_fixed = 16 + push_count * 8;
    // (frame_fixed + total) % 16 must be 0
    if ((frame_fixed + total) % 16 != 0) {
        total = total + 8;
    }
    if (total < 8) { total = 8; }
    ctx.aligned_stack_size = total;

    // Function label
    out_str(func.asm_name_ptr, func.asm_name_len);
    out_cstr(":\n");

    // Prologue
    out_line("push rbp");
    out_line("mov rbp, rsp");
    if (mask & 1) { out_line("push rbx"); }
    if (mask & 2) { out_line("push r12"); }
    if (mask & 4) { out_line("push r13"); }
    if (mask & 8) { out_line("push r14"); }
    if (mask & 16) { out_line("push r15"); }
    if (ctx.aligned_stack_size > 0) {
        out_cstr("  sub rsp, ");
        out_int(cast(i64, ctx.aligned_stack_size));
        out_char(10);
    }

    // Variadic prologue: save 6 arg registers to register save area
    if (func.is_variadic == 1) {
        // va_save_offset = total offset from rbp to start of 48-byte save area
        // Layout: [rbp - va_save_offset] = rdi (first), ..., [rbp - va_save_offset + 40] = r9 (last)
        let is i32 as vso = local_size + spill_size + alloc_size + 48;
        ctx.va_save_offset = vso;
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso)); out_cstr("], rdi\n");
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso - 8)); out_cstr("], rsi\n");
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso - 16)); out_cstr("], rdx\n");
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso - 24)); out_cstr("], rcx\n");
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso - 32)); out_cstr("], r8\n");
        out_cstr("  mov QWORD PTR [rbp-"); out_int(cast(i64, vso - 40)); out_cstr("], r9\n");
    }

    // Instructions
    let is *d.IRInst as inst with mut = func.instructions;
    let is i32 as last_line with mut = 0;
    while (cast(i64, inst) != 0) {
        if (inst.line > 0 && inst.line != last_line) {
            out_cstr(".loc 1 ");
            out_int(cast(i64, inst.line));
            out_cstr(" 0\n");
            last_line = inst.line;
        }
        if (inst.is_dead != 1) {
            gen_inst(inst, ctx);
        }
        inst = inst.next;
    }
}

// === Data sections ===

fn emit_rodata(prog as *d.IRProgram) as void {
    if (cast(i64, prog.strings) == 0) { return; }
    out_cstr(".section .rodata\n");
    let is *d.StringEntry as s with mut = prog.strings;
    while (cast(i64, s) != 0) {
        out_cstr(".LC");
        out_int(cast(i64, s.id));
        out_cstr(":\n  .string \"");
        // Output string with escaping
        let is i32 as i with mut = 0;
        while (i < s.len) {
            let is u8 as c = s.ptr[i];
            if (c == 10) { out_cstr("\\n"); }
            else if (c == 9) { out_cstr("\\t"); }
            else if (c == 0) { out_cstr("\\0"); }
            else if (c == 34) { out_cstr("\\\""); }
            else if (c == 92) { out_cstr("\\\\"); }
            else { out_char(c); }
            i = i + 1;
        }
        out_cstr("\"\n");
        s = s.next;
    }
}

fn emit_data(prog as *d.IRProgram) as void {
    let is i32 as has_data with mut = 0;
    let is i32 as has_bss with mut = 0;
    // .data section (initialized)
    let is *d.IRGlobal as g with mut = prog.globals;
    while (cast(i64, g) != 0) {
        if (g.is_reachable == 1 && g.is_initialized == 1) {
            if (has_data == 0) {
                out_cstr(".data\n");
                has_data = 1;
            }
            out_cstr(".globl ");
            out_str(g.name_ptr, g.name_len);
            out_char(10);
            out_str(g.name_ptr, g.name_len);
            out_cstr(":\n");
            if (g.size == 8) {
                out_cstr("  .quad ");
                out_int(g.init_value);
                out_char(10);
            } else if (g.size == 4) {
                out_cstr("  .long ");
                out_int(g.init_value);
                out_char(10);
            } else if (g.size == 2) {
                out_cstr("  .short ");
                out_int(g.init_value);
                out_char(10);
            } else if (g.size == 1) {
                out_cstr("  .byte ");
                out_int(g.init_value);
                out_char(10);
            } else {
                out_cstr("  .zero ");
                out_int(cast(i64, g.size));
                out_char(10);
            }
        }
        g = g.next;
    }
    // .bss section (uninitialized)
    g = prog.globals;
    while (cast(i64, g) != 0) {
        if (g.is_reachable == 1 && g.is_initialized == 0) {
            if (has_bss == 0) {
                out_cstr(".bss\n");
                has_bss = 1;
            }
            out_cstr(".globl ");
            out_str(g.name_ptr, g.name_len);
            out_char(10);
            out_str(g.name_ptr, g.name_len);
            out_cstr(":\n");
            out_cstr("  .zero ");
            out_int(cast(i64, g.size));
            out_char(10);
        }
        g = g.next;
    }
}

// === codegen entry ===

fn set_opt_level(level as i32) as void {
    al.al_opt_level = level;
}

fn codegen(prog as *u8, fd as i32, filename_ptr as *u8, filename_len as i32) as void {
    let is *d.IRProgram as p = cast(*d.IRProgram, prog);
    io.write_str(linux.STDERR, "codegen: init\n");
    out_init(fd);
    cg_filename = filename_ptr;
    cg_filename_len = filename_len;

    out_cstr(".intel_syntax noprefix\n");

    // rodata
    io.write_str(linux.STDERR, "codegen: rodata\n");
    emit_rodata(p);

    // data + bss
    io.write_str(linux.STDERR, "codegen: data\n");
    emit_data(p);

    // .text
    out_cstr(".text\n");
    // Debug info: .file directive
    out_cstr(".file 1 \"");
    out_str(cg_filename, cg_filename_len);
    out_cstr("\"\n");

    // Emit .globl for all reachable functions
    io.write_str(linux.STDERR, "codegen: globl\n");
    let is *d.IRFunction as f with mut = p.functions;
    while (cast(i64, f) != 0) {
        if (f.is_reachable == 1) {
            out_cstr(".globl ");
            out_str(f.asm_name_ptr, f.asm_name_len);
            out_char(10);
        }
        f = f.next;
    }

    // Generate code for each reachable function
    io.write_str(linux.STDERR, "codegen: funcs\n");
    f = p.functions;
    while (cast(i64, f) != 0) {
        if (f.is_reachable == 1) {
            io.write_str(linux.STDERR, "  gen: ");
            io.write_bytes(linux.STDERR, f.asm_name_ptr, cast(i64, f.asm_name_len));
            io.write_str(linux.STDERR, "\n");
            if (cg_prof_enabled == 1) {
                let is i64 as t0 = cg_prof_get_time_us();
                gen_func(f);
                cg_prof_record(f.asm_name_ptr, f.asm_name_len, f.vreg_count, cg_prof_get_time_us() - t0);
            } else {
                gen_func(f);
            }
        }
        f = f.next;
    }

    out_flush();
    io.write_str(linux.STDERR, "codegen: done\n");
}
