use "../../std/mem.cst" as mem;
use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "../parser/ast.cst" as ast;
use "../ir/defs.cst" as d;
use "alloc_core.cst" as al;
use "alloc_gc.cst" as gc;
use "emit_output.cst" as eo;


// === Operand helpers ===

// get_scratch: if dest vreg is in a register, return that register name.
// If dest is spilled, return "rax" as scratch (caller must store_op after).
fn get_scratch(vreg as i32, ctx as *al.AllocCtx) as *u8 {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) { return eo.reg64(loc); }
    return "rax";
}

// Returns register index for scratch: dest's phys reg, or 0 (rax) if spilled.
fn get_scratch_idx(vreg as i32, ctx as *al.AllocCtx) as i32 {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) { return loc; }
    return 0;
}

// load vreg value into target register

fn load_op(vreg as i32, ctx as *al.AllocCtx, target as *u8) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        let is *u8 as rn = eo.reg64(loc);
        if (cast(i64, rn) != cast(i64, target)) {
            eo.out_cstr("  mov ");
            eo.out_cstr(target);
            eo.out_cstr(", ");
            eo.out_cstr(rn);
            eo.out_char(10);
        }
        if (al.al_opt_level >= 1) {
            eo.rc_invalidate_reg(eo.reg_name_to_idx(target));
        }
    } else {
        if (al.al_opt_level >= 1) {
            // Spilled vreg: check register cache
            let is i32 as tidx = eo.reg_name_to_idx(target);
            let is i32 as cached = eo.rc_find(vreg);
            if (cached >= 0) {
                if (cached == tidx) { return; }
                eo.out_cstr("  mov ");
                eo.out_cstr(target);
                eo.out_cstr(", ");
                eo.out_cstr(eo.reg64(cached));
                eo.out_char(10);
                eo.rc_set(tidx, vreg);
                return;
            }
            let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
            eo.out_cstr("  mov ");
            eo.out_cstr(target);
            eo.out_cstr(", QWORD PTR [rbp-");
            eo.out_int(off);
            eo.out_cstr("]\n");
            eo.rc_set(tidx, vreg);
        } else {
            let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
            eo.out_cstr("  mov ");
            eo.out_cstr(target);
            eo.out_cstr(", QWORD PTR [rbp-");
            eo.out_int(off);
            eo.out_cstr("]\n");
        }
    }
}

fn store_op(vreg as i32, ctx as *al.AllocCtx, source as *u8) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        let is *u8 as rn = eo.reg64(loc);
        if (cast(i64, rn) != cast(i64, source)) {
            eo.out_cstr("  mov ");
            eo.out_cstr(rn);
            eo.out_cstr(", ");
            eo.out_cstr(source);
            eo.out_char(10);
        }
        if (al.al_opt_level >= 1) {
            let is i32 as sidx = eo.reg_name_to_idx(source);
            eo.rc_invalidate_reg(sidx);
            eo.rc_invalidate_reg(loc);
        }
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        eo.out_cstr("  mov QWORD PTR [rbp-");
        eo.out_int(off);
        eo.out_cstr("], ");
        eo.out_cstr(source);
        eo.out_char(10);
        if (al.al_opt_level >= 1) {
            eo.rc_invalidate_vreg(vreg);
            eo.rc_set(eo.reg_name_to_idx(source), vreg);
        }
    }
}

// Emit operand inline: register name or QWORD PTR [rbp-offset]
fn emit_op(vreg as i32, ctx as *al.AllocCtx) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    if (loc >= 0) {
        eo.out_cstr(eo.reg64(loc));
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        eo.out_cstr("QWORD PTR [rbp-");
        eo.out_int(off);
        eo.out_cstr("]");
    }
}

// Emit src2 operand: either immediate or register/memory
fn emit_src2(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    if (inst.src2.op_type == d.OP_IMM) {
        eo.out_int(inst.src2.imm);
    } else {
        emit_op(inst.src2.vreg, ctx);
    }
}

// Emit "  mov DST_LOC, IMM" handling 64-bit large immediates
fn emit_mov_imm(vreg as i32, ctx as *al.AllocCtx, val as i64) as void {
    let is i32 as loc = al.get_loc(vreg, ctx);
    let is i32 as is_large with mut = 0;
    if (val > 2147483647 || val < 0 - 2147483647) { is_large = 1; }
    if (loc >= 0) {
        if (is_large == 1) {
            eo.out_cstr("  mov ");
            eo.out_cstr(eo.reg64(loc));
            eo.out_cstr(", ");
            eo.out_int(val);
            eo.out_char(10);
        } else {
            eo.out_cstr("  mov ");
            eo.out_cstr(eo.reg64(loc));
            eo.out_cstr(", ");
            eo.out_int(val);
            eo.out_char(10);
        }
    } else {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, 0 - loc) * 8;
        if (is_large == 1) {
            eo.out_cstr("  mov rax, ");
            eo.out_int(val);
            eo.out_char(10);
            eo.out_cstr("  mov QWORD PTR [rbp-");
            eo.out_int(off);
            eo.out_cstr("], rax\n");
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(0); }
        } else {
            eo.out_cstr("  mov QWORD PTR [rbp-");
            eo.out_int(off);
            eo.out_cstr("], ");
            eo.out_int(val);
            eo.out_char(10);
        }
    }
}

fn get_type_size(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 8; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    return ty.size;
}

fn is_signed_type(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 1; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    let is i32 as k = ty.kind;
    if (k == ast.TY_I8 || k == ast.TY_I16 || k == ast.TY_I32 || k == ast.TY_I64) { return 1; }
    if (k == ast.TY_CHAR) { return 0; }
    return 0;
}

fn is_float_type(ty_ptr as *u8) as i32 {
    if (cast(i64, ty_ptr) == 0) { return 0; }
    let is *ast.Type as ty = cast(*ast.Type, ty_ptr);
    if (ty.kind == ast.TY_F32 || ty.kind == ast.TY_F64) { return 1; }
    return 0;
}

// Helper: emit binary op using dest register directly when possible
fn gen_binop(inst as *d.IRInst, ctx as *al.AllocCtx, op_name as *u8) as void {
    let is i32 as dest_loc = al.get_loc(inst.dest.vreg, ctx);
    if (dest_loc >= 0) {
        let is i32 as conflict with mut = 0;
        if (inst.src2.op_type == d.OP_VREG) {
            if (al.get_loc(inst.src2.vreg, ctx) == dest_loc) { conflict = 1; }
        }
        if (conflict == 0) {
            let is *u8 as dr = eo.reg64(dest_loc);
            load_op(inst.src1.vreg, ctx, dr);
            eo.out_cstr("  ");
            eo.out_cstr(op_name);
            eo.out_cstr(" ");
            eo.out_cstr(dr);
            eo.out_cstr(", ");
            emit_src2(inst, ctx);
            eo.out_char(10);
            // The op just clobbered dr — clear any stale cache entry
            // (load_op may have set eo.rc_set(dest_loc, src1.vreg) above)
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(dest_loc); }
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            eo.out_cstr("  ");
            eo.out_cstr(op_name);
            eo.out_cstr(" rax, ");
            eo.out_cstr(eo.reg64(dest_loc));
            eo.out_char(10);
            store_op(inst.dest.vreg, ctx, "rax");
        }
    } else {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        eo.out_cstr("  ");
        eo.out_cstr(op_name);
        eo.out_cstr(" ");
        eo.out_cstr(scr);
        eo.out_cstr(", ");
        emit_src2(inst, ctx);
        eo.out_char(10);
        store_op(inst.dest.vreg, ctx, scr);
    }
}

// === gen_inst: IMM, MOV ===

fn gen_inst_imm_mov(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_IMM) {
        emit_mov_imm(inst.dest.vreg, ctx, inst.src1.imm);
        return;
    }
    // IR_MOV
    let is i32 as dloc = al.get_loc(inst.dest.vreg, ctx);
    if (dloc >= 0) {
        load_op(inst.src1.vreg, ctx, eo.reg64(dloc));
    } else {
        let is i32 as sloc = al.get_loc(inst.src1.vreg, ctx);
        if (sloc >= 0) {
            store_op(inst.dest.vreg, ctx, eo.reg64(sloc));
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            store_op(inst.dest.vreg, ctx, "rax");
        }
    }
}

// === gen_inst: ADD, SUB, MUL, DIV, MOD, NEG ===

fn gen_inst_arith(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADD) { gen_binop(inst, ctx, "add"); return; }
    if (op == d.IR_SUB) { gen_binop(inst, ctx, "sub"); return; }
    if (op == d.IR_MUL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        if (inst.src2.op_type == d.OP_IMM) {
            load_op(inst.src1.vreg, ctx, scr);
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
        } else if (al.is_mem(inst.src2.vreg, ctx) == 1) {
            load_op(inst.src1.vreg, ctx, scr);
            load_op(inst.src2.vreg, ctx, "rcx");
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
        } else {
            load_op(inst.src1.vreg, ctx, scr);
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", ");
            emit_op(inst.src2.vreg, ctx);
            eo.out_char(10);
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_DIV) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            load_op(inst.src1.vreg, ctx, scr);
            let is i64 as shift with mut = 0;
            let is i64 as tmp with mut = inst.src2.imm;
            while (tmp > 1) { tmp = tmp >> 1; shift = shift + 1; }
            if (is_signed_type(inst.cast_to) == 1) {
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
                if (shift == 1) {
                    eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                    eo.out_line("shr rcx, 63");
                    eo.out_cstr("  add "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
                    eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", 1\n");
                } else {
                    eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                    eo.out_line("sar rcx, 63");
                    eo.out_cstr("  shr rcx, "); eo.out_int(64 - shift); eo.out_char(10);
                    eo.out_cstr("  add "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
                    eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(shift); eo.out_char(10);
                }
            } else {
                eo.out_cstr("  shr "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(shift); eo.out_char(10);
            }
            store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, "); eo.out_int(inst.src2.imm); eo.out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
        }
        eo.out_line("push rdx");
        if (is_signed_type(inst.cast_to) == 1) {
            eo.out_line("cqo");
            eo.out_line("idiv rcx");
        } else {
            eo.out_line("xor rdx, rdx");
            eo.out_line("div rcx");
        }
        eo.out_line("pop rdx");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_MOD) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            load_op(inst.src1.vreg, ctx, scr);
            let is i64 as mask = inst.src2.imm - 1;
            if (is_signed_type(inst.cast_to) == 1) {
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
                eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", 63\n");
                eo.out_cstr("  and "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(mask); eo.out_char(10);
                eo.out_cstr("  add rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  and rcx, "); eo.out_int(mask); eo.out_char(10);
                eo.out_cstr("  sub rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
            } else {
                eo.out_cstr("  and "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(mask); eo.out_char(10);
            }
            store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, "); eo.out_int(inst.src2.imm); eo.out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
        }
        eo.out_line("push rdx");
        if (is_signed_type(inst.cast_to) == 1) {
            eo.out_line("cqo");
            eo.out_line("idiv rcx");
        } else {
            eo.out_line("xor rdx, rdx");
            eo.out_line("div rcx");
        }
        eo.out_line("mov rax, rdx");
        eo.out_line("pop rdx");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_NEG
    let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
    load_op(inst.src1.vreg, ctx, scr);
    eo.out_cstr("  neg "); eo.out_cstr(scr); eo.out_char(10);
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: FADD, FSUB, FMUL, FDIV, FNEG ===

fn gen_inst_float(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_FNEG) {
        load_op(inst.src1.vreg, ctx, "rax");
        eo.out_line("movq xmm0, rax");
        if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
        eo.out_line("mov rcx, 0x8000000000000000");
        eo.out_line("movq xmm1, rcx");
        eo.out_line("xorpd xmm0, xmm1");
        eo.out_line("movq rax, xmm0");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // FADD, FSUB, FMUL, FDIV
    load_op(inst.src1.vreg, ctx, "rax");
    load_op(inst.src2.vreg, ctx, "rcx");
    eo.out_line("movq xmm0, rax");
    eo.out_line("movq xmm1, rcx");
    if (op == d.IR_FADD) { eo.out_line("addsd xmm0, xmm1"); }
    if (op == d.IR_FSUB) { eo.out_line("subsd xmm0, xmm1"); }
    if (op == d.IR_FMUL) { eo.out_line("mulsd xmm0, xmm1"); }
    if (op == d.IR_FDIV) { eo.out_line("divsd xmm0, xmm1"); }
    eo.out_line("movq rax, xmm0");
    store_op(inst.dest.vreg, ctx, "rax");
}

// === gen_inst: EQ, NE, LT, LE, GT, GE (with branch fusion) ===

fn gen_inst_compare(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    let is i32 as fused with mut = 0;
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) != 0 && nx.is_dead != 1) {
        let is i32 as nx_op = nx.op;
        if ((nx_op == d.IR_JZ || nx_op == d.IR_JNZ) && nx.src1.vreg == inst.dest.vreg) {
            load_op(inst.src1.vreg, ctx, "rax");
            if (inst.src2.op_type == d.OP_IMM && inst.src2.imm == 0) {
                eo.out_cstr("  test rax, rax\n");
            } else {
                eo.out_cstr("  cmp rax, ");
                emit_src2(inst, ctx);
                eo.out_char(10);
            }
            let is i32 as sgn = is_signed_type(inst.cast_to);
            if (nx_op == d.IR_JZ) {
                if (op == d.IR_EQ) { eo.out_cstr("  jne .L"); }
                else if (op == d.IR_NE) { eo.out_cstr("  je .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { eo.out_cstr("  jge .L"); } else { eo.out_cstr("  jae .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { eo.out_cstr("  jg .L"); } else { eo.out_cstr("  ja .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { eo.out_cstr("  jle .L"); } else { eo.out_cstr("  jbe .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { eo.out_cstr("  jl .L"); } else { eo.out_cstr("  jb .L"); } }
            } else {
                if (op == d.IR_EQ) { eo.out_cstr("  je .L"); }
                else if (op == d.IR_NE) { eo.out_cstr("  jne .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { eo.out_cstr("  jl .L"); } else { eo.out_cstr("  jb .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { eo.out_cstr("  jle .L"); } else { eo.out_cstr("  jbe .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { eo.out_cstr("  jg .L"); } else { eo.out_cstr("  ja .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { eo.out_cstr("  jge .L"); } else { eo.out_cstr("  jae .L"); } }
            }
            eo.out_int(cast(i64, nx.dest.label));
            eo.out_char(10);
            nx.is_dead = 1;
            fused = 1;
        }
    }
    if (fused == 0) {
        load_op(inst.src1.vreg, ctx, "rcx");
        eo.out_line("xor eax, eax");
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm == 0) {
            eo.out_cstr("  test rcx, rcx\n");
        } else {
            eo.out_cstr("  cmp rcx, ");
            emit_src2(inst, ctx);
            eo.out_char(10);
        }
        if (op == d.IR_EQ) { eo.out_line("sete al"); }
        if (op == d.IR_NE) { eo.out_line("setne al"); }
        let is i32 as sgn2 = is_signed_type(inst.cast_to);
        if (op == d.IR_LT) { if (sgn2 == 1) { eo.out_line("setl al"); } else { eo.out_line("setb al"); } }
        if (op == d.IR_LE) { if (sgn2 == 1) { eo.out_line("setle al"); } else { eo.out_line("setbe al"); } }
        if (op == d.IR_GT) { if (sgn2 == 1) { eo.out_line("setg al"); } else { eo.out_line("seta al"); } }
        if (op == d.IR_GE) { if (sgn2 == 1) { eo.out_line("setge al"); } else { eo.out_line("setae al"); } }
        store_op(inst.dest.vreg, ctx, "rax");
    }
}

// === gen_inst: SHL, SHR, AND, OR, XOR, NOT ===

fn gen_inst_shift_bitwise(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SHL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            eo.out_cstr("  shl ");
            eo.out_cstr(scr);
            eo.out_cstr(", ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
            eo.out_cstr("  shl ");
            eo.out_cstr(scr);
            eo.out_cstr(", cl\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SHR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            if (is_signed_type(inst.cast_to) == 1) {
                eo.out_cstr("  sar ");
            } else {
                eo.out_cstr("  shr ");
            }
            eo.out_cstr(scr);
            eo.out_cstr(", ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
        } else {
            load_op(inst.src2.vreg, ctx, "rcx");
            if (is_signed_type(inst.cast_to) == 1) {
                eo.out_cstr("  sar ");
            } else {
                eo.out_cstr("  shr ");
            }
            eo.out_cstr(scr);
            eo.out_cstr(", cl\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_AND) { gen_binop(inst, ctx, "and"); return; }
    if (op == d.IR_OR) { gen_binop(inst, ctx, "or"); return; }
    if (op == d.IR_XOR) { gen_binop(inst, ctx, "xor"); return; }
    // IR_NOT
    let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
    load_op(inst.src1.vreg, ctx, scr);
    eo.out_cstr("  not ");
    eo.out_cstr(scr);
    eo.out_char(10);
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: RET, LABEL, JMP, JZ, JNZ ===

fn gen_inst_control(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_RET) {
        if (inst.src1.op_type != d.OP_NONE) {
            load_op(inst.src1.vreg, ctx, "rax");
        }
        if (ctx.aligned_stack_size > 0) {
            eo.out_cstr("  add rsp, ");
            eo.out_int(cast(i64, ctx.aligned_stack_size));
            eo.out_char(10);
        }
        if (ctx.used_callee_mask & 16) { eo.out_line("pop r15"); }
        if (ctx.used_callee_mask & 8) { eo.out_line("pop r14"); }
        if (ctx.used_callee_mask & 4) { eo.out_line("pop r13"); }
        if (ctx.used_callee_mask & 2) { eo.out_line("pop r12"); }
        if (ctx.used_callee_mask & 1) { eo.out_line("pop rbx"); }
        eo.out_line("pop rbp");
        eo.out_line("ret");
        return;
    }
    if (op == d.IR_LABEL) {
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        eo.out_cstr(".L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_cstr(":\n");
        return;
    }
    if (op == d.IR_JMP) {
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        eo.out_cstr("  jmp .L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_char(10);
        return;
    }
    if (op == d.IR_JZ) {
        load_op(inst.src1.vreg, ctx, "rax");
        eo.out_line("test rax, rax");
        eo.out_cstr("  jz .L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_char(10);
        return;
    }
    // IR_JNZ
    load_op(inst.src1.vreg, ctx, "rax");
    eo.out_line("test rax, rax");
    eo.out_cstr("  jnz .L");
    eo.out_int(cast(i64, inst.dest.label));
    eo.out_char(10);
}

// === gen_inst: ADDR, ADDR_GLOBAL, FN_ADDR, GET_ALLOC_ADDR, LOAD, STORE, COPY, ASM, CAST ===

fn gen_inst_memory(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADDR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rbp-");
        eo.out_int(inst.src1.imm);
        eo.out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_ADDR_GLOBAL) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        if (inst.is_extern_global == 1) {
            eo.out_cstr("  mov ");
            eo.out_cstr(scr);
            eo.out_cstr(", QWORD PTR [rip+");
            eo.out_str(inst.global_name_ptr, inst.global_name_len);
            eo.out_cstr("]\n");
        } else {
            eo.out_cstr("  lea ");
            eo.out_cstr(scr);
            eo.out_cstr(", [rip+");
            eo.out_str(inst.global_name_ptr, inst.global_name_len);
            eo.out_cstr("]\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_FN_ADDR) {
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rip+");
        eo.out_str(inst.global_name_ptr, inst.global_name_len);
        eo.out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_GET_ALLOC_ADDR) {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, ctx.stack_slots) * 8 + inst.src1.imm;
        let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rbp-");
        eo.out_int(off);
        eo.out_cstr("]\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SET_CTX) {
        if (inst.src1.op_type == d.OP_IMM) {
            eo.out_line("xor r10, r10");
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(8); }
        } else {
            load_op(inst.src1.vreg, ctx, "r10");
        }
        return;
    }
    if (op == d.IR_LOAD) {
        let is i32 as sz = get_type_size(inst.cast_to);
        let is i32 as sgn = is_signed_type(inst.cast_to);
        let is i32 as si = get_scratch_idx(inst.dest.vreg, ctx);
        let is *u8 as scr = eo.reg64(si);
        let is *u8 as scr32 = eo.reg32(si);
        if (inst.src1.op_type == d.OP_VREG) {
            let is AddrMode as am with mut;
            am.matched = 0;
            if (al.al_opt_level >= 1) {
                am = try_match_addr(inst.src1.vreg, ctx);
            }
            if (am.matched == 1) {
                load_op(am.base_vreg, ctx, "rax");
                load_op(am.index_vreg, ctx, "rcx");
                if (sz == 8) {
                    eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 4) {
                    if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); } else { eo.out_cstr("  mov "); eo.out_cstr(scr32); }
                    eo.out_cstr(", DWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 2) {
                    if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                    eo.out_cstr(scr); eo.out_cstr(", WORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 1) {
                    if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                    eo.out_cstr(scr); eo.out_cstr(", BYTE PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else {
                    eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                }
            } else {
            load_op(inst.src1.vreg, ctx, scr);
            if (sz == 8) {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); eo.out_cstr(", DWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n"); }
                else { eo.out_cstr("  mov "); eo.out_cstr(scr32); eo.out_cstr(", DWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n"); }
            } else if (sz == 2) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", WORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", BYTE PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            }
            }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp-");
                eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) {
                    eo.out_cstr("  movsxd "); eo.out_cstr(scr);
                } else {
                    eo.out_cstr("  mov "); eo.out_cstr(scr32);
                }
                eo.out_cstr(", DWORD PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 2) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", WORD PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", BYTE PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp-");
                eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            }
        }
        // f32 load: widen f32 bitpattern to f64 for internal representation
        if (sz == 4 && is_float_type(inst.cast_to) == 1) {
            eo.out_cstr("  movd xmm0, "); eo.out_cstr(scr32); eo.out_char(10);
            eo.out_line("cvtss2sd xmm0, xmm0");
            eo.out_cstr("  movq "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        }
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_STORE) {
        let is i32 as sz = get_type_size(inst.cast_to);
        load_op(inst.src1.vreg, ctx, "rax");
        // f32 store: value in rax is f64 bitpattern, convert to f32 bitpattern
        if (sz == 4 && is_float_type(inst.cast_to) == 1) {
            eo.out_line("movq xmm0, rax");
            eo.out_line("cvtsd2ss xmm0, xmm0");
            eo.out_line("movd eax, xmm0");
        }
        if (inst.dest.op_type == d.OP_VREG) {
            load_op(inst.dest.vreg, ctx, "rcx");
            if (sz == 8) { eo.out_line("mov QWORD PTR [rcx], rax"); }
            else if (sz == 4) { eo.out_line("mov DWORD PTR [rcx], eax"); }
            else if (sz == 2) { eo.out_line("mov WORD PTR [rcx], ax"); }
            else if (sz == 1) { eo.out_line("mov BYTE PTR [rcx], al"); }
            else { eo.out_line("mov QWORD PTR [rcx], rax"); }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                eo.out_cstr("  mov QWORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], rax\n");
            } else if (sz == 4) {
                eo.out_cstr("  mov DWORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], eax\n");
            } else if (sz == 2) {
                eo.out_cstr("  mov WORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], ax\n");
            } else if (sz == 1) {
                eo.out_cstr("  mov BYTE PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], al\n");
            } else {
                // Struct > 8 bytes: rax is a pointer to the struct data.
                // Copy from [rax] to [rbp-dest] using rcx as scratch.
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(0); eo.rc_invalidate_reg(1); }
                eo.out_line("mov rcx, rax");
                let is i32 as soff with mut = 0;
                while (soff + 8 <= sz) {
                    eo.out_cstr("  mov rax, QWORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov QWORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], rax\n");
                    soff = soff + 8;
                }
                if (soff + 4 <= sz) {
                    eo.out_cstr("  mov eax, DWORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov DWORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], eax\n");
                    soff = soff + 4;
                }
                if (soff + 2 <= sz) {
                    eo.out_cstr("  movzx eax, WORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov WORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], ax\n");
                    soff = soff + 2;
                }
                if (soff < sz) {
                    eo.out_cstr("  movzx eax, BYTE PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov BYTE PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], al\n");
                }
            }
        }
        return;
    }
    if (op == d.IR_COPY) {
        load_op(inst.dest.vreg, ctx, "rdi");
        load_op(inst.src1.vreg, ctx, "rsi");
        eo.out_cstr("  mov rcx, ");
        eo.out_int(inst.src2.imm);
        eo.out_char(10);
        eo.out_line("cld");
        eo.out_line("rep movsb");
        // rep movsb clobbers rdi, rsi, rcx
        if (al.al_opt_level >= 1) {
            eo.rc_invalidate_reg(5);
            eo.rc_invalidate_reg(4);
            eo.rc_invalidate_reg(1);
        }
        return;
    }
    if (op == d.IR_ASM) {
        eo.out_cstr("  ");
        eo.out_str(inst.asm_str_ptr, inst.asm_str_len);
        eo.out_char(10);
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        return;
    }
    // IR_CAST
    let is i32 as to_flt = is_float_type(inst.cast_to);
    let is i32 as from_flt = is_float_type(inst.cast_from);
    let is i32 as si = get_scratch_idx(inst.dest.vreg, ctx);
    let is *u8 as scr = eo.reg64(si);
    load_op(inst.src1.vreg, ctx, scr);
    if (from_flt == 1 && to_flt == 0) {
        eo.out_cstr("  movq xmm0, "); eo.out_cstr(scr); eo.out_char(10);
        eo.out_cstr("  cvttsd2si "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (from_flt == 0 && to_flt == 1) {
        eo.out_cstr("  cvtsi2sd xmm0, "); eo.out_cstr(scr); eo.out_char(10);
        eo.out_cstr("  movq "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    let is i32 as to_sz = get_type_size(inst.cast_to);
    let is i32 as sgn = is_signed_type(inst.cast_to);
    if (to_sz == 4) {
        if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg32(si)); eo.out_char(10); }
        else { eo.out_cstr("  mov "); eo.out_cstr(eo.reg32(si)); eo.out_cstr(", "); eo.out_cstr(eo.reg32(si)); eo.out_char(10); }
    } else if (to_sz == 2) {
        if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
        eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg16(si)); eo.out_char(10);
    } else if (to_sz == 1) {
        if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
        eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg8(si)); eo.out_char(10);
    }
    store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: SET_ARG, GET_ARG, SET_SYS_ARG, SYSCALL, CALL, VA_START ===

fn gen_inst_calls(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SET_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        if (is_float_type(inst.cast_to) == 1) {
            // Extern float arg: load to rax/eax then move to xmmN
            load_op(inst.src1.vreg, ctx, "rax");
            let is i32 as fsz = get_type_size(inst.cast_to);
            if (fsz == 4) {
                // f32: load as f64, convert to f32 for C ABI
                eo.out_cstr("  movq xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", rax\n");
                eo.out_cstr("  cvtsd2ss xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", xmm");
                eo.out_int(cast(i64, idx));
                eo.out_char(10);
            } else {
                // f64: movq xmmN, rax
                eo.out_cstr("  movq xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", rax\n");
            }
        } else if (idx < 6) {
            load_op(inst.src1.vreg, ctx, eo.arg_reg64(idx));
        } else {
            load_op(inst.src1.vreg, ctx, "rax");
            eo.out_line("push rax");
        }
        return;
    }
    if (op == d.IR_GET_ARG) {
        let is i32 as idx = cast(i32, inst.src1.imm);
        if (idx < 6) {
            store_op(inst.dest.vreg, ctx, eo.arg_reg64(idx));
        } else {
            let is i64 as off = 16 + cast(i64, idx - 6) * 8;
            let is *u8 as scr = get_scratch(inst.dest.vreg, ctx);
            eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp+");
            eo.out_int(off);
            eo.out_cstr("]\n");
            store_op(inst.dest.vreg, ctx, scr);
        }
        return;
    }
    if (op == d.IR_SET_SYS_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        load_op(inst.src1.vreg, ctx, eo.syscall_reg(idx));
        return;
    }
    if (op == d.IR_SYSCALL) {
        eo.out_line("syscall");
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_CALL) {
        if (inst.is_variadic_call == 1) {
            let is i32 as xmm_n = cast(i32, inst.src1.imm);
            if (xmm_n > 0) {
                eo.out_cstr("  mov eax, ");
                eo.out_int(cast(i64, xmm_n));
                eo.out_char(10);
            } else {
                eo.out_line("xor eax, eax");
            }
        }
        eo.out_cstr("  call ");
        eo.out_str(inst.call_name_ptr, inst.call_name_len);
        eo.out_char(10);
        // Handle return type ABI (only for extern calls — internal calls return in rax)
        if (cast(i64, inst.cast_to) != 0 && inst.is_extern_call == 1) {
            let is i32 as ret_sz = get_type_size(inst.cast_to);
            if (is_float_type(inst.cast_to) == 1) {
                if (ret_sz == 4) {
                    eo.out_line("cvtss2sd xmm0, xmm0");
                }
                // extern fn returns float in xmm0 — move to rax for internal ABI
                eo.out_line("movq rax, xmm0");
            } else if (ret_sz == 1) {
                if (is_signed_type(inst.cast_to) == 1) { eo.out_line("movsx rax, al"); }
                else { eo.out_line("movzx eax, al"); }
            } else if (ret_sz == 2) {
                if (is_signed_type(inst.cast_to) == 1) { eo.out_line("movsx rax, ax"); }
                else { eo.out_line("movzx eax, ax"); }
            }
        }
        store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_VA_START
    let is i32 as num_args = cast(i32, inst.src2.imm);
    load_op(inst.src1.vreg, ctx, "rcx");
    eo.out_cstr("  mov DWORD PTR [rcx], ");
    eo.out_int(cast(i64, num_args) * 8);
    eo.out_char(10);
    eo.out_line("mov DWORD PTR [rcx+4], 48");
    let is i64 as overflow_off with mut = 16;
    if (num_args > 6) {
        overflow_off = 16 + cast(i64, num_args - 6) * 8;
    }
    eo.out_cstr("  lea rax, [rbp+");
    eo.out_int(overflow_off);
    eo.out_cstr("]\n");
    eo.out_line("mov QWORD PTR [rcx+8], rax");
    eo.out_cstr("  lea rax, [rbp-");
    eo.out_int(cast(i64, ctx.va_save_offset));
    eo.out_cstr("]\n");
    eo.out_line("mov QWORD PTR [rcx+16], rax");
    if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(0); }
}

// === Instruction selection: use counts + pattern matching on IR ===
// vreg_uses[v] = number of times v appears as src1, src2, or STORE/COPY dest
let is *i32 as isel_uses with mut;
let is i32 as isel_vc with mut = 0;

fn isel_init(func as *d.IRFunction) as void {
    isel_vc = func.vreg_count;
    isel_uses = cast(*i32, mem.galloc(cast(i64, isel_vc) * 4));
    let is i32 as i with mut = 0;
    while (i < isel_vc) {
        let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, i) * 4);
        *p = 0;
        i = i + 1;
    }
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.is_dead == 0) {
            if (inst.src1.op_type == d.OP_VREG && inst.src1.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.src1.vreg) * 4);
                *p = *p + 1;
            }
            if (inst.src2.op_type == d.OP_VREG && inst.src2.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.src2.vreg) * 4);
                *p = *p + 1;
            }
            if ((inst.op == d.IR_STORE || inst.op == d.IR_COPY) && inst.dest.op_type == d.OP_VREG && inst.dest.vreg < isel_vc) {
                let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, inst.dest.vreg) * 4);
                *p = *p + 1;
            }
        }
        inst = inst.next;
    }
}

fn isel_get_uses(vreg as i32) as i32 {
    if (vreg < 0 || vreg >= isel_vc) { return 99; }
    let is *i32 as p = cast(*i32, cast(i64, isel_uses) + cast(i64, vreg) * 4);
    return *p;
}

// vreg_def[v] = pointer to the IRInst that defines vreg v (0 = unknown)
let is *i64 as isel_defs with mut;

fn isel_init_defs(func as *d.IRFunction) as void {
    isel_defs = cast(*i64, mem.galloc(cast(i64, isel_vc) * 8));
    let is i32 as i with mut = 0;
    while (i < isel_vc) {
        let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, i) * 8);
        *p = 0;
        i = i + 1;
    }
    let is *d.IRInst as inst with mut = func.instructions;
    while (cast(i64, inst) != 0) {
        if (inst.is_dead == 0 && inst.dest.op_type == d.OP_VREG) {
            let is i32 as dv = inst.dest.vreg;
            if (dv >= 0 && dv < isel_vc) {
                let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, dv) * 8);
                *p = cast(i64, inst);
            }
        }
        inst = inst.next;
    }
}

fn isel_get_def(vreg as i32) as *d.IRInst {
    if (vreg < 0 || vreg >= isel_vc) { return cast(*d.IRInst, 0); }
    let is *i64 as p = cast(*i64, cast(i64, isel_defs) + cast(i64, vreg) * 8);
    return cast(*d.IRInst, *p);
}

// Addressing mode result: [base_reg + index_reg * scale]
// scale: 1, 2, 4, or 8. If scale=0, no index.
struct AddrMode {
    base_vreg as i32;
    index_vreg as i32;
    scale as i32;
    matched as i32;
}

// Try to match addr = ADD(base, SHL(index, log2(scale))) where scale is 1/2/4/8
// Returns matched=1 if successful, 0 otherwise.
fn try_match_addr(addr_vreg as i32, ctx as *al.AllocCtx) as AddrMode {
    let is AddrMode as r;
    r.matched = 0;
    r.base_vreg = addr_vreg;
    r.index_vreg = 0;
    r.scale = 0;
    let is *d.IRInst as def = isel_get_def(addr_vreg);
    if (cast(i64, def) == 0) { return r; }
    if (def.op != d.IR_ADD) { return r; }
    if (def.src1.op_type != d.OP_VREG || def.src2.op_type != d.OP_VREG) { return r; }
    // Only fuse if the ADD result has exactly 1 use (this LOAD/STORE)
    if (isel_get_uses(addr_vreg) != 1) { return r; }
    // Check if src2 is SHL(index, shift) where shift is 0/1/2/3
    let is *d.IRInst as shl_def = isel_get_def(def.src2.vreg);
    if (cast(i64, shl_def) == 0) { return r; }
    if (shl_def.op != d.IR_SHL) { return r; }
    if (shl_def.src2.op_type != d.OP_IMM) { return r; }
    let is i64 as shift = shl_def.src2.imm;
    if (shift < 0 || shift > 3) { return r; }
    // Only fuse if SHL result has exactly 1 use (the ADD)
    if (isel_get_uses(def.src2.vreg) != 1) { return r; }
    r.base_vreg = def.src1.vreg;
    r.index_vreg = shl_def.src1.vreg;
    // Safety: base and index must be spilled (not register-allocated) because
    // the register allocator may have reused their physical registers for the
    // ADD/SHL results by this point. Spilled values are always available.
    if (al.is_mem(r.base_vreg, ctx) == 0 || al.is_mem(r.index_vreg, ctx) == 0) { return r; }
    if (shift == 0) { r.scale = 1; }
    else if (shift == 1) { r.scale = 2; }
    else if (shift == 2) { r.scale = 4; }
    else { r.scale = 8; }
    r.matched = 1;
    return r;
}

fn size_name(sz as i32) as *u8 {
    if (sz == 8) { return "QWORD PTR"; }
    if (sz == 4) { return "DWORD PTR"; }
    if (sz == 2) { return "WORD PTR"; }
    if (sz == 1) { return "BYTE PTR"; }
    return "QWORD PTR";
}

fn size_reg(idx as i32, sz as i32) as *u8 {
    if (sz == 8) { return eo.reg64(idx); }
    if (sz == 4) { return eo.reg32(idx); }
    if (sz == 2) { return eo.reg16(idx); }
    if (sz == 1) { return eo.reg8(idx); }
    return eo.reg64(idx);
}

// Pattern: IR_IMM v=const + IR_STORE [addr]=v → mov PTR [addr], const
// Only when addr is a vreg (indirect store) and imm fits 32-bit
fn try_fuse_imm_store(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_STORE) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    // Safety: only fuse if the IMM vreg has exactly 1 use (the STORE)
    if (isel_get_uses(inst.dest.vreg) != 1) { return 0; }
    if (nx.dest.op_type != d.OP_VREG) { return 0; }
    let is i64 as val = inst.src1.imm;
    if (val > 2147483647 || val < 0 - 2147483647) { return 0; }
    let is i32 as sz = get_type_size(nx.cast_to);
    if (sz > 8) { return 0; }
    // Emit: mov SIZE PTR [addr_reg], imm
    load_op(nx.dest.vreg, ctx, "rcx");
    eo.out_cstr("  mov ");
    eo.out_cstr(size_name(sz));
    eo.out_cstr(" [rcx], ");
    eo.out_int(val);
    eo.out_char(10);
    nx.is_dead = 1;
    return 1;
}

// Pattern: IR_IMM v=const + IR_STORE dest=IMM(offset), src1=v → mov PTR [rbp-off], const
// Store immediate to stack without loading into register first
fn try_fuse_imm_store_stack(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_STORE) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    if (isel_get_uses(inst.dest.vreg) != 1) { return 0; }
    if (nx.dest.op_type != d.OP_IMM) { return 0; }
    let is i64 as val = inst.src1.imm;
    if (val > 2147483647 || val < 0 - 2147483647) { return 0; }
    let is i32 as sz = get_type_size(nx.cast_to);
    if (sz > 8) { return 0; }
    // Emit: mov SIZE PTR [rbp-off], imm
    eo.out_cstr("  mov ");
    eo.out_cstr(size_name(sz));
    eo.out_cstr(" [rbp-");
    eo.out_int(nx.dest.imm);
    eo.out_cstr("], ");
    eo.out_int(val);
    eo.out_char(10);
    nx.is_dead = 1;
    return 1;
}

// Pattern: IR_LOAD v1=[rbp-X] + IR_ADD/SUB v2=v1,imm + IR_STORE [rbp-X]=v2
// → add/sub SIZE PTR [rbp-X], imm
fn try_fuse_inc_stack(inst as *d.IRInst, ctx as *al.AllocCtx) as i32 {
    if (inst.src1.op_type != d.OP_IMM) { return 0; }
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) == 0 || nx.is_dead == 1) { return 0; }
    if (nx.op != d.IR_ADD && nx.op != d.IR_SUB) { return 0; }
    if (nx.src1.op_type != d.OP_VREG || nx.src1.vreg != inst.dest.vreg) { return 0; }
    if (nx.src2.op_type != d.OP_IMM) { return 0; }
    let is i64 as addval = nx.src2.imm;
    if (addval > 2147483647 || addval < 0 - 2147483647) { return 0; }
    let is *d.IRInst as nx2 = nx.next;
    if (cast(i64, nx2) == 0 || nx2.is_dead == 1) { return 0; }
    if (nx2.op != d.IR_STORE) { return 0; }
    if (nx2.dest.op_type != d.OP_IMM) { return 0; }
    if (nx2.dest.imm != inst.src1.imm) { return 0; }
    if (nx2.src1.op_type != d.OP_VREG || nx2.src1.vreg != nx.dest.vreg) { return 0; }
    let is i32 as sz = get_type_size(inst.cast_to);
    if (sz > 8) { return 0; }
    // Emit: add/sub SIZE PTR [rbp-X], imm
    if (nx.op == d.IR_ADD) { eo.out_cstr("  add "); }
    else { eo.out_cstr("  sub "); }
    eo.out_cstr(size_name(sz));
    eo.out_cstr(" [rbp-");
    eo.out_int(inst.src1.imm);
    eo.out_cstr("], ");
    eo.out_int(addval);
    eo.out_char(10);
    // Mark consumed instructions dead but keep them for vreg tracking
    nx.is_dead = 1;
    nx2.is_dead = 1;
    // The LOAD result (inst.dest) may still be needed if it has other uses
    // For safety, still emit the load normally
    return 0;
}

// === gen_inst: thin dispatcher ===

fn gen_inst(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;

    if (al.al_opt_level >= 1) {
        // Invalidate dest register — it will be overwritten by this instruction
        if (inst.dest.op_type == d.OP_VREG && op != d.IR_STORE && op != d.IR_COPY) {
            let is i32 as dest_loc = al.get_loc(inst.dest.vreg, ctx);
            if (dest_loc >= 0) {
                eo.rc_invalidate_reg(dest_loc);
            }
            // Also invalidate any cached entry for this vreg (it's being redefined)
            eo.rc_invalidate_vreg(inst.dest.vreg);
        }

        // Full invalidation on calls (all caller-saved regs clobbered)
        if (op == d.IR_CALL || op == d.IR_SYSCALL) { eo.ph_invalidate(); }

        // Instruction selection: try fused patterns before standard emission
        if (op == d.IR_IMM) {
            if (try_fuse_imm_store(inst, ctx) == 1) { return; }
            if (try_fuse_imm_store_stack(inst, ctx) == 1) { return; }
        }
        if (op == d.IR_LOAD) {
            try_fuse_inc_stack(inst, ctx);
            // Note: try_fuse_inc_stack returns 0 always — load still emitted normally
        }
    }

    if (op == d.IR_IMM || op == d.IR_MOV) { gen_inst_imm_mov(inst, ctx); return; }
    if (op == d.IR_ADD || op == d.IR_SUB || op == d.IR_MUL || op == d.IR_DIV || op == d.IR_MOD || op == d.IR_NEG) { gen_inst_arith(inst, ctx); return; }
    if (op == d.IR_FADD || op == d.IR_FSUB || op == d.IR_FMUL || op == d.IR_FDIV || op == d.IR_FNEG) { gen_inst_float(inst, ctx); return; }
    if (op == d.IR_EQ || op == d.IR_NE || op == d.IR_LT || op == d.IR_LE || op == d.IR_GT || op == d.IR_GE) { gen_inst_compare(inst, ctx); return; }
    if (op == d.IR_SHL || op == d.IR_SHR || op == d.IR_AND || op == d.IR_OR || op == d.IR_XOR || op == d.IR_NOT) { gen_inst_shift_bitwise(inst, ctx); return; }
    if (op == d.IR_RET || op == d.IR_LABEL || op == d.IR_JMP || op == d.IR_JZ || op == d.IR_JNZ) { gen_inst_control(inst, ctx); return; }
    if (op == d.IR_SET_ARG || op == d.IR_GET_ARG || op == d.IR_SET_SYS_ARG || op == d.IR_SYSCALL || op == d.IR_CALL || op == d.IR_VA_START) { gen_inst_calls(inst, ctx); return; }
    // Memory, load/store, copy, asm, cast, set_ctx
    gen_inst_memory(inst, ctx);
}

// === gen_func ===
