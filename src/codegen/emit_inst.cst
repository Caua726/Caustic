use "../../std/mem.cst" as mem;
use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "../parser/ast.cst" as ast;
use "../ir/defs.cst" as d;
use "alloc_core.cst" as al;
use "emit_output.cst" as eo;
use "emit.cst" as e;

fn gen_inst_imm_mov(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_IMM) {
        e.emit_mov_imm(inst.dest.vreg, ctx, inst.src1.imm);
        return;
    }
    // IR_MOV
    let is i32 as dloc = al.get_loc(inst.dest.vreg, ctx);
    if (dloc >= 0) {
        e.load_op(inst.src1.vreg, ctx, eo.reg64(dloc));
    } else {
        let is i32 as sloc = al.get_loc(inst.src1.vreg, ctx);
        if (sloc >= 0) {
            e.store_op(inst.dest.vreg, ctx, eo.reg64(sloc));
        } else {
            e.load_op(inst.src1.vreg, ctx, "rax");
            e.store_op(inst.dest.vreg, ctx, "rax");
        }
    }
}

// === gen_inst: ADD, SUB, MUL, DIV, MOD, NEG ===

fn gen_inst_arith(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADD) { e.gen_binop(inst, ctx, "add"); return; }
    if (op == d.IR_SUB) { e.gen_binop(inst, ctx, "sub"); return; }
    if (op == d.IR_MUL) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        if (inst.src2.op_type == d.OP_IMM) {
            e.load_op(inst.src1.vreg, ctx, scr);
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
        } else if (al.is_mem(inst.src2.vreg, ctx) == 1) {
            e.load_op(inst.src1.vreg, ctx, scr);
            e.load_op(inst.src2.vreg, ctx, "rcx");
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
        } else {
            e.load_op(inst.src1.vreg, ctx, scr);
            eo.out_cstr("  imul "); eo.out_cstr(scr); eo.out_cstr(", ");
            e.emit_op(inst.src2.vreg, ctx);
            eo.out_char(10);
        }
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_DIV) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
            e.load_op(inst.src1.vreg, ctx, scr);
            let is i64 as shift with mut = 0;
            let is i64 as tmp with mut = inst.src2.imm;
            while (tmp > 1) { tmp = tmp >> 1; shift = shift + 1; }
            if (e.is_signed_type(inst.cast_to) == 1) {
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
                if (shift == 1) {
                    eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                    eo.out_line("shr rcx, 63");
                    eo.out_cstr("  add "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
                    eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", 1\n");
                } else {
                    eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                    eo.out_line("sar rcx, 63");
                    eo.out_cstr("  shr rcx, "); eo.out_int(64 - shift); eo.out_char(10);
                    eo.out_cstr("  add "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
                    eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(shift); eo.out_char(10);
                }
            } else {
                eo.out_cstr("  shr "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(shift); eo.out_char(10);
            }
            e.store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        e.load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, "); eo.out_int(inst.src2.imm); eo.out_char(10);
        } else {
            e.load_op(inst.src2.vreg, ctx, "rcx");
        }
        eo.out_line("push rdx");
        if (e.is_signed_type(inst.cast_to) == 1) {
            eo.out_line("cqo");
            eo.out_line("idiv rcx");
        } else {
            eo.out_line("xor rdx, rdx");
            eo.out_line("div rcx");
        }
        eo.out_line("pop rdx");
        e.store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_MOD) {
        // Check for power-of-2 constant divisor
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm > 0 && (inst.src2.imm & (inst.src2.imm - 1)) == 0) {
            let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
            e.load_op(inst.src1.vreg, ctx, scr);
            let is i64 as mask = inst.src2.imm - 1;
            if (e.is_signed_type(inst.cast_to) == 1) {
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
                eo.out_cstr("  mov rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  sar "); eo.out_cstr(scr); eo.out_cstr(", 63\n");
                eo.out_cstr("  and "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(mask); eo.out_char(10);
                eo.out_cstr("  add rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  and rcx, "); eo.out_int(mask); eo.out_char(10);
                eo.out_cstr("  sub rcx, "); eo.out_cstr(scr); eo.out_char(10);
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", rcx\n");
            } else {
                eo.out_cstr("  and "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_int(mask); eo.out_char(10);
            }
            e.store_op(inst.dest.vreg, ctx, scr);
            return;
        }
        e.load_op(inst.src1.vreg, ctx, "rax");
        if (inst.src2.op_type == d.OP_IMM) {
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
            eo.out_cstr("  mov rcx, "); eo.out_int(inst.src2.imm); eo.out_char(10);
        } else {
            e.load_op(inst.src2.vreg, ctx, "rcx");
        }
        eo.out_line("push rdx");
        if (e.is_signed_type(inst.cast_to) == 1) {
            eo.out_line("cqo");
            eo.out_line("idiv rcx");
        } else {
            eo.out_line("xor rdx, rdx");
            eo.out_line("div rcx");
        }
        eo.out_line("mov rax, rdx");
        eo.out_line("pop rdx");
        e.store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_NEG
    let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
    e.load_op(inst.src1.vreg, ctx, scr);
    eo.out_cstr("  neg "); eo.out_cstr(scr); eo.out_char(10);
    e.store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: FADD, FSUB, FMUL, FDIV, FNEG ===

fn gen_inst_float(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_FNEG) {
        e.load_op(inst.src1.vreg, ctx, "rax");
        eo.out_line("movq xmm0, rax");
        if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(1); }
        eo.out_line("mov rcx, 0x8000000000000000");
        eo.out_line("movq xmm1, rcx");
        eo.out_line("xorpd xmm0, xmm1");
        eo.out_line("movq rax, xmm0");
        e.store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // FADD, FSUB, FMUL, FDIV
    e.load_op(inst.src1.vreg, ctx, "rax");
    e.load_op(inst.src2.vreg, ctx, "rcx");
    eo.out_line("movq xmm0, rax");
    eo.out_line("movq xmm1, rcx");
    if (op == d.IR_FADD) { eo.out_line("addsd xmm0, xmm1"); }
    if (op == d.IR_FSUB) { eo.out_line("subsd xmm0, xmm1"); }
    if (op == d.IR_FMUL) { eo.out_line("mulsd xmm0, xmm1"); }
    if (op == d.IR_FDIV) { eo.out_line("divsd xmm0, xmm1"); }
    eo.out_line("movq rax, xmm0");
    e.store_op(inst.dest.vreg, ctx, "rax");
}

// === gen_inst: EQ, NE, LT, LE, GT, GE (with branch fusion) ===

fn cmp_try_inline_imm(inst as *d.IRInst) as i64 {
    // Check if src2 is a vreg defined by a single-use IMM — inline the constant
    if (inst.src2.op_type == d.OP_IMM) { return inst.src2.imm; }
    if (inst.src2.op_type != d.OP_VREG) { return cast(i64, 0) - cast(i64, 9999999999); }
    if (al.al_opt_level < 1) { return cast(i64, 0) - cast(i64, 9999999999); }
    let is i32 as s2v = inst.src2.vreg;
    if (e.isel_get_uses(s2v) != 1) { return cast(i64, 0) - cast(i64, 9999999999); }
    let is *d.IRInst as def = e.isel_get_def(s2v);
    if (cast(i64, def) == 0) { return cast(i64, 0) - cast(i64, 9999999999); }
    if (def.op != d.IR_IMM) { return cast(i64, 0) - cast(i64, 9999999999); }
    let is i64 as v = def.src1.imm;
    if (v < (0 - 2147483647) || v > 2147483647) { return cast(i64, 0) - cast(i64, 9999999999); }
    def.is_dead = 1;
    return v;
}

fn gen_inst_compare(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    let is i32 as fused with mut = 0;
    let is *d.IRInst as nx = inst.next;
    if (cast(i64, nx) != 0 && nx.is_dead != 1) {
        let is i32 as nx_op = nx.op;
        if ((nx_op == d.IR_JZ || nx_op == d.IR_JNZ) && nx.src1.vreg == inst.dest.vreg) {
            // Try inline constant for src2 (done in codegen, not fold, to preserve register barriers)
            let is i64 as imm_val = cmp_try_inline_imm(inst);
            let is i32 as has_imm with mut = 0;
            if (imm_val != cast(i64, 0) - cast(i64, 9999999999)) { has_imm = 1; }
            e.load_op(inst.src1.vreg, ctx, "rax");
            if (has_imm == 1 && imm_val == 0) {
                eo.out_cstr("  test rax, rax\n");
            } else if (has_imm == 1) {
                eo.out_cstr("  cmp rax, ");
                eo.out_int(imm_val);
                eo.out_char(10);
            } else {
                eo.out_cstr("  cmp rax, ");
                e.emit_src2(inst, ctx);
                eo.out_char(10);
            }
            let is i32 as sgn = e.is_signed_type(inst.cast_to);
            if (nx_op == d.IR_JZ) {
                if (op == d.IR_EQ) { eo.out_cstr("  jne .L"); }
                else if (op == d.IR_NE) { eo.out_cstr("  je .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { eo.out_cstr("  jge .L"); } else { eo.out_cstr("  jae .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { eo.out_cstr("  jg .L"); } else { eo.out_cstr("  ja .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { eo.out_cstr("  jle .L"); } else { eo.out_cstr("  jbe .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { eo.out_cstr("  jl .L"); } else { eo.out_cstr("  jb .L"); } }
            } else {
                if (op == d.IR_EQ) { eo.out_cstr("  je .L"); }
                else if (op == d.IR_NE) { eo.out_cstr("  jne .L"); }
                else if (op == d.IR_LT) { if (sgn == 1) { eo.out_cstr("  jl .L"); } else { eo.out_cstr("  jb .L"); } }
                else if (op == d.IR_LE) { if (sgn == 1) { eo.out_cstr("  jle .L"); } else { eo.out_cstr("  jbe .L"); } }
                else if (op == d.IR_GT) { if (sgn == 1) { eo.out_cstr("  jg .L"); } else { eo.out_cstr("  ja .L"); } }
                else if (op == d.IR_GE) { if (sgn == 1) { eo.out_cstr("  jge .L"); } else { eo.out_cstr("  jae .L"); } }
            }
            eo.out_int(cast(i64, nx.dest.label));
            eo.out_char(10);
            nx.is_dead = 1;
            fused = 1;
        }
    }
    if (fused == 0) {
        e.load_op(inst.src1.vreg, ctx, "rcx");
        eo.out_line("xor eax, eax");
        if (inst.src2.op_type == d.OP_IMM && inst.src2.imm == 0) {
            eo.out_cstr("  test rcx, rcx\n");
        } else {
            eo.out_cstr("  cmp rcx, ");
            e.emit_src2(inst, ctx);
            eo.out_char(10);
        }
        if (op == d.IR_EQ) { eo.out_line("sete al"); }
        if (op == d.IR_NE) { eo.out_line("setne al"); }
        let is i32 as sgn2 = e.is_signed_type(inst.cast_to);
        if (op == d.IR_LT) { if (sgn2 == 1) { eo.out_line("setl al"); } else { eo.out_line("setb al"); } }
        if (op == d.IR_LE) { if (sgn2 == 1) { eo.out_line("setle al"); } else { eo.out_line("setbe al"); } }
        if (op == d.IR_GT) { if (sgn2 == 1) { eo.out_line("setg al"); } else { eo.out_line("seta al"); } }
        if (op == d.IR_GE) { if (sgn2 == 1) { eo.out_line("setge al"); } else { eo.out_line("setae al"); } }
        e.store_op(inst.dest.vreg, ctx, "rax");
    }
}

// === gen_inst: SHL, SHR, AND, OR, XOR, NOT ===

fn gen_inst_shift_bitwise(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SHL) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        e.load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            eo.out_cstr("  shl ");
            eo.out_cstr(scr);
            eo.out_cstr(", ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
        } else {
            e.load_op(inst.src2.vreg, ctx, "rcx");
            eo.out_cstr("  shl ");
            eo.out_cstr(scr);
            eo.out_cstr(", cl\n");
        }
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SHR) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        e.load_op(inst.src1.vreg, ctx, scr);
        if (inst.src2.op_type == d.OP_IMM) {
            if (e.is_signed_type(inst.cast_to) == 1) {
                eo.out_cstr("  sar ");
            } else {
                eo.out_cstr("  shr ");
            }
            eo.out_cstr(scr);
            eo.out_cstr(", ");
            eo.out_int(inst.src2.imm);
            eo.out_char(10);
        } else {
            e.load_op(inst.src2.vreg, ctx, "rcx");
            if (e.is_signed_type(inst.cast_to) == 1) {
                eo.out_cstr("  sar ");
            } else {
                eo.out_cstr("  shr ");
            }
            eo.out_cstr(scr);
            eo.out_cstr(", cl\n");
        }
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_AND) { e.gen_binop(inst, ctx, "and"); return; }
    if (op == d.IR_OR) { e.gen_binop(inst, ctx, "or"); return; }
    if (op == d.IR_XOR) { e.gen_binop(inst, ctx, "xor"); return; }
    // IR_NOT
    let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
    e.load_op(inst.src1.vreg, ctx, scr);
    eo.out_cstr("  not ");
    eo.out_cstr(scr);
    eo.out_char(10);
    e.store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: RET, LABEL, JMP, JZ, JNZ ===

fn gen_inst_control(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_RET) {
        if (inst.src1.op_type != d.OP_NONE) {
            e.load_op(inst.src1.vreg, ctx, "rax");
        }
        if (ctx.aligned_stack_size > 0) {
            eo.out_cstr("  add rsp, ");
            eo.out_int(cast(i64, ctx.aligned_stack_size));
            eo.out_char(10);
        }
        if (ctx.used_callee_mask & 16) { eo.out_line("pop r15"); }
        if (ctx.used_callee_mask & 8) { eo.out_line("pop r14"); }
        if (ctx.used_callee_mask & 4) { eo.out_line("pop r13"); }
        if (ctx.used_callee_mask & 2) { eo.out_line("pop r12"); }
        if (ctx.used_callee_mask & 1) { eo.out_line("pop rbx"); }
        eo.out_line("pop rbp");
        eo.out_line("ret");
        return;
    }
    if (op == d.IR_LABEL) {
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        eo.out_cstr(".L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_cstr(":\n");
        return;
    }
    if (op == d.IR_JMP) {
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        eo.out_cstr("  jmp .L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_char(10);
        return;
    }
    if (op == d.IR_JZ) {
        e.load_op(inst.src1.vreg, ctx, "rax");
        eo.out_line("test rax, rax");
        eo.out_cstr("  jz .L");
        eo.out_int(cast(i64, inst.dest.label));
        eo.out_char(10);
        return;
    }
    // IR_JNZ
    e.load_op(inst.src1.vreg, ctx, "rax");
    eo.out_line("test rax, rax");
    eo.out_cstr("  jnz .L");
    eo.out_int(cast(i64, inst.dest.label));
    eo.out_char(10);
}

// === gen_inst: ADDR, ADDR_GLOBAL, FN_ADDR, GET_ALLOC_ADDR, LOAD, STORE, COPY, ASM, CAST ===

fn gen_inst_memory(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_ADDR) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rbp-");
        eo.out_int(inst.src1.imm);
        eo.out_cstr("]\n");
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_ADDR_GLOBAL) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        if (inst.is_extern_global == 1) {
            eo.out_cstr("  mov ");
            eo.out_cstr(scr);
            eo.out_cstr(", QWORD PTR [rip+");
            eo.out_str(inst.global_name_ptr, inst.global_name_len);
            eo.out_cstr("]\n");
        } else {
            eo.out_cstr("  lea ");
            eo.out_cstr(scr);
            eo.out_cstr(", [rip+");
            eo.out_str(inst.global_name_ptr, inst.global_name_len);
            eo.out_cstr("]\n");
        }
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_FN_ADDR) {
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rip+");
        eo.out_str(inst.global_name_ptr, inst.global_name_len);
        eo.out_cstr("]\n");
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_GET_ALLOC_ADDR) {
        let is i64 as off = cast(i64, ctx.arg_spill_base) + cast(i64, ctx.stack_slots) * 8 + inst.src1.imm;
        let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
        eo.out_cstr("  lea ");
        eo.out_cstr(scr);
        eo.out_cstr(", [rbp-");
        eo.out_int(off);
        eo.out_cstr("]\n");
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_SET_CTX) {
        if (inst.src1.op_type == d.OP_IMM) {
            eo.out_line("xor r10, r10");
            if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(8); }
        } else {
            e.load_op(inst.src1.vreg, ctx, "r10");
        }
        return;
    }
    if (op == d.IR_LOAD) {
        let is i32 as sz = e.get_type_size(inst.cast_to);
        let is i32 as sgn = e.is_signed_type(inst.cast_to);
        let is i32 as si = e.get_scratch_idx(inst.dest.vreg, ctx);
        let is *u8 as scr = eo.reg64(si);
        let is *u8 as scr32 = eo.reg32(si);
        if (inst.src1.op_type == d.OP_VREG) {
            let is e.AddrMode as am with mut;
            am.matched = 0;
            if (al.al_opt_level >= 1) {
                am = e.try_match_addr(inst.src1.vreg, ctx);
            }
            if (am.matched == 1) {
                e.load_op(am.base_vreg, ctx, "rax");
                e.load_op(am.index_vreg, ctx, "rcx");
                if (sz == 8) {
                    eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 4) {
                    if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); } else { eo.out_cstr("  mov "); eo.out_cstr(scr32); }
                    eo.out_cstr(", DWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 2) {
                    if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                    eo.out_cstr(scr); eo.out_cstr(", WORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else if (sz == 1) {
                    if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                    eo.out_cstr(scr); eo.out_cstr(", BYTE PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                } else {
                    eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rax + rcx * "); eo.out_int(cast(i64, am.scale)); eo.out_cstr("]\n");
                }
            } else {
            e.load_op(inst.src1.vreg, ctx, scr);
            if (sz == 8) {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); eo.out_cstr(", DWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n"); }
                else { eo.out_cstr("  mov "); eo.out_cstr(scr32); eo.out_cstr(", DWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n"); }
            } else if (sz == 2) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", WORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", BYTE PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            } else {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR ["); eo.out_cstr(scr); eo.out_cstr("]\n");
            }
            }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp-");
                eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 4) {
                if (sgn == 1) {
                    eo.out_cstr("  movsxd "); eo.out_cstr(scr);
                } else {
                    eo.out_cstr("  mov "); eo.out_cstr(scr32);
                }
                eo.out_cstr(", DWORD PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 2) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", WORD PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else if (sz == 1) {
                if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
                eo.out_cstr(scr); eo.out_cstr(", BYTE PTR [rbp-"); eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            } else {
                eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp-");
                eo.out_int(inst.src1.imm); eo.out_cstr("]\n");
            }
        }
        // f32 load: widen f32 bitpattern to f64 for internal representation
        if (sz == 4 && e.is_float_type(inst.cast_to) == 1) {
            eo.out_cstr("  movd xmm0, "); eo.out_cstr(scr32); eo.out_char(10);
            eo.out_line("cvtss2sd xmm0, xmm0");
            eo.out_cstr("  movq "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        }
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (op == d.IR_STORE) {
        let is i32 as sz = e.get_type_size(inst.cast_to);
        e.load_op(inst.src1.vreg, ctx, "rax");
        // f32 store: value in rax is f64 bitpattern, convert to f32 bitpattern
        if (sz == 4 && e.is_float_type(inst.cast_to) == 1) {
            eo.out_line("movq xmm0, rax");
            eo.out_line("cvtsd2ss xmm0, xmm0");
            eo.out_line("movd eax, xmm0");
        }
        if (inst.dest.op_type == d.OP_VREG) {
            e.load_op(inst.dest.vreg, ctx, "rcx");
            if (sz == 8) { eo.out_line("mov QWORD PTR [rcx], rax"); }
            else if (sz == 4) { eo.out_line("mov DWORD PTR [rcx], eax"); }
            else if (sz == 2) { eo.out_line("mov WORD PTR [rcx], ax"); }
            else if (sz == 1) { eo.out_line("mov BYTE PTR [rcx], al"); }
            else { eo.out_line("mov QWORD PTR [rcx], rax"); }
        } else {
            // Stack offset (IMM)
            if (sz == 8) {
                eo.out_cstr("  mov QWORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], rax\n");
            } else if (sz == 4) {
                eo.out_cstr("  mov DWORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], eax\n");
            } else if (sz == 2) {
                eo.out_cstr("  mov WORD PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], ax\n");
            } else if (sz == 1) {
                eo.out_cstr("  mov BYTE PTR [rbp-");
                eo.out_int(inst.dest.imm);
                eo.out_cstr("], al\n");
            } else {
                // Struct > 8 bytes: rax is a pointer to the struct data.
                // Copy from [rax] to [rbp-dest] using rcx as scratch.
                if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(0); eo.rc_invalidate_reg(1); }
                eo.out_line("mov rcx, rax");
                let is i32 as soff with mut = 0;
                while (soff + 8 <= sz) {
                    eo.out_cstr("  mov rax, QWORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov QWORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], rax\n");
                    soff = soff + 8;
                }
                if (soff + 4 <= sz) {
                    eo.out_cstr("  mov eax, DWORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov DWORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], eax\n");
                    soff = soff + 4;
                }
                if (soff + 2 <= sz) {
                    eo.out_cstr("  movzx eax, WORD PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov WORD PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], ax\n");
                    soff = soff + 2;
                }
                if (soff < sz) {
                    eo.out_cstr("  movzx eax, BYTE PTR [rcx+");
                    eo.out_int(cast(i64, soff));
                    eo.out_cstr("]\n");
                    eo.out_cstr("  mov BYTE PTR [rbp-");
                    eo.out_int(inst.dest.imm - cast(i64, soff));
                    eo.out_cstr("], al\n");
                }
            }
        }
        return;
    }
    if (op == d.IR_COPY) {
        e.load_op(inst.dest.vreg, ctx, "rdi");
        e.load_op(inst.src1.vreg, ctx, "rsi");
        eo.out_cstr("  mov rcx, ");
        eo.out_int(inst.src2.imm);
        eo.out_char(10);
        eo.out_line("cld");
        eo.out_line("rep movsb");
        // rep movsb clobbers rdi, rsi, rcx
        if (al.al_opt_level >= 1) {
            eo.rc_invalidate_reg(5);
            eo.rc_invalidate_reg(4);
            eo.rc_invalidate_reg(1);
        }
        return;
    }
    if (op == d.IR_ASM) {
        eo.out_cstr("  ");
        eo.out_str(inst.asm_str_ptr, inst.asm_str_len);
        eo.out_char(10);
        if (al.al_opt_level >= 1) { eo.ph_invalidate(); }
        return;
    }
    // IR_CAST
    let is i32 as to_flt = e.is_float_type(inst.cast_to);
    let is i32 as from_flt = e.is_float_type(inst.cast_from);
    let is i32 as si = e.get_scratch_idx(inst.dest.vreg, ctx);
    let is *u8 as scr = eo.reg64(si);
    e.load_op(inst.src1.vreg, ctx, scr);
    if (from_flt == 1 && to_flt == 0) {
        eo.out_cstr("  movq xmm0, "); eo.out_cstr(scr); eo.out_char(10);
        eo.out_cstr("  cvttsd2si "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    if (from_flt == 0 && to_flt == 1) {
        eo.out_cstr("  cvtsi2sd xmm0, "); eo.out_cstr(scr); eo.out_char(10);
        eo.out_cstr("  movq "); eo.out_cstr(scr); eo.out_cstr(", xmm0\n");
        e.store_op(inst.dest.vreg, ctx, scr);
        return;
    }
    let is i32 as to_sz = e.get_type_size(inst.cast_to);
    let is i32 as sgn = e.is_signed_type(inst.cast_to);
    if (to_sz == 4) {
        if (sgn == 1) { eo.out_cstr("  movsxd "); eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg32(si)); eo.out_char(10); }
        else { eo.out_cstr("  mov "); eo.out_cstr(eo.reg32(si)); eo.out_cstr(", "); eo.out_cstr(eo.reg32(si)); eo.out_char(10); }
    } else if (to_sz == 2) {
        if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
        eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg16(si)); eo.out_char(10);
    } else if (to_sz == 1) {
        if (sgn == 1) { eo.out_cstr("  movsx "); } else { eo.out_cstr("  movzx "); }
        eo.out_cstr(scr); eo.out_cstr(", "); eo.out_cstr(eo.reg8(si)); eo.out_char(10);
    }
    e.store_op(inst.dest.vreg, ctx, scr);
}

// === gen_inst: SET_ARG, GET_ARG, SET_SYS_ARG, SYSCALL, CALL, VA_START ===

fn gen_inst_calls(inst as *d.IRInst, ctx as *al.AllocCtx) as void {
    let is i32 as op = inst.op;
    if (op == d.IR_SET_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        if (e.is_float_type(inst.cast_to) == 1) {
            // Extern float arg: load to rax/eax then move to xmmN
            e.load_op(inst.src1.vreg, ctx, "rax");
            let is i32 as fsz = e.get_type_size(inst.cast_to);
            if (fsz == 4) {
                // f32: load as f64, convert to f32 for C ABI
                eo.out_cstr("  movq xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", rax\n");
                eo.out_cstr("  cvtsd2ss xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", xmm");
                eo.out_int(cast(i64, idx));
                eo.out_char(10);
            } else {
                // f64: movq xmmN, rax
                eo.out_cstr("  movq xmm");
                eo.out_int(cast(i64, idx));
                eo.out_cstr(", rax\n");
            }
        } else if (idx < 6) {
            e.load_op(inst.src1.vreg, ctx, eo.arg_reg64(idx));
        } else {
            e.load_op(inst.src1.vreg, ctx, "rax");
            eo.out_line("push rax");
        }
        return;
    }
    if (op == d.IR_GET_ARG) {
        let is i32 as idx = cast(i32, inst.src1.imm);
        if (idx < 6) {
            e.store_op(inst.dest.vreg, ctx, eo.arg_reg64(idx));
        } else {
            let is i64 as off = 16 + cast(i64, idx - 6) * 8;
            let is *u8 as scr = e.get_scratch(inst.dest.vreg, ctx);
            eo.out_cstr("  mov "); eo.out_cstr(scr); eo.out_cstr(", QWORD PTR [rbp+");
            eo.out_int(off);
            eo.out_cstr("]\n");
            e.store_op(inst.dest.vreg, ctx, scr);
        }
        return;
    }
    if (op == d.IR_SET_SYS_ARG) {
        let is i32 as idx = cast(i32, inst.dest.imm);
        e.load_op(inst.src1.vreg, ctx, eo.syscall_reg(idx));
        return;
    }
    if (op == d.IR_SYSCALL) {
        eo.out_line("syscall");
        e.store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    if (op == d.IR_CALL) {
        if (inst.is_variadic_call == 1) {
            let is i32 as xmm_n = cast(i32, inst.src1.imm);
            if (xmm_n > 0) {
                eo.out_cstr("  mov eax, ");
                eo.out_int(cast(i64, xmm_n));
                eo.out_char(10);
            } else {
                eo.out_line("xor eax, eax");
            }
        }
        eo.out_cstr("  call ");
        eo.out_str(inst.call_name_ptr, inst.call_name_len);
        eo.out_char(10);
        // Handle return type ABI (only for extern calls — internal calls return in rax)
        if (cast(i64, inst.cast_to) != 0 && inst.is_extern_call == 1) {
            let is i32 as ret_sz = e.get_type_size(inst.cast_to);
            if (e.is_float_type(inst.cast_to) == 1) {
                if (ret_sz == 4) {
                    eo.out_line("cvtss2sd xmm0, xmm0");
                }
                // extern fn returns float in xmm0 — move to rax for internal ABI
                eo.out_line("movq rax, xmm0");
            } else if (ret_sz == 1) {
                if (e.is_signed_type(inst.cast_to) == 1) { eo.out_line("movsx rax, al"); }
                else { eo.out_line("movzx eax, al"); }
            } else if (ret_sz == 2) {
                if (e.is_signed_type(inst.cast_to) == 1) { eo.out_line("movsx rax, ax"); }
                else { eo.out_line("movzx eax, ax"); }
            }
        }
        e.store_op(inst.dest.vreg, ctx, "rax");
        return;
    }
    // IR_VA_START
    let is i32 as num_args = cast(i32, inst.src2.imm);
    e.load_op(inst.src1.vreg, ctx, "rcx");
    eo.out_cstr("  mov DWORD PTR [rcx], ");
    eo.out_int(cast(i64, num_args) * 8);
    eo.out_char(10);
    eo.out_line("mov DWORD PTR [rcx+4], 48");
    let is i64 as overflow_off with mut = 16;
    if (num_args > 6) {
        overflow_off = 16 + cast(i64, num_args - 6) * 8;
    }
    eo.out_cstr("  lea rax, [rbp+");
    eo.out_int(overflow_off);
    eo.out_cstr("]\n");
    eo.out_line("mov QWORD PTR [rcx+8], rax");
    eo.out_cstr("  lea rax, [rbp-");
    eo.out_int(cast(i64, ctx.va_save_offset));
    eo.out_cstr("]\n");
    eo.out_line("mov QWORD PTR [rcx+16], rax");
    if (al.al_opt_level >= 1) { eo.rc_invalidate_reg(0); }
}

// === Instruction selection: use counts + pattern matching on IR ===
// vreg_uses[v] = number of times v appears as src1, src2, or STORE/COPY dest
let is *i32 as isel_uses with mut;
let is i32 as isel_vc with mut = 0;

