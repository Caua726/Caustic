
// === Target descriptor ===
// Minimal struct kept deliberately small: SysV ABI is maintained internally
// in all codegen, and FFI ABI conversion (System V → MS x64) happens at
// IR_FFI_CALL sites driven by extern "dll.dll" annotations — not by reading
// fields from this struct. We only track OS-specific facts that the
// compiler genuinely needs at multiple stages.
struct Target {
    name as *u8;             // e.g. "linux-x86_64" — also basis for <TARGET> expansion
    name_len as i32;
    syscall_supported as i32;  // 0 → semantic rejects builtin syscall(...)
    object_format as i32;    // 1 = ELF, 2 = COFF/PE, 3 = CSE (Caustic Standard Executable)
    cse_mode as i32;         // 0 = pure, 1 = compat, 2 = bundle (meaningful when object_format == 3)
    cse_extension as i32;    // 0 = .cse, 1 = .exe, 2 = .com (output filename extension hint)
    allow_unsupported as i32; // 1 → __compile_error() is downgraded to a no-op (build anyway)
    app_version_ptr as *u8;   // free-form program version string for the CSE header, or null
    app_version_len as i32;
    cse_stack_size as i32;    // user-stack bytes for the CSE header (0x2C). 0 = not set by a
                              // flag → codegen COMPUTES it from the call graph (sa_compute).
                              // >0 = explicit --stack-size override. There is NO default: a
                              // program's stack is computed from its own code, or declared
                              // by the author for the recursive/indirect case.
}

// Active target — global struct, populated once via target_init() then
// reconfigured by load_target() when --target= is parsed.
let is Target as g_target with mut;
let is i32 as _target_inited with mut = 0;

fn target_init() as void {
    if (_target_inited == 1) { return; }
    g_target.name = "linux-x86_64";
    g_target.name_len = 12;
    g_target.syscall_supported = 1;
    g_target.object_format = 1;
    g_target.cse_mode = 0;
    g_target.cse_extension = 0;
    g_target.allow_unsupported = 0;
    g_target.app_version_ptr = cast(*u8, 0);
    g_target.app_version_len = 0;
    g_target.cse_stack_size = 0;   // 0 = compute from call graph; --stack-size overrides
    _target_inited = 1;
}

fn target_get() as *Target {
    if (_target_inited == 0) { target_init(); }
    return &g_target;
}

// CSE mode/extension accessors. Kept as plain functions (rather than letting
// callers reach into g_target across modules) to match how the rest of the
// codebase reads the target — through target_get() — and to keep the storage
// private to this module.
fn cse_mode_get() as i32 {
    if (_target_inited == 0) { target_init(); }
    return g_target.cse_mode;
}

fn cse_mode_set(m as i32) as void {
    if (_target_inited == 0) { target_init(); }
    g_target.cse_mode = m;
}

fn cse_extension_set(e as i32) as void {
    if (_target_inited == 0) { target_init(); }
    g_target.cse_extension = e;
}

// Declared user-stack size (CSE header 0x2C). Programs that recurse deeply
// (the self-host compiler) raise it via --stack-size.
fn cse_stack_size_get() as i32 {
    if (_target_inited == 0) { target_init(); }
    return g_target.cse_stack_size;
}

fn cse_stack_size_set(n as i32) as void {
    if (_target_inited == 0) { target_init(); }
    g_target.cse_stack_size = n;
}

// __compile_error() downgrade flag. When set (via --allow-unsupported, the
// __allow_unsupported builtin, or a Causticfile `allow_unsupported` key),
// codegen skips compile-error markers instead of aborting the build.
fn allow_unsupported_get() as i32 {
    if (_target_inited == 0) { target_init(); }
    return g_target.allow_unsupported;
}

fn allow_unsupported_set(v as i32) as void {
    if (_target_inited == 0) { target_init(); }
    g_target.allow_unsupported = v;
}

// Free-form program version string embedded in the CSE binary. The header
// (@0x1C) holds a file offset to a NUL-terminated copy of this string (0 if
// unset). Set from --app-version=<string> (or the Causticfile `version`).
fn app_version_set(ptr as *u8, len as i32) as void {
    if (_target_inited == 0) { target_init(); }
    g_target.app_version_ptr = ptr;
    g_target.app_version_len = len;
}

fn app_version_ptr_get() as *u8 {
    if (_target_inited == 0) { target_init(); }
    return g_target.app_version_ptr;
}

fn app_version_len_get() as i32 {
    if (_target_inited == 0) { target_init(); }
    return g_target.app_version_len;
}

fn str_eq_local(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    if (alen != blen) { return 0; }
    let is i32 as i with mut = 0;
    while (i < alen) {
        if (a[i] != b[i]) { return 0; }
        i = i + 1;
    }
    return 1;
}

// Parse triple string → reconfigures g_target. Returns 1 on success, 0 on unknown.
// Accepts: "linux-x86_64", "windows-x86_64", "caustic-x86_64".
// Note: cse_mode / cse_extension are NOT reset here — they are owned by the
// --mode= / --extension= flags and zero-initialised in target_init(), so this
// stays agnostic to flag ordering on the command line.
fn load_target(triple as *u8, triple_len as i32) as i32 {
    target_init();
    if (str_eq_local(triple, triple_len, "linux-x86_64", 12) == 1) {
        g_target.name = "linux-x86_64";
        g_target.name_len = 12;
        g_target.syscall_supported = 1;
        g_target.object_format = 1;
        return 1;
    }
    if (str_eq_local(triple, triple_len, "windows-x86_64", 14) == 1) {
        g_target.name = "windows-x86_64";
        g_target.name_len = 14;
        g_target.syscall_supported = 0;
        g_target.object_format = 2;
        return 1;
    }
    if (str_eq_local(triple, triple_len, "caustic-x86_64", 14) == 1) {
        // CausticOS native target. ABI is Linux-syscall-compatible in the MVP,
        // so syscall(...) is permitted; the final executable is emitted in the
        // CSE format by caustic-linker (object_format == 3).
        g_target.name = "caustic-x86_64";
        g_target.name_len = 14;
        g_target.syscall_supported = 1;
        g_target.object_format = 3;
        return 1;
    }
    return 0;
}

// Just the OS portion of the triple ("linux" or "windows") — for <TARGET>
// expansion in `use` paths so that `std/io/<TARGET>.cst` resolves to
// `std/io/linux.cst` rather than `std/io/linux-x86_64.cst`.
fn target_os_name(out_len as *i32) as *u8 {
    target_init();
    let is i32 as i with mut = 0;
    while (i < g_target.name_len) {
        if (g_target.name[i] == 45) {  // '-'
            *out_len = i;
            return g_target.name;
        }
        i = i + 1;
    }
    *out_len = g_target.name_len;
    return g_target.name;
}
