// Architecture-dispatching codegen facade.  The x86_64 backend remains in
// emit_driver.cst; AArch64 is deliberately isolated in aarch64/driver.cst.
use "target.cst" as tgt;
use "emit_driver.cst" as x64;
use "aarch64/driver.cst" as a64;
use "wasm/driver.cst" as wasm;

fn set_dyn_stdlib(v as i32) as void {
    x64.set_dyn_stdlib(v);
    a64.set_dyn_stdlib(v);
    wasm.set_dyn_stdlib(v);
}

fn set_opt_level(level as i32) as void {
    x64.set_opt_level(level);
    a64.set_opt_level(level);
    wasm.set_opt_level(level);
}

fn set_snapshot_inline(v as i32) as void {
    x64.set_snapshot_inline(v);
    a64.set_snapshot_inline(v);
    wasm.set_snapshot_inline(v);
}

fn codegen(prog as *u8, fd as i32, filename_ptr as *u8, filename_len as i32) as void {
    let is i32 as arch = tgt.target_get().arch;
    if (arch == tgt.ARCH_WASM32 || arch == tgt.ARCH_WASM64) {
        wasm.codegen(prog, fd, filename_ptr, filename_len);
        return;
    }
    if (arch == tgt.ARCH_AARCH64) {
        a64.codegen(prog, fd, filename_ptr, filename_len);
        return;
    }
    x64.codegen(prog, fd, filename_ptr, filename_len);
}
