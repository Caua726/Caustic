use "../../std/linux.cst" as linux;
use "../../std/io.cst" as io;
use "tokens.cst" as tok;
use "util.cst" as lu;

// === Error reporting ===

fn error_at_report(src as *u8, src_len as i64, filename as *u8, line as i32, col as i32, msg as *u8) as void {
    io.write_str(linux.STDERR, "Error in ");
    io.write_str(linux.STDERR, filename);
    io.write_str(linux.STDERR, ":");
    io.write_int(linux.STDERR, cast(i64, line));
    io.write_str(linux.STDERR, ":");
    io.write_int(linux.STDERR, cast(i64, col));
    io.write_str(linux.STDERR, ": ");
    io.write_str(linux.STDERR, msg);
    io.write_str(linux.STDERR, "\n");
    // Find and print the source line
    let is i64 as i with mut = 0;
    let is i32 as cur_line with mut = 1;
    while (i < src_len && cur_line < line) {
        if (src[i] == lu.CH_NL) { cur_line = cur_line + 1; }
        i = i + 1;
    }
    let is i64 as line_start = i;
    while (i < src_len && src[i] != lu.CH_NL) { i = i + 1; }
    let is i64 as line_len = i - line_start;
    io.write_str(linux.STDERR, "  ");
    if (line_len > 0) {
        linux.write(linux.STDERR, cast(*u8, cast(i64, src) + line_start), line_len);
    }
    io.write_str(linux.STDERR, "\n  ");
    let is i32 as ci with mut = 1;
    while (ci < col) {
        linux.write(linux.STDERR, " ", 1);
        ci = ci + 1;
    }
    io.write_str(linux.STDERR, "^\n");
}

fn error_at(src as *u8, src_len as i64, filename as *u8, line as i32, col as i32, msg as *u8) as void {
    error_at_report(src, src_len, filename, line, col, msg);
    linux.exit(1);
}

// Helper to push a single-char token
fn push1(tl as *tok.TokenList, kind as i32, src as *u8, i as i64, line as i32, col as i32) as void {
    tok.tl_push(tl, tok.make_tok(kind, cast(*u8, cast(i64, src) + i), 1, line, col, 0));
}

// Helper to push a two-char token
fn push2(tl as *tok.TokenList, kind as i32, src as *u8, i as i64, line as i32, col as i32) as void {
    tok.tl_push(tl, tok.make_tok(kind, cast(*u8, cast(i64, src) + i), 2, line, col, 0));
}

// Helper to push a three-char token
fn push3(tl as *tok.TokenList, kind as i32, src as *u8, i as i64, line as i32, col as i32) as void {
    tok.tl_push(tl, tok.make_tok(kind, cast(*u8, cast(i64, src) + i), 3, line, col, 0));
}

// === Main tokenizer ===

fn tokenize(src as *u8, src_len as i64, filename as *u8) as tok.TokenList {
    let is tok.TokenList as tl = tok.tl_init();
    let is i64 as i with mut = 0;
    let is i32 as line with mut = 1;
    let is i32 as col with mut = 1;

    while (i < src_len) {
        let is u8 as c = src[i];

        // Whitespace
        if (c == lu.CH_SPACE || c == lu.CH_TAB || c == lu.CH_CR) {
            col = col + 1; i = i + 1;
        }
        else if (c == lu.CH_NL) {
            line = line + 1; col = 1; i = i + 1;
        }
        // Line comment: //
        else if (c == lu.CH_SLASH && i + 1 < src_len && src[i + 1] == lu.CH_SLASH) {
            while (i < src_len && src[i] != lu.CH_NL) { i = i + 1; }
        }
        // Block comment: /* ... */ (nestable)
        else if (c == lu.CH_SLASH && i + 1 < src_len && src[i + 1] == lu.CH_STAR) {
            let is i32 as sc = col;
            let is i32 as sl = line;
            i = i + 2; col = col + 2;
            let is i32 as depth with mut = 1;
            while (i < src_len && depth > 0) {
                if (src[i] == lu.CH_SLASH && i + 1 < src_len && src[i + 1] == lu.CH_STAR) {
                    depth = depth + 1; i = i + 2; col = col + 2;
                } else if (src[i] == lu.CH_STAR && i + 1 < src_len && src[i + 1] == lu.CH_SLASH) {
                    depth = depth - 1; i = i + 2; col = col + 2;
                } else if (src[i] == lu.CH_NL) {
                    line = line + 1; col = 1; i = i + 1;
                } else {
                    col = col + 1; i = i + 1;
                }
            }
            if (depth > 0) { error_at(src, src_len, filename, sl, sc, "unterminated block comment"); }
        }
        // Identifiers and keywords
        else if (lu.is_alpha(c) == 1) {
            let is i64 as start = i;
            let is i32 as sc = col;
            while (i < src_len && lu.is_alnum(src[i]) == 1) { i = i + 1; col = col + 1; }
            let is i32 as tlen = cast(i32, i - start);
            let is *u8 as tptr = cast(*u8, cast(i64, src) + start);
            tok.tl_push(&tl, tok.make_tok(tok.keyword_lookup(tptr, tlen), tptr, tlen, line, sc, 0));
        }
        // Numbers: decimal, hex (0x), binary (0b), octal (0o), float
        // Underscores allowed as digit separators (1_000, 0xFF_FF, etc.)
        else if (lu.is_digit(c) == 1) {
            let is i64 as start = i;
            let is i32 as sc = col;
            if (c == lu.CH_0 && i + 1 < src_len && (src[i + 1] == lu.CH_x || src[i + 1] == lu.CH_X)) {
                // Hex: 0x...
                i = i + 2; col = col + 2;
                while (i < src_len && (lu.is_hex(src[i]) == 1 || src[i] == lu.CH_UNDER)) { i = i + 1; col = col + 1; }
                let is i32 as tlen = cast(i32, i - start);
                tok.tl_push(&tl, tok.make_tok(tok.TK_INTEGER, cast(*u8, cast(i64, src) + start), tlen, line, sc, lu.parse_hex_val(src, start + 2, i)));
            } else if (c == lu.CH_0 && i + 1 < src_len && (src[i + 1] == lu.CH_b || src[i + 1] == lu.CH_B)) {
                // Binary: 0b...
                i = i + 2; col = col + 2;
                while (i < src_len && (lu.is_binary(src[i]) == 1 || src[i] == lu.CH_UNDER)) { i = i + 1; col = col + 1; }
                let is i32 as tlen = cast(i32, i - start);
                tok.tl_push(&tl, tok.make_tok(tok.TK_INTEGER, cast(*u8, cast(i64, src) + start), tlen, line, sc, lu.parse_binary_val(src, start + 2, i)));
            } else if (c == lu.CH_0 && i + 1 < src_len && (src[i + 1] == lu.CH_o || src[i + 1] == lu.CH_O)) {
                // Octal: 0o...
                i = i + 2; col = col + 2;
                while (i < src_len && (lu.is_octal(src[i]) == 1 || src[i] == lu.CH_UNDER)) { i = i + 1; col = col + 1; }
                let is i32 as tlen = cast(i32, i - start);
                tok.tl_push(&tl, tok.make_tok(tok.TK_INTEGER, cast(*u8, cast(i64, src) + start), tlen, line, sc, lu.parse_octal_val(src, start + 2, i)));
            } else {
                // Decimal or float
                while (i < src_len && (lu.is_digit(src[i]) == 1 || src[i] == lu.CH_UNDER)) { i = i + 1; col = col + 1; }
                if (i < src_len && src[i] == lu.CH_DOT && i + 1 < src_len && lu.is_digit(src[i + 1]) == 1) {
                    i = i + 1; col = col + 1;
                    while (i < src_len && (lu.is_digit(src[i]) == 1 || src[i] == lu.CH_UNDER)) { i = i + 1; col = col + 1; }
                    let is i32 as tlen = cast(i32, i - start);
                    tok.tl_push(&tl, tok.make_tok(tok.TK_FLOAT, cast(*u8, cast(i64, src) + start), tlen, line, sc, 0));
                } else {
                    let is i32 as tlen = cast(i32, i - start);
                    tok.tl_push(&tl, tok.make_tok(tok.TK_INTEGER, cast(*u8, cast(i64, src) + start), tlen, line, sc, lu.parse_decimal(src, start, i)));
                }
            }
        }
        // String literal
        else if (c == lu.CH_DQUOTE) {
            let is i64 as start = i;
            let is i32 as sc = col;
            i = i + 1; col = col + 1;
            while (i < src_len && src[i] != lu.CH_DQUOTE) {
                if (src[i] == lu.CH_BSLASH) { i = i + 1; col = col + 1; }
                if (src[i] == lu.CH_NL) { error_at(src, src_len, filename, line, sc, "unterminated string literal"); }
                i = i + 1; col = col + 1;
            }
            if (i >= src_len) { error_at(src, src_len, filename, line, sc, "unterminated string literal"); }
            i = i + 1; col = col + 1;
            tok.tl_push(&tl, tok.make_tok(tok.TK_STRING, cast(*u8, cast(i64, src) + start), cast(i32, i - start), line, sc, 0));
        }
        // Char literal
        else if (c == lu.CH_SQUOTE) {
            let is i32 as sc = col;
            i = i + 1; col = col + 1;
            let is i64 as cv with mut = 0;
            if (i < src_len && src[i] == lu.CH_BSLASH) {
                i = i + 1; col = col + 1;
                if (i < src_len) { cv = lu.resolve_escape(src[i]); i = i + 1; col = col + 1; }
            } else if (i < src_len) { cv = cast(i64, src[i]); i = i + 1; col = col + 1; }
            if (i >= src_len || src[i] != lu.CH_SQUOTE) { error_at(src, src_len, filename, line, sc, "unterminated char literal"); }
            i = i + 1; col = col + 1;
            tok.tl_push(&tl, tok.make_tok(tok.TK_CHAR, cast(*u8, 0), 0, line, sc, cv));
        }
        // 3-char operators (must come before 2-char prefixes)
        // <<=
        else if (c == lu.CH_LT && i + 2 < src_len && src[i + 1] == lu.CH_LT && src[i + 2] == lu.CH_EQ) {
            push3(&tl, tok.TK_SHL_EQ, src, i, line, col); i = i + 3; col = col + 3;
        }
        // >>=
        else if (c == lu.CH_GT && i + 2 < src_len && src[i + 1] == lu.CH_GT && src[i + 2] == lu.CH_EQ) {
            push3(&tl, tok.TK_SHR_EQ, src, i, line, col); i = i + 3; col = col + 3;
        }
        // ...
        else if (c == lu.CH_DOT && i + 2 < src_len && src[i + 1] == lu.CH_DOT && src[i + 2] == lu.CH_DOT) {
            push3(&tl, tok.TK_ELLIPSIS, src, i, line, col); i = i + 3; col = col + 3;
        }
        // 2-char operators
        // ==
        else if (c == lu.CH_EQ && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_EQEQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // !=
        else if (c == lu.CH_BANG && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_NE, src, i, line, col); i = i + 2; col = col + 2;
        }
        // <=
        else if (c == lu.CH_LT && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_LE, src, i, line, col); i = i + 2; col = col + 2;
        }
        // <<
        else if (c == lu.CH_LT && i + 1 < src_len && src[i + 1] == lu.CH_LT) {
            push2(&tl, tok.TK_SHL, src, i, line, col); i = i + 2; col = col + 2;
        }
        // >=
        else if (c == lu.CH_GT && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_GE, src, i, line, col); i = i + 2; col = col + 2;
        }
        // >>
        else if (c == lu.CH_GT && i + 1 < src_len && src[i + 1] == lu.CH_GT) {
            push2(&tl, tok.TK_SHR, src, i, line, col); i = i + 2; col = col + 2;
        }
        // &&
        else if (c == lu.CH_AMP && i + 1 < src_len && src[i + 1] == lu.CH_AMP) {
            push2(&tl, tok.TK_AND_AND, src, i, line, col); i = i + 2; col = col + 2;
        }
        // &=
        else if (c == lu.CH_AMP && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_AND_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // ||
        else if (c == lu.CH_PIPE && i + 1 < src_len && src[i + 1] == lu.CH_PIPE) {
            push2(&tl, tok.TK_OR_OR, src, i, line, col); i = i + 2; col = col + 2;
        }
        // |=
        else if (c == lu.CH_PIPE && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_OR_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // ^=
        else if (c == lu.CH_CARET && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_XOR_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // :=
        else if (c == lu.CH_COLON && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_ASSIGN, src, i, line, col); i = i + 2; col = col + 2;
        }
        // ->
        else if (c == lu.CH_MINUS && i + 1 < src_len && src[i + 1] == lu.CH_GT) {
            push2(&tl, tok.TK_ARROW, src, i, line, col); i = i + 2; col = col + 2;
        }
        // +=
        else if (c == lu.CH_PLUS && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_PLUS_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // -=
        else if (c == lu.CH_MINUS && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_MINUS_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // *=
        else if (c == lu.CH_STAR && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_STAR_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // /=
        else if (c == lu.CH_SLASH && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_SLASH_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // %=
        else if (c == lu.CH_PERCENT && i + 1 < src_len && src[i + 1] == lu.CH_EQ) {
            push2(&tl, tok.TK_PERCENT_EQ, src, i, line, col); i = i + 2; col = col + 2;
        }
        // Single-char operators
        else if (c == lu.CH_PLUS)    { push1(&tl, tok.TK_PLUS, src, i, line, col); i = i + 1; col = col + 1; }     // '+'
        else if (c == lu.CH_MINUS)   { push1(&tl, tok.TK_MINUS, src, i, line, col); i = i + 1; col = col + 1; }    // '-'
        else if (c == lu.CH_STAR)    { push1(&tl, tok.TK_STAR, src, i, line, col); i = i + 1; col = col + 1; }     // '*'
        else if (c == lu.CH_SLASH)   { push1(&tl, tok.TK_SLASH, src, i, line, col); i = i + 1; col = col + 1; }    // '/'
        else if (c == lu.CH_PERCENT) { push1(&tl, tok.TK_PERCENT, src, i, line, col); i = i + 1; col = col + 1; }  // '%'
        else if (c == lu.CH_EQ)      { push1(&tl, tok.TK_EQ, src, i, line, col); i = i + 1; col = col + 1; }      // '='
        else if (c == lu.CH_BANG)    { push1(&tl, tok.TK_NOT, src, i, line, col); i = i + 1; col = col + 1; }      // '!'
        else if (c == lu.CH_LT)     { push1(&tl, tok.TK_LT, src, i, line, col); i = i + 1; col = col + 1; }      // '<'
        else if (c == lu.CH_GT)     { push1(&tl, tok.TK_GT, src, i, line, col); i = i + 1; col = col + 1; }      // '>'
        else if (c == lu.CH_AMP)    { push1(&tl, tok.TK_AND, src, i, line, col); i = i + 1; col = col + 1; }      // '&'
        else if (c == lu.CH_PIPE)   { push1(&tl, tok.TK_OR, src, i, line, col); i = i + 1; col = col + 1; }       // '|'
        else if (c == lu.CH_CARET)  { push1(&tl, tok.TK_XOR, src, i, line, col); i = i + 1; col = col + 1; }      // '^'
        else if (c == lu.CH_TILDE)  { push1(&tl, tok.TK_BITNOT, src, i, line, col); i = i + 1; col = col + 1; }   // '~'
        else if (c == lu.CH_LPAREN)  { push1(&tl, tok.TK_LPAREN, src, i, line, col); i = i + 1; col = col + 1; }  // '('
        else if (c == lu.CH_RPAREN)  { push1(&tl, tok.TK_RPAREN, src, i, line, col); i = i + 1; col = col + 1; }  // ')'
        else if (c == lu.CH_LBRACE)  { push1(&tl, tok.TK_LBRACE, src, i, line, col); i = i + 1; col = col + 1; }  // '{'
        else if (c == lu.CH_RBRACE)  { push1(&tl, tok.TK_RBRACE, src, i, line, col); i = i + 1; col = col + 1; }  // '}'
        else if (c == lu.CH_LBRACK)  { push1(&tl, tok.TK_LBRACKET, src, i, line, col); i = i + 1; col = col + 1; } // '['
        else if (c == lu.CH_RBRACK)  { push1(&tl, tok.TK_RBRACKET, src, i, line, col); i = i + 1; col = col + 1; } // ']'
        else if (c == lu.CH_COMMA)   { push1(&tl, tok.TK_COMMA, src, i, line, col); i = i + 1; col = col + 1; }   // ','
        else if (c == lu.CH_DOT)     { push1(&tl, tok.TK_DOT, src, i, line, col); i = i + 1; col = col + 1; }     // '.'
        else if (c == lu.CH_SEMI)    { push1(&tl, tok.TK_SEMICOLON, src, i, line, col); i = i + 1; col = col + 1; } // ';'
        else if (c == lu.CH_COLON)   { push1(&tl, tok.TK_COLON, src, i, line, col); i = i + 1; col = col + 1; }   // ':'
        else { error_at(src, src_len, filename, line, col, "unexpected character"); }
    }

    tok.tl_push(&tl, tok.make_tok(tok.TK_EOF, cast(*u8, 0), 0, line, col, 0));
    return tl;
}
