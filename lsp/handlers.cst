use "../std/os/linux.cst" as linux;
use "../std/io.cst" as io;
use "../std/mem.cst" only bins, core as mem;
use "json.cst" as json;
use "json_write.cst" as jw;
use "rpc.cst" as rpc;
use "documents.cst" as docs;
use "uri.cst" as uri;
use "analysis.cst" as analysis;
use "symbols.cst" as syms;
use "keywords.cst" as kw;

// Path to the caustic compiler binary (resolved at startup)
let is *u8 as compiler_path with mut;

// === Helpers ===

fn _write_range(w as *jw.Writer, sl as i32, sc as i32, el as i32, ec as i32) as void {
    jw.obj_start(w);
    jw.key_c(w, "start");
    jw.obj_start(w);
    jw.kv_int(w, "line", cast(i64, sl));
    jw.kv_int(w, "character", cast(i64, sc));
    jw.obj_end(w);
    jw.key_c(w, "end");
    jw.obj_start(w);
    jw.kv_int(w, "line", cast(i64, el));
    jw.kv_int(w, "character", cast(i64, ec));
    jw.obj_end(w);
    jw.obj_end(w);
}

fn send_null_result(id as i64) as void {
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.kv_null(&w, "result");
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

fn send_empty_array(id as i64) as void {
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.arr_start(&w);
    jw.arr_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

// === Initialize ===

fn handle_initialize(id as i64) as void {
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.obj_start(&w);
    jw.key_c(&w, "capabilities");
    jw.obj_start(&w);
    jw.kv_int(&w, "textDocumentSync", 1);
    jw.kv_bool(&w, "hoverProvider", 1);
    jw.kv_bool(&w, "definitionProvider", 1);
    jw.key_c(&w, "completionProvider");
    jw.obj_start(&w);
    jw.key_c(&w, "triggerCharacters");
    jw.arr_start(&w);
    jw.str_c(&w, ".");
    jw.arr_end(&w);
    jw.obj_end(&w);
    jw.kv_bool(&w, "referencesProvider", 1);
    jw.kv_bool(&w, "renameProvider", 1);
    jw.kv_bool(&w, "documentSymbolProvider", 1);
    jw.key_c(&w, "signatureHelpProvider");
    jw.obj_start(&w);
    jw.key_c(&w, "triggerCharacters");
    jw.arr_start(&w);
    jw.str_c(&w, "(");
    jw.str_c(&w, ",");
    jw.arr_end(&w);
    jw.obj_end(&w);
    jw.kv_bool(&w, "foldingRangeProvider", 1);
    jw.obj_end(&w);
    jw.key_c(&w, "serverInfo");
    jw.obj_start(&w);
    jw.kv_str_c(&w, "name", "caustic-lsp");
    jw.kv_str_c(&w, "version", "0.1.0");
    jw.obj_end(&w);
    jw.obj_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

fn handle_shutdown(id as i64) as void {
    send_null_result(id);
}

// === Document sync ===

fn handle_did_open(params as *json.JsonValue) as void {
    let is *json.JsonValue as td = json.obj_get(params, "textDocument", 12);
    if (cast(i64, td) == 0) { return; }
    let is i32 as uri_len with mut = 0;
    let is *u8 as uri_str = json.obj_get_str(td, "uri", 3, &uri_len);
    let is i32 as text_len with mut = 0;
    let is *u8 as text = json.obj_get_str(td, "text", 4, &text_len);
    let is i64 as version = json.obj_get_int(td, "version", 7, 0);
    let is *docs.Document as d = docs.doc_open(uri_str, uri_len, text, text_len, cast(i32, version));
    let is i32 as path_len with mut = 0;
    d.path_ptr = uri.uri_to_path(uri_str, uri_len, &path_len);
    d.path_len = path_len;
    _publish_diagnostics(d);
}

fn handle_did_change(params as *json.JsonValue) as void {
    let is *json.JsonValue as td = json.obj_get(params, "textDocument", 12);
    if (cast(i64, td) == 0) { return; }
    let is i32 as uri_len with mut = 0;
    let is *u8 as uri_str = json.obj_get_str(td, "uri", 3, &uri_len);
    let is i64 as version = json.obj_get_int(td, "version", 7, 0);
    let is *docs.Document as d = docs.find(uri_str, uri_len);
    if (cast(i64, d) == 0) { return; }
    let is *json.JsonValue as changes = json.obj_get(params, "contentChanges", 14);
    if (cast(i64, changes) == 0 || changes.kind != json.JSON_ARRAY) { return; }
    let is *json.JsonValue as first = json.arr_get(changes, 0);
    if (cast(i64, first) == 0) { return; }
    let is i32 as text_len with mut = 0;
    let is *u8 as text = json.obj_get_str(first, "text", 4, &text_len);
    if (cast(i64, text) == 0) { return; }
    docs.update(d, text, text_len, cast(i32, version));
    _publish_diagnostics(d);
}

fn handle_did_close(params as *json.JsonValue) as void {
    let is *json.JsonValue as td = json.obj_get(params, "textDocument", 12);
    if (cast(i64, td) == 0) { return; }
    let is i32 as uri_len with mut = 0;
    let is *u8 as uri_str = json.obj_get_str(td, "uri", 3, &uri_len);
    docs.doc_close(uri_str, uri_len);
    _publish_empty_diagnostics(uri_str, uri_len);
}

fn _publish_diagnostics(d as *docs.Document) as void {
    if (cast(i64, d.path_ptr) == 0) { return; }

    // Scan symbols from source
    syms.scan(d.text_ptr, d.text_len);

    // Run compiler on the document
    let is i32 as count = analysis.analyze_file(d.path_ptr, d.text_ptr, d.text_len, compiler_path);

    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.key_c(&w, "method");
    jw.str_c(&w, "textDocument/publishDiagnostics");
    jw.key_c(&w, "params");
    jw.obj_start(&w);
    jw.kv_str(&w, "uri", d.uri_ptr, d.uri_len);
    jw.key_c(&w, "diagnostics");
    jw.arr_start(&w);

    let is i32 as i with mut = 0;
    while (i < count) {
        jw.obj_start(&w);
        jw.key_c(&w, "range");
        // LSP is 0-based, compiler is 1-based
        let is i32 as ln with mut = analysis.err_lines[i];
        let is i32 as cl with mut = analysis.err_cols[i];
        if (ln > 0) { ln = ln - 1; }
        if (cl > 0) { cl = cl - 1; }
        _write_range(&w, ln, cl, ln, cl + 1);
        jw.kv_int(&w, "severity", cast(i64, analysis.err_severities[i]));
        jw.kv_str_c(&w, "source", "caustic");
        jw.kv_str(&w, "message", cast(*u8, analysis.err_msgs[i]), analysis.err_msg_lens[i]);
        jw.obj_end(&w);
        i = i + 1;
    }

    jw.arr_end(&w);
    jw.obj_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

fn _publish_empty_diagnostics(uri_str as *u8, uri_len as i32) as void {
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.key_c(&w, "method");
    jw.str_c(&w, "textDocument/publishDiagnostics");
    jw.key_c(&w, "params");
    jw.obj_start(&w);
    jw.kv_str(&w, "uri", uri_str, uri_len);
    jw.key_c(&w, "diagnostics");
    jw.arr_start(&w);
    jw.arr_end(&w);
    jw.obj_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

// === Shared request helpers (position / document lookup) ===
// Used by the navigation, completion, and signature-help handlers, which now
// live in handlers_nav.cst / handlers_complete.cst / handlers_sig.cst and reach
// these (plus _write_range / send_null_result / send_empty_array) via `h.`.

fn _get_position(params as *json.JsonValue, out_line as *i32, out_col as *i32) as i32 {
    let is *json.JsonValue as pos = json.obj_get(params, "position", 8);
    if (cast(i64, pos) == 0) { return 0; }
    // LSP is 0-based, we use 1-based
    *out_line = cast(i32, json.obj_get_int(pos, "line", 4, 0)) + 1;
    *out_col = cast(i32, json.obj_get_int(pos, "character", 9, 0)) + 1;
    return 1;
}

fn _get_doc(params as *json.JsonValue, out_uri as **u8, out_uri_len as *i32) as *docs.Document {
    let is *json.JsonValue as td = json.obj_get(params, "textDocument", 12);
    if (cast(i64, td) == 0) { return cast(*docs.Document, 0); }
    let is i32 as uri_len with mut = 0;
    let is *u8 as uri_str = json.obj_get_str(td, "uri", 3, &uri_len);
    *out_uri = uri_str;
    *out_uri_len = uri_len;
    return docs.find(uri_str, uri_len);
}

// === References & Rename ===

fn handle_references(id as i64, params as *json.JsonValue) as void {
    let is i32 as line with mut = 0;
    let is i32 as col with mut = 0;
    let is *u8 as uri_str with mut = cast(*u8, 0);
    let is i32 as uri_len with mut = 0;
    let is *docs.Document as d = _get_doc(params, &uri_str, &uri_len);
    if (cast(i64, d) == 0 || _get_position(params, &line, &col) == 0) {
        send_empty_array(id);
        return;
    }

    let is *u8 as name with mut = cast(*u8, 0);
    let is i32 as nlen with mut = 0;
    syms.find_ident_at(d.text_ptr, d.text_len, line, col, &name, &nlen);
    if (nlen == 0) { send_empty_array(id); return; }

    let is [256]i32 as ref_lines;
    let is [256]i32 as ref_cols;
    let is i32 as count = syms.find_all_refs(d.text_ptr, d.text_len, name, nlen, &ref_lines, &ref_cols, 256);

    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.arr_start(&w);

    let is i32 as i with mut = 0;
    while (i < count) {
        jw.obj_start(&w);
        jw.kv_str(&w, "uri", d.uri_ptr, d.uri_len);
        jw.key_c(&w, "range");
        _write_range(&w, ref_lines[i] - 1, ref_cols[i] - 1, ref_lines[i] - 1, ref_cols[i] - 1 + nlen);
        jw.obj_end(&w);
        i = i + 1;
    }

    jw.arr_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

fn handle_rename(id as i64, params as *json.JsonValue) as void {
    let is i32 as line with mut = 0;
    let is i32 as col with mut = 0;
    let is *u8 as uri_str with mut = cast(*u8, 0);
    let is i32 as uri_len with mut = 0;
    let is *docs.Document as d = _get_doc(params, &uri_str, &uri_len);
    if (cast(i64, d) == 0 || _get_position(params, &line, &col) == 0) {
        send_null_result(id);
        return;
    }

    let is i32 as new_name_len with mut = 0;
    let is *u8 as new_name = json.obj_get_str(params, "newName", 7, &new_name_len);
    if (cast(i64, new_name) == 0) { send_null_result(id); return; }

    let is *u8 as name with mut = cast(*u8, 0);
    let is i32 as nlen with mut = 0;
    syms.find_ident_at(d.text_ptr, d.text_len, line, col, &name, &nlen);
    if (nlen == 0) { send_null_result(id); return; }

    let is [256]i32 as ref_lines;
    let is [256]i32 as ref_cols;
    let is i32 as count = syms.find_all_refs(d.text_ptr, d.text_len, name, nlen, &ref_lines, &ref_cols, 256);

    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.obj_start(&w);
    jw.key_c(&w, "changes");
    jw.obj_start(&w);
    jw.key(&w, d.uri_ptr, d.uri_len);
    jw.arr_start(&w);

    let is i32 as i with mut = 0;
    while (i < count) {
        jw.obj_start(&w);
        jw.key_c(&w, "range");
        _write_range(&w, ref_lines[i] - 1, ref_cols[i] - 1, ref_lines[i] - 1, ref_cols[i] - 1 + nlen);
        jw.kv_str(&w, "newText", new_name, new_name_len);
        jw.obj_end(&w);
        i = i + 1;
    }

    jw.arr_end(&w);
    jw.obj_end(&w);
    jw.obj_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

// === Document Symbols (outline) ===

fn _sym_kind_to_lsp(kind as i32) as i32 {
    // LSP SymbolKind: Function=12, Variable=13, Struct=23, Enum=10, Field=8, TypeParameter=26, Module=2
    if (kind == syms.SK_FUNCTION) { return 12; }
    if (kind == syms.SK_VARIABLE) { return 13; }
    if (kind == syms.SK_STRUCT) { return 23; }
    if (kind == syms.SK_ENUM) { return 10; }
    if (kind == syms.SK_FIELD) { return 8; }
    if (kind == syms.SK_TYPE_ALIAS) { return 26; }
    if (kind == syms.SK_MODULE) { return 2; }
    return 13;
}

fn handle_document_symbol(id as i64, params as *json.JsonValue) as void {
    let is *u8 as uri_str with mut = cast(*u8, 0);
    let is i32 as uri_len with mut = 0;
    let is *docs.Document as d = _get_doc(params, &uri_str, &uri_len);
    if (cast(i64, d) == 0) { send_empty_array(id); return; }

    // Ensure symbols are scanned
    syms.scan(d.text_ptr, d.text_len);

    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.arr_start(&w);

    let is i32 as i with mut = 0;
    while (i < syms.sym_count) {
        // Skip fields — they are children of structs, not top-level
        if (syms.sym_kinds[i] != syms.SK_FIELD) {
            let is i32 as ln = syms.sym_lines[i] - 1;
            let is i32 as cl = syms.sym_cols[i] - 1;
            let is i32 as nlen = syms.sym_name_lens[i];
            jw.obj_start(&w);
            jw.kv_str(&w, "name", cast(*u8, syms.sym_names[i]), nlen);
            if (syms.sym_type_lens[i] > 0) {
                jw.kv_str(&w, "detail", cast(*u8, syms.sym_types[i]), syms.sym_type_lens[i]);
            }
            jw.kv_int(&w, "kind", cast(i64, _sym_kind_to_lsp(syms.sym_kinds[i])));
            jw.key_c(&w, "range");
            _write_range(&w, ln, cl, ln, cl + nlen);
            jw.key_c(&w, "selectionRange");
            _write_range(&w, ln, cl, ln, cl + nlen);
            jw.obj_end(&w);
        }
        i = i + 1;
    }

    jw.arr_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

// === Folding Ranges ===

fn handle_folding_range(id as i64, params as *json.JsonValue) as void {
    let is *u8 as uri_str with mut = cast(*u8, 0);
    let is i32 as uri_len with mut = 0;
    let is *docs.Document as d = _get_doc(params, &uri_str, &uri_len);
    if (cast(i64, d) == 0) { send_empty_array(id); return; }

    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.arr_start(&w);

    let is i32 as pos with mut = 0;
    let is i32 as fline with mut = 0;
    // Stack of opening brace lines (max depth 64)
    let is [64]i32 as brace_stack;
    let is i32 as sp with mut = 0;
    // Track comment blocks
    let is i32 as comment_start with mut = cast(i32, 0 - 1);
    let is i32 as comment_line with mut = 0;

    while (pos < d.text_len) {
        let is u8 as c = d.text_ptr[pos];

        if (c == 10) {
            fline = fline + 1;
            pos = pos + 1;
        }
        // Skip strings
        else if (c == 34) {
            comment_start = cast(i32, 0 - 1);
            pos = pos + 1;
            while (pos < d.text_len && d.text_ptr[pos] != 34) {
                if (d.text_ptr[pos] == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
            if (pos < d.text_len) { pos = pos + 1; }
        }
        // Line comment
        else if (c == 47 && pos + 1 < d.text_len && d.text_ptr[pos + 1] == 47) {
            if (comment_start < 0) { comment_start = fline; }
            comment_line = fline;
            while (pos < d.text_len && d.text_ptr[pos] != 10) { pos = pos + 1; }
            // Check if next line is also a comment
            let is i32 as peek with mut = pos + 1;
            while (peek < d.text_len && (d.text_ptr[peek] == 32 || d.text_ptr[peek] == 9)) { peek = peek + 1; }
            if (peek + 1 >= d.text_len || d.text_ptr[peek] != 47 || d.text_ptr[peek + 1] != 47) {
                if (comment_line > comment_start) {
                    jw.obj_start(&w);
                    jw.kv_int(&w, "startLine", cast(i64, comment_start));
                    jw.kv_int(&w, "endLine", cast(i64, comment_line));
                    jw.kv_str_c(&w, "kind", "comment");
                    jw.obj_end(&w);
                }
                comment_start = cast(i32, 0 - 1);
            }
        }
        // Opening brace
        else if (c == 123) {
            comment_start = cast(i32, 0 - 1);
            if (sp < 64) {
                brace_stack[sp] = fline;
                sp = sp + 1;
            }
            pos = pos + 1;
        }
        // Closing brace
        else if (c == 125) {
            comment_start = cast(i32, 0 - 1);
            if (sp > 0) {
                sp = sp - 1;
                let is i32 as start_line = brace_stack[sp];
                if (fline > start_line) {
                    jw.obj_start(&w);
                    jw.kv_int(&w, "startLine", cast(i64, start_line));
                    jw.kv_int(&w, "endLine", cast(i64, fline));
                    jw.kv_str_c(&w, "kind", "region");
                    jw.obj_end(&w);
                }
            }
            pos = pos + 1;
        }
        else {
            if (c != 32 && c != 9 && c != 13) { comment_start = cast(i32, 0 - 1); }
            pos = pos + 1;
        }
    }

    jw.arr_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}

// === Custom: List modules from current document ===

fn handle_modules(id as i64, params as *json.JsonValue) as void {
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", id);
    jw.key_c(&w, "result");
    jw.obj_start(&w);

    // Language reference topics
    jw.key_c(&w, "language");
    jw.arr_start(&w);
    jw.str_c(&w, "let"); jw.str_c(&w, "fn"); jw.str_c(&w, "struct");
    jw.str_c(&w, "enum"); jw.str_c(&w, "match"); jw.str_c(&w, "use");
    jw.str_c(&w, "impl"); jw.str_c(&w, "if"); jw.str_c(&w, "while");
    jw.str_c(&w, "for"); jw.str_c(&w, "return"); jw.str_c(&w, "break");
    jw.str_c(&w, "continue"); jw.str_c(&w, "cast"); jw.str_c(&w, "sizeof");
    jw.str_c(&w, "defer"); jw.str_c(&w, "type"); jw.str_c(&w, "gen");
    jw.str_c(&w, "extern"); jw.str_c(&w, "syscall"); jw.str_c(&w, "asm");
    jw.str_c(&w, "fn_ptr"); jw.str_c(&w, "call"); jw.str_c(&w, "section");
    jw.str_c(&w, "Types"); jw.str_c(&w, "Operators");
    jw.arr_end(&w);

    // Stdlib modules
    jw.key_c(&w, "stdlib");
    jw.arr_start(&w);
    jw.str_c(&w, "env"); jw.str_c(&w, "io"); jw.str_c(&w, "linux");
    jw.str_c(&w, "map"); jw.str_c(&w, "math"); jw.str_c(&w, "mem");
    jw.str_c(&w, "net"); jw.str_c(&w, "random"); jw.str_c(&w, "slice");
    jw.str_c(&w, "sort"); jw.str_c(&w, "string"); jw.str_c(&w, "time");
    jw.str_c(&w, "types");
    jw.arr_end(&w);

    // Project modules from current open document
    jw.key_c(&w, "project");
    jw.arr_start(&w);
    let is *docs.Document as doc = docs.first_doc();
    if (cast(i64, doc) != 0) {
        syms.scan(doc.text_ptr, doc.text_len);
        let is i32 as i with mut = 0;
        while (i < syms.sym_count) {
            if (syms.sym_kinds[i] == syms.SK_MODULE) {
                // Check if it's NOT a stdlib module (import path doesn't contain "/std/")
                let is *u8 as imp = cast(*u8, syms.sym_types[i]);
                let is i32 as imp_len = syms.sym_type_lens[i];
                let is i32 as is_std with mut = 0;
                let is i32 as j with mut = 0;
                while (j < imp_len - 4) {
                    if (imp[j] == 47 && imp[j + 1] == 115 && imp[j + 2] == 116 && imp[j + 3] == 100 && imp[j + 4] == 47) {
                        is_std = 1;
                        break;
                    }
                    j = j + 1;
                }
                if (is_std == 0) {
                    jw.str_val(&w, cast(*u8, syms.sym_names[i]), syms.sym_name_lens[i]);
                }
            }
            i = i + 1;
        }
    }
    jw.arr_end(&w);

    jw.obj_end(&w);
    jw.obj_end(&w);
    rpc.write_message(jw.finish(&w), jw.finish_len(&w));
}
