use "../std/linux.cst" as linux;
use "../std/io.cst" as io;
use "json.cst" as json;

fn _read_exact(fd as i64, buf as *u8, n as i64) as i32 {
    let is i64 as total with mut = 0;
    while (total < n) {
        let is i64 as got = linux.read(fd, cast(*u8, cast(i64, buf) + total), n - total);
        if (got <= 0) { return cast(i32, 0 - 1); }
        total = total + got;
    }
    return 0;
}

fn read_message(out_body as *i64, out_len as *i32) as i32 {
    let is [4096]u8 as hdr_buf;
    let is i32 as hdr_len with mut = 0;
    let is i32 as content_length with mut = 0;

    while (1 == 1) {
        let is [1]u8 as ch;
        let is i64 as n = linux.read(linux.STDIN, &ch, 1);
        if (n <= 0) { return cast(i32, 0 - 1); }
        hdr_buf[hdr_len] = ch[0];
        hdr_len = hdr_len + 1;
        if (hdr_len >= 4
            && hdr_buf[hdr_len - 4] == 13
            && hdr_buf[hdr_len - 3] == 10
            && hdr_buf[hdr_len - 2] == 13
            && hdr_buf[hdr_len - 1] == 10) {
            break;
        }
        if (hdr_len >= 4090) { return cast(i32, 0 - 1); }
    }

    // Parse Content-Length
    let is i32 as hi with mut = 0;
    while (hi < hdr_len - 16) {
        // Check for "Content-Length: " — C(67) at 0, L(76) at 8, :(58) at 14, sp(32) at 15
        if (hdr_buf[hi] == 67 && hdr_buf[hi + 8] == 76
            && hdr_buf[hi + 14] == 58 && hdr_buf[hi + 15] == 32) {
            let is i32 as ni with mut = hi + 16;
            content_length = 0;
            while (ni < hdr_len && hdr_buf[ni] >= 48 && hdr_buf[ni] <= 57) {
                content_length = content_length * 10 + cast(i32, hdr_buf[ni]) - 48;
                ni = ni + 1;
            }
            break;
        }
        hi = hi + 1;
    }

    if (content_length <= 0) { return cast(i32, 0 - 1); }

    let is *u8 as body = json.alloc(cast(i64, content_length) + 1);
    if (_read_exact(linux.STDIN, body, cast(i64, content_length)) != 0) {
        return cast(i32, 0 - 1);
    }
    body[content_length] = cast(u8, 0);
    *out_body = cast(i64, body);
    *out_len = content_length;
    return 0;
}

fn write_message(json_buf as *u8, json_len as i32) as void {
    io.write_str(linux.STDOUT, "Content-Length: ");
    io.write_int(linux.STDOUT, cast(i64, json_len));
    linux.write(linux.STDOUT, "\r\n\r\n", 4);
    linux.write(linux.STDOUT, json_buf, cast(i64, json_len));
}
