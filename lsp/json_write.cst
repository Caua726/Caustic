use "../std/mem.cst" only core as mem;
use "json.cst" as json;

struct Writer {
    buf as *u8;
    len as i32;
    cap as i32;
    need_comma as i32;
}

fn writer_new() as Writer {
    let is Writer as w;
    w.cap = 1024;
    w.buf = json.alloc(cast(i64, w.cap));
    w.len = 0;
    w.need_comma = 0;
    return w;
}

fn _grow(w as *Writer, need as i32) as void {
    if (w.len + need < w.cap) { return; }
    let is i32 as new_cap with mut = w.cap * 2;
    if (new_cap < w.len + need + 256) { new_cap = w.len + need + 256; }
    let is *u8 as nb = json.alloc(cast(i64, new_cap));
    mem.core.memcpy(nb, w.buf, cast(i64, w.len));
    json.jfree(w.buf);
    w.buf = nb;
    w.cap = new_cap;
}

fn _put(w as *Writer, c as u8) as void {
    _grow(w, 1);
    w.buf[w.len] = c;
    w.len = w.len + 1;
}

fn _puts(w as *Writer, s as *u8, slen as i32) as void {
    _grow(w, slen);
    mem.core.memcpy(cast(*u8, cast(i64, w.buf) + cast(i64, w.len)), s, cast(i64, slen));
    w.len = w.len + slen;
}

fn _comma(w as *Writer) as void {
    if (w.need_comma == 1) { _put(w, 44); }
    w.need_comma = 0;
}

fn _write_escaped_str(w as *Writer, s as *u8, slen as i32) as void {
    _put(w, 34);
    let is i32 as i with mut = 0;
    while (i < slen) {
        let is u8 as c = s[i];
        if (c == 34) { _put(w, 92); _put(w, 34); }
        else if (c == 92) { _put(w, 92); _put(w, 92); }
        else if (c == 10) { _put(w, 92); _put(w, 110); }
        else if (c == 13) { _put(w, 92); _put(w, 114); }
        else if (c == 9) { _put(w, 92); _put(w, 116); }
        else if (c < 32) { }
        else { _put(w, c); }
        i = i + 1;
    }
    _put(w, 34);
}

fn obj_start(w as *Writer) as void {
    _comma(w);
    _put(w, 123);
    w.need_comma = 0;
}

fn obj_end(w as *Writer) as void {
    _put(w, 125);
    w.need_comma = 1;
}

fn arr_start(w as *Writer) as void {
    _comma(w);
    _put(w, 91);
    w.need_comma = 0;
}

fn arr_end(w as *Writer) as void {
    _put(w, 93);
    w.need_comma = 1;
}

fn key(w as *Writer, k as *u8, klen as i32) as void {
    _comma(w);
    _write_escaped_str(w, k, klen);
    _put(w, 58);
    w.need_comma = 0;
}

fn _cstrlen(s as *u8) as i32 {
    let is i32 as i with mut = 0;
    while (s[i] != cast(u8, 0)) { i = i + 1; }
    return i;
}

fn key_c(w as *Writer, k as *u8) as void {
    key(w, k, _cstrlen(k));
}

fn str_val(w as *Writer, s as *u8, slen as i32) as void {
    _comma(w);
    _write_escaped_str(w, s, slen);
    w.need_comma = 1;
}

fn str_c(w as *Writer, s as *u8) as void {
    str_val(w, s, _cstrlen(s));
}

fn int_val(w as *Writer, n as i64) as void {
    _comma(w);
    let is i64 as val with mut = n;
    if (val < 0) {
        _put(w, 45);
        val = 0 - val;
    }
    if (val == 0) { _put(w, 48); w.need_comma = 1; return; }
    let is [20]u8 as digits;
    let is i32 as di with mut = 0;
    while (val > 0) {
        digits[di] = cast(u8, 48 + cast(i32, val - (val / 10) * 10));
        val = val / 10;
        di = di + 1;
    }
    let is i32 as ri with mut = di - 1;
    while (ri >= 0) {
        _put(w, digits[ri]);
        ri = ri - 1;
    }
    w.need_comma = 1;
}

fn bool_val(w as *Writer, b as i32) as void {
    _comma(w);
    if (b != 0) { _puts(w, "true", 4); }
    else { _puts(w, "false", 5); }
    w.need_comma = 1;
}

fn null_val(w as *Writer) as void {
    _comma(w);
    _puts(w, "null", 4);
    w.need_comma = 1;
}

fn kv_str(w as *Writer, k as *u8, s as *u8, slen as i32) as void {
    key_c(w, k);
    str_val(w, s, slen);
}

fn kv_str_c(w as *Writer, k as *u8, s as *u8) as void {
    key_c(w, k);
    str_c(w, s);
}

fn kv_int(w as *Writer, k as *u8, n as i64) as void {
    key_c(w, k);
    int_val(w, n);
}

fn kv_bool(w as *Writer, k as *u8, b as i32) as void {
    key_c(w, k);
    bool_val(w, b);
}

fn kv_null(w as *Writer, k as *u8) as void {
    key_c(w, k);
    null_val(w);
}

fn finish(w as *Writer) as *u8 {
    w.buf[w.len] = cast(u8, 0);
    return w.buf;
}

fn finish_len(w as *Writer) as i32 {
    return w.len;
}
