use "../std/mem.cst" only bins, core as mem;
use "../std/linux.cst" as linux;
use "json.cst" as json;

// Symbol kinds (match LSP CompletionItemKind)
let is i32 as SK_FUNCTION with imut = 3;
let is i32 as SK_VARIABLE with imut = 6;
let is i32 as SK_STRUCT with imut = 22;
let is i32 as SK_ENUM with imut = 13;
let is i32 as SK_FIELD with imut = 5;
let is i32 as SK_TYPE_ALIAS with imut = 25;
let is i32 as SK_MODULE with imut = 9;

let is i32 as MAX_SYMS with imut = 1024;

// Symbol storage (flat arrays for speed)
let is [1024]i64 as sym_names with mut;      // *u8
let is [1024]i32 as sym_name_lens with mut;
let is [1024]i32 as sym_kinds with mut;
let is [1024]i32 as sym_lines with mut;       // 1-based
let is [1024]i32 as sym_cols with mut;        // 1-based
let is [1024]i64 as sym_types with mut;       // *u8 type string
let is [1024]i32 as sym_type_lens with mut;
let is i32 as sym_count with mut = 0;

fn reset() as void {
    sym_count = 0;
}

fn _add_sym(name as *u8, name_len as i32, kind as i32, line as i32, col as i32,
            ty_str as *u8, ty_len as i32) as void {
    if (sym_count >= MAX_SYMS) { return; }
    let is i32 as i = sym_count;
    sym_names[i] = cast(i64, name);
    sym_name_lens[i] = name_len;
    sym_kinds[i] = kind;
    sym_lines[i] = line;
    sym_cols[i] = col;
    sym_types[i] = cast(i64, ty_str);
    sym_type_lens[i] = ty_len;
    sym_count = sym_count + 1;
}

// === Source scanner ===
// Scan source text for definitions. Populates symbol arrays.

fn _is_alpha(c as u8) as i32 {
    if (c >= 65 && c <= 90) { return 1; }   // A-Z
    if (c >= 97 && c <= 122) { return 1; }  // a-z
    if (c == 95) { return 1; }              // _
    return 0;
}

fn _is_alnum(c as u8) as i32 {
    if (_is_alpha(c) == 1) { return 1; }
    if (c >= 48 && c <= 57) { return 1; }   // 0-9
    return 0;
}

fn _match_word(src as *u8, pos as i32, src_len as i32, word as *u8, wlen as i32) as i32 {
    if (pos + wlen > src_len) { return 0; }
    let is i32 as i with mut = 0;
    while (i < wlen) {
        if (src[pos + i] != word[i]) { return 0; }
        i = i + 1;
    }
    // Must not be followed by alnum (word boundary)
    if (pos + wlen < src_len && _is_alnum(src[pos + wlen]) == 1) { return 0; }
    return 1;
}

fn _skip_ws_inline(src as *u8, pos as *i32, src_len as i32) as void {
    while (*pos < src_len && (src[*pos] == 32 || src[*pos] == 9)) {
        *pos = *pos + 1;
    }
}

// Read an identifier at pos. Returns pointer into src, sets out_len.
fn _read_ident(src as *u8, pos as *i32, src_len as i32, out_len as *i32) as *u8 {
    let is i32 as start = *pos;
    while (*pos < src_len && _is_alnum(src[*pos]) == 1) {
        *pos = *pos + 1;
    }
    *out_len = *pos - start;
    return cast(*u8, cast(i64, src) + cast(i64, start));
}

// Read a type expression (simplified: just reads tokens until 'as' or '=' or '{' or ';' or ')')
fn _read_type(src as *u8, pos as *i32, src_len as i32, out_len as *i32) as *u8 {
    _skip_ws_inline(src, pos, src_len);
    let is i32 as start = *pos;
    // Handle pointer prefix
    while (*pos < src_len && src[*pos] == 42) { *pos = *pos + 1; } // *
    // Handle array prefix [N]
    if (*pos < src_len && src[*pos] == 91) {
        while (*pos < src_len && src[*pos] != 93) { *pos = *pos + 1; }
        if (*pos < src_len) { *pos = *pos + 1; } // skip ]
    }
    // Read the type name
    while (*pos < src_len && (_is_alnum(src[*pos]) == 1 || src[*pos] == 46)) {
        *pos = *pos + 1;
    }
    // Handle gen args (e.g. "Slice gen i32")
    _skip_ws_inline(src, pos, src_len);
    if (_match_word(src, *pos, src_len, "gen", 3) == 1) {
        *pos = *pos + 3;
        _skip_ws_inline(src, pos, src_len);
        while (*pos < src_len && (_is_alnum(src[*pos]) == 1 || src[*pos] == 44 || src[*pos] == 32)) {
            *pos = *pos + 1;
        }
    }
    *out_len = *pos - start;
    return cast(*u8, cast(i64, src) + cast(i64, start));
}

fn scan(src as *u8, src_len as i32) as void {
    reset();
    let is i32 as pos with mut = 0;
    let is i32 as line with mut = 1;
    let is i32 as line_start with mut = 0;

    while (pos < src_len) {
        let is u8 as c = src[pos];

        // Track line numbers
        if (c == 10) {
            line = line + 1;
            line_start = pos + 1;
            pos = pos + 1;
        }
        // Skip line comments
        else if (c == 47 && pos + 1 < src_len && src[pos + 1] == 47) {
            while (pos < src_len && src[pos] != 10) { pos = pos + 1; }
        }
        // Skip strings
        else if (c == 34) {
            pos = pos + 1;
            while (pos < src_len && src[pos] != 34) {
                if (src[pos] == 92) { pos = pos + 1; } // skip escape
                pos = pos + 1;
            }
            if (pos < src_len) { pos = pos + 1; }
        }
        // "fn " — function definition
        else if (_match_word(src, pos, src_len, "fn", 2) == 1) {
            let is i32 as fn_col = pos - line_start + 1;
            pos = pos + 2;
            _skip_ws_inline(src, &pos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
            if (nlen > 0) {
                // Skip to return type: find "as TYPE" after params
                let is *u8 as ret_type with mut = cast(*u8, 0);
                let is i32 as ret_len with mut = 0;
                // Scan forward for ") as "
                let is i32 as scan_pos with mut = pos;
                while (scan_pos < src_len - 4 && scan_pos < pos + 500) {
                    if (src[scan_pos] == 41 && src[scan_pos + 1] == 32
                        && src[scan_pos + 2] == 97 && src[scan_pos + 3] == 115
                        && src[scan_pos + 4] == 32) {
                        scan_pos = scan_pos + 5;
                        ret_type = _read_type(src, &scan_pos, src_len, &ret_len);
                        break;
                    }
                    scan_pos = scan_pos + 1;
                }
                if (ret_len == 0) { ret_type = "void"; ret_len = 4; }
                _add_sym(name, nlen, SK_FUNCTION, line, fn_col, ret_type, ret_len);
            }
        }
        // "let is " — variable
        else if (_match_word(src, pos, src_len, "let", 3) == 1) {
            let is i32 as let_col = pos - line_start + 1;
            pos = pos + 3;
            _skip_ws_inline(src, &pos, src_len);
            if (_match_word(src, pos, src_len, "is", 2) == 1) {
                pos = pos + 2;
                _skip_ws_inline(src, &pos, src_len);
                let is i32 as ty_len with mut = 0;
                let is *u8 as ty_str = _read_type(src, &pos, src_len, &ty_len);
                _skip_ws_inline(src, &pos, src_len);
                if (_match_word(src, pos, src_len, "as", 2) == 1) {
                    pos = pos + 2;
                    _skip_ws_inline(src, &pos, src_len);
                    let is i32 as nlen with mut = 0;
                    let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
                    if (nlen > 0) {
                        _add_sym(name, nlen, SK_VARIABLE, line, let_col, ty_str, ty_len);
                    }
                }
            }
        }
        // "struct " — struct definition
        else if (_match_word(src, pos, src_len, "struct", 6) == 1) {
            let is i32 as st_col = pos - line_start + 1;
            pos = pos + 6;
            _skip_ws_inline(src, &pos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
            if (nlen > 0) {
                _add_sym(name, nlen, SK_STRUCT, line, st_col, "struct", 6);
                // Scan fields inside { ... }
                _skip_ws_inline(src, &pos, src_len);
                // Skip gen params
                if (_match_word(src, pos, src_len, "gen", 3) == 1) {
                    while (pos < src_len && src[pos] != 123) { pos = pos + 1; }
                }
                if (pos < src_len && src[pos] == 123) {
                    pos = pos + 1;
                    // Parse fields: "name as type;"
                    while (pos < src_len && src[pos] != 125) {
                        if (src[pos] == 10) { line = line + 1; line_start = pos + 1; pos = pos + 1; }
                        else if (src[pos] == 32 || src[pos] == 9 || src[pos] == 13) { pos = pos + 1; }
                        else if (_is_alpha(src[pos]) == 1) {
                            let is i32 as fld_col = pos - line_start + 1;
                            let is i32 as flen with mut = 0;
                            let is *u8 as fname = _read_ident(src, &pos, src_len, &flen);
                            _skip_ws_inline(src, &pos, src_len);
                            if (_match_word(src, pos, src_len, "as", 2) == 1) {
                                pos = pos + 2;
                                let is i32 as fty_len with mut = 0;
                                let is *u8 as fty = _read_type(src, &pos, src_len, &fty_len);
                                _add_sym(fname, flen, SK_FIELD, line, fld_col, fty, fty_len);
                            }
                            // Skip to next ; or }
                            while (pos < src_len && src[pos] != 59 && src[pos] != 125) {
                                if (src[pos] == 10) { line = line + 1; line_start = pos + 1; }
                                pos = pos + 1;
                            }
                            if (pos < src_len && src[pos] == 59) { pos = pos + 1; }
                        }
                        else { pos = pos + 1; }
                    }
                    if (pos < src_len) { pos = pos + 1; } // skip }
                }
            }
        }
        // "enum " — enum definition
        else if (_match_word(src, pos, src_len, "enum", 4) == 1) {
            let is i32 as en_col = pos - line_start + 1;
            pos = pos + 4;
            _skip_ws_inline(src, &pos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
            if (nlen > 0) {
                _add_sym(name, nlen, SK_ENUM, line, en_col, "enum", 4);
            }
            // Skip to closing }
            while (pos < src_len && src[pos] != 125) {
                if (src[pos] == 10) { line = line + 1; line_start = pos + 1; }
                pos = pos + 1;
            }
            if (pos < src_len) { pos = pos + 1; }
        }
        // "type " — type alias
        else if (_match_word(src, pos, src_len, "type", 4) == 1) {
            let is i32 as ta_col = pos - line_start + 1;
            pos = pos + 4;
            _skip_ws_inline(src, &pos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
            if (nlen > 0) {
                _skip_ws_inline(src, &pos, src_len);
                if (pos < src_len && src[pos] == 61) { // =
                    pos = pos + 1;
                    let is i32 as ty_len with mut = 0;
                    let is *u8 as ty_str = _read_type(src, &pos, src_len, &ty_len);
                    _add_sym(name, nlen, SK_TYPE_ALIAS, line, ta_col, ty_str, ty_len);
                }
            }
        }
        // "use " — module import
        else if (_match_word(src, pos, src_len, "use", 3) == 1) {
            let is i32 as use_col = pos - line_start + 1;
            pos = pos + 3;
            _skip_ws_inline(src, &pos, src_len);
            // Skip the path string
            if (pos < src_len && src[pos] == 34) {
                pos = pos + 1;
                let is i32 as path_start = pos;
                while (pos < src_len && src[pos] != 34) { pos = pos + 1; }
                let is i32 as path_len = pos - path_start;
                if (pos < src_len) { pos = pos + 1; } // skip "
                // Find "as NAME"
                _skip_ws_inline(src, &pos, src_len);
                // Skip "only ..." if present
                if (_match_word(src, pos, src_len, "only", 4) == 1) {
                    while (pos < src_len && src[pos] != 59 && !(_match_word(src, pos, src_len, "as", 2) == 1)) {
                        pos = pos + 1;
                    }
                }
                if (_match_word(src, pos, src_len, "as", 2) == 1) {
                    pos = pos + 2;
                    _skip_ws_inline(src, &pos, src_len);
                    let is i32 as nlen with mut = 0;
                    let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
                    if (nlen > 0) {
                        _add_sym(name, nlen, SK_MODULE, line, use_col,
                                 cast(*u8, cast(i64, src) + cast(i64, path_start)), path_len);
                    }
                }
            }
        }
        else {
            pos = pos + 1;
        }
    }
}

// === Lookup ===

fn _streq(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    if (alen != blen) { return 0; }
    let is i32 as i with mut = 0;
    while (i < alen) {
        if (a[i] != b[i]) { return 0; }
        i = i + 1;
    }
    return 1;
}

// Find symbol by name. Returns index or -1.
fn find_by_name(name as *u8, name_len as i32) as i32 {
    let is i32 as i with mut = 0;
    while (i < sym_count) {
        if (_streq(cast(*u8, sym_names[i]), sym_name_lens[i], name, name_len) == 1) {
            return i;
        }
        i = i + 1;
    }
    return cast(i32, 0 - 1);
}

// Find the identifier at a given cursor position (line, col are 1-based).
// Scans source text to find the word under the cursor.
fn find_ident_at(src as *u8, src_len as i32, target_line as i32, target_col as i32,
                 out_name as **u8, out_len as *i32) as void {
    let is i32 as pos with mut = 0;
    let is i32 as line with mut = 1;
    let is i32 as line_start with mut = 0;

    // Find the target line
    while (pos < src_len && line < target_line) {
        if (src[pos] == 10) { line = line + 1; line_start = pos + 1; }
        pos = pos + 1;
    }

    // Move to target col (1-based)
    pos = line_start + target_col - 1;
    if (pos < 0 || pos >= src_len) { *out_name = cast(*u8, 0); *out_len = 0; return; }

    // Expand to find the full identifier
    let is i32 as start with mut = pos;
    while (start > line_start && _is_alnum(src[start - 1]) == 1) { start = start - 1; }
    let is i32 as end with mut = pos;
    while (end < src_len && _is_alnum(src[end]) == 1) { end = end + 1; }

    if (end <= start) { *out_name = cast(*u8, 0); *out_len = 0; return; }

    *out_name = cast(*u8, cast(i64, src) + cast(i64, start));
    *out_len = end - start;
}

// Find all occurrences of a name in source. Returns count.
// Fills out_lines[] and out_cols[] (1-based).
fn find_all_refs(src as *u8, src_len as i32, name as *u8, name_len as i32,
                 out_lines as *i32, out_cols as *i32, max_refs as i32) as i32 {
    let is i32 as count with mut = 0;
    let is i32 as pos with mut = 0;
    let is i32 as line with mut = 1;
    let is i32 as line_start with mut = 0;

    while (pos < src_len && count < max_refs) {
        if (src[pos] == 10) {
            line = line + 1;
            line_start = pos + 1;
            pos = pos + 1;
        }
        // Skip strings
        else if (src[pos] == 34) {
            pos = pos + 1;
            while (pos < src_len && src[pos] != 34) {
                if (src[pos] == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
            if (pos < src_len) { pos = pos + 1; }
        }
        // Skip comments
        else if (src[pos] == 47 && pos + 1 < src_len && src[pos + 1] == 47) {
            while (pos < src_len && src[pos] != 10) { pos = pos + 1; }
        }
        // Check for identifier match
        else if (_is_alpha(src[pos]) == 1) {
            let is i32 as id_start = pos;
            while (pos < src_len && _is_alnum(src[pos]) == 1) { pos = pos + 1; }
            let is i32 as id_len = pos - id_start;
            if (_streq(cast(*u8, cast(i64, src) + cast(i64, id_start)), id_len, name, name_len) == 1) {
                out_lines[count] = line;
                out_cols[count] = id_start - line_start + 1;
                count = count + 1;
            }
        }
        else {
            pos = pos + 1;
        }
    }
    return count;
}

// === Module member resolution ===

// Submodule info for X.Y.Z patterns (set by find_member_at)
let is *u8 as last_submod_ptr with mut;
let is i32 as last_submod_len with mut = 0;

// Check if cursor is on "mod.member" pattern.
// Returns 1 if found, fills out_mod_name/len and out_member_name/len.
fn find_member_at(src as *u8, src_len as i32, target_line as i32, target_col as i32,
                  out_mod as **u8, out_mod_len as *i32,
                  out_member as **u8, out_member_len as *i32) as i32 {
    // Find cursor position in source
    let is i32 as pos with mut = 0;
    let is i32 as line with mut = 1;
    let is i32 as line_start with mut = 0;
    while (pos < src_len && line < target_line) {
        if (src[pos] == 10) { line = line + 1; line_start = pos + 1; }
        pos = pos + 1;
    }
    pos = line_start + target_col - 1;
    if (pos < 0 || pos >= src_len) { return 0; }

    // Expand the identifier under cursor
    let is i32 as start with mut = pos;
    while (start > line_start && _is_alnum(src[start - 1]) == 1) { start = start - 1; }
    let is i32 as end with mut = pos;
    while (end < src_len && _is_alnum(src[end]) == 1) { end = end + 1; }
    if (end <= start) { return 0; }

    // Check for dot before: "mod.member" or "mod.sub.member" — cursor is on rightmost part
    if (start > 1 && src[start - 1] == 46) {
        let is i32 as mod_end = start - 1;
        let is i32 as mod_start with mut = mod_end - 1;
        while (mod_start > 0 && _is_alnum(src[mod_start - 1]) == 1) { mod_start = mod_start - 1; }
        if (mod_start < mod_end) {
            // Check for another dot before (X.Y.Z pattern — mod_start points to Y)
            if (mod_start > 1 && src[mod_start - 1] == 46) {
                let is i32 as root_end = mod_start - 1;
                let is i32 as root_start with mut = root_end - 1;
                while (root_start > 0 && _is_alnum(src[root_start - 1]) == 1) { root_start = root_start - 1; }
                if (root_start < root_end) {
                    *out_mod = cast(*u8, cast(i64, src) + cast(i64, root_start));
                    *out_mod_len = root_end - root_start;
                    *out_member = cast(*u8, cast(i64, src) + cast(i64, start));
                    *out_member_len = end - start;
                    // Store submodule name (Y)
                    last_submod_ptr = cast(*u8, cast(i64, src) + cast(i64, mod_start));
                    last_submod_len = mod_end - mod_start;
                    return 1;
                }
            }
            last_submod_len = 0;
            *out_mod = cast(*u8, cast(i64, src) + cast(i64, mod_start));
            *out_mod_len = mod_end - mod_start;
            *out_member = cast(*u8, cast(i64, src) + cast(i64, start));
            *out_member_len = end - start;
            return 1;
        }
    }

    // Check for dot after: "mod.member" — cursor is on "mod"
    if (end < src_len && src[end] == 46) {
        let is i32 as mem_start = end + 1;
        let is i32 as mem_end with mut = mem_start;
        while (mem_end < src_len && _is_alnum(src[mem_end]) == 1) { mem_end = mem_end + 1; }
        if (mem_end > mem_start) {
            *out_mod = cast(*u8, cast(i64, src) + cast(i64, start));
            *out_mod_len = end - start;
            *out_member = cast(*u8, cast(i64, src) + cast(i64, mem_start));
            *out_member_len = mem_end - mem_start;
            return 1;
        }
    }

    return 0;
}

// Resolve a module import path to an absolute path.
// Given the document's directory and the import path (e.g. "../std/io.cst"),
// returns the resolved absolute path.
fn resolve_module_path(doc_path as *u8, doc_path_len as i32,
                       import_path as *u8, import_path_len as i32,
                       out_len as *i32) as *u8 {
    // Find directory of the document
    let is i32 as dir_end with mut = doc_path_len - 1;
    while (dir_end >= 0 && doc_path[dir_end] != 47) { dir_end = dir_end - 1; }
    let is i32 as dir_len = dir_end + 1; // includes trailing /

    let is i32 as total = dir_len + import_path_len;
    let is *u8 as buf = json.alloc(cast(i64, total) + 1);
    mem.core.memcpy(buf, doc_path, cast(i64, dir_len));
    mem.core.memcpy(cast(*u8, cast(i64, buf) + cast(i64, dir_len)), import_path, cast(i64, import_path_len));
    buf[total] = cast(u8, 0);
    *out_len = total;
    return buf;
}

// Path to docs/stdlib/ directory (resolved at startup from binary location)
let is *u8 as docs_dir with mut;
let is i32 as docs_dir_len with mut;

// Look up documentation from docs/stdlib/<module>.md files.
// Searches for "## member_name" section and returns content until "---".
// Returns 1 if found, 0 if not.
fn lookup_in_docs(module_name as *u8, module_len as i32,
                  member_name as *u8, member_len as i32,
                  out_buf as *u8, out_max as i32, out_len as *i32) as i32 {
    if (cast(i64, docs_dir) == 0 || docs_dir_len == 0) { return 0; }

    // Build path: docs_dir + module_name + ".md\0"
    let is i32 as path_len = docs_dir_len + module_len + 3;
    let is *u8 as path = json.alloc(cast(i64, path_len) + 1);
    mem.core.memcpy(path, docs_dir, cast(i64, docs_dir_len));
    mem.core.memcpy(cast(*u8, cast(i64, path) + cast(i64, docs_dir_len)), module_name, cast(i64, module_len));
    let is i32 as suf_off = docs_dir_len + module_len;
    path[suf_off] = 46;     // .
    path[suf_off + 1] = 109; // m
    path[suf_off + 2] = 100; // d
    path[suf_off + 3] = cast(u8, 0);

    let is i32 as file_len with mut = 0;
    let is *u8 as file_src = _read_file(path, &file_len);
    if (cast(i64, file_src) == 0) { return 0; }

    // Search for "## member_name\n"
    let is i32 as pos with mut = 0;
    while (pos < file_len - 3) {
        if (file_src[pos] == 35 && file_src[pos + 1] == 35 && file_src[pos + 2] == 32) {
            // Found "## " — check if name matches
            let is i32 as name_start = pos + 3;
            let is i32 as name_end with mut = name_start;
            while (name_end < file_len && file_src[name_end] != 10) { name_end = name_end + 1; }
            let is i32 as hdr_len = name_end - name_start;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, name_start)), hdr_len,
                       member_name, member_len) == 1) {
                // Found! Extract content from after the header line to "---"
                let is i32 as content_start = name_end + 1;
                let is i32 as content_end with mut = content_start;
                while (content_end < file_len - 2) {
                    if (file_src[content_end] == 45 && file_src[content_end + 1] == 45
                        && file_src[content_end + 2] == 45) {
                        break;
                    }
                    content_end = content_end + 1;
                }
                // Trim trailing whitespace
                while (content_end > content_start && (file_src[content_end - 1] == 10
                       || file_src[content_end - 1] == 13 || file_src[content_end - 1] == 32)) {
                    content_end = content_end - 1;
                }
                let is i32 as clen with mut = content_end - content_start;
                if (clen > out_max - 1) { clen = out_max - 1; }
                mem.core.memcpy(out_buf, cast(*u8, cast(i64, file_src) + cast(i64, content_start)), cast(i64, clen));
                *out_len = clen;
                return 1;
            }
        }
        pos = pos + 1;
    }
    return 0;
}

// Find the line number (1-based) of a definition in a file.
// Searches for fn/struct/enum/type/let with the given name.
// Returns 0 if not found.
fn find_def_line(file_src as *u8, file_len as i32, name as *u8, name_len as i32) as i32 {
    let is i32 as pos with mut = 0;
    let is i32 as cur_line with mut = 1;

    while (pos < file_len) {
        if (file_src[pos] == 10) { cur_line = cur_line + 1; pos = pos + 1; }
        else if (file_src[pos] == 34) {
            pos = pos + 1;
            while (pos < file_len && file_src[pos] != 34) {
                if (file_src[pos] == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
            if (pos < file_len) { pos = pos + 1; }
        }
        else if (_match_word(file_src, pos, file_len, "fn", 2) == 1) {
            let is i32 as p with mut = pos + 2;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as ns = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, ns)), p - ns, name, name_len) == 1) {
                return cur_line;
            }
            pos = p;
        }
        else if (_match_word(file_src, pos, file_len, "struct", 6) == 1) {
            let is i32 as p with mut = pos + 6;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as ns = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, ns)), p - ns, name, name_len) == 1) {
                return cur_line;
            }
            pos = p;
        }
        else if (_match_word(file_src, pos, file_len, "enum", 4) == 1) {
            let is i32 as p with mut = pos + 4;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as ns = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, ns)), p - ns, name, name_len) == 1) {
                return cur_line;
            }
            pos = p;
        }
        else if (_match_word(file_src, pos, file_len, "type", 4) == 1) {
            let is i32 as p with mut = pos + 4;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as ns = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, ns)), p - ns, name, name_len) == 1) {
                return cur_line;
            }
            pos = p;
        }
        else if (_match_word(file_src, pos, file_len, "let", 3) == 1) {
            let is i32 as let_line = cur_line;
            let is i32 as p with mut = pos + 3;
            while (p < file_len && file_src[p] != 10 && file_src[p] != 59) {
                if (_match_word(file_src, p, file_len, "as", 2) == 1) {
                    p = p + 2;
                    _skip_ws_inline(file_src, &p, file_len);
                    let is i32 as ns = p;
                    while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
                    if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, ns)), p - ns, name, name_len) == 1) {
                        return let_line;
                    }
                }
                p = p + 1;
            }
            pos = p;
        }
        else { pos = pos + 1; }
    }
    return 0;
}

// Read a file into memory. Returns pointer or null. Sets out_len.
fn _read_file(path as *u8, out_len as *i32) as *u8 {
    let is i64 as fd = linux.open(path, 0, 0); // O_RDONLY=0
    if (fd < 0) { *out_len = 0; return cast(*u8, 0); }
    let is i64 as size = linux.lseek(fd, 0, 2); // SEEK_END=2
    linux.lseek(fd, 0, 0); // SEEK_SET=0
    if (size <= 0 || size > 1048576) { linux.close(fd); *out_len = 0; return cast(*u8, 0); }
    let is *u8 as buf = json.alloc(size + 1);
    linux.read(fd, buf, size);
    buf[size] = cast(u8, 0);
    linux.close(fd);
    *out_len = cast(i32, size);
    return buf;
}

// Find a function/struct/etc definition in a source file and return its
// full signature line + preceding comment block.
// Returns the hover text in out_buf, sets out_len.
fn lookup_in_file(file_src as *u8, file_len as i32, member_name as *u8, member_len as i32,
                  out_buf as *u8, out_max as i32, out_len as *i32) as i32 {
    let is i32 as pos with mut = 0;
    let is i32 as line_start with mut = 0;

    while (pos < file_len) {
        // Skip to start of line content
        if (file_src[pos] == 10) { line_start = pos + 1; pos = pos + 1; }
        // Skip strings
        else if (file_src[pos] == 34) {
            pos = pos + 1;
            while (pos < file_len && file_src[pos] != 34) {
                if (file_src[pos] == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
            if (pos < file_len) { pos = pos + 1; }
        }
        // Check "fn NAME" — also check params inside (...)
        else if (_match_word(file_src, pos, file_len, "fn", 2) == 1) {
            let is i32 as fn_start = line_start;
            let is i32 as p with mut = pos + 2;
            _skip_ws_inline(file_src, &p, file_len);
            // Read function name
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen, member_name, member_len) == 1) {
                return _extract_signature(file_src, file_len, fn_start, out_buf, out_max, out_len);
            }
            // Check params: scan inside (...) for "NAME as TYPE"
            _skip_ws_inline(file_src, &p, file_len);
            // Skip gen params
            if (_match_word(file_src, p, file_len, "gen", 3) == 1) {
                p = p + 3;
                while (p < file_len && file_src[p] != 40) { p = p + 1; } // skip to (
            }
            if (p < file_len && file_src[p] == 40) {
                p = p + 1; // skip (
                while (p < file_len && file_src[p] != 41) {
                    _skip_ws_inline(file_src, &p, file_len);
                    if (_is_alpha(file_src[p]) == 1) {
                        let is i32 as pname_start = p;
                        while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
                        let is i32 as pname_len = p - pname_start;
                        _skip_ws_inline(file_src, &p, file_len);
                        if (_match_word(file_src, p, file_len, "as", 2) == 1) {
                            // This is a parameter: "name as type"
                            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, pname_start)), pname_len, member_name, member_len) == 1) {
                                // Found param! Extract "name as type" as hover
                                let is i32 as param_start = pname_start;
                                let is i32 as param_end with mut = p + 2;
                                _skip_ws_inline(file_src, &param_end, file_len);
                                // Read the type
                                while (param_end < file_len && file_src[param_end] != 44 && file_src[param_end] != 41) {
                                    param_end = param_end + 1;
                                }
                                // Trim
                                while (param_end > param_start && file_src[param_end - 1] == 32) { param_end = param_end - 1; }
                                let is i32 as pclen with mut = param_end - param_start;
                                if (pclen > out_max - 1) { pclen = out_max - 1; }
                                // Prefix with "parameter: "
                                let is *u8 as prefix = "parameter: ";
                                let is i32 as pfx_len = 11;
                                let is i32 as total with mut = pfx_len + pclen;
                                if (total > out_max - 1) { total = out_max - 1; }
                                mem.core.memcpy(out_buf, prefix, cast(i64, pfx_len));
                                mem.core.memcpy(cast(*u8, cast(i64, out_buf) + cast(i64, pfx_len)),
                                               cast(*u8, cast(i64, file_src) + cast(i64, param_start)), cast(i64, pclen));
                                *out_len = total;
                                return 1;
                            }
                        }
                    }
                    // Advance past this param
                    while (p < file_len && file_src[p] != 44 && file_src[p] != 41) { p = p + 1; }
                    if (p < file_len && file_src[p] == 44) { p = p + 1; }
                }
            }
            pos = p;
        }
        // Check "struct NAME"
        else if (_match_word(file_src, pos, file_len, "struct", 6) == 1) {
            let is i32 as st_start = line_start;
            let is i32 as p with mut = pos + 6;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen, member_name, member_len) == 1) {
                return _extract_signature(file_src, file_len, st_start, out_buf, out_max, out_len);
            }
            pos = p;
        }
        // Check "enum NAME"
        else if (_match_word(file_src, pos, file_len, "enum", 4) == 1) {
            let is i32 as en_start = line_start;
            let is i32 as p with mut = pos + 4;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen, member_name, member_len) == 1) {
                return _extract_signature(file_src, file_len, en_start, out_buf, out_max, out_len);
            }
            pos = p;
        }
        // Check "type NAME"
        else if (_match_word(file_src, pos, file_len, "type", 4) == 1) {
            let is i32 as ta_start = line_start;
            let is i32 as p with mut = pos + 4;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen, member_name, member_len) == 1) {
                return _extract_signature(file_src, file_len, ta_start, out_buf, out_max, out_len);
            }
            pos = p;
        }
        // Check "let is ... as NAME"
        else if (_match_word(file_src, pos, file_len, "let", 3) == 1) {
            let is i32 as let_start = line_start;
            // Scan forward for "as NAME"
            let is i32 as p with mut = pos + 3;
            let is i32 as found_name with mut = 0;
            while (p < file_len && file_src[p] != 10 && file_src[p] != 59) {
                if (_match_word(file_src, p, file_len, "as", 2) == 1) {
                    p = p + 2;
                    _skip_ws_inline(file_src, &p, file_len);
                    let is i32 as nstart = p;
                    while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
                    let is i32 as nlen = p - nstart;
                    if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen, member_name, member_len) == 1) {
                        found_name = 1;
                        break;
                    }
                }
                p = p + 1;
            }
            if (found_name == 1) {
                return _extract_signature(file_src, file_len, let_start, out_buf, out_max, out_len);
            }
            pos = p;
        }
        // Check enum variants and skip other identifiers
        else if (_is_alpha(file_src[pos]) == 1) {
            let is i32 as id_start = pos;
            let is i32 as p with mut = pos;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as id_len = p - id_start;
            if (_streq(cast(*u8, cast(i64, file_src) + cast(i64, id_start)), id_len, member_name, member_len) == 1) {
                let is i32 as bp with mut = id_start - 1;
                while (bp > 0 && (file_src[bp] == 32 || file_src[bp] == 9 || file_src[bp] == 10 || file_src[bp] == 13)) { bp = bp - 1; }
                if (bp >= 0 && (file_src[bp] == 123 || file_src[bp] == 59)) {
                    return _extract_signature(file_src, file_len, id_start, out_buf, out_max, out_len);
                }
            }
            pos = p;
        }
        else { pos = pos + 1; }
    }
    *out_len = 0;
    return 0;
}

// Extract a signature: the definition line + preceding comment lines.
// Copies into out_buf. Returns 1 on success.
fn _extract_signature(src as *u8, src_len as i32, def_line_start as i32,
                      out_buf as *u8, out_max as i32, out_len as *i32) as i32 {
    let is i32 as olen with mut = 0;

    // Find preceding comment block (walk backwards from def_line_start)
    let is i32 as comment_start with mut = def_line_start;
    // Go back to find comment lines (lines starting with //)
    if (def_line_start > 1) {
        let is i32 as prev_end with mut = def_line_start - 1;
        // Skip blank line before def
        if (prev_end > 0 && src[prev_end] == 10) { prev_end = prev_end - 1; }
        // Walk back through comment lines
        while (prev_end > 0) {
            // Find start of this line
            let is i32 as ls with mut = prev_end;
            while (ls > 0 && src[ls - 1] != 10) { ls = ls - 1; }
            // Check if line starts with // (skip whitespace)
            let is i32 as lp with mut = ls;
            while (lp <= prev_end && (src[lp] == 32 || src[lp] == 9)) { lp = lp + 1; }
            if (lp + 1 <= prev_end && src[lp] == 47 && src[lp + 1] == 47) {
                comment_start = ls;
                // Continue checking previous line
                if (ls > 1) { prev_end = ls - 2; }
                else { break; }
            } else {
                break;
            }
        }
    }

    // Copy comment lines
    if (comment_start < def_line_start) {
        let is i32 as ci with mut = comment_start;
        while (ci < def_line_start && olen < out_max - 2) {
            out_buf[olen] = src[ci];
            olen = olen + 1;
            ci = ci + 1;
        }
        // Ensure newline before signature
        if (olen > 0 && out_buf[olen - 1] != 10) {
            out_buf[olen] = 10;
            olen = olen + 1;
        }
    }

    // Copy the definition line (up to '{' or ';' or newline)
    let is i32 as di with mut = def_line_start;
    while (di < src_len && olen < out_max - 1) {
        let is u8 as ch = src[di];
        if (ch == 123 || ch == 59) { break; } // { or ;
        if (ch == 10) { break; }
        out_buf[olen] = ch;
        olen = olen + 1;
        di = di + 1;
    }
    // Trim trailing whitespace
    while (olen > 0 && (out_buf[olen - 1] == 32 || out_buf[olen - 1] == 9)) {
        olen = olen - 1;
    }

    *out_len = olen;
    return 1;
}

// === Module export scanning ===
// Scan a module file and collect all top-level fn/struct/enum/type/let names.
// Stores into mod_export_* arrays. Returns count.

let is i32 as MAX_EXPORTS with imut = 256;
let is [256]i64 as mod_export_names with mut;
let is [256]i32 as mod_export_name_lens with mut;
let is [256]i32 as mod_export_kinds with mut;
let is [256]i64 as mod_export_details with mut;  // *u8 detail string (return type / field type)
let is [256]i32 as mod_export_detail_lens with mut;
let is i32 as mod_export_count with mut;

fn scan_module_exports(file_src as *u8, file_len as i32) as i32 {
    mod_export_count = 0;
    let is i32 as pos with mut = 0;

    while (pos < file_len && mod_export_count < MAX_EXPORTS) {
        let is u8 as c = file_src[pos];
        // Skip newlines
        if (c == 10) { pos = pos + 1; }
        // Skip strings
        else if (c == 34) {
            pos = pos + 1;
            while (pos < file_len && file_src[pos] != 34) {
                if (file_src[pos] == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
            if (pos < file_len) { pos = pos + 1; }
        }
        // Skip comments
        else if (c == 47 && pos + 1 < file_len && file_src[pos + 1] == 47) {
            while (pos < file_len && file_src[pos] != 10) { pos = pos + 1; }
        }
        // "fn " at start of line (not indented = top-level)
        else if (_match_word(file_src, pos, file_len, "fn", 2) == 1) {
            let is i32 as p with mut = pos + 2;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (nlen > 0) {
                // Get return type: scan for ") as TYPE"
                let is *u8 as ret with mut = "void";
                let is i32 as ret_len with mut = 4;
                let is i32 as sp with mut = p;
                while (sp < file_len - 4 && sp < p + 500) {
                    if (file_src[sp] == 41 && file_src[sp + 1] == 32
                        && file_src[sp + 2] == 97 && file_src[sp + 3] == 115
                        && file_src[sp + 4] == 32) {
                        sp = sp + 5;
                        ret = cast(*u8, cast(i64, file_src) + cast(i64, sp));
                        ret_len = 0;
                        while (sp + ret_len < file_len && _is_alnum(file_src[sp + ret_len]) == 1) {
                            ret_len = ret_len + 1;
                        }
                        // Include pointer prefix
                        if (ret_len > 0 && sp > 0 && file_src[sp - 1] == 42) {
                            ret = cast(*u8, cast(i64, file_src) + cast(i64, sp) - 1);
                            ret_len = ret_len + 1;
                        }
                        break;
                    }
                    if (file_src[sp] == 123 || file_src[sp] == 10) { break; }
                    sp = sp + 1;
                }
                _add_export(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen,
                           SK_FUNCTION, ret, ret_len);
            }
            pos = p;
        }
        // "struct "
        else if (_match_word(file_src, pos, file_len, "struct", 6) == 1) {
            let is i32 as p with mut = pos + 6;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (nlen > 0) {
                _add_export(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen,
                           SK_STRUCT, "struct", 6);
            }
            // Skip to closing }
            while (pos < file_len && file_src[pos] != 125) { pos = pos + 1; }
            if (pos < file_len) { pos = pos + 1; }
        }
        // "enum "
        else if (_match_word(file_src, pos, file_len, "enum", 4) == 1) {
            let is i32 as p with mut = pos + 4;
            _skip_ws_inline(file_src, &p, file_len);
            let is i32 as nstart = p;
            while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
            let is i32 as nlen = p - nstart;
            if (nlen > 0) {
                _add_export(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen,
                           SK_ENUM, "enum", 4);
            }
            while (pos < file_len && file_src[pos] != 125) { pos = pos + 1; }
            if (pos < file_len) { pos = pos + 1; }
        }
        // "let " (top-level globals)
        else if (_match_word(file_src, pos, file_len, "let", 3) == 1) {
            let is i32 as p with mut = pos + 3;
            _skip_ws_inline(file_src, &p, file_len);
            if (_match_word(file_src, p, file_len, "is", 2) == 1) {
                p = p + 2;
                _skip_ws_inline(file_src, &p, file_len);
                // Read type
                let is i32 as ty_start = p;
                let is i32 as ty_len with mut = 0;
                _read_type(file_src, &p, file_len, &ty_len);
                _skip_ws_inline(file_src, &p, file_len);
                if (_match_word(file_src, p, file_len, "as", 2) == 1) {
                    p = p + 2;
                    _skip_ws_inline(file_src, &p, file_len);
                    let is i32 as nstart = p;
                    while (p < file_len && _is_alnum(file_src[p]) == 1) { p = p + 1; }
                    let is i32 as nlen = p - nstart;
                    if (nlen > 0) {
                        _add_export(cast(*u8, cast(i64, file_src) + cast(i64, nstart)), nlen,
                                   SK_VARIABLE, cast(*u8, cast(i64, file_src) + cast(i64, ty_start)), ty_len);
                    }
                }
            }
            // Skip to end of line
            while (pos < file_len && file_src[pos] != 10) { pos = pos + 1; }
        }
        else { pos = pos + 1; }
    }
    return mod_export_count;
}

fn _add_export(name as *u8, name_len as i32, kind as i32, detail as *u8, detail_len as i32) as void {
    if (mod_export_count >= MAX_EXPORTS) { return; }
    let is i32 as i = mod_export_count;
    mod_export_names[i] = cast(i64, name);
    mod_export_name_lens[i] = name_len;
    mod_export_kinds[i] = kind;
    mod_export_details[i] = cast(i64, detail);
    mod_export_detail_lens[i] = detail_len;
    mod_export_count = mod_export_count + 1;
}

// Generate a full documentation page from source file
// Scans all top-level fn/struct/enum/type, extracts signatures + comments
// Returns length written to out_buf
fn generate_docs(src as *u8, src_len as i32, module_name as *u8, module_len as i32,
                 out_buf as *u8, out_max as i32) as i32 {
    let is i32 as olen with mut = 0;
    // Header: ## _module\n<module_name> module\n---\n
    let is *u8 as hdr1 = "## _module\n";
    let is i32 as hi with mut = 0;
    while (hdr1[hi] != cast(u8, 0) && olen < out_max) { out_buf[olen] = hdr1[hi]; olen = olen + 1; hi = hi + 1; }
    hi = 0;
    while (hi < module_len && olen < out_max) { out_buf[olen] = module_name[hi]; olen = olen + 1; hi = hi + 1; }
    let is *u8 as hdr2 = " module\n---\n";
    hi = 0;
    while (hdr2[hi] != cast(u8, 0) && olen < out_max) { out_buf[olen] = hdr2[hi]; olen = olen + 1; hi = hi + 1; }

    // Scan source for top-level definitions
    let is i32 as pos with mut = 0;
    let is i32 as line_start with mut = 0;
    let is i32 as depth with mut = 0;

    while (pos < src_len && olen < out_max - 200) {
        let is u8 as c = src[pos];
        if (c == 10) { line_start = pos + 1; pos = pos + 1; }
        else if (c == 123) { depth = depth + 1; pos = pos + 1; }
        else if (c == 125) { if (depth > 0) { depth = depth - 1; } pos = pos + 1; }
        else if (c == 34) { pos = pos + 1; while (pos < src_len && src[pos] != 34) { if (src[pos] == 92) { pos = pos + 1; } pos = pos + 1; } if (pos < src_len) { pos = pos + 1; } }
        else if (c == 47 && pos + 1 < src_len && src[pos + 1] == 47) { while (pos < src_len && src[pos] != 10) { pos = pos + 1; } }
        else if (depth == 0 && (_match_word(src, pos, src_len, "fn", 2) == 1 ||
                                _match_word(src, pos, src_len, "struct", 6) == 1 ||
                                _match_word(src, pos, src_len, "enum", 4) == 1 ||
                                _match_word(src, pos, src_len, "type", 4) == 1)) {
            // Extract name
            let is i32 as kw_len with mut = 2;
            if (src[pos] == 115) { kw_len = 6; } // struct
            if (src[pos] == 101) { kw_len = 4; } // enum
            if (src[pos] == 116) { kw_len = 4; } // type
            let is i32 as npos with mut = pos + kw_len;
            _skip_ws_inline(src, &npos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &npos, src_len, &nlen);
            if (nlen > 0 && name[0] != 95) { // skip _private names
                // ## name\n
                let is *u8 as shdr = "## ";
                hi = 0;
                while (shdr[hi] != cast(u8, 0) && olen < out_max) { out_buf[olen] = shdr[hi]; olen = olen + 1; hi = hi + 1; }
                hi = 0;
                while (hi < nlen && olen < out_max) { out_buf[olen] = name[hi]; olen = olen + 1; hi = hi + 1; }
                out_buf[olen] = 10; olen = olen + 1;

                // Extract signature + comments
                let is [1024]u8 as sig_buf;
                let is i32 as sig_len with mut = 0;
                _extract_signature(src, src_len, line_start, &sig_buf, 1000, &sig_len);
                hi = 0;
                while (hi < sig_len && olen < out_max) { out_buf[olen] = sig_buf[hi]; olen = olen + 1; hi = hi + 1; }
                out_buf[olen] = 10; olen = olen + 1;

                // ---\n
                let is *u8 as sep = "---\n";
                hi = 0;
                while (sep[hi] != cast(u8, 0) && olen < out_max) { out_buf[olen] = sep[hi]; olen = olen + 1; hi = hi + 1; }
            }
            // Skip past the definition
            pos = npos;
        }
        else { pos = pos + 1; }
    }
    return olen;
}

// Find field info for a struct type in source
fn lookup_struct_field(src as *u8, src_len as i32, struct_name as *u8, struct_len as i32,
                       field_name as *u8, field_len as i32,
                       out_buf as *u8, out_max as i32, out_len as *i32) as i32 {
    let is i32 as pos with mut = 0;
    while (pos < src_len) {
        if (_match_word(src, pos, src_len, "struct", 6) == 1) {
            pos = pos + 6;
            _skip_ws_inline(src, &pos, src_len);
            let is i32 as nlen with mut = 0;
            let is *u8 as name = _read_ident(src, &pos, src_len, &nlen);
            if (nlen == struct_len && _streq(name, nlen, struct_name, struct_len) == 1) {
                while (pos < src_len && src[pos] != 123) { pos = pos + 1; }
                if (pos >= src_len) { return 0; }
                pos = pos + 1;
                while (pos < src_len && src[pos] != 125) {
                    if (src[pos] == 32 || src[pos] == 9 || src[pos] == 10 || src[pos] == 13) { pos = pos + 1; }
                    else if (_is_alpha(src[pos]) == 1) {
                        let is i32 as flen with mut = 0;
                        let is *u8 as fname = _read_ident(src, &pos, src_len, &flen);
                        _skip_ws_inline(src, &pos, src_len);
                        if (_match_word(src, pos, src_len, "as", 2) == 1) {
                            pos = pos + 2;
                            _skip_ws_inline(src, &pos, src_len);
                            let is i32 as fty_len with mut = 0;
                            let is *u8 as fty = _read_type(src, &pos, src_len, &fty_len);
                            if (flen == field_len && _streq(fname, flen, field_name, field_len) == 1) {
                                let is i32 as wlen with mut = 0;
                                let is i32 as ci with mut = 0;
                                while (ci < flen && wlen < out_max) { out_buf[wlen] = fname[ci]; wlen = wlen + 1; ci = ci + 1; }
                                let is *u8 as sep = " as ";
                                ci = 0;
                                while (sep[ci] != cast(u8, 0) && wlen < out_max) { out_buf[wlen] = sep[ci]; wlen = wlen + 1; ci = ci + 1; }
                                ci = 0;
                                while (ci < fty_len && wlen < out_max) { out_buf[wlen] = fty[ci]; wlen = wlen + 1; ci = ci + 1; }
                                *out_len = wlen;
                                return 1;
                            }
                        }
                        while (pos < src_len && src[pos] != 59 && src[pos] != 125) { pos = pos + 1; }
                        if (pos < src_len && src[pos] == 59) { pos = pos + 1; }
                    }
                    else { pos = pos + 1; }
                }
                return 0;
            }
        }
        else { pos = pos + 1; }
    }
    return 0;
}
