// Keyword hover documentation for the Caustic language.
// Returns a doc string for a given keyword, or null if not a keyword.

fn _streq(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    if (alen != blen) { return 0; }
    let is i32 as i with mut = 0;
    while (i < alen) {
        if (a[i] != b[i]) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn lookup(name as *u8, name_len as i32, out_doc as **u8, out_len as *i32) as i32 {
    if (_streq(name, name_len, "use", 3) == 1) {
        *out_doc = "use \"path/to/module.cst\" as name;\n\nImports a module. The file is compiled and its public symbols become accessible via the alias.\n\nExamples:\n  use \"std/io.cst\" as io;\n  use \"std/mem.cst\" only bins, core as mem;\n  io.write_str(1, \"hello\");";
        *out_len = 261;
        return 1;
    }
    if (_streq(name, name_len, "as", 2) == 1) {
        *out_doc = "as — type annotation or alias\n\nUsed in:\n  let is TYPE as NAME     (variable name)\n  fn f(x as i32)          (parameter type)\n  fn f() as i32            (return type)\n  use \"...\" as name        (module alias)\n  cast(TYPE, expr)  alt: expr as TYPE";
        *out_len = 260;
        return 1;
    }
    if (_streq(name, name_len, "fn", 2) == 1) {
        *out_doc = "fn — function definition\n\nfn name(param as Type) as ReturnType {\n    // body\n}\n\nVariants:\n  fn name gen T (...)       generic function\n  extern fn name(...)       external linkage (no body)\n  impl Type { fn ... }      method/associated function";
        *out_len = 259;
        return 1;
    }
    if (_streq(name, name_len, "let", 3) == 1) {
        *out_doc = "let — variable declaration\n\nlet is TYPE as NAME = EXPR;\nlet is TYPE as NAME with mut = EXPR;   mutable\nlet is TYPE as NAME with imut = EXPR;  immutable constant\n\nExamples:\n  let is i32 as x = 10;\n  let is *u8 as ptr with mut;\n  let is [64]u8 as buf;";
        *out_len = 267;
        return 1;
    }
    if (_streq(name, name_len, "is", 2) == 1) {
        *out_doc = "is — type specifier in variable declarations\n\nlet is TYPE as NAME;\n\nThe type comes after 'is' and before 'as'.\n\nExamples:\n  let is i32 as x = 0;\n  let is *u8 as ptr;\n  let is [128]u8 as buffer;";
        *out_len = 197;
        return 1;
    }
    if (_streq(name, name_len, "with", 4) == 1) {
        *out_doc = "with — variable modifier\n\nlet is TYPE as NAME with mut = EXPR;    mutable (can be reassigned)\nlet is TYPE as NAME with imut = EXPR;   immutable global constant\n\nWithout 'with', local variables are immutable by default.";
        *out_len = 219;
        return 1;
    }
    if (_streq(name, name_len, "mut", 3) == 1) {
        *out_doc = "mut — mutable modifier\n\nlet is i32 as x with mut = 0;\n\nAllows the variable to be reassigned after declaration.\nWithout 'mut', variables are immutable.";
        *out_len = 156;
        return 1;
    }
    if (_streq(name, name_len, "imut", 4) == 1) {
        *out_doc = "imut — immutable constant modifier\n\nlet is i32 as MAX with imut = 100;\n\nDeclares a compile-time constant global.\nNote: cannot use negative values (use 0 - N instead).";
        *out_len = 168;
        return 1;
    }
    if (_streq(name, name_len, "struct", 6) == 1) {
        *out_doc = "struct — composite type definition\n\nstruct Name {\n    field as Type;\n}\n\nStructs are packed (no alignment padding).\nAccess fields with dot: val.field\nPointer access: ptr.field (auto-deref)\n\nWith generics:\n  struct Pair gen T, U { a as T; b as U; }";
        *out_len = 252;
        return 1;
    }
    if (_streq(name, name_len, "enum", 4) == 1) {
        *out_doc = "enum — tagged union type\n\nenum Name {\n    Variant;\n    WithPayload(Type);\n}\n\nCreate: let is Name as x = Name.Variant;\nMatch:\n  match (x) as Name {\n      case Variant { ... }\n      case WithPayload(val) { ... }\n  }";
        *out_len = 214;
        return 1;
    }
    if (_streq(name, name_len, "type", 4) == 1) {
        *out_doc = "type — type alias\n\ntype NewName = ExistingType;\n\nCreates an alias for an existing type.\n\nExamples:\n  type Byte = u8;\n  type Size = i64;\n  type Callback = *u8;";
        *out_len = 159;
        return 1;
    }
    if (_streq(name, name_len, "impl", 4) == 1) {
        *out_doc = "impl — method block for a type\n\nimpl TypeName {\n    fn method(self as *TypeName) as void { ... }\n    fn associated() as TypeName { ... }\n}\n\nMethods: called as val.method() (self passed automatically)\nAssociated: called as TypeName.func()";
        *out_len = 240;
        return 1;
    }
    if (_streq(name, name_len, "return", 6) == 1) {
        *out_doc = "return — exit function with a value\n\nreturn EXPR;\nreturn;       (void functions)\n\nIn main(), the return value becomes the process exit code (0-255).\nDeferred calls execute after the return value is evaluated.";
        *out_len = 213;
        return 1;
    }
    if (_streq(name, name_len, "if", 2) == 1) {
        *out_doc = "if — conditional branch\n\nif (condition) {\n    // then\n} else if (other) {\n    // else if\n} else {\n    // else\n}";
        *out_len = 110;
        return 1;
    }
    if (_streq(name, name_len, "else", 4) == 1) {
        *out_doc = "else — alternative branch\n\nif (cond) { ... } else { ... }\nif (cond) { ... } else if (cond2) { ... }";
        *out_len = 100;
        return 1;
    }
    if (_streq(name, name_len, "while", 5) == 1) {
        *out_doc = "while — loop while condition is true\n\nwhile (condition) {\n    // body\n}\n\nUse break to exit, continue to skip to next iteration.";
        *out_len = 128;
        return 1;
    }
    if (_streq(name, name_len, "for", 3) == 1) {
        *out_doc = "for — C-style loop\n\nfor (INIT; CONDITION; STEP) {\n    // body\n}\n\nExample:\n  for (let is i32 as i = 0; i < 10; i = i + 1) {\n      // ...\n  }";
        *out_len = 142;
        return 1;
    }
    if (_streq(name, name_len, "do", 2) == 1) {
        *out_doc = "do — do-while loop\n\ndo {\n    // body (executes at least once)\n} while (condition);";
        *out_len = 81;
        return 1;
    }
    if (_streq(name, name_len, "break", 5) == 1) {
        *out_doc = "break — exit the innermost loop\n\nwhile (1 == 1) {\n    if (done) { break; }\n}";
        *out_len = 76;
        return 1;
    }
    if (_streq(name, name_len, "continue", 8) == 1) {
        *out_doc = "continue — skip to next loop iteration\n\nwhile (i < 10) {\n    i = i + 1;\n    if (i == 5) { continue; }\n    // skipped when i == 5\n}";
        *out_len = 131;
        return 1;
    }
    if (_streq(name, name_len, "match", 5) == 1) {
        *out_doc = "match — pattern matching on enums\n\nmatch (expr) as EnumType {\n    case Variant { ... }\n    case WithPayload(val) { ... }\n    else { ... }\n}\n\nEach case matches a variant. Payloads are bound to names.";
        *out_len = 199;
        return 1;
    }
    if (_streq(name, name_len, "case", 4) == 1) {
        *out_doc = "case — match arm\n\ncase VariantName { ... }\ncase VariantName(binding) { ... }\n\nUsed inside match blocks to handle each enum variant.";
        *out_len = 133;
        return 1;
    }
    if (_streq(name, name_len, "cast", 4) == 1) {
        *out_doc = "cast — type conversion\n\ncast(TargetType, expression)\n\nExamples:\n  cast(i32, my_i64)        narrow integer\n  cast(*u8, address)       reinterpret as pointer\n  cast(i64, ptr)           pointer to integer\n  cast(*MyStruct, raw_ptr) typed pointer cast";
        *out_len = 258;
        return 1;
    }
    if (_streq(name, name_len, "sizeof", 6) == 1) {
        *out_doc = "sizeof — size of a type in bytes\n\nsizeof(Type)\n\nReturns the byte size as i64.\nNote: structs are packed (no padding).\n\nExamples:\n  sizeof(i32)    = 4\n  sizeof(i64)    = 8\n  sizeof(Point)  = sum of field sizes";
        *out_len = 209;
        return 1;
    }
    if (_streq(name, name_len, "syscall", 7) == 1) {
        *out_doc = "syscall — direct Linux system call\n\nsyscall(number, arg1, arg2, ...)\n\nInvokes a raw x86_64 Linux syscall.\n\nExamples:\n  syscall(1, 1, \"hello\", 5)  write to stdout\n  syscall(60, 0)              exit(0)\n  syscall(9, 0, 4096, 3, 34, -1, 0)  mmap\n\nPrefer std/linux.cst wrappers when available.";
        *out_len = 298;
        return 1;
    }
    if (_streq(name, name_len, "asm", 3) == 1) {
        *out_doc = "asm — inline assembly\n\nasm(\"x86_64 assembly here\\n\");\n\nInserts raw x86_64 assembly instructions into the output.\nUse \\n to separate instructions.\n\nExample:\n  asm(\"mov rax, 1\\nsyscall\\n\");";
        *out_len = 190;
        return 1;
    }
    if (_streq(name, name_len, "defer", 5) == 1) {
        *out_doc = "defer — schedule cleanup before return\n\ndefer function_call(args);\n\nThe deferred call runs before every return in the current scope.\nMultiple defers run in LIFO order (last first).\nReturn value is evaluated before defers.\n\nExample:\n  let is *u8 as p = mem.galloc(1024);\n  defer mem.gfree(p);\n  // ... use p ...\n  return 0;  // gfree(p) called here";
        *out_len = 354;
        return 1;
    }
    if (_streq(name, name_len, "extern", 6) == 1) {
        *out_doc = "extern — external function declaration\n\nextern fn name(params) as RetType;\n\nDeclares a function defined in another object file.\nUsed for multi-file compilation and C FFI.\n\nExample:\n  extern fn printf(fmt as *u8, ...) as i32;";
        *out_len = 228;
        return 1;
    }
    if (_streq(name, name_len, "gen", 3) == 1) {
        *out_doc = "gen — generic type parameter\n\nfn max gen T (a as T, b as T) as T { ... }\nstruct Pair gen T, U { a as T; b as U; }\n\nInstantiate with:\n  max gen i32 (1, 2)\n  let is Pair gen i32, f64 as p;\n\nMonomorphized at compile time (like C++ templates).";
        *out_len = 245;
        return 1;
    }
    if (_streq(name, name_len, "only", 4) == 1) {
        *out_doc = "only — selective module import\n\nuse \"std/mem.cst\" only bins, core as mem;\n\nImports only the specified submodules.\nReduces namespace pollution and can improve compile times.";
        *out_len = 172;
        return 1;
    }
    if (_streq(name, name_len, "fn_ptr", 6) == 1) {
        *out_doc = "fn_ptr — get function pointer\n\nlet is *u8 as cb = fn_ptr(my_func);\nlet is *u8 as cb = fn_ptr(mod.func);\nlet is *u8 as cb = fn_ptr(max gen i32);\n\nReturns a typed function pointer (TY_FN).\nCall with: call(cb, arg1, arg2)";
        *out_len = 221;
        return 1;
    }
    if (_streq(name, name_len, "call", 4) == 1) {
        *out_doc = "call — indirect function call\n\nlet is i64 as result = call(fn_pointer, arg1, arg2);\n\nCalls a function through a pointer obtained from fn_ptr().\nType-checked at compile time against the function signature.";
        *out_len = 207;
        return 1;
    }
    // Primitive types
    if (_streq(name, name_len, "i8", 2) == 1) { *out_doc = "i8 — signed 8-bit integer (-128 to 127)"; *out_len = 39; return 1; }
    if (_streq(name, name_len, "i16", 3) == 1) { *out_doc = "i16 — signed 16-bit integer (-32768 to 32767)"; *out_len = 46; return 1; }
    if (_streq(name, name_len, "i32", 3) == 1) { *out_doc = "i32 — signed 32-bit integer (-2^31 to 2^31-1)"; *out_len = 46; return 1; }
    if (_streq(name, name_len, "i64", 3) == 1) { *out_doc = "i64 — signed 64-bit integer (-2^63 to 2^63-1), default integer type"; *out_len = 67; return 1; }
    if (_streq(name, name_len, "u8", 2) == 1) { *out_doc = "u8 — unsigned 8-bit integer (0 to 255), also used for raw bytes"; *out_len = 63; return 1; }
    if (_streq(name, name_len, "u16", 3) == 1) { *out_doc = "u16 — unsigned 16-bit integer (0 to 65535)"; *out_len = 42; return 1; }
    if (_streq(name, name_len, "u32", 3) == 1) { *out_doc = "u32 — unsigned 32-bit integer (0 to 2^32-1)"; *out_len = 44; return 1; }
    if (_streq(name, name_len, "u64", 3) == 1) { *out_doc = "u64 — unsigned 64-bit integer (0 to 2^64-1)"; *out_len = 44; return 1; }
    if (_streq(name, name_len, "f32", 3) == 1) { *out_doc = "f32 — 32-bit float (single precision IEEE 754)"; *out_len = 47; return 1; }
    if (_streq(name, name_len, "f64", 3) == 1) { *out_doc = "f64 — 64-bit float (double precision IEEE 754), default float type"; *out_len = 66; return 1; }
    if (_streq(name, name_len, "bool", 4) == 1) { *out_doc = "bool — boolean type (1 byte, true or false)"; *out_len = 43; return 1; }
    if (_streq(name, name_len, "char", 4) == 1) { *out_doc = "char — character type (1 byte), literal: 'A'"; *out_len = 44; return 1; }
    if (_streq(name, name_len, "string", 6) == 1) { *out_doc = "string — string literal type (*u8 pointer to null-terminated bytes)"; *out_len = 66; return 1; }
    if (_streq(name, name_len, "void", 4) == 1) { *out_doc = "void — no value, used as return type for functions that return nothing"; *out_len = 69; return 1; }
    return 0;
}
