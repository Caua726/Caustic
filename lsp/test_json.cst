use "../std/mem.cst" only bins, core as mem;
use "json.cst" as json;
use "json_write.cst" as jw;
use "../std/linux.cst" as linux;
use "../std/io.cst" as io;

fn assert_eq(got as i64, expected as i64, label as *u8) as void {
    if (got != expected) {
        io.write_str(linux.STDERR, "FAIL: ");
        io.write_str(linux.STDERR, label);
        io.write_str(linux.STDERR, " got=");
        io.write_int(linux.STDERR, got);
        io.write_str(linux.STDERR, " expected=");
        io.write_int(linux.STDERR, expected);
        io.write_str(linux.STDERR, "\n");
        linux.exit(1);
    }
}

fn main() as i32 {
    // Test 1: object with string and int
    let is *json.JsonValue as v1 = json.parse("{\"id\":42,\"method\":\"initialize\"}", 31);
    assert_eq(cast(i64, json.parse_ok()), 1, "parse ok");
    assert_eq(cast(i64, v1.kind), cast(i64, json.JSON_OBJECT), "is object");
    assert_eq(json.obj_get_int(v1, "id", 2, 0), 42, "id=42");
    let is i32 as mlen with mut = 0;
    let is *u8 as mstr = json.obj_get_str(v1, "method", 6, &mlen);
    assert_eq(cast(i64, mlen), 10, "method len");

    // Test 2: array
    let is *json.JsonValue as v2 = json.parse("[1,2,3]", 7);
    assert_eq(cast(i64, json.parse_ok()), 1, "array ok");
    assert_eq(cast(i64, v2.kind), cast(i64, json.JSON_ARRAY), "is array");
    assert_eq(cast(i64, v2.child_count), 3, "3 elements");
    let is *json.JsonValue as e0 = json.arr_get(v2, 0);
    assert_eq(json.get_int(e0, 0), 1, "arr[0]=1");
    let is *json.JsonValue as e2 = json.arr_get(v2, 2);
    assert_eq(json.get_int(e2, 0), 3, "arr[2]=3");

    // Test 3: nested object
    let is *json.JsonValue as v3 = json.parse("{\"pos\":{\"line\":5,\"character\":10}}", 33);
    assert_eq(cast(i64, json.parse_ok()), 1, "nested ok");
    let is *json.JsonValue as pos = json.obj_get(v3, "pos", 3);
    assert_eq(json.obj_get_int(pos, "line", 4, 0), 5, "line=5");
    assert_eq(json.obj_get_int(pos, "character", 9, 0), 10, "char=10");

    // Test 4: null, true, false
    let is *json.JsonValue as v4 = json.parse("{\"a\":null,\"b\":true,\"c\":false}", 29);
    assert_eq(cast(i64, json.parse_ok()), 1, "null/bool ok");
    let is *json.JsonValue as va = json.obj_get(v4, "a", 1);
    assert_eq(cast(i64, va.kind), cast(i64, json.JSON_NULL), "a=null");
    let is *json.JsonValue as vb = json.obj_get(v4, "b", 1);
    assert_eq(cast(i64, vb.kind), cast(i64, json.JSON_BOOL), "b=bool");
    assert_eq(vb.int_val, 1, "b=true");

    // Test 5: empty object/array
    let is *json.JsonValue as v5 = json.parse("{}", 2);
    assert_eq(cast(i64, json.parse_ok()), 1, "empty obj ok");
    assert_eq(cast(i64, v5.child_count), 0, "empty obj count");

    let is *json.JsonValue as v6 = json.parse("[]", 2);
    assert_eq(cast(i64, json.parse_ok()), 1, "empty arr ok");
    assert_eq(cast(i64, v6.child_count), 0, "empty arr count");

    // Test 6: string with escapes
    let is *json.JsonValue as v7 = json.parse("{\"msg\":\"hello\\nworld\"}", 22);
    assert_eq(cast(i64, json.parse_ok()), 1, "escape ok");
    let is i32 as el with mut = 0;
    let is *u8 as es = json.obj_get_str(v7, "msg", 3, &el);
    assert_eq(cast(i64, el), 11, "escape len=11");

    // === JSON Writer tests ===
    let is jw.Writer as w = jw.writer_new();
    jw.obj_start(&w);
    jw.kv_str_c(&w, "jsonrpc", "2.0");
    jw.kv_int(&w, "id", 1);
    jw.kv_null(&w, "result");
    jw.obj_end(&w);
    let is *u8 as out = jw.finish(&w);
    let is i32 as olen = jw.finish_len(&w);
    let is *json.JsonValue as round = json.parse(out, olen);
    assert_eq(cast(i64, json.parse_ok()), 1, "writer roundtrip");
    assert_eq(json.obj_get_int(round, "id", 2, 0), 1, "writer id=1");

    io.write_str(linux.STDOUT, "json+writer: all tests passed\n");
    return 0;
}
