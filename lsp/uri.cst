use "../std/mem.cst" only bins, core as mem;
use "json.cst" as json;

fn _hex_digit(c as u8) as i32 {
    if (c >= 48 && c <= 57) { return cast(i32, c) - 48; }
    if (c >= 65 && c <= 70) { return cast(i32, c) - 55; }
    if (c >= 97 && c <= 102) { return cast(i32, c) - 87; }
    return 0;
}

fn uri_to_path(uri as *u8, uri_len as i32, out_len as *i32) as *u8 {
    let is i32 as start with mut = 0;
    if (uri_len > 7 && uri[0] == 102 && uri[1] == 105 && uri[2] == 108
        && uri[3] == 101 && uri[4] == 58 && uri[5] == 47 && uri[6] == 47) {
        start = 7;
    }
    let is i32 as max_len = uri_len - start;
    let is *u8 as buf = json.alloc(cast(i64, max_len) + 1);
    let is i32 as bi with mut = 0;
    let is i32 as i with mut = start;
    while (i < uri_len) {
        if (uri[i] == 37 && i + 2 < uri_len) {
            let is i32 as hi = _hex_digit(uri[i + 1]);
            let is i32 as lo = _hex_digit(uri[i + 2]);
            buf[bi] = cast(u8, hi * 16 + lo);
            bi = bi + 1;
            i = i + 3;
        } else {
            buf[bi] = uri[i];
            bi = bi + 1;
            i = i + 1;
        }
    }
    buf[bi] = cast(u8, 0);
    *out_len = bi;
    return buf;
}

fn path_to_uri(path as *u8, path_len as i32, out_len as *i32) as *u8 {
    let is i32 as total = 7 + path_len;
    let is *u8 as buf = json.alloc(cast(i64, total) + 1);
    mem.core.memcpy(buf, "file://", 7);
    mem.core.memcpy(cast(*u8, cast(i64, buf) + 7), path, cast(i64, path_len));
    buf[total] = cast(u8, 0);
    *out_len = total;
    return buf;
}
