// =======================================================
// std/errors.cst — error helpers: compile-time aborts + runtime panic
//
// Two layers:
//   * compile-time — thin wrappers over the __compile_error builtin. They
//     abort the build IF reached (the builtin survives dead-branch elim +
//     function DCE, so it fires only for code actually compiled). Because the
//     builtin needs a string LITERAL, each helper carries a fixed message;
//     for a custom message use __compile_error("...") directly at the site.
//   * runtime — panic/assert that print to stderr and exit. Portable: they
//     route through io, so they work on every target (serial on CausticOS).
//
// NOTE: io.cst does NOT import this module (it would create a cycle, since we
// import io for panic). io.cst uses __compile_error inline; everything else
// can use these helpers.
// =======================================================

use "io.cst" as io;

// === Compile-time errors (abort the build when reached) ===

fn unsupported() as void {
    __compile_error("operation not supported on the target OS");
}

fn no_vfs() as void {
    __compile_error("file/VFS operations are not available on the target OS");
}

fn no_heap() as void {
    __compile_error("dynamic memory (mmap/brk) is not available on the target OS");
}

fn no_network() as void {
    __compile_error("network operations are not available on the target OS");
}

fn no_processes() as void {
    __compile_error("process control (spawn/fork/exec) is not available on the target OS");
}

fn not_implemented() as void {
    __compile_error("not implemented");
}

fn todo() as void {
    __compile_error("TODO: not yet implemented");
}

// === Runtime errors ===

// panic: print "panic: <msg>" to stderr and terminate the process (exit 1).
// Never returns. Portable across all targets via the io facade.
fn panic(msg as *u8) as void {
    io.write_str(io.STDERR, "panic: ");
    io.write_str(io.STDERR, msg);
    io.write_str(io.STDERR, "\n");
    io.exit(1);
}

// panic_code: like panic but with an explicit exit code.
fn panic_code(msg as *u8, code as i32) as void {
    io.write_str(io.STDERR, "panic: ");
    io.write_str(io.STDERR, msg);
    io.write_str(io.STDERR, "\n");
    io.exit(code);
}

// assert: if cond is false (0), panic with msg.
fn assert(cond as i32, msg as *u8) as void {
    if (cond == 0) { panic(msg); }
}
