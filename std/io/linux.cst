// =======================================================
// std/io/linux.cst — Portable I/O backend, Linux impl
//
// Per-OS portable subset used by code that imports via
//   use "std/io/<TARGET>.cst" as io;
// Linux backend delegates to std/linux.cst raw syscalls.
// =======================================================

use "../os/linux.cst" as linux;

// Standard fds match Linux convention directly.
let is i64 as STDIN  with imut = 0;
let is i64 as STDOUT with imut = 1;
let is i64 as STDERR with imut = 2;

fn write_stdout(buf as *u8, len as i64) as i64 {
    return linux.write(STDOUT, buf, len);
}

fn write_stderr(buf as *u8, len as i64) as i64 {
    return linux.write(STDERR, buf, len);
}

fn read_stdin(buf as *u8, max as i64) as i64 {
    return linux.read(STDIN, buf, max);
}

// Returns fd (>=0) on success, negative errno on failure.
fn open_read(path as *u8) as i64 {
    return linux.open(path, linux.O_RDONLY, 0);
}

// Creates/truncates the file (mode 0644).
fn open_write(path as *u8) as i64 {
    return linux.open(path, linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC, 420);
}

fn read(handle as i64, buf as *u8, max as i64) as i64 {
    return linux.read(handle, buf, max);
}

fn write(handle as i64, buf as *u8, len as i64) as i64 {
    return linux.write(handle, buf, len);
}

fn close(handle as i64) as i32 {
    return cast(i32, linux.close(handle));
}

fn exit(code as i32) as void {
    linux.exit(cast(i64, code));
}

// Opens with O_WRONLY | O_CREAT | O_APPEND, mode 0644.
fn open_append(path as *u8) as i64 {
    return linux.open(path, linux.O_WRONLY + linux.O_CREAT + linux.O_APPEND, 420);
}

// Returns new file position (absolute) or negative errno on failure.
// whence: 0 = SEEK_SET (from start), 2 = SEEK_END (from end).
fn lseek(handle as i64, offset as i64, whence as i32) as i64 {
    return linux.lseek(handle, offset, cast(i64, whence));
}

let is i32 as SEEK_SET with imut = 0;
let is i32 as SEEK_CUR with imut = 1;
let is i32 as SEEK_END with imut = 2;

// Filesystem mutators — returns 0 on success, negative errno on failure.
fn unlink(path as *u8) as i32 {
    return cast(i32, linux.unlink(path));
}

fn rename(src as *u8, dst as *u8) as i32 {
    return cast(i32, linux.rename(src, dst));
}

fn mkdir(path as *u8) as i32 {
    return cast(i32, linux.mkdir(path, 493));  // 0755
}

fn exists(path as *u8) as i32 {
    if (linux.access(path, 0) == 0) { return 1; }  // F_OK
    return 0;
}

// Resolves the running executable's absolute path into `buf`. Returns
// length written, or 0 on failure (buf is left untouched on failure).
fn get_self_path(buf as *u8, size as i64) as i64 {
    let is i64 as n = linux.readlink("/proc/self/exe", buf, size);
    if (n <= 0) { return 0; }
    return n;
}

// Sets executable bit (POSIX `chmod 0755`). No-op on filesystems that
// don't track execute permission.
fn make_executable(path as *u8) as i32 {
    return cast(i32, linux.chmod(path, 493));  // 0755
}

// Last-modification time of `path` as an opaque i64 monotonic in this
// OS's clock. Caller may only compare two values returned by the same
// `mtime()` call site on the same OS. Returns 0 if the file is missing.
// Linux: st_mtim.tv_sec from stat(2) (offset 88 of struct stat).
fn mtime(path as *u8) as i64 {
    let is [144]u8 as st;
    let is i64 as rc = linux.stat(path, &st);
    if (rc != 0) { return 0; }
    let is *i64 as mt = cast(*i64, cast(i64, &st) + 88);
    return *mt;
}
