// =======================================================
// std/io/wasm.cst — Portable I/O backend, WASI impl
//
// Per-OS portable subset used via `use "std/io/<TARGET>.cst"` and by io.cst's
// os.current() dispatch. Delegates to std/os/wasm.cst WASI bindings.
//
// Console I/O (write/read/exit) is fully supported. Filesystem operations
// require WASI path_* calls over preopened directory descriptors, which are not
// wired yet — they return errors and are dead-stripped from programs that don't
// use them.
// =======================================================

use "../os/wasm.cst" as wasi;

let is i64 as STDIN  with imut = 0;
let is i64 as STDOUT with imut = 1;
let is i64 as STDERR with imut = 2;

fn write_stdout(buf as *u8, len as i64) as i64 { return wasi.write(STDOUT, buf, len); }
fn write_stderr(buf as *u8, len as i64) as i64 { return wasi.write(STDERR, buf, len); }
fn read_stdin(buf as *u8, max as i64) as i64 { return wasi.read(STDIN, buf, max); }

fn write(handle as i64, buf as *u8, len as i64) as i64 { return wasi.write(handle, buf, len); }
fn read(handle as i64, buf as *u8, max as i64) as i64 { return wasi.read(handle, buf, max); }
fn exit(code as i32) as void { wasi.exit(cast(i64, code)); }

// SEEK_* kept for API parity.
let is i32 as SEEK_SET with imut = 0;
let is i32 as SEEK_CUR with imut = 1;
let is i32 as SEEK_END with imut = 2;

// --- Filesystem ops: not yet supported under WASI (need preopened dirs) ---
fn open_read(path as *u8) as i64 { return cast(i64, 0 - 1); }
fn open_write(path as *u8) as i64 { return cast(i64, 0 - 1); }
fn open_append(path as *u8) as i64 { return cast(i64, 0 - 1); }
fn close(handle as i64) as i32 { return 0; }
fn lseek(handle as i64, offset as i64, whence as i32) as i64 { return cast(i64, 0 - 1); }
fn unlink(path as *u8) as i32 { return cast(i32, 0 - 1); }
fn rename(src as *u8, dst as *u8) as i32 { return cast(i32, 0 - 1); }
fn mkdir(path as *u8) as i32 { return cast(i32, 0 - 1); }
fn exists(path as *u8) as i32 { return 0; }
fn get_self_path(buf as *u8, size as i64) as i64 { return 0; }
fn make_executable(path as *u8) as i32 { return 0; }
fn mtime(path as *u8) as i64 { return 0; }
