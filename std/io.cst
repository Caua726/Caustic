use "linux.cst" as linux;
use "string.cst" as string;
use "mem.cst" only bins, core as mem;

let is mem.Bins as _bins with mut;
let is i32 as _ready with mut = 0;

fn _alloc(size as i64) as *u8 {
    if (_ready == 0) { _bins = mem.bins.bins_new(65536); _ready = 1; }
    return mem.bins.bins_alloc(&_bins, size);
}

fn _free(ptr as *u8) as void {
    if (_ready == 1) { mem.bins.bins_free(&_bins, ptr); }
}

// --- Buffered Reader ---

struct Reader {
    fd as i64;
    buf as *u8;
    cap as i64;
    len as i64;
    pos as i64;
}

fn Reader(fd as i64, buf as *u8, cap as i64) as Reader {
    let is Reader as r;
    r.fd = fd;
    r.buf = buf;
    r.cap = cap;
    r.len = 0;
    r.pos = 0;
    return r;
}

// Refills buffer if empty. Returns byte (0-255) or -1 (EOF/Error)
fn read(r as *Reader) as i32 {
    // Cache buf pointer locally
    let is *u8 as buf = r.buf;
    let is i64 as cap = r.cap;
    let is i64 as fd = r.fd;
    
    if (r.pos >= r.len) {
        r.pos = 0;
        let is i64 as n = linux.read(fd, buf, cap);
        r.len = n;
        
        if (n <= 0) {
            return cast(i32, 0 - 1); // EOF or Error
        }
    }

    let is i64 as p = r.pos;
    let is u8 as b = buf[p];
    r.pos = p + 1;
    
    return cast(i32, b);
}

// Reads a line efficiently using the internal buffer
fn readline(r as *Reader) as string.String {
    // Initial guess for line length
    let is i64 as cap with mut = 64;
    let is i64 as len with mut = 0;
    let is *u8 as ptr with mut = _alloc(cap);
    if (cast(i64, ptr) == 0) {
        let is string.String as empty;
        empty.ptr = cast(*u8, 0);
        empty.len = 0;
        empty.cap = 0;
        return empty;
    }

    while (1 == 1) {
        let is i32 as b = read(r);

        if (b == (0 - 1)) {
            break;
        }

        if (b == 10) { // \n
            break;
        }

        if (len + 1 >= cap) {
            let is i64 as new_cap = cap * 2;
            let is *u8 as new_ptr = _alloc(new_cap);
            mem.core.memcpy(new_ptr, ptr, len);
            _free(ptr);
            ptr = new_ptr;
            cap = new_cap;
        }

        ptr[len] = cast(u8, b);
        len = len + 1;
    }

    ptr[len] = cast(u8, 0); // Null terminator

    let is string.String as s;
    s.ptr = ptr;
    s.len = cast(i32, len);
    s.cap = cast(i32, cap);

    return s;
}

fn peek(r as *Reader) as i32 {
    if (r.pos >= r.len) {
        r.pos = 0;
        let is i64 as n = linux.read(r.fd, r.buf, r.cap);
        r.len = n;
        if (n <= 0) {
            return cast(i32, 0 - 1);
        }
    }
    return cast(i32, r.buf[r.pos]);
}

fn skip(r as *Reader, count as i64) as void {
    let is i64 as remaining with mut = count;
    while (remaining > 0) {
        let is i32 as b = read(r);
        if (b == (0 - 1)) { return; }
        remaining = remaining - 1;
    }
}

fn read_until(r as *Reader, delim as u8) as string.String {
    let is i64 as cap with mut = 64;
    let is i64 as len with mut = 0;
    let is *u8 as ptr with mut = _alloc(cap);
    if (cast(i64, ptr) == 0) {
        let is string.String as empty;
        empty.ptr = cast(*u8, 0);
        empty.len = 0;
        empty.cap = 0;
        return empty;
    }

    while (1 == 1) {
        let is i32 as b = read(r);
        if (b == (0 - 1)) { break; }
        if (cast(u8, b) == delim) { break; }

        if (len + 1 >= cap) {
            let is i64 as new_cap = cap * 2;
            let is *u8 as new_ptr = _alloc(new_cap);
            mem.core.memcpy(new_ptr, ptr, len);
            _free(ptr);
            ptr = new_ptr;
            cap = new_cap;
        }

        ptr[len] = cast(u8, b);
        len = len + 1;
    }

    ptr[len] = cast(u8, 0);

    let is string.String as s;
    s.ptr = ptr;
    s.len = cast(i32, len);
    s.cap = cast(i32, cap);
    return s;
}

fn read_all(r as *Reader) as string.String {
    let is i64 as cap with mut = 1024;
    let is i64 as len with mut = 0;
    let is *u8 as ptr with mut = _alloc(cap);
    if (cast(i64, ptr) == 0) {
        let is string.String as empty;
        empty.ptr = cast(*u8, 0);
        empty.len = 0;
        empty.cap = 0;
        return empty;
    }

    while (1 == 1) {
        let is i32 as b = read(r);
        if (b == (0 - 1)) { break; }

        if (len + 1 >= cap) {
            let is i64 as new_cap = cap * 2;
            let is *u8 as new_ptr = _alloc(new_cap);
            mem.core.memcpy(new_ptr, ptr, len);
            _free(ptr);
            ptr = new_ptr;
            cap = new_cap;
        }

        ptr[len] = cast(u8, b);
        len = len + 1;
    }

    ptr[len] = cast(u8, 0);

    let is string.String as s;
    s.ptr = ptr;
    s.len = cast(i32, len);
    s.cap = cast(i32, cap);
    return s;
}

// --- Buffered Writer ---

struct Writer {
    fd as i64;
    buf as *u8;
    cap as i64;
    len as i64;
}

fn Writer(fd as i64, buf as *u8, cap as i64) as Writer {
    let is Writer as w;
    w.fd = fd;
    w.buf = buf;
    w.cap = cap;
    w.len = 0;
    return w;
}

fn flush(w as *Writer) as void {
    if (w.len > 0) {
        linux.write(w.fd, w.buf, w.len);
        w.len = 0;
    }
}

fn put(w as *Writer, b as u8) as void {
    if (w.len >= w.cap) {
        flush(w);
    }
    let is i64 as l = w.len;
    w.buf[l] = b;
    w.len = l + 1;
}

fn write(w as *Writer, s as string.String) as void {
    let is i64 as i with mut = 0;
    let is i64 as slen = cast(i64, s.len);

    // Optimization: if string is larger than buffer, flush and write directly
    if (slen > w.cap) {
        flush(w);
        linux.write(w.fd, s.ptr, slen);
        return;
    }

    while (i < slen) {
        put(w, s.ptr[i]);
        i = i + 1;
    }
}

fn writer_bytes(w as *Writer, ptr as *u8, len as i64) as void {
    if (len > w.cap) {
        flush(w);
        linux.write(w.fd, ptr, len);
        return;
    }
    let is i64 as i with mut = 0;
    while (i < len) {
        put(w, ptr[i]);
        i = i + 1;
    }
}

fn writeln(w as *Writer, s as string.String) as void {
    write(w, s);
    put(w, cast(u8, 10));
}

fn write_i64(w as *Writer, n as i64) as void {
    if (n == 0) { put(w, 48); return; }

    if (n == (0 - 9223372036854775807 - 1)) {
        writer_bytes(w, "-9223372036854775808", 20);
        return;
    }

    let is [24]u8 as buf;
    let is i64 as val with mut = n;
    let is i64 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is i32 as pos with mut = 23;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    if (neg == 1) { buf[pos] = 45; pos = pos - 1; }
    let is i32 as start with mut = pos + 1;
    while (start < 24) {
        put(w, buf[start]);
        start = start + 1;
    }
}

// --- Low-level helpers ---

fn strlen(s as *u8) as i64 {
    let is i64 as i with mut = 0;
    while (s[i] != 0) { i = i + 1; }
    return i;
}

fn write_str(fd as i64, s as *u8) as void {
    linux.write(fd, s, strlen(s));
}

fn write_int(fd as i64, n as i64) as void {
    if (n == 0) { linux.write(fd, "0", 1); return; }

    // Special case INT64_MIN
    if (n == (0 - 9223372036854775807 - 1)) {
        linux.write(fd, "-9223372036854775808", 20);
        return;
    }

    let is [24]u8 as buf;
    let is i64 as val with mut = n;
    let is i64 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is i32 as pos with mut = 23;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    if (neg == 1) { buf[pos] = 45; pos = pos - 1; }
    let is i64 as start = cast(i64, pos) + 1;
    linux.write(fd, cast(*u8, cast(i64, &buf) + start), 24 - start);
}

// --- Generic IO ---

fn write_bytes(fd as i64, ptr as *u8, len as i64) as i64 {
    return linux.write(fd, ptr, len);
}

fn write_string(fd as i64, s as string.String) as i64 {
    return linux.write(fd, s.ptr, cast(i64, s.len));
}

fn read_exact(fd as i64, buf as *u8, count as i64) as i64 {
    let is i64 as total with mut = 0;
    while (total < count) {
        let is i64 as addr = cast(i64, buf) + total;
        let is i64 as n = linux.read(fd, cast(*u8, addr), count - total);
        if (n <= 0) {
            break;
        }
        total = total + n;
    }
    return total;
}

// --- Formatted Output Helpers ---

fn print_hex(n as i64) as void {
    let is *u8 as hex = "0123456789abcdef";
    let is [18]u8 as buf;

    buf[0] = 48;  // '0'
    buf[1] = 120; // 'x'

    let is i64 as val with mut = n;
    let is i32 as i with mut = 15;

    while (i >= 0) {
        buf[2 + i] = hex[val & 15];
        val = val >> 4;
        i = i - 1;
    }

    linux.write(linux.STDOUT, &buf, 18);
}

fn print_bool(b as i32) as void {
    if (b != 0) {
        linux.write(linux.STDOUT, "true", 4);
    } else {
        linux.write(linux.STDOUT, "false", 5);
    }
}

fn print_ptr(ptr as *u8) as void {
    print_hex(cast(i64, ptr));
}

// --- Formatted Output (printf) ---

// --- Formatted Output (printf) ---

struct VaList {
    gp_offset as i32;
    fp_offset as i32;
    overflow_arg_area as *u8;
    reg_save_area as *u8;
}

fn print_uint(n as u64) as void {
    if (n == 0) { linux.write(linux.STDOUT, "0", 1); return; }
    let is [20]u8 as buf;
    let is u64 as val with mut = n;
    let is i32 as pos with mut = 19;
    while (val > 0) {
        buf[pos] = cast(u8, cast(i64, val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    let is i64 as start = cast(i64, pos) + 1;
    linux.write(linux.STDOUT, cast(*u8, cast(i64, &buf) + start), 20 - start);
}

fn _pad(count as i64, ch as u8) as void {
    let is u8 as c = ch;
    let is i64 as k with mut = 0;
    while (k < count) { linux.write(linux.STDOUT, &c, 1); k = k + 1; }
}

fn printf(fmt as *u8, ...) as void {
    let is VaList as va;
    __builtin_va_start(&va);
    let is i64 as i with mut = 0;

    while (fmt[i] != 0) {
        if (fmt[i] != 37) {
            linux.write(linux.STDOUT, &fmt[i], 1);
            i = i + 1;
        } else {
            i = i + 1; // skip '%'
            if (fmt[i] == 0) { break; }

            if (fmt[i] == 37) { // '%%'
                let is u8 as pct = 37;
                linux.write(linux.STDOUT, &pct, 1);
                i = i + 1;
            } else {
                // Parse flags
                let is i32 as left with mut = 0;
                if (fmt[i] == 45) { left = 1; i = i + 1; } // '-'

                // Parse width
                let is i32 as width with mut = 0;
                while (fmt[i] >= 48 && fmt[i] <= 57) {
                    width = width * 10 + (cast(i32, fmt[i]) - 48);
                    i = i + 1;
                }

                // Skip optional 'l' length modifier
                if (fmt[i] == 108) { i = i + 1; }
                if (fmt[i] == 0) { break; }

                // Known specifiers that consume an arg
                if (fmt[i] == 100 || fmt[i] == 117 || fmt[i] == 115 || fmt[i] == 83 || fmt[i] == 120 || fmt[i] == 99 || fmt[i] == 112) {
                    let is *i64 as arg_ptr with mut = cast(*i64, 0);
                    if (va.gp_offset < 48) {
                        arg_ptr = cast(*i64, va.reg_save_area + cast(i64, va.gp_offset));
                        va.gp_offset = va.gp_offset + 8;
                    } else {
                        arg_ptr = cast(*i64, va.overflow_arg_area);
                        va.overflow_arg_area = va.overflow_arg_area + 8;
                    }

                    if (fmt[i] == 100) { // %d
                        let is [21]u8 as dbuf;
                        let is i32 as dpos with mut = 20;
                        let is i64 as dval with mut = *arg_ptr;
                        let is i32 as neg with mut = 0;
                        if (dval < 0) { neg = 1; dval = 0 - dval; }
                        if (dval == 0) { dbuf[dpos] = 48; dpos = dpos - 1; }
                        else { while (dval > 0) { dbuf[dpos] = cast(u8, 48 + cast(i32, dval % 10)); dval = dval / 10; dpos = dpos - 1; } }
                        if (neg == 1) { dbuf[dpos] = 45; dpos = dpos - 1; }
                        let is i32 as dstart = dpos + 1;
                        let is i64 as dlen = 21 - cast(i64, dstart);
                        let is i64 as pad = cast(i64, width) - dlen;
                        if (left == 0 && pad > 0) { _pad(pad, 32); }
                        linux.write(linux.STDOUT, cast(*u8, cast(i64, &dbuf) + cast(i64, dstart)), dlen);
                        if (left == 1 && pad > 0) { _pad(pad, 32); }
                    } else if (fmt[i] == 117) { // %u
                        let is [21]u8 as ubuf;
                        let is i32 as upos with mut = 20;
                        let is u64 as uval with mut = cast(u64, *arg_ptr);
                        if (uval == 0) { ubuf[upos] = 48; upos = upos - 1; }
                        else { while (uval > 0) { ubuf[upos] = cast(u8, 48 + cast(i32, uval % 10)); uval = uval / 10; upos = upos - 1; } }
                        let is i32 as ustart = upos + 1;
                        let is i64 as ulen = 21 - cast(i64, ustart);
                        let is i64 as pad = cast(i64, width) - ulen;
                        if (left == 0 && pad > 0) { _pad(pad, 32); }
                        linux.write(linux.STDOUT, cast(*u8, cast(i64, &ubuf) + cast(i64, ustart)), ulen);
                        if (left == 1 && pad > 0) { _pad(pad, 32); }
                    } else if (fmt[i] == 115) { // %s
                        let is *u8 as val = cast(*u8, *arg_ptr);
                        let is i64 as slen with mut = 0;
                        while (val[slen] != 0) { slen = slen + 1; }
                        let is i64 as pad = cast(i64, width) - slen;
                        if (left == 0 && pad > 0) { _pad(pad, 32); }
                        linux.write(linux.STDOUT, val, slen);
                        if (left == 1 && pad > 0) { _pad(pad, 32); }
                    } else if (fmt[i] == 83) { // %S
                        let is *string.String as s_ptr = cast(*string.String, *arg_ptr);
                        let is i64 as pad = cast(i64, width) - cast(i64, s_ptr.len);
                        if (left == 0 && pad > 0) { _pad(pad, 32); }
                        linux.write(linux.STDOUT, s_ptr.ptr, cast(i64, s_ptr.len));
                        if (left == 1 && pad > 0) { _pad(pad, 32); }
                    } else if (fmt[i] == 120) { // %x
                        print_hex(*arg_ptr);
                    } else if (fmt[i] == 99) { // %c
                        let is u8 as ch = cast(u8, *arg_ptr);
                        linux.write(linux.STDOUT, &ch, 1);
                    } else if (fmt[i] == 112) { // %p
                        print_hex(*arg_ptr);
                    }
                } else {
                    // Unknown specifier — print literal, do NOT consume arg
                    let is u8 as pct = 37;
                    linux.write(linux.STDOUT, &pct, 1);
                    linux.write(linux.STDOUT, &fmt[i], 1);
                }
                i = i + 1;
            }
        }
    }
}

fn sprintf(buf as *u8, cap as i64, fmt as *u8, ...) as i64 {
    let is VaList as va;
    __builtin_va_start(&va);
    let is i64 as i with mut = 0;
    let is i64 as pos with mut = 0;
    let is i64 as lim = cap - 1;

    while (fmt[i] != 0 && pos < lim) {
        if (fmt[i] != 37) {
            buf[pos] = fmt[i]; pos = pos + 1;
            i = i + 1;
        } else {
            i = i + 1;
            if (fmt[i] == 0) { break; }

            if (fmt[i] == 37) {
                buf[pos] = 37; pos = pos + 1;
                i = i + 1;
            } else {
                // Parse flags
                let is i32 as left with mut = 0;
                if (fmt[i] == 45) { left = 1; i = i + 1; }

                // Parse width
                let is i32 as width with mut = 0;
                while (fmt[i] >= 48 && fmt[i] <= 57) {
                    width = width * 10 + (cast(i32, fmt[i]) - 48);
                    i = i + 1;
                }

                if (fmt[i] == 108) { i = i + 1; }
                if (fmt[i] == 0) { break; }

                if (fmt[i] == 100 || fmt[i] == 117 || fmt[i] == 115 || fmt[i] == 99) {
                    let is *i64 as arg_ptr with mut = cast(*i64, 0);
                    if (va.gp_offset < 48) {
                        arg_ptr = cast(*i64, va.reg_save_area + cast(i64, va.gp_offset));
                        va.gp_offset = va.gp_offset + 8;
                    } else {
                        arg_ptr = cast(*i64, va.overflow_arg_area);
                        va.overflow_arg_area = va.overflow_arg_area + 8;
                    }

                    if (fmt[i] == 100) { // %d
                        let is [21]u8 as dbuf;
                        let is i32 as dpos with mut = 20;
                        let is i64 as dval with mut = *arg_ptr;
                        let is i32 as neg with mut = 0;
                        if (dval < 0) { neg = 1; dval = 0 - dval; }
                        if (dval == 0) { dbuf[dpos] = 48; dpos = dpos - 1; }
                        else { while (dval > 0) { dbuf[dpos] = cast(u8, 48 + cast(i32, dval % 10)); dval = dval / 10; dpos = dpos - 1; } }
                        if (neg == 1) { dbuf[dpos] = 45; dpos = dpos - 1; }
                        let is i32 as dstart = dpos + 1;
                        let is i64 as dlen = 21 - cast(i64, dstart);
                        let is i64 as pad = cast(i64, width) - dlen;
                        if (left == 0 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                        let is i64 as di with mut = cast(i64, dstart);
                        while (di < 21 && pos < lim) { buf[pos] = dbuf[di]; pos = pos + 1; di = di + 1; }
                        if (left == 1 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                    } else if (fmt[i] == 117) { // %u
                        let is [21]u8 as ubuf;
                        let is i32 as upos with mut = 20;
                        let is u64 as uval with mut = cast(u64, *arg_ptr);
                        if (uval == 0) { ubuf[upos] = 48; upos = upos - 1; }
                        else { while (uval > 0) { ubuf[upos] = cast(u8, 48 + cast(i32, uval % 10)); uval = uval / 10; upos = upos - 1; } }
                        let is i32 as ustart = upos + 1;
                        let is i64 as ulen = 21 - cast(i64, ustart);
                        let is i64 as pad = cast(i64, width) - ulen;
                        if (left == 0 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                        let is i64 as ui with mut = cast(i64, ustart);
                        while (ui < 21 && pos < lim) { buf[pos] = ubuf[ui]; pos = pos + 1; ui = ui + 1; }
                        if (left == 1 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                    } else if (fmt[i] == 115) { // %s
                        let is *u8 as val = cast(*u8, *arg_ptr);
                        let is i64 as slen with mut = 0;
                        while (val[slen] != 0) { slen = slen + 1; }
                        let is i64 as pad = cast(i64, width) - slen;
                        if (left == 0 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                        let is i64 as si with mut = 0;
                        while (si < slen && pos < lim) { buf[pos] = val[si]; pos = pos + 1; si = si + 1; }
                        if (left == 1 && pad > 0) { let is i64 as pi with mut = 0; while (pi < pad && pos < lim) { buf[pos] = 32; pos = pos + 1; pi = pi + 1; } }
                    } else if (fmt[i] == 99) { // %c
                        buf[pos] = cast(u8, *arg_ptr); pos = pos + 1;
                    }
                } else {
                    buf[pos] = 37; pos = pos + 1;
                    if (pos < lim) { buf[pos] = fmt[i]; pos = pos + 1; }
                }
                i = i + 1;
            }
        }
    }
    buf[pos] = 0;
    return pos;
}

struct File {
    fd as i64;
}

fn print(s as string.String) as void {
    if (s.len > 0) {
        linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
    }
}

fn println(s as string.String) as void {
    print(s);
    linux.write(linux.STDOUT, "\n", 1);
}

fn eprint(s as string.String) as void {
    if (s.len > 0) {
        linux.write(linux.STDERR, s.ptr, cast(i64, s.len));
    }
}

fn eprintln(s as string.String) as void {
    eprint(s);
    linux.write(linux.STDERR, "\n", 1);
}

fn eprint_str(s as *u8) as void {
    linux.write(linux.STDERR, s, strlen(s));
}

fn print_int(n as i64) as void {
    let is [21]u8 as buf;
    let is i32 as pos with mut = 20;
    let is i64 as val with mut = n;
    let is i32 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    if (val == 0) { buf[pos] = 48; pos = pos - 1; }
    else { while (val > 0) { buf[pos] = cast(u8, 48 + cast(i32, val % 10)); val = val / 10; pos = pos - 1; } }
    if (neg == 1) { buf[pos] = 45; pos = pos - 1; }
    let is i32 as start = pos + 1;
    linux.write(linux.STDOUT, cast(*u8, cast(i64, &buf) + cast(i64, start)), 21 - cast(i64, start));
}

// Legacy read_line (slow, unbuffered) - kept for compatibility
// or could be rewritten to use a stack buffer
fn read_line() as string.String {
    // Implementation using small stack buffer for basic buffering
    let is i64 as cap with mut = 128;
    let is i64 as len with mut = 0;
    let is *u8 as ptr with mut = _alloc(cap);

    while (1 == 1) {
        if (len + 1 >= cap) {
            let is i64 as new_cap = cap * 2;
            let is *u8 as new_ptr = _alloc(new_cap);
            mem.core.memcpy(new_ptr, ptr, len);
            _free(ptr);
            ptr = new_ptr;
            cap = new_cap;
        }

        let is i64 as addr = cast(i64, ptr) + len;
        let is i64 as n = linux.read(linux.STDIN, cast(*u8, addr), 1);

        if (n <= 0) {
            break;
        }

        if (ptr[len] == 10) { // \n
            break;
        }

        len = len + 1;
    }

    ptr[len] = cast(u8, 0);

    let is string.String as s;
    s.ptr = ptr;
    s.len = cast(i32, len);
    s.cap = cast(i32, cap);

    return s;
}

fn read_file(path as string.String) as string.String {
    let is i64 as fd = linux.open(path.ptr, linux.O_RDONLY, 0);
    if (fd < 0) {
        return string.String("");
    }

    let is i64 as size = linux.lseek(fd, 0, linux.SEEK_END);
    if (size < 0) {
        linux.close(fd);
        return string.String("");
    }
    linux.lseek(fd, 0, linux.SEEK_SET);

    let is string.String as s;

    // Guard: String.len/cap are i32, max ~2GB
    if (size > 2147483647) {
        linux.close(fd);
        s.ptr = cast(*u8, 0);
        s.len = 0;
        s.cap = 0;
        return s;
    }

    s.len = cast(i32, size);
    s.cap = cast(i32, size);

    if (size > 0) {
        s.ptr = cast(*u8, _alloc(size + 1));
        read_exact(fd, s.ptr, size);
        s.ptr[size] = cast(u8, 0);
    } else {
        s.ptr = cast(*u8, 0);
    }

    linux.close(fd);
    return s;
}

fn write_file(path as string.String, content as string.String) as i64 {
    let is i64 as flags = linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC;
    let is i64 as fd = linux.open(path.ptr, flags, 420);
    if (fd < 0) { return fd; }
    let is i64 as res = linux.write(fd, content.ptr, cast(i64, content.len));
    linux.close(fd);
    return res;
}

fn append_file(path as string.String, content as string.String) as i64 {
    let is i64 as flags = linux.O_WRONLY + linux.O_CREAT + linux.O_APPEND;
    let is i64 as fd = linux.open(path.ptr, flags, 420);
    if (fd < 0) { return fd; }
    let is i64 as res = linux.write(fd, content.ptr, cast(i64, content.len));
    linux.close(fd);
    return res;
}

fn file_exists(path as string.String) as i32 {
    let is i64 as fd = linux.open(path.ptr, 0, 0);
    if (fd >= 0) {
        linux.close(fd);
        return cast(i32, 1);
    }
    return cast(i32, 0);
}

fn file_size(path as *u8) as i64 {
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    if (fd < 0) {
        return cast(i64, 0 - 1);
    }
    let is i64 as size = linux.lseek(fd, 0, linux.SEEK_END);
    linux.close(fd);
    return size;
}

fn open_file(path as string.String) as File {
    let is i64 as fd = linux.open(path.ptr, linux.O_RDONLY, 0);
    let is File as f;
    f.fd = fd;
    return f;
}

fn close_file(file as File) as void {
    linux.close(file.fd);
}

fn copy_file(src as string.String, dst as string.String) as i64 {
    let is i64 as in_fd = linux.open(src.ptr, linux.O_RDONLY, 0);
    if (in_fd < 0) { return in_fd; }

    let is i64 as flags = linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC;
    let is i64 as out_fd = linux.open(dst.ptr, flags, 420);
    if (out_fd < 0) {
        linux.close(in_fd);
        return out_fd;
    }

    let is [4096]u8 as buf;
    let is i64 as total with mut = 0;

    while (1 == 1) {
        let is i64 as n = linux.read(in_fd, &buf, 4096);
        if (n <= 0) { break; }
        let is i64 as w = linux.write(out_fd, &buf, n);
        if (w != n) {
            linux.close(in_fd);
            linux.close(out_fd);
            return cast(i64, 0 - 1);
        }
        total = total + n;
    }

    linux.close(in_fd);
    linux.close(out_fd);
    return total;
}

fn read_file_in(h as *u8, path as *u8) as string.String {
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    let is string.String as s;

    if (fd < 0) {
        s.ptr = cast(*u8, 0);
        s.len = 0;
        s.cap = 0;
        return s;
    }

    let is i64 as size = linux.lseek(fd, 0, linux.SEEK_END);
    linux.lseek(fd, 0, linux.SEEK_SET);

    if (size > 2147483647 || size <= 0) {
        linux.close(fd);
        s.ptr = cast(*u8, 0);
        s.len = 0;
        s.cap = 0;
        return s;
    }

    s.len = cast(i32, size);
    s.cap = cast(i32, size);
    s.ptr = cast(*u8, _alloc(size + 1));
    read_exact(fd, s.ptr, size);
    s.ptr[size] = cast(u8, 0);

    linux.close(fd);
    return s;
}

// --- Directory Operations ---

// dirent64 field offsets (packed linux_dirent64):
//   d_ino:    offset 0,  size 8 (i64)
//   d_off:    offset 8,  size 8 (i64)
//   d_reclen: offset 16, size 2 (u16)
//   d_type:   offset 18, size 1 (u8)
//   d_name:   offset 19, variable length (null-terminated)

// File type constants (d_type)
let is u8 as DT_UNKNOWN with imut = 0;
let is u8 as DT_FIFO    with imut = 1;
let is u8 as DT_CHR     with imut = 2;
let is u8 as DT_DIR     with imut = 4;
let is u8 as DT_BLK     with imut = 6;
let is u8 as DT_REG     with imut = 8;
let is u8 as DT_LNK     with imut = 10;
let is u8 as DT_SOCK    with imut = 12;

struct DirEntry {
    name_ptr as *u8;
    name_len as i64;
    file_type as i64;
}

// List directory entries.
// Fills entries array. Names are copied to heap (caller must free name_ptr).
// Skips "." and ".." automatically.
// Returns number of entries found, or -1 on error.
fn list_dir(path as *u8, entries as *DirEntry, max_entries as i32) as i32 {
    let is i64 as fd = linux.open(path, linux.O_RDONLY + linux.O_DIRECTORY, 0);
    if (fd < 0) { return cast(i32, 0 - 1); }

    let is [4096]u8 as buf;
    let is i32 as count with mut = 0;

    while (1 == 1) {
        let is i64 as nread = linux.getdents64(fd, &buf, 4096);
        if (nread <= 0) { break; }

        let is i64 as pos with mut = 0;
        while (pos < nread) {
            let is *u8 as entry_ptr = cast(*u8, cast(i64, &buf) + pos);

            // d_reclen at offset 16 (2 bytes, little-endian)
            let is *u8 as reclen_ptr = cast(*u8, cast(i64, entry_ptr) + 16);
            let is i64 as reclen = cast(i64, reclen_ptr[0]) + cast(i64, reclen_ptr[1]) * 256;

            // d_type at offset 18
            let is u8 as dtype = entry_ptr[18];

            // d_name at offset 19
            let is *u8 as name = cast(*u8, cast(i64, entry_ptr) + 19);

            // Skip "." and ".."
            let is i64 as skip with mut = 0;
            if (name[0] == 46 && name[1] == 0) { skip = 1; }
            if (name[0] == 46 && name[1] == 46 && name[2] == 0) { skip = 1; }

            if (skip == 0 && count < max_entries) {
                let is i32 as nlen with mut = 0;
                while (name[nlen] != 0) {
                    nlen = nlen + 1;
                }

                // Copy name to heap so it survives buffer reuse
                let is *u8 as name_copy = _alloc(cast(i64, nlen) + 1);
                mem.core.memcpy(name_copy, name, cast(i64, nlen));
                name_copy[nlen] = 0;

                entries[count].name_ptr = name_copy;
                entries[count].name_len = cast(i64, nlen);
                entries[count].file_type = cast(i64, dtype);
                count = count + 1;
            }

            pos = pos + reclen;
        }
    }

    linux.close(fd);
    return count;
}

// Count entries in a directory (excluding . and ..)
fn count_dir_entries(path as *u8) as i32 {
    let is [4096]u8 as buf;
    let is i64 as fd = linux.open(path, linux.O_RDONLY + linux.O_DIRECTORY, 0);
    if (fd < 0) { return cast(i32, 0 - 1); }

    let is i32 as count with mut = 0;

    while (1 == 1) {
        let is i64 as nread = linux.getdents64(fd, &buf, 4096);
        if (nread <= 0) { break; }

        let is i64 as pos with mut = 0;
        while (pos < nread) {
            let is *u8 as entry_ptr = cast(*u8, cast(i64, &buf) + pos);
            let is *u8 as reclen_ptr = cast(*u8, cast(i64, entry_ptr) + 16);
            let is i64 as reclen = cast(i64, reclen_ptr[0]) + cast(i64, reclen_ptr[1]) * 256;

            let is *u8 as name = cast(*u8, cast(i64, entry_ptr) + 19);
            let is i64 as skip with mut = 0;
            if (name[0] == 46 && name[1] == 0) { skip = 1; }
            if (name[0] == 46 && name[1] == 46 && name[2] == 0) { skip = 1; }
            if (skip == 0) { count = count + 1; }

            pos = pos + reclen;
        }
    }

    linux.close(fd);
    return count;
}

// Check if path is a directory
fn is_dir(path as *u8) as i32 {
    let is i64 as fd = linux.open(path, linux.O_RDONLY + linux.O_DIRECTORY, 0);
    if (fd < 0) { return 0; }
    linux.close(fd);
    return 1;
}

// Get current working directory
fn get_cwd(buf as *u8, size as i64) as i64 {
    return linux.getcwd(buf, size);
}