// =======================================================
// std/mem/freelist.cst
// Free-list allocator with address-ordered coalescing
// O(n) alloc/free, 16 bytes header per block
// =======================================================

use "core.cst" as core;

struct Header {
    size as i64;
    next as *u8;
}

// THREADS: shared use is lazy-locked (no-op until mem.set_mt()). O(n) coalescing
// needs a global view, so this stays a single locked heap — for scalable
// per-thread allocation, give each thread its own Heap.
struct Heap {
    freelist  as *Header;
    start     as *u8;
    top       as *u8;
    limit     as *u8;
    committed as *u8;     // end of the backed region; the bump commits more on demand
    lock      as u32;     // B6: lazy futex lock
    _pad      as u32;
}

// Commit granularity for the reserve-large + commit-on-grow path. The window is
// reserved once; each chunk is backed only when the bump pointer reaches it
// (on CausticOS via SYS_COMMIT; a no-op where the OS demand-pages).
let is i64 as COMMIT_CHUNK with imut = 65536;

fn reserve(req_size as i64) as *Heap {
    let is i64 as size with mut = req_size;
    let is i64 as total with mut = size + sizeof(Heap);

    // Reserve the whole window, then back only the first chunk (enough for the
    // Heap header + the initial allocations); alloc commits more as it grows.
    let is *u8 as ptr = core.reserve_anon(total);

    if (cast(i64, ptr) < 0 || cast(i64, ptr) == 0) {
        core.write_str(2, "reserve failed\n");
        return cast(*Heap, 0);
    }

    let is i64 as init with mut = total;
    if (init > COMMIT_CHUNK) { init = COMMIT_CHUNK; }
    if (core.commit_anon(ptr, init) != cast(i32, 0)) {
        core.munmap(ptr, total);
        return cast(*Heap, 0);
    }

    let is *Heap as h = cast(*Heap, ptr);
    let is i64 as base = cast(i64, ptr);
    let is i64 as data_start = base + sizeof(Heap);

    h.start = cast(*u8, data_start);
    h.top   = cast(*u8, data_start);
    h.limit = cast(*u8, base + total);
    h.committed = cast(*u8, base + init);
    h.freelist = cast(*Header, 0);

    return h;
}

fn release(h as *Heap) as void {
    if (cast(i64, h) == 0) { return; }
    let is i64 as total = cast(i64, h.limit) - cast(i64, h);
    core.munmap(cast(*u8, h), total);
}

fn alloc(h as *Heap, req_size as i64) as *u8 {
    core._lk(&h.lock);
    let is *u8 as r = _alloc_inner(h, req_size);
    core._unlk(&h.lock);
    return r;
}
fn _alloc_inner(h as *Heap, req_size as i64) as *u8 {
    if (req_size <= 0) { return cast(*u8, 0); }
    let is i64 as size with mut = (req_size + 7) & (0 - 8);
    if (size < 8) { size = 8; }

    let is *Header as curr with mut = h.freelist;
    let is *Header as prev with mut = cast(*Header, 0);

    while (cast(i64, curr) != 0) {
        if (curr.size >= size) {
            let is i64 as remaining = curr.size - size;

            if (remaining >= sizeof(Header) + 8) {
                let is i64 as split_addr = cast(i64, curr) + sizeof(Header) + size;
                let is *Header as split = cast(*Header, split_addr);
                split.size = remaining - sizeof(Header);
                split.next = curr.next;
                if (cast(i64, prev) == 0) { h.freelist = split; }
                else { prev.next = split; }
                curr.size = size;
            } else {
                if (cast(i64, prev) == 0) { h.freelist = curr.next; }
                else { prev.next = curr.next; }
            }

            return cast(*u8, cast(i64, curr) + sizeof(Header));
        }

        prev = curr;
        curr = curr.next;
    }

    let is i64 as current_top with mut = cast(i64, h.top);
    let is i64 as limit = cast(i64, h.limit);
    let is i64 as needed = sizeof(Header) + size;

    if (current_top + needed > limit) {
        return cast(*u8, 0);
    }

    // Commit-on-grow: if the bump would pass the backed region, back more chunks
    // (rounded up to COMMIT_CHUNK, clamped to limit) before writing.
    let is i64 as committed = cast(i64, h.committed);
    if (current_top + needed > committed) {
        let is i64 as newc with mut = (current_top + needed + (COMMIT_CHUNK - 1)) & (0 - COMMIT_CHUNK);
        if (newc > limit) { newc = limit; }
        if (core.commit_anon(h.committed, newc - committed) != cast(i32, 0)) {
            return cast(*u8, 0);
        }
        h.committed = cast(*u8, newc);
    }

    let is *Header as new_head = cast(*Header, h.top);
    new_head.size = size;
    h.top = cast(*u8, current_top + needed);

    return cast(*u8, current_top + sizeof(Header));
}

fn free(h as *Heap, ptr as *u8) as void {
    core._lk(&h.lock);
    _free_inner(h, ptr);
    core._unlk(&h.lock);
}
fn _free_inner(h as *Heap, ptr as *u8) as void {
    if (cast(i64, ptr) == 0) { return; }
    if (cast(i64, h) == 0) { return; }

    let is i64 as p = cast(i64, ptr);
    if (p < cast(i64, h.start) || p >= cast(i64, h.top)) { return; }

    let is i64 as header_addr = cast(i64, ptr) - sizeof(Header);
    let is *Header as block = cast(*Header, header_addr);

    let is *Header as curr with mut = h.freelist;
    let is *Header as prev with mut = cast(*Header, 0);

    while (cast(i64, curr) != 0 && cast(i64, curr) < header_addr) {
        prev = curr;
        curr = cast(*Header, curr.next);
    }
    if (cast(i64, curr) != 0 && cast(i64, curr) == header_addr) { return; }

    block.next = cast(*u8, curr);
    if (cast(i64, prev) == 0) {
        h.freelist = block;
    } else {
        prev.next = cast(*u8, block);
    }

    if (cast(i64, curr) != 0) {
        let is i64 as block_end = header_addr + sizeof(Header) + block.size;
        if (block_end == cast(i64, curr)) {
            block.size = block.size + sizeof(Header) + curr.size;
            block.next = curr.next;
        }
    }

    if (cast(i64, prev) != 0) {
        let is i64 as prev_end = cast(i64, prev) + sizeof(Header) + prev.size;
        if (prev_end == header_addr) {
            prev.size = prev.size + sizeof(Header) + block.size;
            prev.next = block.next;
        }
    }
}

