// =======================================================
// std/mem/windows.cst — Portable raw page allocator, Windows impl
//
// VirtualAlloc with MEM_COMMIT|MEM_RESERVE + PAGE_READWRITE rounds up
// to allocation granularity (64KB) but returns the lowest page address
// usable as if mmap'd.
// =======================================================

use "../os/windows.cst" as win;

let is u32 as _COMMIT_RESERVE with imut = 12288;   // MEM_COMMIT | MEM_RESERVE = 0x3000

// Returns committed RW memory of at least size bytes, or cast(*u8, 0)
// on failure.
fn page_alloc(size as i64) as *u8 {
    return win.VirtualAlloc(cast(*u8, 0), size, _COMMIT_RESERVE, win.PAGE_READWRITE);
}

// MEM_RELEASE requires size = 0 (releases the whole reservation made by
// the matching VirtualAlloc). Caller still passes size for API parity
// with the Linux side; it's ignored here.
fn page_free(ptr as *u8, _size as i64) as i32 {
    return win.VirtualFree(ptr, 0, win.MEM_RELEASE);
}
