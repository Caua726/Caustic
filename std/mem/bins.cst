// =======================================================
// std/mem/bins.cst
// Bin allocator — O(1) alloc/free, zero header overhead, lazy mmap
//
// - 16 default size classes: 8,16,24,32,48,64,96,128,192,256,384,512,768,1024,2048,4096
// - Lookup table for O(1) bin selection
// - 8-byte header per block (bin index) for O(1) free
// - Bitmap per slab for O(1) double-free detection
// - Freelist per slab (LIFO pop/push)
// - Multiple slabs per bin (auto-growth)
// - Full introspection (stats, overhead, waste)
// =======================================================

use "../linux.cst" as linux;
use "core.cst" as core;

// --- Constants ---

let is i64 as HEADER_SIZE with imut = 8;
let is i64 as NUM_DEFAULT_BINS with imut = 20;
let is i64 as LOOKUP_SIZE with imut = 8193;

// --- Structs ---

struct Slab {
    region as *u8;
    bitmap as *u8;
    freelist as *u8;
    region_size as i64;
    total_slots as i64;
    used_slots as i64;
    next as *u8;
}

struct Bin {
    slot_size as i64;
    alloc_size as i64;
    slab_head as *u8;
    page_size as i64;
}

struct Bins {
    bin_data as *u8;
    bin_count as i64;
    page_size as i64;
    lookup as *u8;
    lookup_entries as i64;
}


// --- Internal: slab ---

fn _slab_create(alloc_size as i64, page_size as i64, bin_idx as i64) as *Slab {
    if (alloc_size > page_size) { return cast(*Slab, 0); }

    let is i64 as total_slots = page_size / alloc_size;
    if (total_slots == 0) { return cast(*Slab, 0); }

    let is i64 as bitmap_bytes = (total_slots + 7) >> 3;
    let is i64 as meta_size = sizeof(Slab) + bitmap_bytes;

    let is *u8 as meta = core.mmap_anon(meta_size);
    if (cast(i64, meta) < 0) { return cast(*Slab, 0); }

    let is *u8 as region = core.mmap_anon(page_size);
    if (cast(i64, region) < 0) {
        core.munmap(meta, meta_size);
        return cast(*Slab, 0);
    }

    let is *Slab as slab = cast(*Slab, meta);
    slab.region = region;
    slab.bitmap = cast(*u8, cast(i64, meta) + sizeof(Slab));
    slab.region_size = page_size;
    slab.total_slots = total_slots;
    slab.used_slots = 0;
    slab.next = cast(*u8, 0);

    // Init bitmap: all 1s (all free)
    let is i64 as i with mut = 0;
    while (i < bitmap_bytes) {
        slab.bitmap[i] = 255;
        i = i + 1;
    }
    let is i64 as extra = bitmap_bytes * 8 - total_slots;
    if (extra > 0) {
        let is i64 as last = bitmap_bytes - 1;
        slab.bitmap[last] = cast(u8, (1 << (8 - extra)) - 1);
    }

    // Build freelist
    i = 0;
    while (i < total_slots - 1) {
        let is *u8 as slot = cast(*u8, cast(i64, region) + i * alloc_size);
        let is *i64 as np = cast(*i64, slot);
        *np = cast(i64, region) + (i + 1) * alloc_size;
        i = i + 1;
    }
    let is *u8 as last_slot = cast(*u8, cast(i64, region) + (total_slots - 1) * alloc_size);
    let is *i64 as last_np = cast(*i64, last_slot);
    *last_np = 0;

    slab.freelist = region;
    return slab;
}

fn _slab_destroy(slab as *Slab) as void {
    let is i64 as bitmap_bytes = (slab.total_slots + 7) >> 3;
    core.munmap(slab.region, slab.region_size);
    core.munmap(cast(*u8, slab), sizeof(Slab) + bitmap_bytes);
}

// --- Internal: bin helpers ---

fn _bin_at(b as *Bins, idx as i64) as *Bin {
    return cast(*Bin, cast(i64, b.bin_data) + idx * sizeof(Bin));
}

fn _build_lookup(b as *Bins) as void {
    let is i64 as entries = b.lookup_entries;
    let is i64 as i with mut = 0;
    while (i < entries * 2) {
        b.lookup[i] = 255;
        i = i + 1;
    }
    i = 0;
    while (i < entries) {
        let is i64 as size with mut = i * 8;
        if (size == 0) { size = 1; }
        let is i64 as j with mut = 0;
        while (j < b.bin_count) {
            let is *Bin as bin = _bin_at(b, j);
            if (bin.slot_size >= size) {
                let is *u8 as lp = cast(*u8, cast(i64, b.lookup) + i * 2);
                lp[0] = cast(u8, j & 255);
                lp[1] = cast(u8, (j >> 8) & 255);
                break;
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

fn _lookup_bin(b as *Bins, size as i64) as i64 {
    let is i64 as idx with mut = size >> 3;
    if ((size & 7) != 0) { idx = idx + 1; }
    if (idx >= b.lookup_entries) { return 0 - 1; }
    let is *u8 as lp = cast(*u8, cast(i64, b.lookup) + idx * 2);
    let is i64 as bin_idx = cast(i64, lp[0]) + cast(i64, lp[1]) * 256;
    if (bin_idx >= 255) { return 0 - 1; }
    return bin_idx;
}

fn _setup_default(b as *Bins) as void {
    let is [20]i64 as sizes;
    sizes[0] = 8;     sizes[1] = 16;    sizes[2] = 24;    sizes[3] = 32;
    sizes[4] = 48;    sizes[5] = 64;    sizes[6] = 96;    sizes[7] = 128;
    sizes[8] = 192;   sizes[9] = 256;   sizes[10] = 384;  sizes[11] = 512;
    sizes[12] = 768;  sizes[13] = 1024; sizes[14] = 2048; sizes[15] = 4096;
    sizes[16] = 8192; sizes[17] = 16384; sizes[18] = 32768; sizes[19] = 65536;

    let is i64 as i with mut = 0;
    while (i < 20) {
        let is *Bin as bin = _bin_at(b, i);
        bin.slot_size = sizes[i];
        bin.alloc_size = sizes[i] + HEADER_SIZE;
        bin.slab_head = cast(*u8, 0);
        bin.page_size = b.page_size;
        i = i + 1;
    }
}

// --- Public API ---

fn bins_new(page_size as i64) as Bins {
    let is Bins as b;
    b.bin_count = NUM_DEFAULT_BINS;
    b.page_size = page_size;

    let is i64 as meta_size = NUM_DEFAULT_BINS * sizeof(Bin);
    b.bin_data = core.mmap_anon(meta_size);
    if (cast(i64, b.bin_data) < 0) {
        b.bin_data = cast(*u8, 0);
        b.bin_count = 0;
        return b;
    }

    b.lookup_entries = LOOKUP_SIZE;
    b.lookup = core.mmap_anon(LOOKUP_SIZE * 2);
    if (cast(i64, b.lookup) < 0) {
        core.munmap(b.bin_data, meta_size);
        b.bin_data = cast(*u8, 0);
        b.bin_count = 0;
        return b;
    }

    _setup_default(&b);
    _build_lookup(&b);
    return b;
}

fn bins_custom(page_size as i64, sizes as *i64, count as i64) as Bins {
    let is Bins as b;
    if (count <= 0) {
        b.bin_data = cast(*u8, 0);
        b.bin_count = 0;
        b.page_size = 0;
        b.lookup = cast(*u8, 0);
        b.lookup_entries = 0;
        return b;
    }

    // Validate ascending order
    let is i64 as v with mut = 1;
    while (v < count) {
        if (sizes[v] <= sizes[v - 1]) {
            b.bin_data = cast(*u8, 0);
            b.bin_count = 0;
            b.page_size = 0;
            b.lookup = cast(*u8, 0);
            b.lookup_entries = 0;
            return b;
        }
        v = v + 1;
    }

    b.bin_count = count;
    b.page_size = page_size;
    let is i64 as meta_size = count * sizeof(Bin);
    b.bin_data = core.mmap_anon(meta_size);
    if (cast(i64, b.bin_data) < 0) {
        b.bin_data = cast(*u8, 0);
        b.bin_count = 0;
        return b;
    }

    let is i64 as max_size = sizes[count - 1];
    b.lookup_entries = (max_size >> 3) + 2;
    b.lookup = core.mmap_anon(b.lookup_entries * 2);
    if (cast(i64, b.lookup) < 0) {
        core.munmap(b.bin_data, meta_size);
        b.bin_data = cast(*u8, 0);
        b.bin_count = 0;
        return b;
    }

    let is i64 as i with mut = 0;
    while (i < count) {
        let is *Bin as bin = _bin_at(&b, i);
        bin.slot_size = sizes[i];
        bin.alloc_size = sizes[i] + HEADER_SIZE;
        bin.slab_head = cast(*u8, 0);
        bin.page_size = page_size;
        i = i + 1;
    }

    _build_lookup(&b);
    return b;
}

// Alloc — O(1) lookup + O(1) freelist pop
fn bins_alloc(b as *Bins, size as i64) as *u8 {
    if (size <= 0) { return cast(*u8, 0); }

    let is i64 as idx = _lookup_bin(b, size);
    if (idx < 0) {
        core.write_str(2, "bins_alloc: size ");
        core.write_int(2, size);
        core.write_str(2, " exceeds max bin 65536\n");
        return cast(*u8, 0);
    }

    let is *Bin as bin = _bin_at(b, idx);

    // Search slabs for free slot
    let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
    while (cast(i64, slab) != 0) {
        if (cast(i64, slab.freelist) != 0) {
            let is *u8 as slot = slab.freelist;
            let is *i64 as np = cast(*i64, slot);
            slab.freelist = cast(*u8, *np);
            // Header layout (8 bytes):
            //   byte 0: bin_index
            //   bytes 1-3: slot_index (24 bits, up to 16M slots)
            //   bytes 4-7: unused
            let is i64 as si = (cast(i64, slot) - cast(i64, slab.region)) / bin.alloc_size;
            let is *u8 as hdr = cast(*u8, slot);
            hdr[0] = cast(u8, idx);
            hdr[1] = cast(u8, si & 255);
            hdr[2] = cast(u8, (si >> 8) & 255);
            hdr[3] = cast(u8, (si >> 16) & 255);
            core.bit_clear(slab.bitmap, si);
            slab.used_slots = slab.used_slots + 1;
            return cast(*u8, cast(i64, slot) + HEADER_SIZE);
        }
        slab = cast(*Slab, slab.next);
    }

    // No free slot — create new slab
    let is *Slab as new_slab = _slab_create(bin.alloc_size, bin.page_size, idx);
    if (cast(i64, new_slab) == 0) { return cast(*u8, 0); }

    new_slab.next = bin.slab_head;
    bin.slab_head = cast(*u8, new_slab);

    let is *u8 as slot = new_slab.freelist;
    let is *i64 as np = cast(*i64, slot);
    new_slab.freelist = cast(*u8, *np);
    let is *u8 as hdr = cast(*u8, slot);
    hdr[0] = cast(u8, idx);
    hdr[1] = 0;
    hdr[2] = 0;
    hdr[3] = 0;
    core.bit_clear(new_slab.bitmap, 0);
    new_slab.used_slots = 1;
    return cast(*u8, cast(i64, slot) + HEADER_SIZE);
}

// Free — O(1): header read (no division) + bit test + freelist push
fn bins_free(b as *Bins, ptr as *u8) as void {
    if (cast(i64, ptr) == 0) { return; }

    let is *u8 as slot = cast(*u8, cast(i64, ptr) - HEADER_SIZE);

    // Read bin_index and slot_index from header — no division needed
    let is *u8 as hdr = cast(*u8, slot);
    let is i64 as idx = cast(i64, hdr[0]);
    let is i64 as si = cast(i64, hdr[1]) + cast(i64, hdr[2]) * 256 + cast(i64, hdr[3]) * 65536;

    if (idx >= b.bin_count) { return; }

    let is *Bin as bin = _bin_at(b, idx);

    // Find slab (still need to validate ptr belongs to a slab)
    let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
    while (cast(i64, slab) != 0) {
        let is i64 as start = cast(i64, slab.region);
        let is i64 as end = start + slab.region_size;
        if (cast(i64, slot) >= start && cast(i64, slot) < end) {
            // Double-free detection — O(1) bit test
            if (core.bit_test(slab.bitmap, si) == 1) { return; }
            core.bit_set(slab.bitmap, si);
            slab.used_slots = slab.used_slots - 1;
            // Push onto freelist
            let is *i64 as np = cast(*i64, slot);
            *np = cast(i64, slab.freelist);
            slab.freelist = slot;
            return;
        }
        slab = cast(*Slab, slab.next);
    }
}

// Destroy
fn bins_destroy(b as *Bins) as void {
    let is i64 as i with mut = 0;
    while (i < b.bin_count) {
        let is *Bin as bin = _bin_at(b, i);
        let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
        while (cast(i64, slab) != 0) {
            let is *Slab as next = cast(*Slab, slab.next);
            _slab_destroy(slab);
            slab = next;
        }
        i = i + 1;
    }
    if (cast(i64, b.lookup) != 0) { core.munmap(b.lookup, b.lookup_entries * 2); }
    if (cast(i64, b.bin_data) != 0) { core.munmap(b.bin_data, b.bin_count * sizeof(Bin)); }
    b.bin_data = cast(*u8, 0);
    b.bin_count = 0;
}

// --- Introspection ---

fn bins_which(b as *Bins, size as i64) as i64 {
    if (size <= 0) { return 0; }
    let is i64 as idx = _lookup_bin(b, size);
    if (idx < 0) { return 0; }
    return _bin_at(b, idx).slot_size;
}

fn bins_overhead(b as *Bins, size as i64) as i64 {
    let is i64 as sc = bins_which(b, size);
    if (sc == 0) { return 0; }
    return sc - size + HEADER_SIZE;
}

fn bins_used(b as *Bins) as i64 {
    let is i64 as total with mut = 0;
    let is i64 as i with mut = 0;
    while (i < b.bin_count) {
        let is *Bin as bin = _bin_at(b, i);
        let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
        while (cast(i64, slab) != 0) {
            total = total + bin.alloc_size * slab.used_slots;
            slab = cast(*Slab, slab.next);
        }
        i = i + 1;
    }
    return total;
}

fn bins_total(b as *Bins) as i64 {
    let is i64 as total with mut = 0;
    let is i64 as i with mut = 0;
    while (i < b.bin_count) {
        let is *Bin as bin = _bin_at(b, i);
        let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
        while (cast(i64, slab) != 0) {
            total = total + slab.region_size;
            slab = cast(*Slab, slab.next);
        }
        i = i + 1;
    }
    return total;
}

fn bins_bin_count(b as *Bins) as i64 { return b.bin_count; }

fn bins_bin_size(b as *Bins, bin_idx as i64) as i64 {
    if (bin_idx < 0 || bin_idx >= b.bin_count) { return 0; }
    return _bin_at(b, bin_idx).slot_size;
}

fn bins_waste(b as *Bins) as i64 {
    let is i64 as tr = bins_total(b);
    let is i64 as tu = bins_used(b);
    if (tr == 0) { return 0; }
    return ((tr - tu) * 100) / tr;
}

fn bins_stats(b as *Bins) as void {
    let is i64 as i with mut = 0;
    while (i < b.bin_count) {
        let is *Bin as bin = _bin_at(b, i);
        let is *Slab as slab with mut = cast(*Slab, bin.slab_head);
        let is i64 as tu with mut = 0;
        let is i64 as tc with mut = 0;
        let is i64 as sc with mut = 0;
        while (cast(i64, slab) != 0) {
            tu = tu + slab.used_slots;
            tc = tc + slab.total_slots;
            sc = sc + 1;
            slab = cast(*Slab, slab.next);
        }
        if (tc > 0) {
            linux.write(linux.STDOUT, "  bin ", 6);
            _write_num(bin.slot_size);
            linux.write(linux.STDOUT, ": ", 2);
            _write_num(tu);
            linux.write(linux.STDOUT, "/", 1);
            _write_num(tc);
            linux.write(linux.STDOUT, " (", 2);
            _write_num(sc);
            linux.write(linux.STDOUT, " slabs)\n", 8);
        }
        i = i + 1;
    }
    linux.write(linux.STDOUT, "  used: ", 8);
    _write_num(bins_used(b));
    linux.write(linux.STDOUT, " kernel: ", 9);
    _write_num(bins_total(b));
    linux.write(linux.STDOUT, " overhead: ", 11);
    _write_num(HEADER_SIZE);
    linux.write(linux.STDOUT, "b/blk\n", 6);
}

fn _write_num(n as i64) as void {
    if (n == 0) { linux.write(linux.STDOUT, "0", 1); return; }
    if (n == (0 - 9223372036854775807 - 1)) {
        linux.write(linux.STDOUT, "-9223372036854775808", 20);
        return;
    }
    let is [20]u8 as buf;
    let is i64 as val with mut = n;
    if (val < 0) {
        linux.write(linux.STDOUT, "-", 1);
        val = 0 - val;
    }
    let is i32 as pos with mut = 19;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    let is i64 as start = cast(i64, pos) + 1;
    linux.write(linux.STDOUT, cast(*u8, cast(i64, &buf) + start), 20 - start);
}
