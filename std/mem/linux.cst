// =======================================================
// std/mem/linux.cst — Portable raw page allocator, Linux impl
//
// Backs higher-level allocators (freelist, bins, arena, pool, lifo).
// mmap MAP_ANONYMOUS|MAP_PRIVATE + PROT_READ|PROT_WRITE.
// =======================================================

use "../os/linux.cst" as linux;

let is i64 as _PROT_RW   with imut = 3;   // PROT_READ | PROT_WRITE
let is i64 as _MAP_PRIVANON with imut = 34;  // MAP_PRIVATE | MAP_ANONYMOUS

// Returns a pointer to size bytes (rounded up to page size by mmap),
// or cast(*u8, -1) on failure (MAP_FAILED).
fn page_alloc(size as i64) as *u8 {
    return linux.mmap(cast(*u8, 0), size, _PROT_RW, _MAP_PRIVANON, 0 - 1, 0);
}

fn page_free(ptr as *u8, size as i64) as i32 {
    return cast(i32, linux.munmap(ptr, size));
}
