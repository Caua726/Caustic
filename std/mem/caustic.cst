// =======================================================
// std/mem/caustic.cst — raw page allocator for the CausticOS target.
//
// Backs the higher-level allocators (freelist, bins, arena, pool, lifo) the
// same way std/mem/linux.cst does on Linux. CausticOS has no demand paging:
// memory is strict reserve+commit. page_alloc's contract is "ready-to-use
// pages", so it reserves the VA window then commits (backs + zeroes) it. An
// allocator that wants sparse growth reserves a large window once and commits
// chunks on demand via the os.reserve / os.commit wrappers directly.
// =======================================================

use "../os/causticos.cst" as os;

let is i64 as _PROT_RW with imut = 2;   // MMAP_PROT_WRITE (read implied, no exec)

// Reserve + commit `size` bytes, returning the base VA, or cast(*u8, -1) on
// failure (the MAP_FAILED convention the callers — freelist.reserve etc. —
// already test for, alongside 0).
fn page_alloc(size as i64) as *u8 {
    let is i64 as va = os.reserve(cast(i64, 0), size, _PROT_RW);
    if (va < 0) { return cast(*u8, 0 - 1); }
    if (os.commit(va, size, _PROT_RW) != 0) {
        os.munmap(va, size);
        return cast(*u8, 0 - 1);
    }
    return cast(*u8, va);
}

fn page_free(ptr as *u8, size as i64) as i32 {
    return cast(i32, os.munmap(cast(i64, ptr), size));
}
