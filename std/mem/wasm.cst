// =======================================================
// std/mem/wasm.cst — page allocator over the wasm linear memory
//
// wasm has no mmap: the only way to obtain fresh memory is to grow the single
// linear memory with the `memory.grow` instruction (in 64 KiB pages), which
// appends above the current end and returns the previous page count. That end
// starts just past the static data + shadow stack the backend lays out, so the
// region memory.grow hands back never overlaps globals, strings, or the stack.
//
// There is no per-region free: `memory.grow` only ever extends. page_free is a
// no-op, so this backs a bump/arena discipline — the higher allocators (bins,
// freelist) recycle within the pages they already hold and rarely give any back.
// =======================================================

use "../os/wasm.cst" as wasi;

let is i64 as PAGE  with imut = 65536;
let is i64 as CHUNK with imut = 16777216;   // grow the linear memory 16 MiB at a time

// Bump allocator over the linear memory. Since page_free never returns pages
// (wasm memory only ever grows) and this is the sole caller of memory.grow, the
// grown memory is one contiguous run: [_bump, _end) is memory we already grew but
// have not handed out yet, so we can satisfy most allocations without growing.
// Growing in 16 MiB chunks keeps `memory.grow` calls rare, cutting both syscalls
// and host-side work. (The memory is declared SHARED by the backend so a grow
// never detaches the backing store — see emit_memory_section — which is what lets
// node:wasi and other view-caching hosts survive a growing compile.)
let is i64 as _bump with mut = 0;
let is i64 as _end  with mut = 0;

// Return `size` bytes (4 KiB-aligned, matching native mmap granularity), or 0 if
// the host refuses to grow the memory.
fn page_alloc(size as i64) as *u8 {
    if (size <= 0) { return cast(*u8, 0); }
    let is i64 as need = (size + 4095) / 4096 * 4096;    // round up to 4 KiB
    if (_bump + need > _end) {
        // Grow enough to cover the shortfall, at least CHUNK. The new pages append
        // at the current memory end (== _end after the first grow), so the run
        // stays contiguous and any leftover [_bump, _end) is not wasted.
        let is i64 as shortfall = need - (_end - _bump);
        let is i64 as grow_bytes with mut = shortfall;
        if (grow_bytes < CHUNK) { grow_bytes = CHUNK; }
        let is i64 as pages = (grow_bytes + PAGE - 1) / PAGE;
        let is i64 as prev = wasi.__wasm_memory_grow(pages);
        if (prev < 0) { return cast(*u8, 0); }           // memory.grow returned -1
        if (_bump == 0) { _bump = prev * PAGE; }         // first grow: anchor the bump ptr
        _end = prev * PAGE + pages * PAGE;
    }
    let is i64 as r = _bump;
    _bump = _bump + need;
    return cast(*u8, r);
}

// No unmap in wasm linear memory — pages are only ever appended. The higher-level
// allocators reuse freed blocks within their existing pages.
fn page_free(ptr as *u8, size as i64) as i32 { return 0; }

// Two-phase reserve/commit collapse to page_alloc/no-op: growth is eager (the
// pages are backed the moment memory.grow succeeds).
fn reserve(size as i64) as *u8 { return page_alloc(size); }
fn commit(ptr as *u8, size as i64) as i32 { return 0; }
