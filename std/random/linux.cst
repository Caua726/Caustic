// =======================================================
// std/random/linux.cst — Portable RNG entropy, Linux impl
// =======================================================

use "../os/linux.cst" as linux;

// Returns number of bytes written (== count on success), or negative
// errno. Loops on partial fills.
fn fill_bytes(buf as *u8, count as i64) as i64 {
    let is i64 as got with mut = 0;
    while (got < count) {
        let is i64 as n = linux.getrandom(cast(*u8, cast(i64, buf) + got),
                                          count - got, 0);
        if (n < 0) { return n; }
        if (n == 0) { return got; }
        got = got + n;
    }
    return got;
}
