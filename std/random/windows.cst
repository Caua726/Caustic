// =======================================================
// std/random/windows.cst — Portable RNG entropy, Windows impl
//
// BCryptGenRandom with BCRYPT_USE_SYSTEM_PREFERRED_RNG flag taps the
// system CSPRNG without needing to open an algorithm provider handle.
// Returns 0 on success (STATUS_SUCCESS); on failure the count is left
// untouched and we surface a negative error.
// =======================================================

use "../os/windows.cst" as win;

fn fill_bytes(buf as *u8, count as i64) as i64 {
    let is i32 as status = win.BCryptGenRandom(0, buf, cast(u32, count),
                                               win.BCRYPT_USE_SYSTEM_PREFERRED_RNG);
    if (status != 0) { return cast(i64, status); }
    return count;
}
