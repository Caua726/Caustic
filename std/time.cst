// =======================================================
// std/time.cst
// Time utilities — monotonic clock, sleep, elapsed measurement
// =======================================================

use "linux.cst" as linux;

// --- Current time ---

// Get current monotonic time in nanoseconds
fn now_ns() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_MONOTONIC, &ts);
    let is *i64 as p = cast(*i64, &ts);
    let is i64 as secs = p[0];
    let is i64 as nsecs = p[1];
    return secs * 1000000000 + nsecs;
}

// Get current monotonic time in microseconds
fn now_us() as i64 {
    return now_ns() / 1000;
}

// Get current monotonic time in milliseconds
fn now_ms() as i64 {
    return now_ns() / 1000000;
}

// Get current monotonic time in seconds
fn now_s() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_MONOTONIC, &ts);
    let is *i64 as p = cast(*i64, &ts);
    return p[0];
}

// Get real (wall clock) time in seconds since epoch (Unix timestamp)
fn unix_time() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_REALTIME, &ts);
    let is *i64 as p = cast(*i64, &ts);
    return p[0];
}

// Get real time in milliseconds since epoch
fn unix_time_ms() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_REALTIME, &ts);
    let is *i64 as p = cast(*i64, &ts);
    return p[0] * 1000 + p[1] / 1000000;
}

// --- Sleep ---

// Sleep for the given number of seconds
fn sleep_s(secs as i64) as void {
    let is [16]u8 as req;
    let is *i64 as p = cast(*i64, &req);
    p[0] = secs;
    p[1] = 0;
    linux.nanosleep(&req, cast(*u8, 0));
}

// Sleep for the given number of milliseconds
fn sleep_ms(ms as i64) as void {
    let is [16]u8 as req;
    let is *i64 as p = cast(*i64, &req);
    p[0] = ms / 1000;
    p[1] = (ms % 1000) * 1000000;
    linux.nanosleep(&req, cast(*u8, 0));
}

// Sleep for the given number of microseconds
fn sleep_us(us as i64) as void {
    let is [16]u8 as req;
    let is *i64 as p = cast(*i64, &req);
    p[0] = us / 1000000;
    p[1] = (us % 1000000) * 1000;
    linux.nanosleep(&req, cast(*u8, 0));
}

// Sleep for the given number of nanoseconds
fn sleep_ns(ns as i64) as void {
    let is [16]u8 as req;
    let is *i64 as p = cast(*i64, &req);
    p[0] = ns / 1000000000;
    p[1] = ns % 1000000000;
    linux.nanosleep(&req, cast(*u8, 0));
}

// --- Elapsed measurement ---

// Returns elapsed nanoseconds since start_ns
fn elapsed_ns(start_ns as i64) as i64 {
    return now_ns() - start_ns;
}

// Returns elapsed microseconds since start_ns
fn elapsed_us(start_ns as i64) as i64 {
    return (now_ns() - start_ns) / 1000;
}

// Returns elapsed milliseconds since start_ns
fn elapsed_ms(start_ns as i64) as i64 {
    return (now_ns() - start_ns) / 1000000;
}

// Returns elapsed seconds since start_ns
fn elapsed_s(start_ns as i64) as i64 {
    return (now_ns() - start_ns) / 1000000000;
}
