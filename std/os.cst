// =======================================================
// std/os.cst — Raw OS bindings hub + target identity
//
// Re-exports both Linux and Windows raw bindings as submodules. Safe to
// import unconditionally on any target: extern declarations without bodies
// are DCE'd from IR, and syscall-wrapping functions on the wrong-target
// side are dead-stripped at codegen by the IR-gen branch elim once their
// guarding `if (os.current == os.OS_X)` folds to false.
//
// User pattern for portable code:
//   use "std/os.cst" as os;
//   if (os.current == os.OS_LINUX) {
//       os.linux.write(1, "hi", 2);
//   } else if (os.current == os.OS_WINDOWS) {
//       let is u32 as w with mut = 0;
//       os.windows.WriteFile(os.windows.GetStdHandle(0 - 11), "hi", 2, &w, cast(*u8, 0));
//   }
//
// Mechanics: `os.current` is a `with imut` global whose init folds to a
// literal in semantic (1 = Linux, 2 = Windows). The compiler propagates
// that literal at every use site, so `os.current == os.OS_LINUX` collapses
// to `1 == 1` → `1` → dead-branch elim — the wrong-target code path never
// reaches codegen and the syscall/kernel32 gate never fires.
// =======================================================

use "os/linux.cst" as linux;
use "os/windows.cst" as windows;

// Numeric OS identifiers — single source of truth.
let is i32 as OS_UNKNOWN with imut = 0;
let is i32 as OS_LINUX   with imut = 1;
let is i32 as OS_WINDOWS with imut = 2;

// Active target, folded to a literal at parse time via the parser builtins.
// __target_is_linux is 1 on Linux builds and 0 elsewhere (and vice versa
// for Windows), so this expression evaluates to exactly one of the OS_*
// values at semantic time.
let is i32 as current with imut = __target_is_linux * OS_LINUX + __target_is_windows * OS_WINDOWS;
