// =======================================================
// std/path.cst
// Path manipulation utilities
// =======================================================

use "string.cst" as str;
use "mem.cst" only bins, core as mem;
use "env.cst" as env;

let is mem.Bins as _bins with mut;
let is i32 as _ready with mut = 0;

fn _alloc(size as i64) as *u8 {
    if (_ready == 0) { _bins = mem.bins.bins_new(16384); _ready = 1; }
    return mem.bins.bins_alloc(&_bins, size);
}

fn _free(ptr as *u8) as void {
    if (_ready == 1) { mem.bins.bins_free(&_bins, ptr); }
}

// Join two path components with '/'
fn join(a as *u8, b as *u8) as str.String {
    let is i64 as alen = str.strlen(a);
    let is i64 as blen = str.strlen(b);
    let is i64 as need_sep with mut = 0;
    if (alen > 0 && a[alen - 1] != 47 && blen > 0 && b[0] != 47) { need_sep = 1; }
    let is i64 as total = alen + blen + need_sep;
    let is str.String as s;
    s.ptr = _alloc(total + 1);
    s.len = cast(i32, total);
    s.cap = cast(i32, total + 1);
    mem.core.memcpy(s.ptr, a, alen);
    if (need_sep == 1) { s.ptr[alen] = 47; }
    mem.core.memcpy(cast(*u8, cast(i64, s.ptr) + alen + need_sep), b, blen);
    s.ptr[total] = 0;
    return s;
}

// Join three path components
fn join3(a as *u8, b as *u8, c as *u8) as str.String {
    let is str.String as ab = join(a, b);
    let is str.String as result = join(ab.ptr, c);
    _free(ab.ptr);
    return result;
}

// Get directory part: "/foo/bar" → "/foo"
fn dirname(path as *u8) as str.String {
    let is i64 as len = str.strlen(path);
    let is i64 as i with mut = len - 1;
    while (i >= 0 && path[i] != 47) { i = i - 1; }
    if (i <= 0) {
        if (len > 0 && path[0] == 47) { return str.String("/"); }
        return str.String(".");
    }
    let is str.String as s;
    s.ptr = _alloc(i + 1);
    s.len = cast(i32, i);
    s.cap = cast(i32, i + 1);
    mem.core.memcpy(s.ptr, path, i);
    s.ptr[i] = 0;
    return s;
}

// Get file part: "/foo/bar" → "bar"
fn basename(path as *u8) as str.String {
    let is i64 as len = str.strlen(path);
    let is i64 as i with mut = len - 1;
    while (i >= 0 && path[i] != 47) { i = i - 1; }
    let is *u8 as start = cast(*u8, cast(i64, path) + i + 1);
    return str.String(start);
}

// Get extension: "file.txt" → ".txt", "file" → ""
fn ext(path as *u8) as str.String {
    let is i64 as len = str.strlen(path);
    let is i64 as i with mut = len - 1;
    while (i >= 0) {
        if (path[i] == 46) {
            let is *u8 as start = cast(*u8, cast(i64, path) + i);
            return str.String(start);
        }
        if (path[i] == 47) { break; }
        i = i - 1;
    }
    let is str.String as empty;
    empty.ptr = _alloc(1);
    empty.ptr[0] = 0;
    empty.len = 0;
    empty.cap = 1;
    return empty;
}

// Expand ~ to $HOME: "~/.ssh" → "/home/caua/.ssh"
fn expand_home(path as *u8) as str.String {
    if (path[0] != 126) { return str.String(path); }
    let is *u8 as home = env.getenv("HOME");
    if (cast(i64, home) == 0) { return str.String(path); }
    if (path[1] == 0) { return str.String(home); }
    if (path[1] == 47) {
        return join(home, cast(*u8, cast(i64, path) + 2));
    }
    return str.String(path);
}
