// =======================================================
// std/linux.cst
// Syscalls Essenciais (Linux x86_64 System V ABI)
// =======================================================

// --- Flags (Argumentos Imutáveis) ---

// File Descriptors
let is i64 as STDIN  with imut = 0;
let is i64 as STDOUT with imut = 1;
let is i64 as STDERR with imut = 2;

// open() flags
let is i64 as O_RDONLY with imut = 0;
let is i64 as O_WRONLY with imut = 1;
let is i64 as O_RDWR   with imut = 2;
let is i64 as O_CREAT  with imut = 64;  // 0x40
let is i64 as O_TRUNC  with imut = 512; // 0x200
let is i64 as O_APPEND    with imut = 1024;   // 0x400
let is i64 as O_EXCL      with imut = 128;     // 0x80
let is i64 as O_NONBLOCK  with imut = 2048;    // 0x800
let is i64 as O_DIRECTORY with imut = 65536;   // 0x10000
let is i64 as O_CLOEXEC   with imut = 524288;  // 0x80000

// lseek() whence
let is i64 as SEEK_SET with imut = 0;
let is i64 as SEEK_CUR with imut = 1;
let is i64 as SEEK_END with imut = 2;

// mmap() prot & flags
let is i64 as PROT_READ     with imut = 1;
let is i64 as PROT_WRITE    with imut = 2;
let is i64 as PROT_EXEC     with imut = 4;
let is i64 as MAP_SHARED    with imut = 1;
let is i64 as MAP_PRIVATE   with imut = 2;
let is i64 as MAP_ANONYMOUS with imut = 32;
let is i64 as PROT_NONE     with imut = 0;
let is i64 as MAP_FIXED     with imut = 16;
let is i64 as MAP_FAILED    with imut = 0 - 1;  // (void*)-1

// clock_gettime() clk_id
let is i64 as CLOCK_REALTIME  with imut = 0;
let is i64 as CLOCK_MONOTONIC with imut = 1;

// socket() domain
let is i64 as AF_UNIX   with imut = 1;
let is i64 as AF_INET   with imut = 2;
let is i64 as AF_INET6  with imut = 10;

// socket() type
let is i64 as SOCK_STREAM with imut = 1;
let is i64 as SOCK_DGRAM  with imut = 2;

// socket() protocol
let is i64 as IPPROTO_TCP with imut = 6;
let is i64 as IPPROTO_UDP with imut = 17;

// setsockopt() levels/options
let is i64 as SOL_SOCKET    with imut = 1;
let is i64 as SO_REUSEADDR  with imut = 2;
let is i64 as SO_REUSEPORT  with imut = 15;

// access() mode
let is i64 as F_OK with imut = 0;
let is i64 as R_OK with imut = 4;
let is i64 as W_OK with imut = 2;
let is i64 as X_OK with imut = 1;

// openat/fstatat
let is i64 as AT_FDCWD with imut = 0 - 100;

// fcntl() commands
let is i64 as F_GETFD with imut = 1;
let is i64 as F_SETFD with imut = 2;
let is i64 as F_GETFL with imut = 3;
let is i64 as F_SETFL with imut = 4;
let is i64 as FD_CLOEXEC with imut = 1;

// poll() events
let is i64 as POLLIN   with imut = 1;
let is i64 as POLLOUT  with imut = 4;
let is i64 as POLLERR  with imut = 8;
let is i64 as POLLHUP  with imut = 16;
let is i64 as POLLNVAL with imut = 32;

// --- Wrappers (Ordem Numérica) ---

// 0: READ - Ler de arquivo/stream
fn read(fd as i64, buf as *u8, count as i64) as i64 {
    return syscall(0, fd, buf, count);
}

// 1: WRITE - Escrever em arquivo/stream
fn write(fd as i64, buf as *u8, count as i64) as i64 {
    return syscall(1, fd, buf, count);
}

// 2: OPEN - Abrir arquivo
fn open(path as *u8, flags as i64, mode as i64) as i64 {
    return syscall(2, path, flags, mode);
}

// 3: CLOSE - Fechar descritor
fn close(fd as i64) as i64 {
    return syscall(3, fd);
}

// 8: LSEEK - Mover cursor (útil para pegar tamanho de arquivo)
fn lseek(fd as i64, offset as i64, whence as i64) as i64 {
    return syscall(8, fd, offset, whence);
}

// 9: MMAP - Alocar páginas de memória
fn mmap(addr as *u8, len as i64, prot as i64, flags as i64, fd as i64, off as i64) as *u8 {
    return cast(*u8, syscall(9, addr, len, prot, flags, fd, off));
}

// 11: MUNMAP - Desalocar páginas
fn munmap(addr as *u8, len as i64) as i64 {
    return syscall(11, addr, len);
}

// 12: BRK - Ajustar topo da heap (alocador simples)
fn brk(addr as *u8) as *u8 {
    return cast(*u8, syscall(12, addr));
}

// 231: EXIT_GROUP - Terminar processo (todos os threads)
fn exit(code as i64) as void {
    syscall(231, code);
}

// 4: STAT - Info sobre arquivo (preenche statbuf de 144 bytes)
// st_mtime offset = 88 (8 bytes)
fn stat(path as *u8, statbuf as *u8) as i64 {
    return syscall(4, path, statbuf);
}

// 82: RENAME - Renomear arquivo
fn rename(oldpath as *u8, newpath as *u8) as i64 {
    return syscall(82, oldpath, newpath);
}

// 83: MKDIR - Criar diretorio
fn mkdir(path as *u8, mode as i64) as i64 {
    return syscall(83, path, mode);
}

// 87: UNLINK - Deletar arquivo
fn unlink(path as *u8) as i64 {
    return syscall(87, path);
}

// 89: READLINK - Ler link simbólico
fn readlink(path as *u8, buf as *u8, bufsiz as i64) as i64 {
    return syscall(89, path, buf, bufsiz);
}

// --- Processos ---

// 39: GETPID
fn getpid() as i64 {
    return syscall(39);
}

// 110: GETPPID
fn getppid() as i64 {
    return syscall(110);
}

// 57: FORK
fn fork() as i64 {
    return syscall(57);
}

// 59: EXECVE
fn execve(path as *u8, argv as *u8, envp as *u8) as i64 {
    return syscall(59, path, argv, envp);
}

// 61: WAIT4
fn wait4(pid as i64, status as *i32, options as i64, rusage as *u8) as i64 {
    return syscall(61, pid, status, options, rusage);
}

// 22: PIPE
fn pipe(pipefd as *i32) as i64 {
    return syscall(22, pipefd);
}

// 293: PIPE2
fn pipe2(pipefd as *i32, flags as i64) as i64 {
    return syscall(293, pipefd, flags);
}

// 33: DUP2
fn dup2(oldfd as i64, newfd as i64) as i64 {
    return syscall(33, oldfd, newfd);
}

// 292: DUP3
fn dup3(oldfd as i64, newfd as i64, flags as i64) as i64 {
    return syscall(292, oldfd, newfd, flags);
}

// --- Filesystem ---

// 5: FSTAT
fn fstat(fd as i64, statbuf as *u8) as i64 {
    return syscall(5, fd, statbuf);
}

// 77: FTRUNCATE
fn ftruncate(fd as i64, length as i64) as i64 {
    return syscall(77, fd, length);
}

// 84: RMDIR
fn rmdir(path as *u8) as i64 {
    return syscall(84, path);
}

// 217: GETDENTS64
fn getdents64(fd as i64, dirp as *u8, count as i64) as i64 {
    return syscall(217, fd, dirp, count);
}

// 79: GETCWD
fn getcwd(buf as *u8, size as i64) as i64 {
    return syscall(79, buf, size);
}

// 80: CHDIR
fn chdir(path as *u8) as i64 {
    return syscall(80, path);
}

// 21: ACCESS
fn access(path as *u8, mode as i64) as i64 {
    return syscall(21, path, mode);
}

// 90: CHMOD
fn chmod(path as *u8, mode as i64) as i64 {
    return syscall(90, path, mode);
}

// 88: SYMLINK
fn symlink(target as *u8, linkpath as *u8) as i64 {
    return syscall(88, target, linkpath);
}

// 86: LINK
fn link(oldpath as *u8, newpath as *u8) as i64 {
    return syscall(86, oldpath, newpath);
}

// --- Tempo ---

// 228: CLOCK_GETTIME
fn clock_gettime(clk_id as i64, tp as *u8) as i64 {
    return syscall(228, clk_id, tp);
}

// 35: NANOSLEEP
fn nanosleep(req as *u8, rem as *u8) as i64 {
    return syscall(35, req, rem);
}

// --- Memória ---

// 10: MPROTECT
fn mprotect(addr as *u8, len as i64, prot as i64) as i64 {
    return syscall(10, addr, len, prot);
}

// 25: MREMAP
fn mremap(old_addr as *u8, old_size as i64, new_size as i64, flags as i64, new_addr as *u8) as *u8 {
    return cast(*u8, syscall(25, old_addr, old_size, new_size, flags, new_addr));
}

// --- Networking ---

// 41: SOCKET
fn socket(domain as i64, sock_type as i64, protocol as i64) as i64 {
    return syscall(41, domain, sock_type, protocol);
}

// 42: CONNECT
fn connect(sockfd as i64, addr as *u8, addrlen as i64) as i64 {
    return syscall(42, sockfd, addr, addrlen);
}

// 43: ACCEPT
fn accept(sockfd as i64, addr as *u8, addrlen as *u32) as i64 {
    return syscall(43, sockfd, addr, addrlen);
}

// 44: SENDTO
fn sendto(sockfd as i64, buf as *u8, len as i64, flags as i64, dest_addr as *u8, addrlen as i64) as i64 {
    return syscall(44, sockfd, buf, len, flags, dest_addr, addrlen);
}

// 45: RECVFROM
fn recvfrom(sockfd as i64, buf as *u8, len as i64, flags as i64, src_addr as *u8, addrlen as *u32) as i64 {
    return syscall(45, sockfd, buf, len, flags, src_addr, addrlen);
}

// 49: BIND
fn bind(sockfd as i64, addr as *u8, addrlen as i64) as i64 {
    return syscall(49, sockfd, addr, addrlen);
}

// 50: LISTEN
fn listen(sockfd as i64, backlog as i64) as i64 {
    return syscall(50, sockfd, backlog);
}

// 54: SETSOCKOPT
fn setsockopt(sockfd as i64, level as i64, optname as i64, optval as *u8, optlen as i64) as i64 {
    return syscall(54, sockfd, level, optname, optval, optlen);
}

// --- Outros ---

// 318: GETRANDOM
fn getrandom(buf as *u8, buflen as i64, flags as i64) as i64 {
    return syscall(318, buf, buflen, flags);
}

// 16: IOCTL
fn ioctl(fd as i64, request as i64, arg as *u8) as i64 {
    return syscall(16, fd, request, arg);
}

// 72: FCNTL
fn fcntl(fd as i64, cmd as i64, arg as i64) as i64 {
    return syscall(72, fd, cmd, arg);
}

// 7: POLL
fn poll(fds as *u8, nfds as i64, timeout as i64) as i64 {
    return syscall(7, fds, nfds, timeout);
}