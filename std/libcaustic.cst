// std/libcaustic.cst — the whole standard library in one module.
//
// Compiled into the shared runtimes that ship with a release:
//   caustic --shared lib/caustic/std/libcaustic.cst -o libcaustic.so   (ELF, Linux)
//   caustic --target=caustic-x86_64 --mode=compat --shared ... -o libcaustic.csl
// `--allow-unsupported` is used so the per-OS `__compile_error` stubs become
// no-ops and every facade's globals/functions are kept (a library exports all).
//
// User code never needs to import this — it imports the individual facades.
use "io.cst" as io;
use "mem.cst" as mem;
use "string.cst" as string;
use "slice.cst" as slice;
use "map.cst" as map;
use "math.cst" as math;
use "sort.cst" as sort;
use "random.cst" as random;
use "net.cst" as net;
use "time.cst" as time;
use "env.cst" as env;
use "term.cst" as term;
use "process.cst" as process;
use "path.cst" as path;
use "types.cst" as types;
use "errors.cst" as errors;
use "arena.cst" as arena;
use "compatcffi.cst" as cffi;
use "os.cst" as os;

// Convenience C-ABI entry points exported by the shared runtime.
fn caustic_print(s as *u8) as void {
    let is i64 as n with mut = 0;
    while (s[n] != 0) { n = n + 1; }
    io._write_fd(io.STDOUT, s, n);
}
fn caustic_print_int(n as i64) as void { io.write_int(io.STDOUT, n); }
