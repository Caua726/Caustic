// =======================================================
// std/mem.cst
// Memory management — central module
//
// Submódulos:
//   use "std/mem.cst" only freelist as freelist;
//   use "std/mem.cst" only bins as bins;
//   use "std/mem.cst" only arena as arena;
//
// Ou importe tudo:
//   use "std/mem.cst" as mem;
//   mem.galloc(32);              // freelist global (compatibilidade)
//   mem.bins.bins_new(4096);     // bin allocator
//   mem.arena.create(4096);      // bump allocator
// =======================================================

use "mem/core.cst" as core;
use "mem/freelist.cst" as freelist;
use "mem/bins.cst" as bins;
use "mem/arena.cst" as arena;
use "mem/pool.cst" as pool;
use "mem/lifo.cst" as lifo;

// --- Type aliases for compatibility ---
type Heap = freelist.Heap;
type Header = freelist.Header;

// --- Compatibility wrappers (delegate to freelist) ---
// These will be removed once all code migrates to explicit allocator imports.

let is *freelist.Heap as _std_heap with mut;

fn reserve(req_size as i64) as *freelist.Heap {
    return freelist.reserve(req_size);
}

fn release(h as *freelist.Heap) as void {
    freelist.release(h);
}

fn alloc(h as *freelist.Heap, req_size as i64) as *u8 {
    return freelist.alloc(h, req_size);
}

fn free(h as *freelist.Heap, ptr as *u8) as void {
    freelist.free(h, ptr);
}

fn gheapinit(size as i64) as void {
    if (cast(i64, _std_heap) == 0) {
        _std_heap = freelist.reserve(size);
    }
}

fn gheapreset(size as i64) as void {
    freelist.release(_std_heap);
    _std_heap = freelist.reserve(size);
}

fn galloc(size as i64) as *u8 {
    return freelist.alloc(_std_heap, size);
}

fn gfree(ptr as *u8) as void {
    freelist.free(_std_heap, ptr);
}

fn memcpy(dst as *u8, src as *u8, n as i64) as *u8 {
    return core.memcpy(dst, src, n);
}

fn memset(dst as *u8, c as i32, n as i64) as *u8 {
    return core.memset(dst, c, n);
}

fn memcmp(mem1 as *u8, mem2 as *u8, data_size as i64) as i32 {
    return core.memcmp(mem1, mem2, data_size);
}

fn memzero(dst as *u8, n as i64) as void {
    core.memzero(dst, n);
}
