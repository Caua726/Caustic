// =======================================================
// std/mem.cst
// Memory management — central module
//
//   use "std/mem.cst" as mem;
//   mem.gheapinit(size);   // init global heap (bins-backed)
//   mem.galloc(n);         // allocate n bytes
//   mem.gfree(ptr);        // free
// =======================================================

use "mem/core.cst" as core;
use "mem/freelist.cst" as freelist;
use "mem/bins.cst" as bins;
use "mem/arena.cst" as arena;
use "mem/pool.cst" as pool;
use "mem/lifo.cst" as lifo;

// --- Global heap (bins-backed, lazy init) ---
let is bins.Bins as _gheap with mut;
let is i32 as _gheap_ready with mut = 0;

fn init(page_size as i64) as void {
    if (_gheap_ready == 0) {
        _gheap = bins.bins_new(page_size);
        _gheap_ready = 1;
    }
}

fn alloc(size as i64) as *u8 {
    if (_gheap_ready == 0) { init(1048576); }
    return bins.bins_alloc(&_gheap, size);
}

fn free(ptr as *u8) as void {
    if (_gheap_ready == 0) { return; }
    bins.bins_free(&_gheap, ptr);
}

// --- Direct mmap for large allocations ---
fn mmap_alloc(size as i64) as *u8 {
    return core.mmap_anon(size);
}

fn mmap_free(ptr as *u8, size as i64) as void {
    core.munmap(ptr, size);
}

fn memcpy(dst as *u8, src as *u8, n as i64) as *u8 {
    return core.memcpy(dst, src, n);
}

fn memset(dst as *u8, c as i32, n as i64) as *u8 {
    return core.memset(dst, c, n);
}

fn memcmp(mem1 as *u8, mem2 as *u8, data_size as i64) as i32 {
    return core.memcmp(mem1, mem2, data_size);
}

fn memzero(dst as *u8, n as i64) as void {
    core.memzero(dst, n);
}
