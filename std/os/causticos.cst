// =======================================================
// std/os/causticos.cst — CausticOS raw kernel bindings
//
// CausticOS is its own operating system (os.OS_CAUSTIC), NOT Linux. It has
// its own kernel syscall ABI: only 7 syscalls exist today, with their own
// numbers AND shapes. The instruction convention is standard x86_64:
//   rax = number; args rdi, rsi, rdx, r10, r8, r9; return in rax.
//   preserves rbx, rbp, r12-r15, rsp; clobbers rax, rcx, r11 + arg regs.
// An unknown/unimplemented number returns E_NOSYS (-2) WITHOUT killing the
// thread.
//
// Syscall table (everything that exists):
//   0 KERN_INFO(buf,size)   -> bytes written; size==0 -> 48 (probe)
//   1 TIME_NOW_NS()         -> monotonic ns since boot
//   2 TIME_SLEEP_NS(ns)     -> 0; ns<0 -> E_INVAL
//   3 PROC_EXIT(code)       -> never returns
//   4 PROC_GETPID()         -> tid
//   5 PROC_YIELD()          -> 0
//   6 IO_WRITE_SERIAL(buf,len) -> bytes written (COM1; no fd)
//
// NOT available (calling -> E_NOSYS): read, open, close, mmap/brk, any fd or
// VFS op. The portable facades surface those as a compile-time error on this
// target via __compile_error.
// =======================================================

let is i64 as SYS_KERN_INFO       with imut = 0;
let is i64 as SYS_TIME_NOW_NS     with imut = 1;
let is i64 as SYS_TIME_SLEEP_NS   with imut = 2;
let is i64 as SYS_PROC_EXIT       with imut = 3;
let is i64 as SYS_PROC_GETPID     with imut = 4;
let is i64 as SYS_PROC_YIELD      with imut = 5;
let is i64 as SYS_IO_WRITE_SERIAL with imut = 6;

// Errno values the kernel returns (negative in rax; (u64)rax > (u64)-4096).
let is i64 as E_OK    with imut = 0;
let is i64 as E_INVAL with imut = 0 - 1;
let is i64 as E_NOSYS with imut = 0 - 2;
let is i64 as E_FAULT with imut = 0 - 3;

// IO_WRITE_SERIAL(buf, len) — the only output channel (serial console / COM1).
// CRITICAL: there is NO fd. The portable io.cst dispatcher calls write with a
// Linux-shaped (fd, buf, n); we DROP the fd and pass (buf, n) -> (rdi, rsi).
// Each syscall is gated on __target_is_caustic so that on a non-CausticOS build
// (where these functions are still emitted because --shared exports every
// global) the `syscall` instruction is dead-stripped before codegen — only the
// caustic-x86_64 target ever emits it.
fn write(fd as i64, buf as *u8, n as i64) as i64 {
    if (__target_is_caustic == 1) { return syscall(6, buf, n); }
    return 0 - 1;
}

// PROC_EXIT(code) — terminates the thread; never returns.
fn exit(code as i32) as void {
    if (__target_is_caustic == 1) { syscall(3, cast(i64, code)); }
}

// Direct kernel services (for code that targets CausticOS specifically).
fn getpid() as i64 { if (__target_is_caustic == 1) { return syscall(4); } return 0 - 1; }
fn yield_cpu() as i64 { if (__target_is_caustic == 1) { return syscall(5); } return 0; }
fn sleep_ns(ns as i64) as i64 { if (__target_is_caustic == 1) { return syscall(2, ns); } return 0; }
fn time_ns() as i64 { if (__target_is_caustic == 1) { return syscall(1); } return 0; }
fn kern_info(buf as *u8, size as i64) as i64 { if (__target_is_caustic == 1) { return syscall(0, buf, size); } return 0 - 1; }
