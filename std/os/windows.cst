// =======================================================
// std/os/windows.cst — Raw Win32 bindings (Fase 2.6 minimum)
//
// This is the Caustic equivalent of <windows.h>: bare extern declarations
// of Windows DLL functions, matching kernel32 / ws2_32 / bcrypt signatures.
// User code can import this directly for low-level access. Portable
// stdlib wrappers (io.cst, mem.cst, net.cst) sit on top of this.
//
// Fase 2.6 ships a minimum surface — just enough to build hello-world,
// argv parsing, simple file I/O, and process exit. Phases 4-5 expand to
// the full ~48-function surface (memory, networking, time, env).
//
// Common STD_HANDLE values for GetStdHandle. Stored as i64 because
// global init in Caustic doesn't currently accept narrowing of negative
// integer literals or cast() expressions; callers pass these directly
// to GetStdHandle which auto-narrows (the int<->i32 arg passing path
// already handles negative narrowing properly).
let is i64 as STD_INPUT_HANDLE  with imut = 0 - 10;
let is i64 as STD_OUTPUT_HANDLE with imut = 0 - 11;
let is i64 as STD_ERROR_HANDLE  with imut = 0 - 12;

// CreateFileA dwDesiredAccess flags:
let is u32 as GENERIC_READ    with imut = 2147483648; // 0x80000000
let is u32 as GENERIC_WRITE   with imut = 1073741824; // 0x40000000
let is u32 as GENERIC_EXECUTE with imut = 536870912;  // 0x20000000

// CreateFileA dwShareMode flags:
let is u32 as FILE_SHARE_READ   with imut = 1;
let is u32 as FILE_SHARE_WRITE  with imut = 2;
let is u32 as FILE_SHARE_DELETE with imut = 4;

// CreateFileA dwCreationDisposition values:
let is u32 as CREATE_NEW        with imut = 1;
let is u32 as CREATE_ALWAYS     with imut = 2;
let is u32 as OPEN_EXISTING     with imut = 3;
let is u32 as OPEN_ALWAYS       with imut = 4;
let is u32 as TRUNCATE_EXISTING with imut = 5;

// FILE_ATTRIBUTE_NORMAL — pass to CreateFileA's dwFlagsAndAttributes for
// a regular file with no special attributes.
let is u32 as FILE_ATTRIBUTE_NORMAL with imut = 128;

// VirtualAlloc flAllocationType + flProtect:
let is u32 as MEM_COMMIT    with imut = 4096;     // 0x1000
let is u32 as MEM_RESERVE   with imut = 8192;     // 0x2000
let is u32 as MEM_RELEASE   with imut = 32768;    // 0x8000
let is u32 as PAGE_READONLY with imut = 2;
let is u32 as PAGE_READWRITE with imut = 4;
let is u32 as PAGE_EXECUTE  with imut = 16;
let is u32 as PAGE_EXECUTE_READ with imut = 32;
let is u32 as PAGE_EXECUTE_READWRITE with imut = 64;

// INVALID_HANDLE_VALUE: returned by CreateFileA on failure (and others).
let is i64 as INVALID_HANDLE_VALUE with imut = 0 - 1;

// === kernel32.dll — process, I/O, memory, console ===

extern "kernel32.dll" fn GetStdHandle(which as i64) as i64;
extern "kernel32.dll" fn WriteFile(handle as i64, buf as *u8, n as u32,
                                   written as *u32, overlapped as *u8) as i32;
extern "kernel32.dll" fn ReadFile(handle as i64, buf as *u8, n as u32,
                                  got as *u32, overlapped as *u8) as i32;
extern "kernel32.dll" fn CloseHandle(handle as i64) as i32;
extern "kernel32.dll" fn CreateFileA(name as *u8, access as u32, share as u32,
                                     sec as *u8, disp as u32, attrs as u32,
                                     templ as i64) as i64;
extern "kernel32.dll" fn SetFilePointerEx(handle as i64, dist as i64,
                                          newpos as *i64, method as u32) as i32;
extern "kernel32.dll" fn GetFileSizeEx(handle as i64, size as *i64) as i32;
extern "kernel32.dll" fn DeleteFileA(name as *u8) as i32;
extern "kernel32.dll" fn MoveFileA(src as *u8, dst as *u8) as i32;
extern "kernel32.dll" fn CreateDirectoryA(name as *u8, sec as *u8) as i32;
extern "kernel32.dll" fn RemoveDirectoryA(name as *u8) as i32;

extern "kernel32.dll" fn VirtualAlloc(addr as *u8, size as i64,
                                      alloc_type as u32, protect as u32) as *u8;
extern "kernel32.dll" fn VirtualFree(addr as *u8, size as i64, free_type as u32) as i32;
extern "kernel32.dll" fn VirtualProtect(addr as *u8, size as i64,
                                        protect as u32, old as *u32) as i32;

extern "kernel32.dll" fn GetSystemTimeAsFileTime(ft as *i64) as void;
extern "kernel32.dll" fn Sleep(ms as u32) as void;
extern "kernel32.dll" fn QueryPerformanceCounter(c as *i64) as i32;
extern "kernel32.dll" fn QueryPerformanceFrequency(f as *i64) as i32;

extern "kernel32.dll" fn ExitProcess(code as u32) as void;
extern "kernel32.dll" fn GetCurrentProcessId() as u32;
extern "kernel32.dll" fn GetCommandLineA() as *u8;
extern "kernel32.dll" fn GetEnvironmentVariableA(name as *u8, buf as *u8, size as u32) as u32;
extern "kernel32.dll" fn GetModuleFileNameA(mod as i64, buf as *u8, size as u32) as u32;
extern "kernel32.dll" fn GetLastError() as u32;
