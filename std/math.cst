// =======================================================
// std/math.cst
// Funções matemáticas para inteiros
// =======================================================

// --- Absolute Value ---

fn abs_i64(n as i64) as i64 {
    if (n < 0) { return 0 - n; }
    return n;
}

fn abs_i32(n as i32) as i32 {
    if (n < 0) { return cast(i32, 0) - n; }
    return n;
}

// --- Min / Max ---

fn min_i64(a as i64, b as i64) as i64 {
    if (a < b) { return a; }
    return b;
}

fn max_i64(a as i64, b as i64) as i64 {
    if (a > b) { return a; }
    return b;
}

fn min_i32(a as i32, b as i32) as i32 {
    if (a < b) { return a; }
    return b;
}

fn max_i32(a as i32, b as i32) as i32 {
    if (a > b) { return a; }
    return b;
}

// --- Clamp ---

fn clamp_i64(val as i64, lo as i64, hi as i64) as i64 {
    if (val < lo) { return lo; }
    if (val > hi) { return hi; }
    return val;
}

fn clamp_i32(val as i32, lo as i32, hi as i32) as i32 {
    if (val < lo) { return lo; }
    if (val > hi) { return hi; }
    return val;
}

// --- Power ---

fn pow_i64(base as i64, exp as i64) as i64 {
    if (exp < 0) { return 0; }
    if (exp == 0) { return 1; }
    let is i64 as result with mut = 1;
    let is i64 as b with mut = base;
    let is i64 as e with mut = exp;
    while (e > 0) {
        if (e & 1 == 1) {
            result = result * b;
        }
        b = b * b;
        e = e >> 1;
    }
    return result;
}

// --- GCD / LCM ---

fn gcd(a as i64, b as i64) as i64 {
    let is i64 as x with mut = a;
    let is i64 as y with mut = b;
    if (x < 0) { x = 0 - x; }
    if (y < 0) { y = 0 - y; }
    while (y != 0) {
        let is i64 as t = y;
        y = x % y;
        x = t;
    }
    return x;
}

fn lcm(a as i64, b as i64) as i64 {
    if (a == 0 || b == 0) { return 0; }
    let is i64 as g = gcd(a, b);
    let is i64 as aa with mut = a;
    if (aa < 0) { aa = 0 - aa; }
    return (aa / g) * b;
}

// --- Sign ---

fn sign_i64(n as i64) as i64 {
    if (n > 0) { return 1; }
    if (n < 0) { return 0 - 1; }
    return 0;
}

fn sign_i32(n as i32) as i32 {
    if (n > 0) { return cast(i32, 1); }
    if (n < 0) { return cast(i32, 0 - 1); }
    return cast(i32, 0);
}

// --- Division ---

fn div_ceil(a as i64, b as i64) as i64 {
    let is i64 as d = a / b;
    let is i64 as r = a % b;
    if (r != 0 && ((a > 0 && b > 0) || (a < 0 && b < 0))) {
        return d + 1;
    }
    return d;
}

fn is_power_of_two(n as i64) as i64 {
    if (n <= 0) { return 0; }
    if ((n & (n - 1)) == 0) { return 1; }
    return 0;
}

fn align_up(val as i64, align as i64) as i64 {
    let is i64 as mask = align - 1;
    return (val + mask) & (0 - align);
}

fn align_down(val as i64, align as i64) as i64 {
    return val & (0 - align);
}
