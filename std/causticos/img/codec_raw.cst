// std/causticos/img/codec_raw.cst — CSIF codec 0 (RAW), decode side.
//
// RAW is the identity codec: no entropy, no prediction, no colour transform.
// This decoder supports the BASELINE variant png2csif emits: interleaved,
// byte-aligned, row_alignment = 1 (params 0x01 0x00 0x01). The container
// (csif.cst) validates the params before calling; here we only copy.
//
// Pure byte ops, no syscalls — portable. Returns 0 on success, a negative
// code on invalid dimensions/overflow, truncation, or trailing bytes.

// decode(src, src_len, out, w, h, nchan): copy w*h*nchan bytes src -> out.
// out must hold at least w*h*nchan bytes (the caller sized it from IHDR).
fn decode(src as *u8, src_len as i64, out as *u8, w as i64, h as i64, nchan as i64) as i64 {
    if (w <= 0 || h <= 0 || (nchan != 3 && nchan != 4)) { return 0 - 3; }
    if (w > 0x7FFFFFFFFFFFFFFF / h) { return 0 - 3; }
    let is i64 as pixels = w * h;
    if (pixels > 0x7FFFFFFFFFFFFFFF / nchan) { return 0 - 3; }
    let is i64 as need = w * h * nchan;
    if (src_len < need) { return 0 - 1; }        // E_TRUNC: fewer bytes than pixels
    if (src_len != need) { return 0 - 2; }       // canonical RAW has no trailing bytes
    let is i64 as i with mut = 0;
    while (i < need) { out[i] = src[i]; i = i + 1; }
    return 0;
}
