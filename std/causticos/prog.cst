// std/causticos/prog.cst — tiny runtime for CausticOS userspace programs.
//
// A program spawned by the shell gets fd 1 = a console channel (its stdout) and
// argv on its stack. This wraps the two things every little program needs:
// write to stdout, and read argv. `out*` go to fd 1 -> the shell renders them on
// the framebuffer (or, run bare with no console, they fall back to serial).
// argv (from main's 2nd param) is char** — a NUL-terminated array of string
// pointers; arg(argv, i) returns the i-th.
use "../os/causticos.cst" as sys;

fn slen(s as *u8) as i64 { let is i64 as n with mut = 0; while (s[n] != 0) { n = n + 1; } return n; }

fn out(s as *u8, n as i64) as void { sys.write(cast(i64, 1), s, n); }
fn outs(s as *u8) as void { sys.write(cast(i64, 1), s, slen(s)); }

fn out_num(v as i64) as void {
    if (v == 0) { sys.write(cast(i64, 1), "0", 1); return; }
    let is [24]u8 as b;
    let is i64 as x with mut = v;
    if (x < 0) { sys.write(cast(i64, 1), "-", 1); x = 0 - x; }
    let is i64 as i with mut = 24;
    while (x > 0) { i = i - 1; b[i] = cast(u8, 48 + (x % 10)); x = x / 10; }
    sys.write(cast(i64, 1), cast(*u8, &b[i]), 24 - i);
}

// --- stdin (fd 0): a program spawned by the terminal gets fd 0 = a channel the
// terminal feeds keystrokes into, one raw byte per key, no echo (the program
// echoes what it wants). Run bare with no terminal, fd 0 doesn't exist and read
// returns an error → getc reports EOF. ---

// getc(): read one byte from stdin. Blocks until a key arrives. Returns the
// byte (0..255), or -1 on EOF / no stdin.
fn getc() as i64 {
    let is [1]u8 as b;
    let is i64 as r = sys.read(cast(i64, 0), cast(*u8, &b[0]), 1);
    if (r <= 0) { return 0 - 1; }
    return cast(i64, b[0]);
}

// getline(buf, cap): read a line into buf (up to cap-1 bytes), ECHOING each
// char as typed (raw mode → the program echoes) and handling Backspace. Enter
// ends the line and is not stored. Returns the length, or -1 on EOF before any
// byte. A convenience over getc for prompt-style input.
fn getline(buf as *u8, cap as i64) as i64 {
    let is i64 as len with mut = 0;
    while (1 == 1) {
        let is i64 as c = getc();
        if (c < 0) { if (len == 0) { return 0 - 1; } return len; }   // EOF
        if (c == 0x0A) { return len; }                               // Enter
        if (c == 0x08 || c == 0x7F) {                                // Backspace / Del
            if (len > 0) {
                len = len - 1;
                let is [3]u8 as er;
                er[0] = cast(u8, 0x08); er[1] = cast(u8, 0x20); er[2] = cast(u8, 0x08);
                out(cast(*u8, &er[0]), 3);                           // erase: BS space BS
            }
        } else if (len < cap - 1) {
            buf[len] = cast(u8, c & 0xFF);
            len = len + 1;
            let is [1]u8 as e;
            e[0] = cast(u8, c & 0xFF);
            out(cast(*u8, &e[0]), 1);                                // echo
        }
    }
    return len;
}

// arg(argv, i): the i-th command-line argument as a NUL-terminated *u8.
fn arg(argv as *u8, i as i64) as *u8 {
    let is *i64 as p = cast(*i64, argv);
    return cast(*u8, p[i]);
}

// abspath(raw, out): CausticOS has no cwd, so every VFS path must be absolute.
// Return `raw` unchanged if it already starts with '/', else copy "/" + raw into
// `out` (caller provides a buffer >= len+2) and return it.
fn abspath(raw as *u8, out as *u8) as *u8 {
    if (raw[0] == cast(u8, 47)) { return raw; }
    out[0] = cast(u8, 47);
    let is i64 as i with mut = 0;
    while (raw[i] != 0 && i < 254) { out[1 + i] = raw[i]; i = i + 1; }
    out[1 + i] = cast(u8, 0);
    return out;
}
