// std/causticos/prog.cst — tiny runtime for CausticOS userspace programs.
//
// A program spawned by the shell gets fd 1 = a console channel (its stdout) and
// argv on its stack. This wraps the two things every little program needs:
// write to stdout, and read argv. `out*` go to fd 1 -> the shell renders them on
// the framebuffer (or, run bare with no console, they fall back to serial).
// argv (from main's 2nd param) is char** — a NUL-terminated array of string
// pointers; arg(argv, i) returns the i-th.
use "../os/causticos.cst" as sys;

fn slen(s as *u8) as i64 { let is i64 as n with mut = 0; while (s[n] != 0) { n = n + 1; } return n; }

fn out(s as *u8, n as i64) as void { sys.write(cast(i64, 1), s, n); }
fn outs(s as *u8) as void { sys.write(cast(i64, 1), s, slen(s)); }

fn out_num(v as i64) as void {
    if (v == 0) { sys.write(cast(i64, 1), "0", 1); return; }
    let is [24]u8 as b;
    let is i64 as x with mut = v;
    if (x < 0) { sys.write(cast(i64, 1), "-", 1); x = 0 - x; }
    let is i64 as i with mut = 24;
    while (x > 0) { i = i - 1; b[i] = cast(u8, 48 + (x % 10)); x = x / 10; }
    sys.write(cast(i64, 1), cast(*u8, &b[i]), 24 - i);
}

// arg(argv, i): the i-th command-line argument as a NUL-terminated *u8.
fn arg(argv as *u8, i as i64) as *u8 {
    let is *i64 as p = cast(*i64, argv);
    return cast(*u8, p[i]);
}
