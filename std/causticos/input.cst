// std/causticos/input.cst — CausticOS keyboard facade.
//
// CausticOS-ONLY. dev_open(DEV_KEYBOARD) → an fd whose reads return raw 2-byte
// events (scancode + flags). The kernel applies NO keymap — scancode→char is
// userspace policy; scancode_to_ascii below is a convenience US Set-1 map you
// can ignore or replace. Import only from `--target=caustic-x86_64` programs.
use "../os/causticos.cst" as cos;

struct KeyEvent {
    scancode as i64;   // PS/2 Set-1 scancode (0x01..0x7F)
    pressed  as i64;   // 1 = key down, 0 = key up
    extended as i64;   // 1 = was 0xE0-prefixed (arrows, right-ctrl, ...)
}

// open_keyboard — grab the raw keyboard device. Returns an fd, or < 0 on error.
fn open_keyboard() as i64 {
    if (__target_is_caustic == 0) { __compile_error("std/causticos/input is CausticOS-only — build with --target=caustic-x86_64"); }
    return cos.dev_open(cos.DEV_KEYBOARD, 0, 0);
}

// read_event — block for one 2-byte event, unpack into `out`. Returns 1 on a
// full event, 0 if the read returned no full event, < 0 on error.
fn read_event(fd as i64, out as *KeyEvent) as i64 {
    let is [2]u8 as ev;
    let is i64 as n = cos.read(fd, cast(*u8, &ev[0]), 2);
    if (n != 2) { return n; }
    out.scancode = cast(i64, ev[0]);
    out.pressed  = cast(i64, ev[1]) & 1;
    out.extended = (cast(i64, ev[1]) >> 1) & 1;
    return 1;
}

// scancode_to_ascii — US QWERTY PS/2 Set-1, printable keys + a few controls.
// Returns 0 for unmapped keys. `shift` selects the shifted glyph / uppercase.
// This is policy: a real terminal swaps it for the user's layout.
fn scancode_to_ascii(sc as i64, shift as i64) as i64 {
    // number row: 0x02..0x0B
    if (sc >= 0x02 && sc <= 0x0B) {
        let is *u8 as d = "1234567890";
        let is *u8 as s = "!@#$%^&*()";
        if (shift != 0) { return cast(i64, s[sc - 0x02]); }
        return cast(i64, d[sc - 0x02]);
    }
    if (sc == 0x0C) { if (shift != 0) { return 0x5F; } return 0x2D; }   // - _
    if (sc == 0x0D) { if (shift != 0) { return 0x2B; } return 0x3D; }   // = +
    if (sc == 0x39) { return 0x20; }    // space
    if (sc == 0x1C) { return 0x0A; }    // enter -> newline
    if (sc == 0x0E) { return 0x08; }    // backspace
    if (sc == 0x0F) { return 0x09; }    // tab
    // letter rows (uppercase when shifted: subtract 0x20)
    if (sc >= 0x10 && sc <= 0x19) {
        let is *u8 as r = "qwertyuiop";
        let is i64 as c = cast(i64, r[sc - 0x10]);
        if (shift != 0) { return c - 0x20; }
        return c;
    }
    if (sc >= 0x1E && sc <= 0x26) {
        let is *u8 as r = "asdfghjkl";
        let is i64 as c = cast(i64, r[sc - 0x1E]);
        if (shift != 0) { return c - 0x20; }
        return c;
    }
    if (sc >= 0x2C && sc <= 0x32) {
        let is *u8 as r = "zxcvbnm";
        let is i64 as c = cast(i64, r[sc - 0x2C]);
        if (shift != 0) { return c - 0x20; }
        return c;
    }
    return 0;
}

// is_shift — true for either shift scancode (Set-1 left=0x2A, right=0x36).
fn is_shift(sc as i64) as i64 {
    if (sc == 0x2A || sc == 0x36) { return 1; }
    return 0;
}
