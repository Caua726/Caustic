// std/causticos/term.cst — text-grid renderer on a CausticOS framebuffer.
//
// CausticOS-ONLY. Renders an 8x16 bitmap console font (font.cst, the VGA
// default8x16) the way Linux fbcon does: each glyph bit maps 1:1 to a pixel,
// no anti-aliasing. The font carries its own spacing (blank top/bottom/side
// rows are part of the 8x16 glyph), so we draw cells edge-to-edge and add only
// a small screen margin (fbcon centres the grid the same way). flush() blits
// via SYS_PRESENT. Drives rendering only — the keyboard is input.cst's job.
//
//   let is gfx.Framebuffer as fb = gfx.open();
//   let is term.Term as t = term.init(fb.base, fb.fd, fb.width, fb.height, fb.pitch, fb.bpp);
//   term.puts(&t, "hello\n", 6);  term.flush(&t);
use "../os/causticos.cst" as cos;
use "font.cst" as font;

let is i64 as GLYPH_W with imut = 8;
let is i64 as GLYPH_H with imut = 16;
let is i64 as PAD_X   with imut = 12;     // left/right screen margin (px)
let is i64 as PAD_Y   with imut = 12;     // top/bottom screen margin (px)

// Transient CSI parameter buffer. term.cst is statically linked into each
// program and each program drives a single Term at a time, so one module-level
// scratch buffer is safe: it only holds the parameters of the escape sequence
// being parsed right now (e.g. CSI 38;2;255;100;50 m → [38,2,255,100,50]).
let is [16]i64 as _csi_p;

struct Term {
    base   as *u8;   // backbuffer user VA
    fd     as i64;   // surface fd (for present)
    width  as i64;   // pixels
    height as i64;
    pitch  as i64;   // bytes per row
    bpp    as i64;   // bytes per pixel
    cols   as i64;   // usable text columns
    rows   as i64;   // usable text rows
    cx     as i64;   // cursor column
    cy     as i64;   // cursor row
    fg     as u32;
    bg     as u32;
    // -- appended (all i64): windowed-rendering support --
    present_mode as i64;  // 1 = flush() presents (init, the fullscreen path);
                          // 0 = render-only PIXELS (init_buffer: a pixel segment,
                          //     no surface — the holder commits dirty pixel rects);
                          // 2 = TEXT (init_text: NO pixel backbuffer at all — the
                          //     glyph rasterisers are no-ops, only the cell grid is
                          //     maintained; the holder flattens the grid into a text
                          //     segment and the WM rasterises it on compose).
    d_x0   as i64;        // accumulated dirty rect (pixel coords, x1/y1
    d_y0   as i64;        // EXCLUSIVE); empty when d_x1 <= d_x0. The caller
    d_x1   as i64;        // drains it with take_dirty() to know what to
    d_y1   as i64;        // commit/present.
    grid   as i64;        // *i64 cell array (0 = no grid attached)
    grid_stride as i64;   // cells per grid row (fixed at attach)
    grid_rows   as i64;   // grid row capacity (a RING of lines)
    live_top as i64;      // physical grid row of the first LIVE visible line
    hist_count as i64;    // valid history lines above the live view
    view_off as i64;      // 0 = live; >0 = scrolled back this many lines
    // -- appended (all i64): the ANSI/VT escape parser, so a TUI (btop, an
    //    editor) running INSIDE the terminal can address the cursor, set
    //    colour and clear — instead of grabbing the framebuffer. --
    esc      as i64;      // parser state: 0 normal, 1 saw-ESC, 2 in-CSI
    csi_q    as i64;      // 1 if the CSI carried a '?' (private sequence)
    csi_n    as i64;      // index of the last CSI parameter (params in _csi_p)
    cur_vis  as i64;      // 1 = draw the cursor on flush; CSI ?25l clears it
    want_size as i64;     // CSI 18t sets this; the holder reports size + clears
    def_fg   as i64;      // default fg/bg — SGR 0/39/49 restore these
    def_bg   as i64;
}

// The grid is a ring of grid_rows text lines. The live view occupies
// physical rows live_top..live_top+rows-1 (mod grid_rows); scrolling
// advances live_top and the line that falls off the top BECOMES history
// (up to grid_rows - rows lines of it). view_off slides the visible
// window up into that history; any output snaps it back to live.
fn _phys_row(t as *Term, r as i64) as i64 {
    let is i64 as p = t.live_top + t.grid_rows - t.view_off + r;
    return p - (p / t.grid_rows) * t.grid_rows;     // p % grid_rows
}

// A grid cell packs everything needed to repaint it after a resize:
// ch (8 bits, CP437) | fg (24-bit RGB) << 8 | bg (24-bit RGB) << 32.
fn _cell_pack(ch as i64, fgc as u32, bgc as u32) as i64 {
    return (ch & 0xFF) | ((cast(i64, fgc) & 0xFFFFFF) << 8) | ((cast(i64, bgc) & 0xFFFFFF) << 32);
}

// Accumulate a pixel rect into the dirty union (x1/y1 exclusive).
fn _mark(t as *Term, x as i64, y as i64, w as i64, h as i64) as void {
    if (w <= 0 || h <= 0) { return; }
    if (t.d_x1 <= t.d_x0) {              // empty → take the rect as-is
        t.d_x0 = x; t.d_y0 = y; t.d_x1 = x + w; t.d_y1 = y + h;
        return;
    }
    if (x < t.d_x0) { t.d_x0 = x; }
    if (y < t.d_y0) { t.d_y0 = y; }
    if (x + w > t.d_x1) { t.d_x1 = x + w; }
    if (y + h > t.d_y1) { t.d_y1 = y + h; }
}

// Drain the dirty rect: writes {x, y, w, h} to out and resets the
// accumulator. Returns 1 if there was anything to take, 0 if clean.
fn take_dirty(t as *Term, out as *i64) as i64 {
    if (t.d_x1 <= t.d_x0) { return 0; }
    out[0] = t.d_x0;
    out[1] = t.d_y0;
    out[2] = t.d_x1 - t.d_x0;
    out[3] = t.d_y1 - t.d_y0;
    t.d_x0 = 0; t.d_y0 = 0; t.d_x1 = 0; t.d_y1 = 0;
    return 1;
}

fn _putpix(t as *Term, x as i64, y as i64, color as u32) as void {
    if (t.present_mode == 2) { return; }   // TEXT mode: no pixel backbuffer to write
    if (x < 0 || y < 0 || x >= t.width || y >= t.height) { return; }
    let is *u32 as p = cast(*u32, cast(i64, t.base) + y * t.pitch + x * t.bpp);
    p[0] = color;
}

// Pixel origin of text cell (cx,cy), inside the margin.
fn _cellx(t as *Term, cx as i64) as i64 { return PAD_X + cx * GLYPH_W; }
fn _celly(t as *Term, cy as i64) as i64 { return PAD_Y + cy * GLYPH_H; }

// Blit one 8x16 glyph cell at pixel (px,py) with explicit colors: set bits →
// fgc, clear bits → bgc, so the cell is fully repainted (erasing whatever was
// there). MSB = leftmost.
fn _glyph_c(t as *Term, ch as i64, px as i64, py as i64, fgc as u32, bgc as u32) as void {
    let is *u8 as g = font.get_glyph(cast(i32, ch));
    let is i64 as row with mut = 0;
    while (row < GLYPH_H) {
        let is i64 as bits = cast(i64, g[row]);
        let is i64 as col with mut = 0;
        while (col < GLYPH_W) {
            let is i64 as mask = 128 >> col;
            if ((bits & mask) != 0) { _putpix(t, px + col, py + row, fgc); }
            else { _putpix(t, px + col, py + row, bgc); }
            col = col + 1;
        }
        row = row + 1;
    }
    _mark(t, px, py, GLYPH_W, GLYPH_H);
}

fn _glyph(t as *Term, ch as i64, px as i64, py as i64) as void {
    _glyph_c(t, ch, px, py, t.fg, t.bg);
}

// Record the cell at visible (col,row) in the grid, if one is attached.
// Writers always target the LIVE view (callers reset view_off first).
fn _grid_set(t as *Term, col as i64, row as i64, ch as i64) as void {
    if (t.grid == 0) { return; }
    if (col < 0 || row < 0 || col >= t.grid_stride || row >= t.grid_rows) { return; }
    let is i64 as p = t.live_top + row;
    let is i64 as phys = p - (p / t.grid_rows) * t.grid_rows;
    let is *i64 as g = cast(*i64, t.grid);
    g[phys * t.grid_stride + col] = _cell_pack(ch, t.fg, t.bg);
}

// Blank one physical grid row.
fn _grid_blank_phys(t as *Term, phys as i64) as void {
    let is *i64 as g = cast(*i64, t.grid);
    let is i64 as blank = _cell_pack(0x20, t.fg, t.bg);
    let is i64 as c with mut = 0;
    while (c < t.grid_stride) {
        g[phys * t.grid_stride + c] = blank;
        c = c + 1;
    }
    return;
}

// Repaint every visible cell from the grid (honors view_off) and refill the
// background first — the one true re-render, used by resize and scrollback.
fn _repaint_view(t as *Term) as void {
    _fill_bg(t, t.width, t.height);
    if (t.grid == 0) { _mark(t, 0, 0, t.width, t.height); return; }
    let is *i64 as g = cast(*i64, t.grid);
    let is i64 as r with mut = 0;
    while (r < t.rows) {
        let is i64 as phys = _phys_row(t, r);
        let is i64 as c with mut = 0;
        while (c < t.cols) {
            let is i64 as cell = g[phys * t.grid_stride + c];
            let is i64 as ch = cell & 0xFF;
            let is u32 as cfg = cast(u32, (cell >> 8) & 0xFFFFFF);
            let is u32 as cbg = cast(u32, (cell >> 32) & 0xFFFFFF);
            if (ch != 0x20 || cbg != t.bg) {
                _glyph_c(t, ch, _cellx(t, c), _celly(t, r), cfg, cbg);
            }
            c = c + 1;
        }
        r = r + 1;
    }
    _mark(t, 0, 0, t.width, t.height);
    return;
}

// scroll_view — slide the visible window into history (delta > 0 = older)
// or back toward live (delta < 0). Clamped to what history holds; any
// change re-renders. The cursor is only drawn at live (flush skips it
// while scrolled back).
fn scroll_view(t as *Term, delta as i64) as void {
    if (t.grid == 0) { return; }
    let is i64 as v with mut = t.view_off + delta;
    if (v < 0) { v = 0; }
    if (v > t.hist_count) { v = t.hist_count; }
    if (v == t.view_off) { return; }
    t.view_off = v;
    _repaint_view(t);
    return;
}

// Scroll the text area up one row (GLYPH_H px) and clear the bottom row. The
// copy spans full pitch rows (side margins are bg, copying them up is a no-op;
// in windowed mode — pitch wider than the window — the overshoot stays inside
// the caller's own buffer and outside its visible rect, harmless). The grid,
// when attached, shifts in lockstep so a later resize() re-renders the truth.
fn _scroll(t as *Term) as void {
    if (t.present_mode != 2) {              // TEXT mode keeps NO pixel backbuffer:
        // scroll the pixels; the grid (below) carries the scroll on its own.
        let is i64 as top = cast(i64, t.base) + PAD_Y * t.pitch;   // top of text area
        let is i64 as rowbytes = t.pitch * GLYPH_H;
        let is i64 as span = t.pitch * (t.rows * GLYPH_H);          // text-area height
        let is *i64 as dst = cast(*i64, top);
        let is *i64 as src = cast(*i64, top + rowbytes);
        let is i64 as words = (span - rowbytes) / 8;
        let is i64 as i with mut = 0;
        while (i < words) { dst[i] = src[i]; i = i + 1; }
        // clear the bottom text row to bg, as u32 pixels
        let is *u32 as p = cast(*u32, top + (span - rowbytes));
        let is i64 as pw = rowbytes / 4;
        let is i64 as j with mut = 0;
        while (j < pw) { p[j] = t.bg; j = j + 1; }
    }
    if (t.grid != 0) {
        // the ring absorbs the scroll: the line leaving the top becomes
        // history, the fresh bottom line is blanked in place
        t.live_top = t.live_top + 1;
        if (t.live_top >= t.grid_rows) { t.live_top = 0; }
        let is i64 as p = t.live_top + t.rows - 1;
        let is i64 as phys = p - (p / t.grid_rows) * t.grid_rows;
        _grid_blank_phys(t, phys);
        let is i64 as hmax = t.grid_rows - t.rows;
        if (t.hist_count < hmax) { t.hist_count = t.hist_count + 1; }
    }
    _mark(t, 0, PAD_Y, t.width, t.rows * GLYPH_H);
    if (t.cy > 0) { t.cy = t.cy - 1; }
}

fn _newline(t as *Term) as void {
    t.cx = 0;
    t.cy = t.cy + 1;
    if (t.cy >= t.rows) { _scroll(t); }
}

fn init(base as *u8, fd as i64, width as i64, height as i64, pitch as i64, bpp as i64) as Term {
    font.init();
    let is Term as t;
    t.base = base; t.fd = fd; t.width = width; t.height = height;
    t.pitch = pitch; t.bpp = bpp;
    t.cols = (width - 2 * PAD_X) / GLYPH_W; t.rows = (height - 2 * PAD_Y) / GLYPH_H;
    t.cx = 0; t.cy = 0;
    t.fg = 0x00d3d7cf;        // soft light grey (Tango), not harsh pure white
    t.bg = 0x00121417;        // near-black blue-grey, easier on the eyes than #000
    t.present_mode = 1;
    t.d_x0 = 0; t.d_y0 = 0; t.d_x1 = 0; t.d_y1 = 0;
    t.grid = 0; t.grid_stride = 0; t.grid_rows = 0;
    t.live_top = 0; t.hist_count = 0; t.view_off = 0;
    t.esc = 0; t.csi_q = 0; t.csi_n = 0; t.cur_vis = 1; t.want_size = 0;
    t.def_fg = cast(i64, t.fg); t.def_bg = cast(i64, t.bg);
    // clear the whole backbuffer to bg
    let is *u32 as p = cast(*u32, cast(i64, base));
    let is i64 as pw = (pitch * height) / 4;
    let is i64 as i with mut = 0;
    while (i < pw) { p[i] = t.bg; i = i + 1; }
    _mark(&t, 0, 0, width, height);
    return t;
}

// init_buffer — construct a Term over plain memory (a shared segment, not a
// surface): clears the visible w x h region only (the buffer may be a full-
// screen-pitch window sub-rect), never presents (no fd to present on); the
// holder drains take_dirty() and tells its compositor what changed.
fn init_buffer(base as *u8, width as i64, height as i64, pitch as i64, bpp as i64) as Term {
    font.init();
    let is Term as t;
    t.base = base; t.fd = 0 - 1; t.width = width; t.height = height;
    t.pitch = pitch; t.bpp = bpp;
    t.cols = (width - 2 * PAD_X) / GLYPH_W; t.rows = (height - 2 * PAD_Y) / GLYPH_H;
    t.cx = 0; t.cy = 0;
    t.fg = 0x00d3d7cf;
    t.bg = 0x00121417;
    t.present_mode = 0;
    t.d_x0 = 0; t.d_y0 = 0; t.d_x1 = 0; t.d_y1 = 0;
    t.grid = 0; t.grid_stride = 0; t.grid_rows = 0;
    t.live_top = 0; t.hist_count = 0; t.view_off = 0;
    t.esc = 0; t.csi_q = 0; t.csi_n = 0; t.cur_vis = 1; t.want_size = 0;
    t.def_fg = cast(i64, t.fg); t.def_bg = cast(i64, t.bg);
    _fill_bg(&t, width, height);
    _mark(&t, 0, 0, width, height);
    return t;
}

// init_text — construct a Term that keeps NO pixel backbuffer (present_mode 2).
// The glyph rasterisers are inert (they no-op on t.base) and only the cell grid
// is maintained: every putc still updates the grid via _grid_set and accumulates
// a dirty rect via _mark. The holder (wterm) attaches a grid, then on flush
// flattens the visible grid view into a small TEXT segment for the WM to
// rasterise — so a terminal costs (header + cols*rows) i64 instead of a
// full-screen pixel buffer. width/height are in PIXELS (the WM frames the window
// in pixels and 8x16 cells), used only to derive cols/rows the same way init does.
fn init_text(width as i64, height as i64) as Term {
    font.init();
    let is Term as t;
    t.base = cast(*u8, 0); t.fd = 0 - 1; t.width = width; t.height = height;
    t.pitch = 0; t.bpp = 4;
    t.cols = (width - 2 * PAD_X) / GLYPH_W; t.rows = (height - 2 * PAD_Y) / GLYPH_H;
    t.cx = 0; t.cy = 0;
    t.fg = 0x00d3d7cf;
    t.bg = 0x00121417;
    t.present_mode = 2;
    t.d_x0 = 0; t.d_y0 = 0; t.d_x1 = 0; t.d_y1 = 0;
    t.grid = 0; t.grid_stride = 0; t.grid_rows = 0;
    t.live_top = 0; t.hist_count = 0; t.view_off = 0;
    t.esc = 0; t.csi_q = 0; t.csi_n = 0; t.cur_vis = 1; t.want_size = 0;
    t.def_fg = cast(i64, t.fg); t.def_bg = cast(i64, t.bg);
    _mark(&t, 0, 0, width, height);
    return t;
}

// Clear the visible w x h region to bg, row by row (pitch-aware: in windowed
// mode the buffer is wider than the window and the slack is not ours to wipe
// beyond a clean row — staying inside w keeps the write pattern obvious).
fn _fill_bg(t as *Term, w as i64, h as i64) as void {
    if (t.present_mode == 2) { return; }   // TEXT mode: no pixel backbuffer
    let is i64 as y with mut = 0;
    while (y < h) {
        let is *u32 as p = cast(*u32, cast(i64, t.base) + y * t.pitch);
        let is i64 as x with mut = 0;
        while (x < w) { p[x] = t.bg; x = x + 1; }
        y = y + 1;
    }
}

// attach_grid — give the Term a cell-grid backing store so resize() can
// re-render content. `cells` must hold stride * nrows i64 cells. The visible
// grid is clamped to the backing dimensions; the cells are blanked.
fn attach_grid(t as *Term, cells as *i64, stride as i64, nrows as i64) as void {
    t.grid = cast(i64, cells);
    t.grid_stride = stride;
    t.grid_rows = nrows;
    t.live_top = 0;
    t.hist_count = 0;
    t.view_off = 0;
    if (t.cols > stride) { t.cols = stride; }
    if (t.rows > nrows) { t.rows = nrows; }
    let is i64 as blank = _cell_pack(0x20, t.fg, t.bg);
    let is i64 as i with mut = 0;
    let is i64 as total = stride * nrows;
    while (i < total) { cells[i] = blank; i = i + 1; }
}

// Cursor: a thin underline (bottom 2 rows of the cell) in fg. It sits on the
// empty input cell, so painting/erasing the whole cell is safe. putc lifts it
// before moving; flush repaints it after a batch — so it tracks (cx,cy) cleanly.
fn _cursor(t as *Term, on as i64) as void {
    if (t.cur_vis == 0) { return; }       // hidden (CSI ?25l): nothing to draw OR erase
    if (t.view_off != 0) { return; }     // the cursor lives at the live view only
    let is i64 as px = _cellx(t, t.cx);
    let is i64 as py = _celly(t, t.cy);
    let is u32 as color with mut = t.bg;
    if (on != 0) { color = t.fg; }
    let is i64 as ry with mut = GLYPH_H - 2;
    while (ry < GLYPH_H) {
        let is i64 as rx with mut = 0;
        while (rx < GLYPH_W) { _putpix(t, px + rx, py + ry, color); rx = rx + 1; }
        ry = ry + 1;
    }
    _mark(t, px, py + GLYPH_H - 2, GLYPH_W, 2);
}

// ============================================================================
// ANSI / VT escape parser — lets a TUI running INSIDE the terminal address the
// cursor, set colour and clear, instead of grabbing the framebuffer. The
// terminal is the emulator; the app just writes bytes to its stdout.
// ============================================================================

// The 16-colour ANSI palette (Tango, to match the default fg/bg). bright=1
// selects the high-intensity variant (SGR 90-97 / 100-107).
fn _ansi_color(idx as i64, bright as i64) as u32 {
    if (bright == 0) {
        if (idx == 0) { return cast(u32, 0x00000000); }
        if (idx == 1) { return cast(u32, 0x00cc0000); }
        if (idx == 2) { return cast(u32, 0x004e9a06); }
        if (idx == 3) { return cast(u32, 0x00c4a000); }
        if (idx == 4) { return cast(u32, 0x003465a4); }
        if (idx == 5) { return cast(u32, 0x0075507b); }
        if (idx == 6) { return cast(u32, 0x0006989a); }
        return cast(u32, 0x00d3d7cf);
    }
    if (idx == 0) { return cast(u32, 0x00555753); }
    if (idx == 1) { return cast(u32, 0x00ef2929); }
    if (idx == 2) { return cast(u32, 0x008ae234); }
    if (idx == 3) { return cast(u32, 0x00fce94f); }
    if (idx == 4) { return cast(u32, 0x00729fcf); }
    if (idx == 5) { return cast(u32, 0x00ad7fa8); }
    if (idx == 6) { return cast(u32, 0x0034e2e2); }
    return cast(u32, 0x00eeeeec);
}

fn _cube(c as i64) as i64 {
    if (c == 0) { return 0; }
    return 55 + c * 40;
}

// xterm 256-colour index → RGB (16 base + 6x6x6 cube + 24 greys).
fn _xterm256(n as i64) as u32 {
    if (n < 16) {
        if (n >= 8) { return _ansi_color(n - 8, 1); }
        return _ansi_color(n, 0);
    }
    if (n < 232) {
        let is i64 as v = n - 16;
        let is i64 as r = v / 36;
        let is i64 as g = (v / 6) - (v / 36) * 6;
        let is i64 as b = v - (v / 6) * 6;
        return cast(u32, (_cube(r) << 16) | (_cube(g) << 8) | _cube(b));
    }
    let is i64 as gray = 8 + (n - 232) * 10;
    return cast(u32, (gray << 16) | (gray << 8) | gray);
}

fn _clamp_cursor(t as *Term) as void {
    if (t.cx < 0) { t.cx = 0; }
    if (t.cy < 0) { t.cy = 0; }
    if (t.cx >= t.cols) { t.cx = t.cols - 1; }
    if (t.cy >= t.rows) { t.cy = t.rows - 1; }
}

// Erase one cell to the current bg (a space glyph repaints the whole cell).
fn _erase_cell(t as *Term, col as i64, row as i64) as void {
    if (col < 0 || row < 0 || col >= t.cols || row >= t.rows) { return; }
    _glyph(t, 0x20, _cellx(t, col), _celly(t, row));
    _grid_set(t, col, row, 0x20);
}

// CSI J — 0: cursor→end, 1: start→cursor, 2: whole screen.
fn _erase_display(t as *Term, mode as i64) as void {
    let is i64 as r with mut = 0;
    let is i64 as c with mut = 0;
    if (mode == 2) {
        while (r < t.rows) { c = 0; while (c < t.cols) { _erase_cell(t, c, r); c = c + 1; } r = r + 1; }
        return;
    }
    if (mode == 1) {
        while (r < t.cy) { c = 0; while (c < t.cols) { _erase_cell(t, c, r); c = c + 1; } r = r + 1; }
        c = 0; while (c <= t.cx) { _erase_cell(t, c, t.cy); c = c + 1; }
        return;
    }
    c = t.cx; while (c < t.cols) { _erase_cell(t, c, t.cy); c = c + 1; }
    r = t.cy + 1;
    while (r < t.rows) { c = 0; while (c < t.cols) { _erase_cell(t, c, r); c = c + 1; } r = r + 1; }
}

// CSI K — 0: cursor→eol, 1: bol→cursor, 2: whole line.
fn _erase_line(t as *Term, mode as i64) as void {
    let is i64 as c0 with mut = 0;
    let is i64 as c1 with mut = t.cols;
    if (mode == 0) { c0 = t.cx; }
    if (mode == 1) { c1 = t.cx + 1; }
    let is i64 as c with mut = c0;
    while (c < c1) { _erase_cell(t, c, t.cy); c = c + 1; }
}

// CSI m — Select Graphic Rendition: 0 reset, 30-37/90-97 fg, 40-47/100-107 bg,
// 38/48;2;r;g;b truecolor, 38/48;5;n 256-colour, 39/49 default fg/bg.
fn _sgr(t as *Term) as void {
    let is i64 as n = t.csi_n + 1;
    let is i64 as i with mut = 0;
    while (i < n) {
        let is i64 as code = _csi_p[i];
        if (code == 0) { t.fg = cast(u32, t.def_fg); t.bg = cast(u32, t.def_bg); }
        else if (code == 39) { t.fg = cast(u32, t.def_fg); }
        else if (code == 49) { t.bg = cast(u32, t.def_bg); }
        else if (code >= 30 && code <= 37) { t.fg = _ansi_color(code - 30, 0); }
        else if (code >= 40 && code <= 47) { t.bg = _ansi_color(code - 40, 0); }
        else if (code >= 90 && code <= 97) { t.fg = _ansi_color(code - 90, 1); }
        else if (code >= 100 && code <= 107) { t.bg = _ansi_color(code - 100, 1); }
        else if (code == 38 || code == 48) {
            let is i64 as kind with mut = 0;
            if (code == 48) { kind = 1; }
            if (i + 1 < n) {
                if (_csi_p[i + 1] == 2 && i + 4 < n) {
                    let is u32 as col = cast(u32, (_csi_p[i + 2] << 16) | (_csi_p[i + 3] << 8) | _csi_p[i + 4]);
                    if (kind == 0) { t.fg = col; } else { t.bg = col; }
                    i = i + 4;
                } else if (_csi_p[i + 1] == 5 && i + 2 < n) {
                    let is u32 as col = _xterm256(_csi_p[i + 2]);
                    if (kind == 0) { t.fg = col; } else { t.bg = col; }
                    i = i + 2;
                }
            }
        }
        i = i + 1;
    }
}

// Dispatch a complete CSI sequence on its final byte. Cursor moves lift the
// drawn cursor first (flush repaints it); colours/erase use the live fg/bg.
fn _csi_dispatch(t as *Term, final as i64) as void {
    let is i64 as p0 = _csi_p[0];
    let is i64 as p1 = _csi_p[1];
    if (final == 0x48 || final == 0x66) {                    // 'H'/'f' position
        _cursor(t, 0);
        let is i64 as r with mut = p0; if (r < 1) { r = 1; }
        let is i64 as c with mut = p1; if (c < 1) { c = 1; }
        t.cy = r - 1; t.cx = c - 1; _clamp_cursor(t); return;
    }
    if (final == 0x41) { _cursor(t, 0); let is i64 as n with mut = p0; if (n < 1) { n = 1; } t.cy = t.cy - n; _clamp_cursor(t); return; }  // 'A' up
    if (final == 0x42) { _cursor(t, 0); let is i64 as n with mut = p0; if (n < 1) { n = 1; } t.cy = t.cy + n; _clamp_cursor(t); return; }  // 'B' down
    if (final == 0x43) { _cursor(t, 0); let is i64 as n with mut = p0; if (n < 1) { n = 1; } t.cx = t.cx + n; _clamp_cursor(t); return; }  // 'C' right
    if (final == 0x44) { _cursor(t, 0); let is i64 as n with mut = p0; if (n < 1) { n = 1; } t.cx = t.cx - n; _clamp_cursor(t); return; }  // 'D' left
    if (final == 0x47) { _cursor(t, 0); let is i64 as c with mut = p0; if (c < 1) { c = 1; } t.cx = c - 1; _clamp_cursor(t); return; }     // 'G' column
    if (final == 0x64) { _cursor(t, 0); let is i64 as r with mut = p0; if (r < 1) { r = 1; } t.cy = r - 1; _clamp_cursor(t); return; }     // 'd' row
    if (final == 0x4A) { _cursor(t, 0); _erase_display(t, p0); return; }   // 'J'
    if (final == 0x4B) { _cursor(t, 0); _erase_line(t, p0); return; }      // 'K'
    if (final == 0x6D) { _sgr(t); return; }                               // 'm' SGR
    if (final == 0x6C) { if (t.csi_q == 1 && p0 == 25) { _cursor(t, 0); t.cur_vis = 0; } return; }  // 'l' ?25l: erase, then hide
    if (final == 0x68) { if (t.csi_q == 1 && p0 == 25) { t.cur_vis = 1; } return; }  // 'h' ?25h
    if (final == 0x74) { if (p0 == 18) { t.want_size = 1; } return; }      // 't' 18t size report
}

// Feed one byte to the escape parser (called by putc when t.esc != 0).
fn _esc_feed(t as *Term, ch as i64) as void {
    if (t.esc == 1) {                            // just saw ESC
        if (ch == 0x5B) {                        // '[' → CSI
            t.esc = 2; t.csi_q = 0; t.csi_n = 0;
            let is i64 as i with mut = 0;
            while (i < 16) { _csi_p[i] = 0; i = i + 1; }
            return;
        }
        t.esc = 0; return;                       // ESC + other: not handled
    }
    // t.esc == 2: collecting a CSI sequence
    if (ch >= 0x30 && ch <= 0x39) { _csi_p[t.csi_n] = _csi_p[t.csi_n] * 10 + (ch - 0x30); return; }
    if (ch == 0x3B) { if (t.csi_n < 15) { t.csi_n = t.csi_n + 1; } return; }   // ';'
    if (ch == 0x3F) { t.csi_q = 1; return; }                                  // '?'
    if (ch >= 0x40 && ch <= 0x7E) { _csi_dispatch(t, ch); t.esc = 0; return; }  // final byte
    // intermediates (0x20-0x2F) and stray bytes: stay in CSI
}

fn putc(t as *Term, ch as i64) as void {
    if (t.esc != 0) { _esc_feed(t, ch); return; }
    if (ch == 0x1B) { t.esc = 1; return; }                   // ESC begins a sequence
    if (t.view_off != 0) {                                   // output snaps back to live
        t.view_off = 0;
        _repaint_view(t);
    }
    _cursor(t, 0);                                           // lift the cursor before moving/writing
    if (ch == 0x0A) { _newline(t); return; }                 // \n
    if (ch == 0x0D) { t.cx = 0; return; }                    // \r
    if (ch == 0x0C) { clear(t); return; }                    // \f form feed → clear + home
    if (ch == 0x08) {                                        // backspace
        if (t.cx > 0) {
            t.cx = t.cx - 1;
            _glyph(t, 0x20, _cellx(t, t.cx), _celly(t, t.cy));
            _grid_set(t, t.cx, t.cy, 0x20);
        }
        return;
    }
    if (ch == 0x09) {                                        // tab → 4 spaces
        let is i64 as k with mut = 0;
        while (k < 4) { putc(t, 0x20); k = k + 1; }
        return;
    }
    _glyph(t, ch, _cellx(t, t.cx), _celly(t, t.cy));
    _grid_set(t, t.cx, t.cy, ch);
    t.cx = t.cx + 1;
    if (t.cx >= t.cols) { _newline(t); }
}

fn puts(t as *Term, s as *u8, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) { putc(t, cast(i64, s[i])); i = i + 1; }
}

// flush — paint the cursor, then (fullscreen mode) publish to the scanout.
// In render-only mode (init_buffer) presenting is the holder's job: it drains
// take_dirty() and routes the rect to its compositor instead.
fn flush(t as *Term) as void {
    if (t.cur_vis != 0) { _cursor(t, 1); }       // a TUI hides it via CSI ?25l
    if (t.present_mode == 1) {
        cos.present(t.fd, 0, 0, t.width, t.height);
    }
}

// set_color — change fg/bg for subsequent glyphs (the shell uses this to colour
// the prompt green, errors red, etc.).
fn set_color(t as *Term, fg as u32, bg as u32) as void {
    t.fg = fg; t.bg = bg;
}

// clear — wipe the visible region to bg and home the cursor (the shell's
// `clear`). Pitch-aware row fill so windowed buffers only touch their rect.
fn clear(t as *Term) as void {
    _fill_bg(t, t.width, t.height);
    if (t.grid != 0) {
        let is *i64 as g = cast(*i64, t.grid);
        let is i64 as blank = _cell_pack(0x20, t.fg, t.bg);
        let is i64 as i with mut = 0;
        let is i64 as total = t.grid_stride * t.grid_rows;
        while (i < total) { g[i] = blank; i = i + 1; }
        t.live_top = 0;
        t.hist_count = 0;
        t.view_off = 0;
    }
    t.cx = 0; t.cy = 0;
    _mark(t, 0, 0, t.width, t.height);
    flush(t);
}

// resize — re-lay the terminal out over a new w x h inside the SAME buffer
// (the buffer is allocated full-screen once; pitch never changes). Lines do
// not re-wrap: each grid row maps to the same row, truncated to the new
// width. The view anchors at the BOTTOM — if the cursor row would fall off,
// the grid shifts up so the prompt stays visible. Requires an attached grid
// to re-render content; without one the screen is cleared (documented: a
// grid is what makes content survive a resize).
fn resize(t as *Term, new_w as i64, new_h as i64) as void {
    let is i64 as new_cols with mut = (new_w - 2 * PAD_X) / GLYPH_W;
    let is i64 as new_rows with mut = (new_h - 2 * PAD_Y) / GLYPH_H;
    if (new_cols < 1) { new_cols = 1; }
    if (new_rows < 1) { new_rows = 1; }
    if (t.grid != 0) {
        if (new_cols > t.grid_stride) { new_cols = t.grid_stride; }
        if (new_rows > t.grid_rows) { new_rows = t.grid_rows; }
        t.view_off = 0;                              // a resize snaps to live
        // bottom anchor: lines pushed off the top become HISTORY (the ring
        // just advances — nothing is copied or lost)
        if (t.cy >= new_rows) {
            let is i64 as shift = t.cy - new_rows + 1;
            let is i64 as p = t.live_top + shift;
            t.live_top = p - (p / t.grid_rows) * t.grid_rows;
            t.hist_count = t.hist_count + shift;
            t.cy = new_rows - 1;
        }
        // growing: physical rows entering at the bottom may hold recycled
        // ancient ring lines — blank them
        if (new_rows > t.rows) {
            let is i64 as r with mut = t.rows;
            while (r < new_rows) {
                let is i64 as q = t.live_top + r;
                _grid_blank_phys(t, q - (q / t.grid_rows) * t.grid_rows);
                r = r + 1;
            }
        }
        let is i64 as hmax = t.grid_rows - new_rows;
        if (t.hist_count > hmax) { t.hist_count = hmax; }
    } else {
        if (t.cy >= new_rows) { t.cy = new_rows - 1; }
    }
    if (t.cx >= new_cols) { t.cx = new_cols - 1; }
    t.width = new_w; t.height = new_h;
    t.cols = new_cols; t.rows = new_rows;
    _repaint_view(t);
}
