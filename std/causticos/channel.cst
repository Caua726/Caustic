// std/causticos/channel.cst — CausticOS IPC channel facade.
//
// CausticOS-ONLY. channel_create mints a connected bidirectional pair; you keep
// one endpoint fd and hand the other to a child at spawn (via fdacts). read /
// write / close on an endpoint are the ordinary fd ops (a channel fd is just a
// KObject) — `send`/`recv`/`close` below are thin aliases. The kernel does NO
// framing: a record protocol (e.g. length-prefix) is the caller's policy.
// Import only from `--target=caustic-x86_64` programs.
use "../os/causticos.cst" as cos;

struct Channel {
    a  as i64;   // endpoint fd A (keep)
    b  as i64;   // endpoint fd B (typically handed to a child)
    ok as i64;   // 1 if create() succeeded
}

// create — mint a connected pair. ch.ok == 0 on failure.
fn create() as Channel {
    if (__target_is_caustic == 0) { __compile_error("std/causticos/channel is CausticOS-only — build with --target=caustic-x86_64"); }
    let is Channel as ch;
    ch.a = 0 - 1; ch.b = 0 - 1; ch.ok = 0;
    let is [2]i64 as fds;
    if (cos.channel_create(cast(*i64, &fds[0])) == 0) {
        ch.a = fds[0];
        ch.b = fds[1];
        ch.ok = 1;
    }
    return ch;
}

// send / recv / close — an endpoint fd is just a KObject, so these ride the
// ordinary read/write/close. recv returns 0 at EOF (peer closed); send returns
// E_PIPE (-16) if the peer closed.
fn send(fd as i64, buf as *u8, n as i64) as i64 { return cos.write(fd, buf, n); }
fn recv(fd as i64, buf as *u8, n as i64) as i64 { return cos.read(fd, buf, n); }
fn close(fd as i64) as i32 { return cos.close(fd); }
