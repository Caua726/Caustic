// =======================================================
// std/net/linux.cst — Portable network backend, Linux impl
//
// init/cleanup are no-ops; sockets are file descriptors handled by
// std/linux.cst syscall wrappers.
// =======================================================

use "../os/linux.cst" as linux;

fn init() as i32 { return 0; }
fn cleanup() as i32 { return 0; }

fn tcp_socket() as i64 {
    return linux.socket(linux.AF_INET, linux.SOCK_STREAM, 0);
}

fn udp_socket() as i64 {
    return linux.socket(linux.AF_INET, 2, 0);   // SOCK_DGRAM
}

fn close_socket(s as i64) as i32 {
    return cast(i32, linux.close(s));
}
