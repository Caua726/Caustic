// =======================================================
// std/net/windows.cst — Portable network backend, Windows impl
//
// User MUST call net.init() once at the start of main before using any
// other function here. This invokes WSAStartup which is mandatory before
// any ws2_32 socket call. Mirror call to net.cleanup() at exit is
// optional (process tear-down releases winsock resources anyway).
//
// WSAStartup version word is little-endian (low byte major, high byte
// minor). Request 2.2 → 0x0202.
// =======================================================

use "../os/windows.cst" as win;

let is i32 as _wsa_inited with mut = 0;
let is [408]u8 as _wsa_data;        // WSADATA layout: 408 bytes
let is u32 as _WSA_VERSION_22 with imut = 514;   // 0x0202

fn init() as i32 {
    if (_wsa_inited == 1) { return 0; }
    let is i32 as rc = win.WSAStartup(_WSA_VERSION_22, &_wsa_data);
    if (rc == 0) { _wsa_inited = 1; }
    return rc;
}

fn cleanup() as i32 {
    if (_wsa_inited == 0) { return 0; }
    let is i32 as rc = win.WSACleanup();
    _wsa_inited = 0;
    return rc;
}

fn tcp_socket() as i64 {
    return win.WSASocketA(win.W_AF_INET, win.W_SOCK_STREAM, win.W_IPPROTO_TCP,
                          cast(*u8, 0), 0, 0);
}

fn udp_socket() as i64 {
    return win.WSASocketA(win.W_AF_INET, win.W_SOCK_DGRAM, win.W_IPPROTO_UDP,
                          cast(*u8, 0), 0, 0);
}

fn close_socket(s as i64) as i32 {
    return win.closesocket(s);
}
