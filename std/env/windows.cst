// =======================================================
// std/env/windows.cst — Portable env backend, Windows impl
//
// argc/argv arrive in main(rdi=argc, rsi=argv) thanks to the entry stub's
// __caustic_parse_argv (see caustic-linker/pe_writer.cst:613). Caller pattern
// matches Linux verbatim:
//   fn main(argc as i64, argv as *u8) as i32 {
//       env.init(argc, argv);
//       ...
//   }
//
// Environment variables go through GetEnvironmentVariableA — there's no
// flat envp[] block on Windows, so getenv() copies the value into a
// fixed scratch buffer (caller copies further out if it needs to retain
// across subsequent getenv calls).
// =======================================================

use "../os/windows.cst" as win;

let is i64 as _argc with mut = 0;
let is *u8 as _argv with mut;

fn init(argc as i64, argv as *u8) as void {
    _argc = argc;
    _argv = argv;
}

fn argc() as i64 { return _argc; }

fn argv(index as i64) as *u8 {
    if (index < 0 || index >= _argc) { return cast(*u8, 0); }
    let is *i64 as ptrs = cast(*i64, _argv);
    return cast(*u8, ptrs[index]);
}

// Scratch buffer reused across getenv() calls. Callers that need to keep
// the result alive must copy it out before the next call.
let is [4096]u8 as _env_scratch;

fn getenv(name as *u8) as *u8 {
    let is u32 as got = win.GetEnvironmentVariableA(name, &_env_scratch, 4096);
    if (got == 0) { return cast(*u8, 0); }
    if (got >= 4096) { return cast(*u8, 0); }  // truncated — refuse
    return &_env_scratch;
}
