use "mem.cst" only bins, core as mem;
use "linux.cst" as linux;

let is mem.Bins as _bins with mut;
let is i32 as _ready with mut = 0;

fn _alloc(size as i64) as *u8 {
    if (_ready == 0) { _bins = mem.bins.bins_new(16384); _ready = 1; }
    return mem.bins.bins_alloc(&_bins, size);
}

fn _free(ptr as *u8) as void {
    if (_ready == 1) { mem.bins.bins_free(&_bins, ptr); }
}

struct Slice gen T {
    ptr as *T;
    len as i32;
    cap as i32;
}

fn slice_new gen T (cap as i32) as Slice gen T {
    let is Slice gen T as s;
    if (cap > 0) {
        s.ptr = cast(*T, _alloc(cast(i64, cap) * sizeof(T)));
    } else {
        s.ptr = cast(*T, 0);
    }
    s.len = 0;
    s.cap = cap;
    return s;
}

impl Slice gen T {
    fn push(self as *Slice gen T, val as T) as void {
        if (self.len >= self.cap) {
            let is i32 as new_cap with mut = self.cap * 2;
            if (new_cap <= self.cap) { new_cap = self.cap + 1; }
            if (new_cap < 4) { new_cap = 4; }
            let is *T as new_ptr = cast(*T, _alloc(cast(i64, new_cap) * sizeof(T)));
            if (cast(i64, new_ptr) == 0) {
                linux.write(linux.STDERR, "slice: out of memory\n", 21);
                linux.exit(1);
            }
            if (self.len > 0) {
                mem.core.memcpy(cast(*u8, new_ptr), cast(*u8, self.ptr), cast(i64, self.len) * sizeof(T));
            }
            if (cast(i64, self.ptr) != 0) {
                _free(cast(*u8, self.ptr));
            }
            self.ptr = new_ptr;
            self.cap = new_cap;
        }
        self.ptr[self.len] = val;
        self.len = self.len + 1;
    }

    fn get(self as *Slice gen T, idx as i32) as T {
        if (idx < 0 || idx >= self.len) {
            linux.write(linux.STDERR, "slice: index out of bounds\n", 27);
            linux.exit(1);
        }
        return self.ptr[idx];
    }

    fn set(self as *Slice gen T, idx as i32, val as T) as void {
        if (idx < 0 || idx >= self.len) {
            linux.write(linux.STDERR, "slice: index out of bounds\n", 27);
            linux.exit(1);
        }
        self.ptr[idx] = val;
    }

    fn pop(self as *Slice gen T) as T {
        if (self.len <= 0) {
            linux.write(linux.STDERR, "slice: pop on empty\n", 21);
            linux.exit(1);
        }
        self.len = self.len - 1;
        return self.ptr[self.len];
    }

    fn free(self as *Slice gen T) as void {
        if (cast(i64, self.ptr) != 0) {
            _free(cast(*u8, self.ptr));
            self.ptr = cast(*T, 0);
        }
        self.len = 0;
        self.cap = 0;
    }

    // Reset length to 0 without freeing memory (reuse buffer)
    fn clear(self as *Slice gen T) as void {
        self.len = 0;
    }

    // Number of elements
    fn length(self as *Slice gen T) as i32 {
        return self.len;
    }

    // Is the slice empty?
    fn is_empty(self as *Slice gen T) as i32 {
        if (self.len == 0) { return 1; }
        return 0;
    }

    // Get first element. Aborts if empty.
    fn first(self as *Slice gen T) as T {
        if (self.len <= 0) {
            linux.write(linux.STDERR, "slice: first on empty\n", 22);
            linux.exit(1);
        }
        return self.ptr[0];
    }

    // Get last element. Aborts if empty.
    fn last(self as *Slice gen T) as T {
        if (self.len <= 0) {
            linux.write(linux.STDERR, "slice: last on empty\n", 21);
            linux.exit(1);
        }
        return self.ptr[self.len - 1];
    }

    // Reverse in-place
    fn reverse(self as *Slice gen T) as void {
        let is i32 as lo with mut = 0;
        let is i32 as hi with mut = self.len - 1;
        while (lo < hi) {
            let is T as tmp = self.ptr[lo];
            self.ptr[lo] = self.ptr[hi];
            self.ptr[hi] = tmp;
            lo = lo + 1;
            hi = hi - 1;
        }
    }

    // Insert at index, shifting elements right. Aborts if out of bounds.
    fn insert(self as *Slice gen T, idx as i32, val as T) as void {
        if (idx < 0 || idx > self.len) {
            linux.write(linux.STDERR, "slice: insert out of bounds\n", 28);
            linux.exit(1);
        }
        // Ensure capacity (push a dummy then shift)
        self.push(val); // grows if needed, puts val at end
        // Shift elements from idx..len-2 to idx+1..len-1
        let is i32 as i with mut = self.len - 1;
        while (i > idx) {
            self.ptr[i] = self.ptr[i - 1];
            i = i - 1;
        }
        self.ptr[idx] = val;
    }

    // Remove element at index, shifting elements left. Aborts if out of bounds.
    fn remove_at(self as *Slice gen T, idx as i32) as T {
        if (idx < 0 || idx >= self.len) {
            linux.write(linux.STDERR, "slice: remove out of bounds\n", 28);
            linux.exit(1);
        }
        let is T as removed = self.ptr[idx];
        let is i32 as i with mut = idx;
        while (i < self.len - 1) {
            self.ptr[i] = self.ptr[i + 1];
            i = i + 1;
        }
        self.len = self.len - 1;
        return removed;
    }

    // Swap two elements by index
    fn swap(self as *Slice gen T, a as i32, b as i32) as void {
        if (a < 0 || a >= self.len || b < 0 || b >= self.len) {
            linux.write(linux.STDERR, "slice: swap out of bounds\n", 26);
            linux.exit(1);
        }
        let is T as tmp = self.ptr[a];
        self.ptr[a] = self.ptr[b];
        self.ptr[b] = tmp;
    }

    // Clone — deep copy, allocates new buffer
    fn clone(self as *Slice gen T) as Slice gen T {
        let is Slice gen T as copy;
        copy.len = self.len;
        copy.cap = self.len;
        if (self.len > 0) {
            copy.ptr = cast(*T, _alloc(cast(i64, self.len) * sizeof(T)));
            mem.core.memcpy(cast(*u8, copy.ptr), cast(*u8, self.ptr), cast(i64, self.len) * sizeof(T));
        } else {
            copy.ptr = cast(*T, 0);
        }
        return copy;
    }

    // Ensure capacity is at least min_cap without changing length
    fn reserve(self as *Slice gen T, min_cap as i32) as void {
        if (min_cap <= self.cap) { return; }
        let is *T as new_ptr = cast(*T, _alloc(cast(i64, min_cap) * sizeof(T)));
        if (cast(i64, new_ptr) == 0) {
            linux.write(linux.STDERR, "slice: out of memory\n", 21);
            linux.exit(1);
        }
        if (self.len > 0) {
            mem.core.memcpy(cast(*u8, new_ptr), cast(*u8, self.ptr), cast(i64, self.len) * sizeof(T));
        }
        if (cast(i64, self.ptr) != 0) {
            _free(cast(*u8, self.ptr));
        }
        self.ptr = new_ptr;
        self.cap = min_cap;
    }

    // Truncate to new_len (does nothing if new_len >= len)
    fn truncate(self as *Slice gen T, new_len as i32) as void {
        if (new_len < 0) { new_len = 0; }
        if (new_len < self.len) {
            self.len = new_len;
        }
    }
}
