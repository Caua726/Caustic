// =======================================================
// std/time/linux.cst — Portable time backend, Linux impl
// =======================================================

use "../os/linux.cst" as linux;

// timespec layout matches Linux kernel: { tv_sec as i64, tv_nsec as i64 }.
fn now_ns() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_MONOTONIC, &ts);
    let is *i64 as sec = cast(*i64, &ts);
    let is *i64 as nsec = cast(*i64, cast(i64, &ts) + 8);
    return *sec * 1000000000 + *nsec;
}

fn unix_time_ms() as i64 {
    let is [16]u8 as ts;
    linux.clock_gettime(linux.CLOCK_REALTIME, &ts);
    let is *i64 as sec = cast(*i64, &ts);
    let is *i64 as nsec = cast(*i64, cast(i64, &ts) + 8);
    return *sec * 1000 + *nsec / 1000000;
}

fn sleep_ms(ms as i64) as void {
    let is [16]u8 as ts;
    let is *i64 as sec = cast(*i64, &ts);
    let is *i64 as nsec = cast(*i64, cast(i64, &ts) + 8);
    *sec = ms / 1000;
    *nsec = (ms % 1000) * 1000000;
    linux.nanosleep(&ts, cast(*u8, 0));
}
