// =======================================================
// std/time/wasm.cst — time backend, WASI impl
//
// Monotonic + wall clock come straight from WASI clock_time_get (which returns
// nanoseconds). WASI has no simple sleep primitive (poll_oneoff needs
// subscription structs), so sleep_ms busy-waits on the monotonic clock — fine
// for the single-threaded wasm model, if not power-efficient.
// =======================================================

use "../os/wasm.cst" as wasi;

// Monotonic nanoseconds (arbitrary origin) — for elapsed-time measurement.
fn now_ns() as i64 { return wasi.now_ns(); }

// Wall-clock milliseconds since the Unix epoch.
fn unix_time_ms() as i64 { return wasi.unix_time_ms(); }

// Busy-wait `ms` milliseconds against the monotonic clock.
fn sleep_ms(ms as i64) as void {
    if (ms <= 0) { return; }
    let is i64 as deadline = wasi.now_ns() + ms * 1000000;
    while (wasi.now_ns() < deadline) { }
}
