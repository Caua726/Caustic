// =======================================================
// std/time/windows.cst — Portable time backend, Windows impl
//
// QPC frequency is cached on first call to now_ns(). QPC is ticks since
// boot at QPF Hz; convert to ns by ticks * 1e9 / freq (carefully to avoid
// overflow on 64-bit math: split into seconds + remainder).
//
// Wall-clock uses GetSystemTimeAsFileTime (100ns since 1601-01-01 UTC).
// FILETIME_TO_UNIX_NS offset: 11644473600 seconds * 1e9 ns/s.
// =======================================================

use "../os/windows.cst" as win;

let is i64 as _qpf with mut = 0;
let is i64 as FILETIME_TO_UNIX_100NS with imut = 116444736000000000;

fn _ensure_qpf() as i64 {
    if (_qpf == 0) { win.QueryPerformanceFrequency(&_qpf); }
    return _qpf;
}

fn now_ns() as i64 {
    let is i64 as qpf = _ensure_qpf();
    let is i64 as ticks with mut = 0;
    win.QueryPerformanceCounter(&ticks);
    let is i64 as secs = ticks / qpf;
    let is i64 as rem  = ticks % qpf;
    return secs * 1000000000 + rem * 1000000000 / qpf;
}

fn unix_time_ms() as i64 {
    let is i64 as ft with mut = 0;
    win.GetSystemTimeAsFileTime(&ft);
    return (ft - FILETIME_TO_UNIX_100NS) / 10000;
}

fn sleep_ms(ms as i64) as void {
    win.Sleep(cast(u32, ms));
}
