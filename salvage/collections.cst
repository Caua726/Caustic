use "mem.cst" as mem;
use "linux.cst" as linux;

// ============================================================================
// Result Type - Error handling sem exceptions
// ============================================================================

struct Result {
    ok as i32;      // 1 = sucesso, 0 = erro
    value as i64;   // valor ou codigo de erro
    msg as *u8;     // mensagem de erro (opcional)
}

fn Result_ok(val as i64) as Result {
    let is Result as r;
    r.ok = 1;
    r.value = val;
    r.msg = cast(*u8, 0);
    return r;
}

fn Result_err(code as i64, msg as *u8) as Result {
    let is Result as r;
    r.ok = 0;
    r.value = code;
    r.msg = msg;
    return r;
}

fn is_ok(r as *Result) as i32 {
    return r.ok;
}

fn is_err(r as *Result) as i32 {
    if (r.ok == 0) { return 1; }
    return 0;
}

fn unwrap(r as *Result) as i64 {
    if (r.ok == 0) {
        linux.write(linux.STDERR, "panic: unwrap on error\n", 23);
        linux.exit(cast(i32, 1));
    }
    return r.value;
}

fn unwrap_or(r as *Result, default_val as i64) as i64 {
    if (r.ok == 0) {
        return default_val;
    }
    return r.value;
}

// ============================================================================
// Callback Pattern - Closures sem GC
// ============================================================================

struct Callback {
    fn_ptr as *u8;  // ponteiro para funcao
    ctx as *u8;     // contexto do usuario
}

fn Callback_new(fn_ptr as *u8, ctx as *u8) as Callback {
    let is Callback as cb;
    cb.fn_ptr = fn_ptr;
    cb.ctx = ctx;
    return cb;
}

fn Callback_empty() as Callback {
    let is Callback as cb;
    cb.fn_ptr = cast(*u8, 0);
    cb.ctx = cast(*u8, 0);
    return cb;
}

fn Callback_is_valid(cb as *Callback) as i32 {
    if (cast(i64, cb.fn_ptr) != 0) { return 1; }
    return 0;
}

// ============================================================================
// Vec - Array Dinamico
// ============================================================================

struct Vec {
    data as *u8;
    len as i64;
    cap as i64;
    elem_size as i64;
}

fn Vec_new(elem_size as i64) as Vec {
    let is Vec as v;
    v.data = cast(*u8, 0);
    v.len = 0;
    v.cap = 0;
    v.elem_size = elem_size;
    return v;
}

fn Vec_with_capacity(elem_size as i64, cap as i64) as Vec {
    let is Vec as v;
    v.elem_size = elem_size;
    v.len = 0;
    v.cap = cap;
    v.data = mem.galloc(cap * elem_size);
    return v;
}

fn Vec_push(v as *Vec, elem as *u8) as void {
    if (v.len >= v.cap) {
        let is i64 as new_cap with mut = v.cap * 2;
        if (new_cap == 0) { new_cap = 8; }
        let is *u8 as new_data = mem.galloc(new_cap * v.elem_size);
        if (v.len > 0) {
            mem.memcpy(new_data, v.data, v.len * v.elem_size);
        }
        if (cast(i64, v.data) != 0) {
            mem.gfree(v.data);
        }
        v.data = new_data;
        v.cap = new_cap;
    }
    let is i64 as offset = v.len * v.elem_size;
    mem.memcpy(v.data + offset, elem, v.elem_size);
    v.len = v.len + 1;
}

fn Vec_push_i64(v as *Vec, val as i64) as void {
    let is i64 as tmp = val;
    Vec_push(v, cast(*u8, &tmp));
}

fn Vec_push_i32(v as *Vec, val as i32) as void {
    let is i32 as tmp = val;
    Vec_push(v, cast(*u8, &tmp));
}

fn Vec_push_ptr(v as *Vec, ptr as *u8) as void {
    let is *u8 as tmp = ptr;
    Vec_push(v, cast(*u8, &tmp));
}

fn Vec_get(v as *Vec, index as i64) as *u8 {
    if (index < 0) { return cast(*u8, 0); }
    if (index >= v.len) { return cast(*u8, 0); }
    return v.data + (index * v.elem_size);
}

fn Vec_get_i64(v as *Vec, index as i64) as i64 {
    let is *u8 as ptr = Vec_get(v, index);
    if (cast(i64, ptr) == 0) { return 0; }
    return *cast(*i64, ptr);
}

fn Vec_get_i32(v as *Vec, index as i64) as i32 {
    let is *u8 as ptr = Vec_get(v, index);
    if (cast(i64, ptr) == 0) { return cast(i32, 0); }
    return *cast(*i32, ptr);
}

fn Vec_get_ptr(v as *Vec, index as i64) as *u8 {
    let is *u8 as ptr = Vec_get(v, index);
    if (cast(i64, ptr) == 0) { return cast(*u8, 0); }
    return *cast(**u8, ptr);
}

fn Vec_set(v as *Vec, index as i64, elem as *u8) as void {
    if (index < 0) { return; }
    if (index >= v.len) { return; }
    let is i64 as offset = index * v.elem_size;
    mem.memcpy(v.data + offset, elem, v.elem_size);
}

fn Vec_pop(v as *Vec) as *u8 {
    if (v.len == 0) { return cast(*u8, 0); }
    v.len = v.len - 1;
    return v.data + (v.len * v.elem_size);
}

fn Vec_len(v as *Vec) as i64 {
    return v.len;
}

fn Vec_cap(v as *Vec) as i64 {
    return v.cap;
}

fn Vec_is_empty(v as *Vec) as i32 {
    if (v.len == 0) { return 1; }
    return 0;
}

fn Vec_clear(v as *Vec) as void {
    v.len = 0;
}

fn Vec_free(v as *Vec) as void {
    if (cast(i64, v.data) != 0) {
        mem.gfree(v.data);
    }
    v.data = cast(*u8, 0);
    v.len = 0;
    v.cap = 0;
}

// ============================================================================
// HashMap - Tabela hash com chaining
// ============================================================================

struct HashEntry {
    key as *u8;
    key_len as i64;
    value as *u8;
    value_len as i64;
    next as *HashEntry;
}

struct HashMap {
    buckets as *u8;  // na verdade **HashEntry, mas caustic nao suporta
    num_buckets as i64;
    count as i64;
}

fn hash_bytes(data as *u8, len as i64) as i64 {
    // DJB2 hash (mais simples, funciona bem)
    let is i64 as hash with mut = 5381;
    let is i64 as i with mut = 0;
    while (i < len) {
        // hash = hash * 33 + c
        hash = ((hash * 32) + hash) + cast(i64, data[i]);
        i = i + 1;
    }
    return hash;
}

fn HashMap_new(num_buckets as i64) as HashMap {
    let is HashMap as m;
    m.num_buckets = num_buckets;
    m.count = 0;
    let is i64 as size = num_buckets * 8;
    m.buckets = mem.galloc(size);
    mem.memset(m.buckets, cast(i32, 0), size);
    return m;
}

fn HashMap_get_bucket(m as *HashMap, idx as i64) as *HashEntry {
    let is **HashEntry as buckets = cast(**HashEntry, m.buckets);
    return buckets[idx];
}

fn HashMap_set_bucket(m as *HashMap, idx as i64, entry as *HashEntry) as void {
    let is **HashEntry as buckets = cast(**HashEntry, m.buckets);
    buckets[idx] = entry;
}

fn HashMap_put(m as *HashMap, key as *u8, key_len as i64, val as *u8, val_len as i64) as void {
    let is i64 as h = hash_bytes(key, key_len);
    let is i64 as idx with mut = h % m.num_buckets;
    if (idx < 0) { idx = 0 - idx; }

    // Verificar se key ja existe
    let is *HashEntry as existing with mut = HashMap_get_bucket(m, idx);
    while (cast(i64, existing) != 0) {
        if (existing.key_len == key_len) {
            if (mem.memcmp(existing.key, key, key_len) == 0) {
                // Atualizar valor existente
                mem.gfree(existing.value);
                existing.value = mem.galloc(val_len);
                mem.memcpy(existing.value, val, val_len);
                existing.value_len = val_len;
                return;
            }
        }
        existing = existing.next;
    }

    // Criar nova entry
    let is *HashEntry as entry = cast(*HashEntry, mem.galloc(sizeof(HashEntry)));
    entry.key = mem.galloc(key_len);
    mem.memcpy(entry.key, key, key_len);
    entry.key_len = key_len;
    entry.value = mem.galloc(val_len);
    mem.memcpy(entry.value, val, val_len);
    entry.value_len = val_len;

    // Insert at head of bucket
    entry.next = HashMap_get_bucket(m, idx);
    HashMap_set_bucket(m, idx, entry);
    m.count = m.count + 1;
}

fn HashMap_get(m as *HashMap, key as *u8, key_len as i64) as *u8 {
    let is i64 as h = hash_bytes(key, key_len);
    let is i64 as idx with mut = h % m.num_buckets;
    if (idx < 0) { idx = 0 - idx; }

    let is *HashEntry as entry with mut = HashMap_get_bucket(m, idx);
    while (cast(i64, entry) != 0) {
        if (entry.key_len == key_len) {
            if (mem.memcmp(entry.key, key, key_len) == 0) {
                return entry.value;
            }
        }
        entry = entry.next;
    }
    return cast(*u8, 0);
}

fn HashMap_contains(m as *HashMap, key as *u8, key_len as i64) as i32 {
    let is *u8 as val = HashMap_get(m, key, key_len);
    if (cast(i64, val) != 0) { return 1; }
    return 0;
}

fn HashMap_remove(m as *HashMap, key as *u8, key_len as i64) as i32 {
    let is i64 as h = hash_bytes(key, key_len);
    let is i64 as idx with mut = h % m.num_buckets;
    if (idx < 0) { idx = 0 - idx; }

    let is *HashEntry as prev with mut = cast(*HashEntry, 0);
    let is *HashEntry as entry with mut = HashMap_get_bucket(m, idx);

    while (cast(i64, entry) != 0) {
        if (entry.key_len == key_len) {
            if (mem.memcmp(entry.key, key, key_len) == 0) {
                // Encontrado - remover
                if (cast(i64, prev) == 0) {
                    HashMap_set_bucket(m, idx, entry.next);
                } else {
                    prev.next = entry.next;
                }
                mem.gfree(entry.key);
                mem.gfree(entry.value);
                mem.gfree(cast(*u8, entry));
                m.count = m.count - 1;
                return 1;
            }
        }
        prev = entry;
        entry = entry.next;
    }
    return 0;
}

fn HashMap_count(m as *HashMap) as i64 {
    return m.count;
}

fn HashMap_free(m as *HashMap) as void {
    let is i64 as i with mut = 0;
    while (i < m.num_buckets) {
        let is *HashEntry as entry with mut = HashMap_get_bucket(m, i);
        while (cast(i64, entry) != 0) {
            let is *HashEntry as next = entry.next;
            mem.gfree(entry.key);
            mem.gfree(entry.value);
            mem.gfree(cast(*u8, entry));
            entry = next;
        }
        i = i + 1;
    }
    mem.gfree(m.buckets);
    m.buckets = cast(*u8, 0);
    m.num_buckets = 0;
    m.count = 0;
}

// ============================================================================
// Helper functions para strings como keys
// ============================================================================

fn HashMap_put_str(m as *HashMap, key as *u8, val as *u8, val_len as i64) as void {
    let is i64 as key_len = str_len(key);
    HashMap_put(m, key, key_len, val, val_len);
}

fn HashMap_get_str(m as *HashMap, key as *u8) as *u8 {
    let is i64 as key_len = str_len(key);
    return HashMap_get(m, key, key_len);
}

fn HashMap_contains_str(m as *HashMap, key as *u8) as i32 {
    let is i64 as key_len = str_len(key);
    return HashMap_contains(m, key, key_len);
}

fn HashMap_remove_str(m as *HashMap, key as *u8) as i32 {
    let is i64 as key_len = str_len(key);
    return HashMap_remove(m, key, key_len);
}

// Helper para calcular tamanho de string
fn str_len(s as *u8) as i64 {
    let is i64 as len with mut = 0;
    while (s[len] != cast(u8, 0)) {
        len = len + 1;
    }
    return len;
}
