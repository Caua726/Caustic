use "../mem.cst" as mem;
use "../linux.cst" as linux;

// --- Arena Allocator ---
// Bump allocator that allocates linearly and frees everything at once

struct Arena {
    base as *u8;
    used as i64;
    size as i64;
}

fn Arena_new(size as i64) as Arena {
    let is Arena as a;
    let is i64 as minus_one = 0 - 1;
    let is *u8 as ptr = linux.mmap(cast(*u8, 0), size, 3, 34, minus_one, 0);

    // Use explicit variable to avoid inline cast comparison bug
    let is i64 as ptr_val = cast(i64, ptr);
    if (ptr_val < 0) {
        a.base = cast(*u8, 0);
        a.used = 0;
        a.size = 0;
        return a;
    }

    a.base = ptr;
    a.used = 0;
    a.size = size;
    return a;
}

fn Arena_alloc(a as *Arena, size as i64) as *u8 {
    // Align to 8 bytes
    let is i64 as remainder = size % 8;
    let is i64 as aligned_size with mut = size;
    if (remainder != 0) {
        aligned_size = size + (8 - remainder);
    }

    if (a.used + aligned_size > a.size) {
        return cast(*u8, 0);
    }

    let is *u8 as ptr = cast(*u8, cast(i64, a.base) + a.used);
    a.used = a.used + aligned_size;
    return ptr;
}

fn Arena_reset(a as *Arena) as void {
    a.used = 0;
}

fn Arena_free(a as *Arena) as void {
    if (cast(i64, a.base) != 0) {
        linux.munmap(a.base, a.size);
        a.base = cast(*u8, 0);
        a.used = 0;
        a.size = 0;
    }
}

fn Arena_remaining(a as *Arena) as i64 {
    return a.size - a.used;
}

// --- Simplified Global Memory Helpers ---
// These auto-initialize the global heap with a default size

let is i32 as _ez_heap_initialized with mut = 0;

fn ensure_heap() as void {
    if (_ez_heap_initialized == 0) {
        mem.gheapinit(65536);
        _ez_heap_initialized = 1;
    }
}

fn new(size as i64) as *u8 {
    ensure_heap();
    return mem.galloc(size);
}

fn delete(ptr as *u8) as void {
    mem.gfree(ptr);
}

fn resize(ptr as *u8, size as i64) as *u8 {
    ensure_heap();
    return mem.grealloc(ptr, size);
}

// --- Typed Allocation Helpers ---

fn new_array(elem_size as i64, count as i64) as *u8 {
    return new(elem_size * count);
}

fn resize_array(ptr as *u8, elem_size as i64, new_count as i64) as *u8 {
    return resize(ptr, elem_size * new_count);
}

// --- Zero-initialized allocation ---

fn new_zeroed(size as i64) as *u8 {
    let is *u8 as ptr = new(size);
    if (cast(i64, ptr) != 0) {
        mem.memset(ptr, 0, size);
    }
    return ptr;
}

fn new_array_zeroed(elem_size as i64, count as i64) as *u8 {
    return new_zeroed(elem_size * count);
}
