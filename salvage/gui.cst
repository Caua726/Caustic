// =============================================================
// TRAMPOLINS LIBC
// =============================================================

fn libc_puts(msg as *u8) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp puts");
}

fn libc_calloc(nmemb as i64, size as i64) as *u8 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp calloc");
    return cast(*u8, 0);
}

fn libc_free(ptr as *u8) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp free");
}

// =============================================================
// TRAMPOLINS X11
// =============================================================

fn x11_open_display(name as *u8) as i64 {
    // CORREÇÃO: Removemos 'xor rdi, rdi'. 
    // Agora o argumento 'name' passado pelo Caustic (em RDI) é preservado.
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XOpenDisplay");
    return 0;
}

fn x11_create_window(dys as i64, win as i64, x as i64, y as i64, w as i64, h as i64, border as i64, border_c as i64, bg_c as i64) as i64 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XCreateSimpleWindow");
    return 0;
}

fn x11_select_input(dys as i64, win as i64, mask as i64) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XSelectInput");
}

fn x11_map_window(dys as i64, win as i64) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XMapWindow");
}

fn x11_store_name(dys as i64, win as i64, name as *u8) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XStoreName");
}

fn x11_create_gc(dys as i64, win as i64, mask as i64, values as *u8) as i64 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XCreateGC");
    return 0;
}

fn x11_draw_string(dys as i64, win as i64, gc as i64, x as i64, y as i64, str as *u8, len as i32) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XDrawString");
}

fn x11_next_event(dys as i64, event_ptr as *u8) as void {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XNextEvent");
}

fn x11_default_root(dys as i64) as i64 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XDefaultRootWindow");
    return 0;
}

fn x11_black_pixel(dys as i64, screen as i32) as i64 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XBlackPixel");
    return 0;
}

fn x11_white_pixel(dys as i64, screen as i32) as i64 {
    asm("lea rsp, [rbp-40]\npop r15\npop r14\npop r13\npop r12\npop rbx\npop rbp\njmp XWhitePixel");
    return 0;
}

// =============================================================
// LÓGICA DO PROGRAMA (ALINHADA)
// =============================================================

fn run() as i64 {
    libc_puts(">> Iniciando App...");

    // Tenta NULL primeiro (padrão)
    let is i64 as display with mut = x11_open_display(cast(*u8, 0));
    
    if (display == 0) {
        libc_puts(">> NULL falhou. Tentando ':0'...");
        // Se falhar, tenta conectar explicitamente no display 0
        display = x11_open_display(":0");
        
        if (display == 0) {
            libc_puts("Erro Fatal: Display nao encontrado.");
            return 1;
        }
    }
    libc_puts(">> Display conectado.");

    let is i64 as black = x11_black_pixel(display, cast(i32, 0));
    let is i64 as white = x11_white_pixel(display, cast(i32, 0));
    let is i64 as root = x11_default_root(display);

    let is i64 as win = x11_create_window(
        display, root, 
        100, 100, 400, 300, 
        1, black, white
    );
    libc_puts(">> Janela criada.");

    // Eventos: KeyPress (1) + Expose (32768) = 32769
    x11_select_input(display, win, 32769); 
    x11_store_name(display, win, "Caustic Window");
    x11_map_window(display, win);

    let is i64 as gc = x11_create_gc(display, win, 0, cast(*u8, 0));
    
    let is *u8 as event = libc_calloc(1, 256);
    if (cast(i64, event) == 0) { return 1; }

    libc_puts(">> Loop iniciado.");

    while (1 == 1) {
        x11_next_event(display, event);

        let is *i32 as type_ptr = cast(*i32, event);
        let is i32 as type = *type_ptr;

        if (type == 2) { // KeyPress
            libc_puts(">> Encerrando.");
            break;
        }

        if (type == 12) { // Expose
            let is *u8 as text = "HELLO CAUSTIC!";
            x11_draw_string(display, win, gc, 140, 150, text, cast(i32, 14));
        }
    }
    
    libc_free(event);
    return 0;
}

// =============================================================
// MAIN (WRAPPER)
// =============================================================

fn main() as i64 {
    // Chama run para garantir alinhamento de stack
    return run();
}
