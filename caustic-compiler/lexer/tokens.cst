use "../../std/mem.cst" as mem;

// === Token kinds ===

// Literals
let is i32 as TK_EOF     with imut = 0;
let is i32 as TK_IDENT   with imut = 1;
let is i32 as TK_INTEGER with imut = 2;
let is i32 as TK_FLOAT   with imut = 3;
let is i32 as TK_STRING  with imut = 4;
let is i32 as TK_CHAR    with imut = 5;

// Arithmetic
let is i32 as TK_PLUS    with imut = 6;
let is i32 as TK_MINUS   with imut = 7;
let is i32 as TK_STAR    with imut = 8;
let is i32 as TK_SLASH   with imut = 9;
let is i32 as TK_PERCENT with imut = 10;

// Comparison
let is i32 as TK_EQ      with imut = 11;
let is i32 as TK_EQEQ    with imut = 12;
let is i32 as TK_NE      with imut = 13;
let is i32 as TK_LT      with imut = 14;
let is i32 as TK_LE      with imut = 15;
let is i32 as TK_GT      with imut = 16;
let is i32 as TK_GE      with imut = 17;

// Logical / Bitwise
let is i32 as TK_NOT     with imut = 18;
let is i32 as TK_AND     with imut = 19;
let is i32 as TK_OR      with imut = 20;
let is i32 as TK_AND_AND with imut = 21;
let is i32 as TK_OR_OR   with imut = 22;
let is i32 as TK_XOR     with imut = 23;
let is i32 as TK_BITNOT  with imut = 24;
let is i32 as TK_SHL     with imut = 25;
let is i32 as TK_SHR     with imut = 26;

// Special
let is i32 as TK_ASSIGN  with imut = 27;
let is i32 as TK_ARROW   with imut = 28;

// Delimiters
let is i32 as TK_LPAREN    with imut = 29;
let is i32 as TK_RPAREN    with imut = 30;
let is i32 as TK_LBRACE    with imut = 31;
let is i32 as TK_RBRACE    with imut = 32;
let is i32 as TK_LBRACKET  with imut = 33;
let is i32 as TK_RBRACKET  with imut = 34;
let is i32 as TK_COMMA     with imut = 35;
let is i32 as TK_DOT       with imut = 36;
let is i32 as TK_SEMICOLON with imut = 37;
let is i32 as TK_COLON     with imut = 38;
let is i32 as TK_ELLIPSIS  with imut = 39;

// Keywords
let is i32 as TK_FN       with imut = 40;
let is i32 as TK_RETURN   with imut = 41;
let is i32 as TK_LET      with imut = 42;
let is i32 as TK_IS       with imut = 43;
let is i32 as TK_AS       with imut = 44;
let is i32 as TK_WITH     with imut = 45;
let is i32 as TK_IF       with imut = 46;
let is i32 as TK_ELSE     with imut = 47;
let is i32 as TK_WHILE    with imut = 48;
let is i32 as TK_FOR      with imut = 49;
let is i32 as TK_DO       with imut = 50;
let is i32 as TK_BREAK    with imut = 51;
let is i32 as TK_CONTINUE with imut = 52;
let is i32 as TK_STRUCT   with imut = 53;
let is i32 as TK_ENUM     with imut = 54;
let is i32 as TK_MATCH    with imut = 55;
let is i32 as TK_CASE     with imut = 56;
let is i32 as TK_USE      with imut = 57;
let is i32 as TK_ASM      with imut = 58;
let is i32 as TK_SYSCALL  with imut = 59;
let is i32 as TK_SIZEOF   with imut = 60;
let is i32 as TK_CAST     with imut = 61;
let is i32 as TK_GEN      with imut = 62;
let is i32 as TK_DEFER    with imut = 63;
let is i32 as TK_EXTERN   with imut = 64;
let is i32 as TK_IMPL     with imut = 65;
let is i32 as TK_FN_PTR   with imut = 66;

// === Token struct (32 bytes) ===
struct Token {
    kind as i32;
    ptr as *u8;
    len as i32;
    line as i32;
    col as i32;
    int_val as i64;
}

// === TokenList ===
struct TokenList {
    data as *u8;
    count as i32;
    cap as i32;
}

fn tl_init() as TokenList {
    let is i32 as cap = 8192;
    let is TokenList as tl;
    tl.data = mem.galloc(cast(i64, cap) * sizeof(Token));
    tl.count = 0;
    tl.cap = cap;
    return tl;
}

fn tl_push(tl as *TokenList, tok as Token) as void {
    if (tl.count >= tl.cap) {
        let is i32 as new_cap = tl.cap * 2;
        let is *u8 as new_data = mem.galloc(cast(i64, new_cap) * sizeof(Token));
        mem.memcpy(new_data, tl.data, cast(i64, tl.count) * sizeof(Token));
        mem.gfree(tl.data);
        tl.data = new_data;
        tl.cap = new_cap;
    }
    let is *Token as slot = cast(*Token, cast(i64, tl.data) + cast(i64, tl.count) * sizeof(Token));
    slot.kind = tok.kind;
    slot.ptr = tok.ptr;
    slot.len = tok.len;
    slot.line = tok.line;
    slot.col = tok.col;
    slot.int_val = tok.int_val;
    tl.count = tl.count + 1;
}

fn tl_get(tl as *TokenList, idx as i32) as *Token {
    return cast(*Token, cast(i64, tl.data) + cast(i64, idx) * sizeof(Token));
}

fn make_tok(kind as i32, ptr as *u8, len as i32, line as i32, col as i32, int_val as i64) as Token {
    let is Token as t;
    t.kind = kind;
    t.ptr = ptr;
    t.len = len;
    t.line = line;
    t.col = col;
    t.int_val = int_val;
    return t;
}

// === String comparison ===
fn streq(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    if (alen != blen) { return 0; }
    let is i32 as i with mut = 0;
    while (i < alen) {
        if (a[i] != b[i]) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn streq_lit(a as *u8, alen as i32, lit as *u8) as i32 {
    let is i32 as i with mut = 0;
    while (lit[i] != 0) {
        if (i >= alen) { return 0; }
        if (a[i] != lit[i]) { return 0; }
        i = i + 1;
    }
    return cast(i32, i == alen);
}

// === Keyword lookup (dispatch by length) ===
fn keyword_lookup(ptr as *u8, len as i32) as i32 {
    if (len == 2) {
        if (streq_lit(ptr, len, "fn") == 1) { return TK_FN; }
        if (streq_lit(ptr, len, "is") == 1) { return TK_IS; }
        if (streq_lit(ptr, len, "as") == 1) { return TK_AS; }
        if (streq_lit(ptr, len, "if") == 1) { return TK_IF; }
        if (streq_lit(ptr, len, "do") == 1) { return TK_DO; }
    }
    else if (len == 3) {
        if (streq_lit(ptr, len, "let") == 1) { return TK_LET; }
        if (streq_lit(ptr, len, "for") == 1) { return TK_FOR; }
        if (streq_lit(ptr, len, "asm") == 1) { return TK_ASM; }
        if (streq_lit(ptr, len, "use") == 1) { return TK_USE; }
        if (streq_lit(ptr, len, "gen") == 1) { return TK_GEN; }
    }
    else if (len == 4) {
        if (streq_lit(ptr, len, "with") == 1) { return TK_WITH; }
        if (streq_lit(ptr, len, "else") == 1) { return TK_ELSE; }
        if (streq_lit(ptr, len, "case") == 1) { return TK_CASE; }
        if (streq_lit(ptr, len, "cast") == 1) { return TK_CAST; }
        if (streq_lit(ptr, len, "enum") == 1) { return TK_ENUM; }
        if (streq_lit(ptr, len, "impl") == 1) { return TK_IMPL; }
    }
    else if (len == 5) {
        if (streq_lit(ptr, len, "while") == 1) { return TK_WHILE; }
        if (streq_lit(ptr, len, "break") == 1) { return TK_BREAK; }
        if (streq_lit(ptr, len, "match") == 1) { return TK_MATCH; }
        if (streq_lit(ptr, len, "defer") == 1) { return TK_DEFER; }
    }
    else if (len == 6) {
        if (streq_lit(ptr, len, "return") == 1) { return TK_RETURN; }
        if (streq_lit(ptr, len, "struct") == 1) { return TK_STRUCT; }
        if (streq_lit(ptr, len, "sizeof") == 1) { return TK_SIZEOF; }
        if (streq_lit(ptr, len, "extern") == 1) { return TK_EXTERN; }
        if (streq_lit(ptr, len, "fn_ptr") == 1) { return TK_FN_PTR; }
    }
    else if (len == 7) {
        if (streq_lit(ptr, len, "syscall") == 1) { return TK_SYSCALL; }
    }
    else if (len == 8) {
        if (streq_lit(ptr, len, "continue") == 1) { return TK_CONTINUE; }
    }
    return TK_IDENT;
}
