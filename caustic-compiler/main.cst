use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "tokens.cst" as tok;
use "lexer.cst" as lex;

// === I/O helpers ===

fn strlen(s as *u8) as i64 {
    let is i64 as i with mut = 0;
    while (s[i] != 0) { i = i + 1; }
    return i;
}

fn print_str(s as *u8) as void {
    linux.write(linux.STDOUT, s, strlen(s));
}

fn print_int(n as i64) as void {
    if (n == 0) { linux.write(linux.STDOUT, "0", 1); return; }
    let is [24]u8 as buf;
    let is i64 as val with mut = n;
    let is i64 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is i32 as pos with mut = 23;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    if (neg == 1) { buf[pos] = 45; pos = pos - 1; }
    let is i64 as start = cast(i64, pos) + 1;
    linux.write(linux.STDOUT, cast(*u8, cast(i64, &buf) + start), 24 - start);
}

fn read_file(path as *u8, out_size as *i64) as *u8 {
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    if (fd < 0) { return cast(*u8, 0); }
    let is i64 as size = linux.lseek(fd, 0, linux.SEEK_END);
    linux.lseek(fd, 0, linux.SEEK_SET);
    if (size <= 0) { linux.close(fd); return cast(*u8, 0); }
    let is *u8 as buf = mem.galloc(size + 1);
    linux.read(fd, buf, size);
    buf[size] = cast(u8, 0);
    linux.close(fd);
    *out_size = size;
    return buf;
}

// === Token name lookup ===

fn tk_name(kind as i32) as *u8 {
    if (kind == tok.TK_EOF)       { return "TK_EOF"; }
    if (kind == tok.TK_IDENT)     { return "TK_IDENT"; }
    if (kind == tok.TK_INTEGER)   { return "TK_INTEGER"; }
    if (kind == tok.TK_FLOAT)     { return "TK_FLOAT"; }
    if (kind == tok.TK_STRING)    { return "TK_STRING"; }
    if (kind == tok.TK_CHAR)      { return "TK_CHAR"; }
    if (kind == tok.TK_PLUS)      { return "TK_PLUS"; }
    if (kind == tok.TK_MINUS)     { return "TK_MINUS"; }
    if (kind == tok.TK_STAR)      { return "TK_STAR"; }
    if (kind == tok.TK_SLASH)     { return "TK_SLASH"; }
    if (kind == tok.TK_PERCENT)   { return "TK_PERCENT"; }
    if (kind == tok.TK_EQ)        { return "TK_EQ"; }
    if (kind == tok.TK_EQEQ)     { return "TK_EQEQ"; }
    if (kind == tok.TK_NE)        { return "TK_NE"; }
    if (kind == tok.TK_LT)        { return "TK_LT"; }
    if (kind == tok.TK_LE)        { return "TK_LE"; }
    if (kind == tok.TK_GT)        { return "TK_GT"; }
    if (kind == tok.TK_GE)        { return "TK_GE"; }
    if (kind == tok.TK_NOT)       { return "TK_NOT"; }
    if (kind == tok.TK_AND)       { return "TK_AND"; }
    if (kind == tok.TK_OR)        { return "TK_OR"; }
    if (kind == tok.TK_AND_AND)   { return "TK_AND_AND"; }
    if (kind == tok.TK_OR_OR)     { return "TK_OR_OR"; }
    if (kind == tok.TK_XOR)       { return "TK_XOR"; }
    if (kind == tok.TK_BITNOT)    { return "TK_BITNOT"; }
    if (kind == tok.TK_SHL)       { return "TK_SHL"; }
    if (kind == tok.TK_SHR)       { return "TK_SHR"; }
    if (kind == tok.TK_ASSIGN)    { return "TK_ASSIGN"; }
    if (kind == tok.TK_ARROW)     { return "TK_ARROW"; }
    if (kind == tok.TK_LPAREN)    { return "TK_LPAREN"; }
    if (kind == tok.TK_RPAREN)    { return "TK_RPAREN"; }
    if (kind == tok.TK_LBRACE)    { return "TK_LBRACE"; }
    if (kind == tok.TK_RBRACE)    { return "TK_RBRACE"; }
    if (kind == tok.TK_LBRACKET)  { return "TK_LBRACKET"; }
    if (kind == tok.TK_RBRACKET)  { return "TK_RBRACKET"; }
    if (kind == tok.TK_COMMA)     { return "TK_COMMA"; }
    if (kind == tok.TK_DOT)       { return "TK_DOT"; }
    if (kind == tok.TK_SEMICOLON) { return "TK_SEMICOLON"; }
    if (kind == tok.TK_COLON)     { return "TK_COLON"; }
    if (kind == tok.TK_ELLIPSIS)  { return "TK_ELLIPSIS"; }
    if (kind == tok.TK_FN)        { return "TK_FN"; }
    if (kind == tok.TK_RETURN)    { return "TK_RETURN"; }
    if (kind == tok.TK_LET)       { return "TK_LET"; }
    if (kind == tok.TK_IS)        { return "TK_IS"; }
    if (kind == tok.TK_AS)        { return "TK_AS"; }
    if (kind == tok.TK_WITH)      { return "TK_WITH"; }
    if (kind == tok.TK_IF)        { return "TK_IF"; }
    if (kind == tok.TK_ELSE)      { return "TK_ELSE"; }
    if (kind == tok.TK_WHILE)     { return "TK_WHILE"; }
    if (kind == tok.TK_FOR)       { return "TK_FOR"; }
    if (kind == tok.TK_DO)        { return "TK_DO"; }
    if (kind == tok.TK_BREAK)     { return "TK_BREAK"; }
    if (kind == tok.TK_CONTINUE)  { return "TK_CONTINUE"; }
    if (kind == tok.TK_STRUCT)    { return "TK_STRUCT"; }
    if (kind == tok.TK_ENUM)      { return "TK_ENUM"; }
    if (kind == tok.TK_MATCH)     { return "TK_MATCH"; }
    if (kind == tok.TK_CASE)      { return "TK_CASE"; }
    if (kind == tok.TK_USE)       { return "TK_USE"; }
    if (kind == tok.TK_ASM)       { return "TK_ASM"; }
    if (kind == tok.TK_SYSCALL)   { return "TK_SYSCALL"; }
    if (kind == tok.TK_SIZEOF)    { return "TK_SIZEOF"; }
    if (kind == tok.TK_CAST)      { return "TK_CAST"; }
    if (kind == tok.TK_GEN)       { return "TK_GEN"; }
    if (kind == tok.TK_DEFER)     { return "TK_DEFER"; }
    if (kind == tok.TK_EXTERN)    { return "TK_EXTERN"; }
    if (kind == tok.TK_IMPL)      { return "TK_IMPL"; }
    if (kind == tok.TK_FN_PTR)    { return "TK_FN_PTR"; }
    return "TK_UNKNOWN";
}

// === Token dumper ===

fn dump_tokens(tl as *tok.TokenList, src as *u8) as void {
    let is i32 as i with mut = 0;
    while (i < tl.count) {
        let is *tok.Token as t = tok.tl_get(tl, i);
        print_str(tk_name(t.kind));

        // Print token text for identifiers, keywords, strings, numbers
        if (t.len > 0) {
            print_str(" '");
            linux.write(linux.STDOUT, t.ptr, cast(i64, t.len));
            print_str("'");
        }

        // Print int_val for integers and chars
        if (t.kind == tok.TK_INTEGER || t.kind == tok.TK_CHAR) {
            print_str(" =");
            print_int(t.int_val);
        }

        print_str("\n");
        i = i + 1;
    }
}

// === Main ===

fn main(argc as i64, argv as i64) as i32 {
    if (argc < 2) {
        linux.write(linux.STDERR, "Usage: caustic-cc <source.cst>\n", 31);
        return 1;
    }

    mem.gheapinit(2097152); // 2MB heap

    let is *i64 as argv_arr = cast(*i64, argv);
    let is *u8 as filename = cast(*u8, argv_arr[1]);

    let is i64 as file_size with mut = 0;
    let is *u8 as src = read_file(filename, &file_size);
    if (cast(i64, src) == 0) {
        linux.write(linux.STDERR, "Error: cannot read file\n", 24);
        return 1;
    }

    print_str("caustic-cc: lexing ");
    print_str(filename);
    print_str(" (");
    print_int(file_size);
    print_str(" bytes)\n");

    let is tok.TokenList as tokens = lex.tokenize(src, file_size, filename);

    print_str("tokens: ");
    print_int(cast(i64, tokens.count));
    print_str("\n\n");

    dump_tokens(&tokens, src);

    return 0;
}
