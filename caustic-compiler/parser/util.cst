use "../../std/linux.cst" as linux;
use "../../std/mem.cst" as mem;
use "../lexer/tokens.cst" as tok;
use "../lexer/lexer.cst" as lex;
use "ast.cst" as ast;

let is *tok.TokenList as p_tl with mut;
let is i32 as p_pos with mut;
let is *u8 as p_src with mut;
let is i64 as p_src_len with mut;
let is *u8 as p_filename with mut;
let is i32 as p_in_params with mut;

fn cur() as *tok.Token { return tok.tl_get(p_tl, p_pos); }
fn peek() as *tok.Token { return tok.tl_get(p_tl, p_pos + 1); }
fn peek_n(n as i32) as *tok.Token { return tok.tl_get(p_tl, p_pos + n); }
fn advance() as void { p_pos = p_pos + 1; }

fn error_tok(msg as *u8) as void {
    let is *tok.Token as t = cur();
    lex.error_at(p_src, p_src_len, p_filename, t.line, t.col, msg);
}

fn expect(kind as i32) as void {
    if (cur().kind != kind) {
        if (kind == tok.TK_SEMICOLON)  { error_tok("expected ';'"); }
        else if (kind == tok.TK_LPAREN)   { error_tok("expected '('"); }
        else if (kind == tok.TK_RPAREN)   { error_tok("expected ')'"); }
        else if (kind == tok.TK_LBRACE)   { error_tok("expected '{'"); }
        else if (kind == tok.TK_RBRACE)   { error_tok("expected '}'"); }
        else if (kind == tok.TK_LBRACKET) { error_tok("expected '['"); }
        else if (kind == tok.TK_RBRACKET) { error_tok("expected ']'"); }
        else if (kind == tok.TK_COMMA)    { error_tok("expected ','"); }
        else if (kind == tok.TK_AS)       { error_tok("expected 'as'"); }
        else if (kind == tok.TK_IS)       { error_tok("expected 'is'"); }
        else if (kind == tok.TK_LET)      { error_tok("expected 'let'"); }
        else if (kind == tok.TK_FN)       { error_tok("expected 'fn'"); }
        else if (kind == tok.TK_EQ)       { error_tok("expected '='"); }
        else { error_tok("unexpected token"); }
    }
    advance();
}

fn eat(kind as i32) as i32 {
    if (cur().kind == kind) { advance(); return 1; }
    return 0;
}

fn str_dup(ptr as *u8, len as i32) as *u8 {
    let is *u8 as buf = mem.galloc(cast(i64, len) + 1);
    mem.memcpy(buf, ptr, cast(i64, len));
    buf[len] = cast(u8, 0);
    return buf;
}

fn str_len(s as *u8) as i32 {
    let is i32 as i with mut = 0;
    while (s[i] != 0) { i = i + 1; }
    return i;
}

fn type_name_str(t as *ast.Type) as *u8 {
    if (t.kind == ast.TY_I8)     { return "i8"; }
    if (t.kind == ast.TY_I16)    { return "i16"; }
    if (t.kind == ast.TY_I32)    { return "i32"; }
    if (t.kind == ast.TY_I64)    { return "i64"; }
    if (t.kind == ast.TY_U8)     { return "u8"; }
    if (t.kind == ast.TY_U16)    { return "u16"; }
    if (t.kind == ast.TY_U32)    { return "u32"; }
    if (t.kind == ast.TY_U64)    { return "u64"; }
    if (t.kind == ast.TY_F32)    { return "f32"; }
    if (t.kind == ast.TY_F64)    { return "f64"; }
    if (t.kind == ast.TY_BOOL)   { return "bool"; }
    if (t.kind == ast.TY_CHAR)   { return "char"; }
    if (t.kind == ast.TY_STRING) { return "string"; }
    if (t.kind == ast.TY_VOID)   { return "void"; }
    if (t.kind == ast.TY_PTR)    { return "ptr"; }
    if (t.kind == ast.TY_STRUCT && t.name_len > 0) { return t.name_ptr; }
    return "unknown";
}

fn mangle_name(base_ptr as *u8, base_len as i32, args as *u8, arg_count as i32) as *u8 {
    let is i32 as total with mut = base_len;
    let is i32 as i with mut = 0;
    while (i < arg_count) {
        let is *u8 as tn = type_name_str(ast.ga_get(args, i));
        total = total + 1 + str_len(tn);
        i = i + 1;
    }
    let is *u8 as buf = mem.galloc(cast(i64, total) + 1);
    mem.memcpy(buf, base_ptr, cast(i64, base_len));
    let is i32 as pos with mut = base_len;
    i = 0;
    while (i < arg_count) {
        buf[pos] = 95;
        pos = pos + 1;
        let is *u8 as tn = type_name_str(ast.ga_get(args, i));
        let is i32 as tl = str_len(tn);
        mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, pos)), tn, cast(i64, tl));
        pos = pos + tl;
        i = i + 1;
    }
    buf[pos] = cast(u8, 0);
    return buf;
}

fn concat_underscore(a as *u8, alen as i32, b as *u8, blen as i32) as *u8 {
    let is i32 as total = alen + 1 + blen;
    let is *u8 as buf = mem.galloc(cast(i64, total) + 1);
    mem.memcpy(buf, a, cast(i64, alen));
    buf[alen] = 95;
    mem.memcpy(cast(*u8, cast(i64, buf) + cast(i64, alen) + 1), b, cast(i64, blen));
    buf[total] = cast(u8, 0);
    return buf;
}

fn is_param_boundary() as i32 {
    if (p_in_params == 0) { return 0; }
    if (cur().kind != tok.TK_COMMA) { return 0; }
    if (peek().kind == tok.TK_IDENT && peek_n(2).kind == tok.TK_AS) { return 1; }
    return 0;
}
