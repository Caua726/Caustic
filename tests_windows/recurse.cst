// Deep recursion test for Windows port: validates SEH .pdata/.xdata
// unwind info and __caustic_chkstk page probing on large frames.
// Each call uses a ~1.6 KiB local frame; 100 levels deep = ~160 KiB total.

fn recurse(n as i64) as i64 {
    let is [200]i64 as scratch;
    scratch[0] = n;
    scratch[199] = n * 2;
    if (n <= 0) {
        return scratch[0] + scratch[199];
    }
    return n + recurse(n - 1);
}

fn main() as i32 {
    // 100+99+...+1 = 5050. mod 256 = 186.
    let is i64 as r = recurse(100);
    return cast(i32, r);
}
