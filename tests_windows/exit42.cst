// Fase 1 milestone test: produce a hardcoded PE executable that calls
// kernel32!ExitProcess(42). Verify with `wine exit42.exe; echo $?` → 42.
use "../std/os/linux.cst" as linux;
use "../caustic-linker/pe_writer.cst" as pe;

fn main() as i32 {
    let is i64 as fd = linux.open("/tmp/exit42.exe", linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC, 511);
    if (fd < 0) {
        linux.write(linux.STDERR, "open failed\n", 12);
        return 1;
    }
    pe.write_minimal_exit42(fd);
    linux.close(fd);
    linux.write(linux.STDOUT, "wrote /tmp/exit42.exe\n", 22);
    return 0;
}
