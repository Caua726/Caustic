use "../std/mem.cst" as mem;
let is mem.bins.Bins as _heap with mut;
use "../std/mem/bins.cst" as bins;
use "../std/linux.cst" as linux;

let is *u8 as g_bins_ptr with mut;

fn init_bins() as void {
    g_bins_ptr = mem.bins.bins_alloc(&_heap,  sizeof(bins.Bins));
    let is *bins.Bins as b = cast(*bins.Bins, g_bins_ptr);
    let is bins.Bins as tmp with mut;
    tmp = bins.bins_new(131072);
    // Copy struct to heap
    mem.memcpy(g_bins_ptr, cast(*u8, &tmp), sizeof(bins.Bins));
}

fn my_alloc(size as i64) as *u8 {
    return bins.bins_alloc(cast(*bins.Bins, g_bins_ptr), size);
}

fn my_free(ptr as *u8) as void {
    bins.bins_free(cast(*bins.Bins, g_bins_ptr), ptr);
}

fn main() as i32 {
    _heap = mem.bins.bins_new(1048576);
    init_bins();

    let is i32 as round with mut = 0;
    while (round < 500) {
        let is i64 as vc = cast(i64, round) * 4 + 100;
        let is *u8 as p1 = my_alloc(vc * 4);
        let is *u8 as p2 = my_alloc(vc * 8);
        let is *u8 as p3 = my_alloc(vc * 4);

        let is i64 as i with mut = 0;
        while (i < vc * 4) { p1[i] = cast(u8, 0); i = i + 1; }
        i = 0;
        while (i < vc * 8) { p2[i] = cast(u8, 0); i = i + 1; }
        i = 0;
        while (i < vc * 4) { p3[i] = cast(u8, 0); i = i + 1; }

        my_free(p1);
        my_free(p2);
        my_free(p3);
        round = round + 1;
    }

    return 0;
}
