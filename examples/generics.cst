// Generics — monomorphized generic functions and structs
//
// Caustic generates specialized versions at compile time:
//   max gen i32 → max_i32
//   Pair gen i32, i64 → Pair_i32_i64

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;


fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
    str.string_free(s);
}

// Generic max function
fn max gen T (a as T, b as T) as T {
    if (a > b) { return a; }
    return b;
}

// Generic struct
struct Pair gen T, U {
    first as T;
    second as U;
}

// Generic swap
fn swap gen T (a as *T, b as *T) as void {
    let is T as tmp = *a;
    *a = *b;
    *b = tmp;
}

fn main() as i32 {
    mem.init(1048576);

    print("--- Generic Functions ---\n");

    print("  max(10, 20) = ");
    print_num(cast(i64, max gen i32 (10, 20)));
    print("\n");

    print("  max(100, 42) = ");
    print_num(max gen i64 (100, 42));
    print("\n");

    print("\n--- Generic Structs ---\n");

    let is Pair gen i32, i64 as p;
    p.first = 42;
    p.second = 1000;
    print("  pair = (");
    print_num(cast(i64, p.first));
    print(", ");
    print_num(p.second);
    print(")\n");

    print("\n--- Generic Swap ---\n");

    let is i32 as x with mut = 10;
    let is i32 as y with mut = 20;
    print("  before: x=");
    print_num(cast(i64, x));
    print(", y=");
    print_num(cast(i64, y));
    print("\n");

    swap gen i32 (&x, &y);

    print("  after:  x=");
    print_num(cast(i64, x));
    print(", y=");
    print_num(cast(i64, y));
    print("\n");

    return 0;
}
