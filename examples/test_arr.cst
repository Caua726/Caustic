use "../../std/linux.cst" as linux;

fn main() as i32 {
    let is [4]i64 as arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    let is i64 as sum with mut = 0;
    let is i64 as i with mut = 0;
    while (i < 4) {
        sum = sum + arr[i];
        i = i + 1;
    }
    syscall(60, sum);
    return 0;
}
