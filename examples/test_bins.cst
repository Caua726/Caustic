use "../std/mem/bins.cst" as bins;
use "../std/linux.cst" as linux;

fn main() as i32 {
    let is bins.Bins as b with mut;
    b = bins.bins_new(131072);

    // Simulate optimizer pattern: many variable-size allocs, use, free per round
    let is i32 as round with mut = 0;
    while (round < 500) {
        // Simulate vc_alloc * 4 and vc_alloc * 8
        let is i64 as vc = cast(i64, round) * 4 + 100;
        let is *u8 as p1 = bins.bins_alloc(&b, vc * 4);
        let is *u8 as p2 = bins.bins_alloc(&b, vc * 8);
        let is *u8 as p3 = bins.bins_alloc(&b, vc * 4);

        // Zero-init like optimizer does
        let is i64 as i with mut = 0;
        while (i < vc * 4) { p1[i] = cast(u8, 0); i = i + 1; }
        i = 0;
        while (i < vc * 8) { p2[i] = cast(u8, 0); i = i + 1; }
        i = 0;
        while (i < vc * 4) { p3[i] = cast(u8, 0); i = i + 1; }

        bins.bins_free(&b, p1);
        bins.bins_free(&b, p2);
        bins.bins_free(&b, p3);
        round = round + 1;
    }

    bins.bins_destroy(&b);
    return 0;
}
