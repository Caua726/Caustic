// FFI example: calling C standard library functions
// Note: must call exit() from libc to flush stdio buffers
extern fn puts(s as *u8) as i32;
extern fn printf(fmt as *u8, val as i64) as i32;
extern fn rand() as i32;
extern fn srand(seed as u32) as void;
extern fn time(t as *u8) as i64;
extern fn exit(code as i32) as void;

fn main() as i32 {
    puts("Hello from Caustic via libc!");
    printf("sizeof(i64) = %ld\n", 8);
    srand(cast(u32, time(cast(*u8, 0))));
    let is i32 as r = rand() % 100;
    printf("random number: %ld\n", cast(i64, r));
    exit(0);
    return 0;
}
