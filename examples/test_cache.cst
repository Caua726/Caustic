// Test register cache correctness
// Exercises patterns that stress the register cache:
// - Spilled vregs loaded, modified by arithmetic, then re-loaded
// - Multiple return paths writing to the same vreg
// - Binary ops where dest is register-allocated

use "../std/io.cst" as io;
use "../std/linux.cst" as linux;

fn is_alpha(c as i32) as i32 {
    if (c >= 65 && c <= 90) { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    return 0;
}

fn classify(x as i32) as i32 {
    if (x < 0) { return 0; }
    if (x == 0) { return 1; }
    if (x < 10) { return 2; }
    if (x < 100) { return 3; }
    return 4;
}

// Force many spills by using lots of variables
fn spill_test(a as i64, b as i64, c as i64) as i64 {
    let is i64 as v0 with mut = a + 1;
    let is i64 as v1 with mut = b + 2;
    let is i64 as v2 with mut = c + 3;
    let is i64 as v3 with mut = a * 2;
    let is i64 as v4 with mut = b * 3;
    let is i64 as v5 with mut = c * 4;
    let is i64 as v6 with mut = a + b;
    let is i64 as v7 with mut = b + c;
    let is i64 as v8 with mut = a + c;
    let is i64 as v9 with mut = v0 + v1;
    let is i64 as v10 with mut = v2 + v3;
    let is i64 as v11 with mut = v4 + v5;
    // Use all variables to prevent dead code elimination
    let is i64 as sum with mut = v0 + v1 + v2 + v3 + v4 + v5;
    sum = sum + v6 + v7 + v8 + v9 + v10 + v11;
    // Modify some and re-use
    v0 = v0 + v6;
    v1 = v1 + v7;
    v2 = v2 + v8;
    sum = sum + v0 + v1 + v2;
    return sum;
}

// Test binary ops with register-allocated dest
fn binop_test(x as i64, y as i64) as i64 {
    let is i64 as a with mut = x + y;
    let is i64 as b with mut = x - y;
    let is i64 as c with mut = a + b;
    let is i64 as d with mut = a - b;
    let is i64 as e with mut = c + d;
    return e;
}

fn main() as i32 {
    // Test is_alpha
    let is i32 as t1 = is_alpha(65);  // 'A' -> 1
    let is i32 as t2 = is_alpha(48);  // '0' -> 0
    let is i32 as t3 = is_alpha(122); // 'z' -> 1

    if (t1 != 1) { io.print("FAIL: is_alpha('A')\n"); return 1; }
    if (t2 != 0) { io.print("FAIL: is_alpha('0')\n"); return 2; }
    if (t3 != 1) { io.print("FAIL: is_alpha('z')\n"); return 3; }

    // Test classify
    let is i32 as c1 = classify(cast(i32, 0 - 5));
    let is i32 as c2 = classify(0);
    let is i32 as c3 = classify(5);
    let is i32 as c4 = classify(50);
    let is i32 as c5 = classify(500);

    if (c1 != 0) { io.print("FAIL: classify(-5)\n"); return 4; }
    if (c2 != 1) { io.print("FAIL: classify(0)\n"); return 5; }
    if (c3 != 2) { io.print("FAIL: classify(5)\n"); return 6; }
    if (c4 != 3) { io.print("FAIL: classify(50)\n"); return 7; }
    if (c5 != 4) { io.print("FAIL: classify(500)\n"); return 8; }

    // Test spill_test
    let is i64 as sp = spill_test(10, 20, 30);
    // v0=11, v1=22, v2=33, v3=20, v4=60, v5=120, v6=30, v7=50, v8=40
    // v9=33, v10=53, v11=180
    // sum = 11+22+33+20+60+120 + 30+50+40+33+53+180 = 652
    // v0=11+30=41, v1=22+50=72, v2=33+40=73
    // sum = 652 + 41+72+73 = 838
    if (sp != 838) { io.print("FAIL: spill_test\n"); return 9; }

    // Test binop_test
    let is i64 as bp = binop_test(10, 3);
    // a=13, b=7, c=20, d=6, e=26
    if (bp != 26) { io.print("FAIL: binop_test\n"); return 10; }

    io.print("ALL TESTS PASSED\n");
    return 0;
}
