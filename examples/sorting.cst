// Sorting Algorithms — demonstrates all 5 sorts in the stdlib
//
// Algorithms: insertion sort, bubble sort, quicksort, heapsort, mergesort
// Each tested with ascending and descending order

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/io.cst" as io;
use "../std/sort.cst" as sort;
use "../std/math.cst" as math;


fn print_arr(arr as *i64, count as i64) as void {
    let is i64 as i with mut = 0;
    io.write_str(linux.STDOUT, "  [");
    while (i < count) {
        if (i > 0) { io.write_str(linux.STDOUT, ", "); }
        io.write_int(linux.STDOUT, arr[i]);
        i = i + 1;
    }
    io.write_str(linux.STDOUT, "]\n");
}

fn fill_random(arr as *i64, count as i64) as void {
    let is *u8 as rbuf = mem.alloc( count * 8);
    linux.getrandom(rbuf, count * 8, 0);
    let is i64 as i with mut = 0;
    while (i < count) {
        let is *i64 as p = cast(*i64, cast(i64, rbuf) + i * 8);
        // clamp to 0..999
        let is i64 as val with mut = *p;
        if (val < 0) { val = 0 - val; }
        arr[i] = val % 1000;
        i = i + 1;
    }
    mem.free( rbuf);
}

fn copy_arr(dst as *i64, src as *i64, count as i64) as void {
    mem.memcpy(cast(*u8, dst), cast(*u8, src), count * 8);
}

fn main() as i32 {
    mem.init(65536);
    let is i64 as n = 10;
    let is *i64 as original = cast(*i64, mem.alloc( n * 8));
    let is *i64 as arr = cast(*i64, mem.alloc( n * 8));

    // Generate random data
    fill_random(original, n);

    io.write_str(linux.STDOUT, "=== Caustic Sorting Algorithms ===\n\n");
    io.write_str(linux.STDOUT, "Original data:\n");
    print_arr(original, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Insertion Sort ---
    io.write_str(linux.STDOUT, "1. Insertion Sort (stable, O(n^2), best for small arrays)\n");
    copy_arr(arr, original, n);
    sort.insertion_sort_i64(arr, n);
    io.write_str(linux.STDOUT, "   asc: ");
    print_arr(arr, n);
    copy_arr(arr, original, n);
    sort.insertion_sort_desc_i64(arr, n);
    io.write_str(linux.STDOUT, "   desc:");
    print_arr(arr, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Bubble Sort ---
    io.write_str(linux.STDOUT, "2. Bubble Sort (stable, O(n^2), early-exit optimization)\n");
    copy_arr(arr, original, n);
    sort.bubble_sort_i64(arr, n);
    io.write_str(linux.STDOUT, "   asc: ");
    print_arr(arr, n);
    copy_arr(arr, original, n);
    sort.bubble_sort_desc_i64(arr, n);
    io.write_str(linux.STDOUT, "   desc:");
    print_arr(arr, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Quicksort ---
    io.write_str(linux.STDOUT, "3. Quicksort (O(n log n) avg, median-of-three, insertion fallback)\n");
    copy_arr(arr, original, n);
    sort.quicksort_i64(arr, n);
    io.write_str(linux.STDOUT, "   asc: ");
    print_arr(arr, n);
    copy_arr(arr, original, n);
    sort.quicksort_desc_i64(arr, n);
    io.write_str(linux.STDOUT, "   desc:");
    print_arr(arr, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Heapsort ---
    io.write_str(linux.STDOUT, "4. Heapsort (O(n log n) worst-case, in-place, no extra alloc)\n");
    copy_arr(arr, original, n);
    sort.heapsort_i64(arr, n);
    io.write_str(linux.STDOUT, "   asc: ");
    print_arr(arr, n);
    copy_arr(arr, original, n);
    sort.heapsort_desc_i64(arr, n);
    io.write_str(linux.STDOUT, "   desc:");
    print_arr(arr, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Mergesort ---
    io.write_str(linux.STDOUT, "5. Mergesort (O(n log n), stable, uses temp buffer)\n");
    copy_arr(arr, original, n);
    sort.mergesort_i64(arr, n);
    io.write_str(linux.STDOUT, "   asc: ");
    print_arr(arr, n);
    copy_arr(arr, original, n);
    sort.mergesort_desc_i64(arr, n);
    io.write_str(linux.STDOUT, "   desc:");
    print_arr(arr, n);
    linux.write(linux.STDOUT, "\n", 1);

    // --- Utilities ---
    io.write_str(linux.STDOUT, "--- Utilities ---\n");

    copy_arr(arr, original, n);
    sort.quicksort_i64(arr, n);
    io.write_str(linux.STDOUT, "is_sorted (after sort): ");
    io.write_int(linux.STDOUT, sort.is_sorted_i64(arr, n));
    linux.write(linux.STDOUT, "\n", 1);

    io.write_str(linux.STDOUT, "is_sorted (original):   ");
    io.write_int(linux.STDOUT, sort.is_sorted_i64(original, n));
    linux.write(linux.STDOUT, "\n", 1);

    sort.reverse_i64(arr, n);
    io.write_str(linux.STDOUT, "reversed:");
    print_arr(arr, n);

    // --- Verify all produce same result ---
    io.write_str(linux.STDOUT, "\n--- Verification ---\n");
    let is *i64 as ref = cast(*i64, mem.alloc( n * 8));
    copy_arr(ref, original, n);
    sort.quicksort_i64(ref, n);

    let is i64 as all_ok with mut = 1;
    let is i64 as j with mut = 0;

    // Check insertion sort matches quicksort
    copy_arr(arr, original, n);
    sort.insertion_sort_i64(arr, n);
    j = 0;
    while (j < n) {
        if (arr[j] != ref[j]) { all_ok = 0; }
        j = j + 1;
    }

    // Check bubble sort
    copy_arr(arr, original, n);
    sort.bubble_sort_i64(arr, n);
    j = 0;
    while (j < n) {
        if (arr[j] != ref[j]) { all_ok = 0; }
        j = j + 1;
    }

    // Check heapsort
    copy_arr(arr, original, n);
    sort.heapsort_i64(arr, n);
    j = 0;
    while (j < n) {
        if (arr[j] != ref[j]) { all_ok = 0; }
        j = j + 1;
    }

    // Check mergesort
    copy_arr(arr, original, n);
    sort.mergesort_i64(arr, n);
    j = 0;
    while (j < n) {
        if (arr[j] != ref[j]) { all_ok = 0; }
        j = j + 1;
    }

    if (all_ok == 1) {
        io.write_str(linux.STDOUT, "All 5 algorithms produce identical results!\n");
    } else {
        io.write_str(linux.STDOUT, "MISMATCH: algorithms disagree!\n");
    }

    return 0;
}
