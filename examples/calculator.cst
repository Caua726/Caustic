// Calculator — parse and evaluate arithmetic expressions from stdin
//
// Reads lines like "12 + 34", "100 * 3", "42 / 7", "10 - 3"
// and prints the result. Type "quit" or press Ctrl+D to exit.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;

fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_str(s as str.String) as void {
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
}

fn print_num(n as i64) as void {
    let is i64 as val with mut = n;
    if (val < 0) {
        print("-");
        val = 0 - val;
    }
    let is str.String as s = str.int_to_string(val);
    print_str(s);
    str.string_free(s);
}

// Read a line from stdin into a buffer. Returns length (0 on EOF).
fn read_line(buf as *u8, max as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < max - 1) {
        let is i64 as n = linux.read(linux.STDIN, cast(*u8, cast(i64, buf) + i), 1);
        if (n <= 0) {
            return i;
        }
        if (buf[i] == 10) {
            buf[i] = 0;
            return i;
        }
        i = i + 1;
    }
    buf[i] = 0;
    return i;
}

// Skip whitespace, returns new position
fn skip_spaces(buf as *u8, start as i64, len as i64) as i64 {
    let is i64 as pos with mut = start;
    while (pos < len && buf[pos] == 32) {
        pos = pos + 1;
    }
    return pos;
}

// Parse an integer from buf starting at pos. Returns the number.
// Updates pos_out to point past the number.
fn parse_number(buf as *u8, start as i64, pos_out as *i64) as i64 {
    let is i64 as result with mut = 0;
    let is i64 as neg with mut = 0;
    let is i64 as p with mut = start;

    if (buf[p] == 45) {
        neg = 1;
        p = p + 1;
    }

    while (buf[p] >= 48) {
        if (buf[p] > 57) {
            break;
        }
        result = result * 10 + cast(i64, buf[p]) - 48;
        p = p + 1;
    }

    *pos_out = p;
    if (neg == 1) {
        return 0 - result;
    }
    return result;
}

fn main() as i32 {
    mem.gheapinit(1048576);

    print("Caustic Calculator\n");
    print("Enter expressions like: 12 + 34\n");
    print("Operators: + - * /\n");
    print("Type 'q' to quit.\n\n");

    let is [256]u8 as buf;

    while (1 == 1) {
        print("> ");
        let is i64 as len = read_line(&buf, 256);

        if (len == 0) {
            print("\n");
            break;
        }

        // Check for quit
        if (buf[0] == 113) {
            break;
        }

        // Parse: number operator number
        let is i64 as pos with mut = 0;
        pos = skip_spaces(&buf, pos, len);

        let is i64 as pos_after with mut = 0;
        let is i64 as lhs = parse_number(&buf, pos, &pos_after);
        pos = pos_after;

        pos = skip_spaces(&buf, pos, len);

        let is u8 as op = buf[pos];
        pos = pos + 1;

        pos = skip_spaces(&buf, pos, len);

        let is i64 as rhs = parse_number(&buf, pos, &pos_after);

        // Evaluate
        let is i64 as result with mut = 0;
        let is i32 as ok with mut = 1;

        if (op == 43) {
            result = lhs + rhs;
        } else if (op == 45) {
            result = lhs - rhs;
        } else if (op == 42) {
            result = lhs * rhs;
        } else if (op == 47) {
            if (rhs == 0) {
                print("  error: division by zero\n");
                ok = 0;
            } else {
                result = lhs / rhs;
            }
        } else {
            print("  error: unknown operator\n");
            ok = 0;
        }

        if (ok == 1) {
            print("  = ");
            print_num(result);
            print("\n");
        }
    }

    return 0;
}
