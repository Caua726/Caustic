    run_one("Zig ReleaseFast", "zig", "cd /tmp/caustic_bench && zig build-exe -OReleaseFast bench.zig -femit-bin=/tmp/caustic_bench/zig_rf >/dev/null 2>&1; cd /home/caua/Documentos/Projetos-Pessoais/Caustic", "/tmp/caustic_bench/zig_rf", "/tmp/caustic_bench/zig_rf 38 10000000 1000000 64 1000000");
    run_one("Go", "go", "cd /tmp/caustic_bench && (test -f go.mod || go mod init bench >/dev/null 2>&1) && go build -o /tmp/caustic_bench/go_bin bench.go >/dev/null 2>&1; cd /home/caua/Documentos/Projetos-Pessoais/Caustic", "/tmp/caustic_bench/go_bin", "/tmp/caustic_bench/go_bin 38 10000000 1000000 64 1000000");
