// CLBG fannkuch-redux — portable across all Caustic versions (no stdlib I/O)

fn write_str_lit(s as *u8, n as i64) as void {
    syscall(1, 1, s, n);
}

fn write_int(n as i64) as void {
    if (n == 0) {
        let is [1]u8 as z;
        z[0] = cast(u8, 48);
        syscall(1, 1, &z, 1);
        return;
    }
    let is [24]u8 as buf;
    let is i64 as val with mut = n;
    let is i32 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is i32 as pos with mut = 23;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    if (neg == 1) { buf[pos] = cast(u8, 45); pos = pos - 1; }
    let is i64 as start = cast(i64, pos) + 1;
    syscall(1, 1, cast(*u8, cast(i64, &buf) + start), 24 - start);
}

fn fannkuch(n as i32) as i32 {
    let is [16]i32 as perm;
    let is [16]i32 as perm1;
    let is [16]i32 as count;
    let is i32 as max_flips with mut = 0;
    let is i32 as perm_count with mut = 0;
    let is i32 as checksum with mut = 0;

    let is i32 as i with mut = 0;
    while (i < n) { perm1[i] = i; i = i + 1; }
    let is i32 as r with mut = n;

    while (1 == 1) {
        while (r != 1) { count[r-1] = r; r = r - 1; }
        i = 0;
        while (i < n) { perm[i] = perm1[i]; i = i + 1; }
        let is i32 as flips with mut = 0;
        let is i32 as k with mut = perm[0];
        while (k != 0) {
            let is i32 as k2 = (k + 1) >> 1;
            let is i32 as ii with mut = 0;
            while (ii < k2) {
                let is i32 as t = perm[ii];
                perm[ii] = perm[k - ii];
                perm[k - ii] = t;
                ii = ii + 1;
            }
            flips = flips + 1;
            k = perm[0];
        }
        if ((perm_count & 1) == 1) { checksum = checksum - flips; }
        else { checksum = checksum + flips; }
        if (flips > max_flips) { max_flips = flips; }

        let is i32 as done with mut = 0;
        let is i32 as ret with mut = 0;
        while (done == 0) {
            if (r == n) {
                write_int(cast(i64, checksum));
                write_str_lit("\n", 1);
                ret = 1; done = 1;
            } else {
                let is i32 as perm0 = perm1[0];
                let is i32 as ii with mut = 0;
                while (ii < r) { perm1[ii] = perm1[ii + 1]; ii = ii + 1; }
                perm1[r] = perm0;
                count[r] = count[r] - 1;
                if (count[r] > 0) { done = 1; }
                else { r = r + 1; }
            }
        }
        if (ret == 1) { return max_flips; }
        perm_count = perm_count + 1;
    }
    return max_flips;
}

fn main() as i32 {
    let is i32 as n = 11;
    let is i32 as max = fannkuch(n);
    write_str_lit("Pfannkuchen(", 12);
    write_int(cast(i64, n));
    write_str_lit(") = ", 4);
    write_int(cast(i64, max));
    write_str_lit("\n", 1);
    return 0;
}
