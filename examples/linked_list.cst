// Linked List — heap-allocated singly linked list
//
// Demonstrates heap allocation, pointers, and data structures.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;


fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
    str.string_free(s);
}

// Node: value + pointer to next node
struct Node {
    value as i64;
    next as *u8;  // *Node (use *u8 for pointer flexibility)
}

// List: pointer to head node
struct List {
    head as *u8;  // *Node
    len as i64;
}

// Create an empty list
fn list_new() as List {
    let is List as l;
    l.head = cast(*u8, 0);
    l.len = 0;
    return l;
}

// Push a value to the front of the list
fn list_push(l as *List, value as i64) as void {
    let is *u8 as raw = mem.alloc( sizeof(Node));
    let is *Node as node = cast(*Node, raw);
    node.value = value;
    node.next = l.head;
    l.head = raw;
    l.len = l.len + 1;
}

// Pop the front value. Returns the value (or -1 if empty).
fn list_pop(l as *List) as i64 {
    if (l.head == cast(*u8, 0)) {
        return cast(i64, 0 - 1);
    }
    let is *Node as node = cast(*Node, l.head);
    let is i64 as value = node.value;
    let is *u8 as old = l.head;
    l.head = node.next;
    mem.free( old);
    l.len = l.len - 1;
    return value;
}

// Get value at index (0-based). Returns -1 if out of bounds.
fn list_get(l as *List, index as i64) as i64 {
    let is *u8 as cur with mut = l.head;
    let is i64 as i with mut = 0;
    while (cur != cast(*u8, 0)) {
        if (i == index) {
            let is *Node as node = cast(*Node, cur);
            return node.value;
        }
        let is *Node as node = cast(*Node, cur);
        cur = node.next;
        i = i + 1;
    }
    return cast(i64, 0 - 1);
}

// Print the list: [a, b, c]
fn list_print(l as *List) as void {
    print("[");
    let is *u8 as cur with mut = l.head;
    let is i64 as first with mut = 1;
    while (cur != cast(*u8, 0)) {
        if (first == 0) {
            print(", ");
        }
        let is *Node as node = cast(*Node, cur);
        print_num(node.value);
        cur = node.next;
        first = 0;
    }
    print("]");
}

// Free all nodes
fn list_free(l as *List) as void {
    let is *u8 as cur with mut = l.head;
    while (cur != cast(*u8, 0)) {
        let is *Node as node = cast(*Node, cur);
        let is *u8 as next = node.next;
        mem.free( cur);
        cur = next;
    }
    l.head = cast(*u8, 0);
    l.len = 0;
}

fn main() as i32 {
    mem.init(1048576);

    let is List as list = list_new();

    // Push values
    print("--- Push ---\n");
    list_push(&list, 10);
    list_push(&list, 20);
    list_push(&list, 30);
    list_push(&list, 40);
    list_push(&list, 50);
    print("  list = ");
    list_print(&list);
    print("\n");
    print("  len = ");
    print_num(list.len);
    print("\n");

    // Get by index
    print("\n--- Get ---\n");
    print("  list[0] = ");
    print_num(list_get(&list, 0));
    print("\n");
    print("  list[2] = ");
    print_num(list_get(&list, 2));
    print("\n");
    print("  list[4] = ");
    print_num(list_get(&list, 4));
    print("\n");

    // Pop values
    print("\n--- Pop ---\n");
    let is i64 as v1 = list_pop(&list);
    print("  popped: ");
    print_num(v1);
    print("\n");

    let is i64 as v2 = list_pop(&list);
    print("  popped: ");
    print_num(v2);
    print("\n");

    print("  list = ");
    list_print(&list);
    print("\n");
    print("  len = ");
    print_num(list.len);
    print("\n");

    // Clean up
    list_free(&list);
    print("\n--- After free ---\n");
    print("  len = ");
    print_num(list.len);
    print("\n");

    return 0;
}
