// Enums — simple enums, tagged unions, and pattern matching
//
// Demonstrates enum declarations, match expressions, and data-carrying variants.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;

fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
    str.string_free(s);
}

// --- Simple Enum ---

enum Color {
    Red;
    Green;
    Blue;
}

fn color_name(c as Color) as *u8 {
    match Color (c) {
        case Red {
            return "Red";
        }
        case Green {
            return "Green";
        }
        case Blue {
            return "Blue";
        }
    }
    return "Unknown";
}

// --- Tagged Union (enum with data) ---

enum Shape {
    Circle as i32;
    Square as i32;
    None;
}

fn shape_area(s as Shape) as i64 {
    match Shape (s) {
        case Circle(r) {
            return cast(i64, r) * cast(i64, r) * 3;
        }
        case Square(side) {
            return cast(i64, side) * cast(i64, side);
        }
        case None {
            return 0;
        }
    }
    return 0;
}

fn shape_describe(s as Shape) as void {
    match Shape (s) {
        case Circle(r) {
            print("Circle(r=");
            print_num(cast(i64, r));
            print(")");
        }
        case Square(side) {
            print("Square(side=");
            print_num(cast(i64, side));
            print(")");
        }
        else {
            print("None");
        }
    }
}

// --- Enum for state machine ---

enum State {
    Idle;
    Running;
    Done;
    Error;
}

fn state_name(s as State) as *u8 {
    match State (s) {
        case Idle { return "Idle"; }
        case Running { return "Running"; }
        case Done { return "Done"; }
        case Error { return "Error"; }
    }
    return "Unknown";
}

fn next_state(s as State) as State {
    match State (s) {
        case Idle { return State.Running; }
        case Running { return State.Done; }
        else { return s; }
    }
    return s;
}

fn main() as i32 {
    mem.gheapinit(1048576);

    // Simple enum
    print("--- Simple Enum ---\n");
    let is Color as r = Color.Red;
    let is Color as g = Color.Green;
    let is Color as b = Color.Blue;

    print("  r = ");
    print(color_name(r));
    print("\n");
    print("  g = ");
    print(color_name(g));
    print("\n");
    print("  b = ");
    print(color_name(b));
    print("\n");

    // Comparison
    print("\n--- Comparison ---\n");
    if (r == Color.Red) {
        print("  r is Red\n");
    }
    if (r != Color.Blue) {
        print("  r is not Blue\n");
    }

    // Tagged unions
    print("\n--- Tagged Unions ---\n");
    let is Shape as circle = Shape.Circle(10);
    let is Shape as square = Shape.Square(5);
    let is Shape as none = Shape.None;

    print("  ");
    shape_describe(circle);
    print(" area ~= ");
    print_num(shape_area(circle));
    print("\n");

    print("  ");
    shape_describe(square);
    print(" area = ");
    print_num(shape_area(square));
    print("\n");

    print("  ");
    shape_describe(none);
    print(" area = ");
    print_num(shape_area(none));
    print("\n");

    // State machine
    print("\n--- State Machine ---\n");
    let is State as st with mut = State.Idle;
    print("  state: ");
    print(state_name(st));
    print("\n");

    st = next_state(st);
    print("  state: ");
    print(state_name(st));
    print("\n");

    st = next_state(st);
    print("  state: ");
    print(state_name(st));
    print("\n");

    st = next_state(st);
    print("  state: ");
    print(state_name(st));
    print(" (no change)\n");

    return 0;
}
