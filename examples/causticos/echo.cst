// echo — print the arguments, space-separated, + newline. Proves argv reaches a
// spawned program and its stdout pumps back to the terminal.
use "../../std/causticos/prog.cst" as prog;

fn main(argc as i64, argv as *u8) as i32 {
    let is i64 as i with mut = 1;
    while (i < argc) {
        prog.outs(prog.arg(argv, i));
        if (i < argc - 1) { prog.out(" ", 1); }
        i = i + 1;
    }
    prog.out("\n", 1);
    return 0;
}
