// sysinfo — kernel ABI version + limits. `sysinfo`. Reads SYS_KERN_INFO into a
// KernInfo block (i64 fields: [0] info_size, [1] abi_major, [2] abi_minor,
// [3] syscalls_max, [4] page_size).
use "../../std/causticos/prog.cst" as prog;
use "../../std/os/causticos.cst" as sys;

fn main(argc as i64, argv as *u8) as i32 {
    let is [8]i64 as info;
    sys.kern_info(cast(*u8, &info[0]), 64);
    prog.outs("CausticOS  abi ");
    prog.out_num(info[1]); prog.outs("."); prog.out_num(info[2]);
    prog.outs("  syscalls="); prog.out_num(info[3]);
    prog.outs("  page="); prog.out_num(info[4]);
    prog.outs("  pid="); prog.out_num(sys.getpid());
    prog.out("\n", 1);
    return 0;
}
