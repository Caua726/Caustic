// examples/causticos/terminal.cst — a CausticOS framebuffer terminal.
//
// The userspace terminal from architecture.md §9: holds the framebuffer surface
// + the keyboard device, applies the keymap, renders text. v0 is the standalone
// "typing terminal" — echoes typed characters to the screen. Building it as
// /init.cse proves fb + kbd + keymap + render end-to-end before the shell is
// wired on top. Serial markers (write_serial) trace the boot path headless.
//
// Build: caustic --target=caustic-x86_64 examples/causticos/terminal.cst -o /tmp/init.cse
use "../../std/causticos/gfx.cst" as gfx;
use "../../std/causticos/term.cst" as term;
use "../../std/causticos/input.cst" as input;
use "../../std/os/causticos.cst" as sys;

fn _slen(s as *u8) as i64 { let is i64 as n with mut = 0; while (s[n] != 0) { n = n + 1; } return n; }
fn _log(s as *u8) as void { sys.write_serial(s, _slen(s)); }

fn main() as i32 {
    let is gfx.Framebuffer as fb = gfx.open();
    if (fb.ok == 0) { _log("terminal: NO FB\n"); sys.exit(cast(i32, 1)); }
    _log("terminal: fb opened\n");

    let is term.Term as t = term.init(fb.base, fb.fd, fb.width, fb.height, fb.pitch, fb.bpp);
    term.set_color(&t, 0x0040ff80, 0x00101018);
    term.puts(&t, "CausticOS terminal v0\n", 22);
    term.set_color(&t, 0x00c8c8c8, 0x00101018);
    term.puts(&t, "type away (echo). keymap = US Set-1.\n\n> ", 41);
    term.flush(&t);
    _log("terminal: banner drawn\n");

    let is i64 as kfd = input.open_keyboard();
    if (kfd < 0) { _log("terminal: NO KBD\n"); sys.exit(cast(i32, 2)); }
    _log("terminal: ready (input loop)\n");

    let is i64 as shift with mut = 0;
    let is input.KeyEvent as ev;
    while (1 == 1) {
        if (input.read_event(kfd, &ev) == 1) {
            if (input.is_shift(ev.scancode) == 1) {
                shift = ev.pressed;
            } else if (ev.pressed == 1) {
                let is i64 as c = input.scancode_to_ascii(ev.scancode, shift);
                if (c != 0) { term.putc(&t, c); term.flush(&t); }
            }
        }
    }
    return 0;
}
