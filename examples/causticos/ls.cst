// ls — list a directory (default "/"). `ls [path]`. Reads VFS dir entries via
// SYS_READDIR on an open dir fd; each VfsDirEntry is name[256] + name_len@256.
use "../../std/causticos/prog.cst" as prog;
use "../../std/os/causticos.cst" as sys;

fn main(argc as i64, argv as *u8) as i32 {
    let is *u8 as path with mut = "/";
    if (argc >= 2) { path = prog.arg(argv, 1); }
    let is i64 as fd = sys.open_read(path);
    if (fd < 0) { prog.outs("ls: cannot open "); prog.outs(path); prog.out("\n", 1); return cast(i32, 1); }
    let is [320]u8 as de;                                    // VfsDirEntry is 296 B (name[256] + 5*i64); kernel copies sizeof -> need >=296
    while (sys.readdir(fd, cast(*u8, &de[0])) == 0) {
        let is *i64 as nl = cast(*i64, cast(i64, &de[0]) + 256);
        prog.out(cast(*u8, &de[0]), nl[0]);
        prog.out("\n", 1);
    }
    sys.close(fd);
    return 0;
}
