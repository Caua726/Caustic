// examples/causticos/shell.cst — CausticOS framebuffer shell (the /init).
//
// Fuses the terminal (architecture.md §9) and the shell: it holds the framebuffer
// surface + the keyboard, renders text (term.cst), applies the keymap, and runs a
// REPL. A command line is split into argv; a builtin runs in-process, otherwise
// the shell loads "/<cmd>.cse" from the FAT32 disk, mints a console channel,
// spawns the program with argv + its stdout wired to the channel (fd 1), pumps
// the program's output to the screen, and waits. argv is data; the kernel never
// resolves it — the child acts only through the channel key it was handed.
//
// Build: caustic --target=caustic-x86_64 examples/causticos/shell.cst -o /tmp/init.cse
use "../../std/causticos/gfx.cst" as gfx;
use "../../std/causticos/term.cst" as term;
use "../../std/causticos/input.cst" as input;
use "../../std/os/causticos.cst" as sys;

let is i64 as MAX_ARGS  with imut = 16;
let is i64 as LINE_CAP  with imut = 256;
let is i64 as IMG_CAP   with imut = 65536;

// --- small helpers ---
fn slen(s as *u8) as i64 { let is i64 as n with mut = 0; while (s[n] != 0) { n = n + 1; } return n; }
fn puts(t as *term.Term, s as *u8) as void { term.puts(t, s, slen(s)); }

// serial trace (headless): markers so a screenless boot can confirm the path.
fn _log(s as *u8) as void { sys.write_serial(s, slen(s)); }
fn _lognum(v as i64) as void {
    let is i64 as x with mut = v;
    if (x < 0) { sys.write_serial("-", 1); x = 0 - x; }
    if (x == 0) { sys.write_serial("0", 1); return; }
    let is [24]u8 as b;
    let is i64 as i with mut = 24;
    while (x > 0) { i = i - 1; b[i] = cast(u8, 48 + (x % 10)); x = x / 10; }
    sys.write_serial(cast(*u8, &b[i]), 24 - i);
}

// Read a whole file into a fresh mmap'd buffer. Returns the buffer (or null) and
// writes the byte count to *out_len.
fn read_file(path as *u8, out_len as *i64) as *u8 {
    *out_len = 0;
    let is i64 as fd = sys.open_read(path);
    if (fd < 0) { return cast(*u8, 0); }
    let is i64 as sz = sys.lseek(fd, 0, cast(i32, sys.SEEK_END));
    sys.lseek(fd, 0, cast(i32, sys.SEEK_SET));
    if (sz <= 0 || sz > IMG_CAP) { sys.close(fd); return cast(*u8, 0); }
    let is i64 as va = sys.mmap(cast(i64, 0), IMG_CAP, sys.PROT_READ | sys.PROT_WRITE);
    if (va < 0) { sys.close(fd); return cast(*u8, 0); }
    let is *u8 as buf = cast(*u8, va);
    let is i64 as got = sys.read(fd, buf, sz);
    sys.close(fd);
    *out_len = got;
    return buf;
}

// Run an external program: argv_ptr[i] = byte pointer, argv_len[i] = length
// (argv[0] is the command). Loads /<cmd>.cse, spawns with a console channel +
// argv, pumps its stdout to the terminal, waits.
fn run_program(t as *term.Term, argv_ptr as *i64, argv_len as *i64, argc as i64) as void {
    // path = "/" + argv[0] + ".cse"
    let is [128]u8 as path;
    let is *u8 as cmd = cast(*u8, argv_ptr[0]);
    let is i64 as cl = argv_len[0];
    if (cl > 110) { puts(t, "name too long\n"); return; }
    path[0] = cast(u8, 47);                              // '/'
    let is i64 as i with mut = 0;
    while (i < cl) { path[1 + i] = cmd[i]; i = i + 1; }
    let is *u8 as ext = ".cse";
    let is i64 as j with mut = 0;
    while (j < 4) { path[1 + cl + j] = ext[j]; j = j + 1; }
    path[1 + cl + 4] = cast(u8, 0);

    let is i64 as img_len with mut = 0;
    let is *u8 as img = read_file(cast(*u8, &path[0]), &img_len);
    if (cast(i64, img) == 0) { puts(t, cast(*u8, &path[0])); puts(t, ": not found\n"); return; }

    // console channel: child's stdout (fd 1) = channel write end.
    let is [2]i64 as fds;
    if (sys.channel_create(cast(*i64, &fds[0])) != 0) { puts(t, "channel fail\n"); return; }
    let is [2]i64 as fdacts;
    fdacts[0] = 1;                                       // child_fd 1 (stdout)
    fdacts[1] = fds[1];                                  // <- shell's channel write end

    // argv array of {str_ptr, str_len} (16 B each) — the parsed tokens.
    let is [32]i64 as av;
    let is i64 as k with mut = 0;
    while (k < argc) { av[2 * k] = argv_ptr[k]; av[2 * k + 1] = argv_len[k]; k = k + 1; }

    let is i64 as pid = sys.spawn(img, img_len, cast(*u8, &fdacts[0]), 1, cast(*u8, &av[0]), argc);
    sys.close(fds[1]);                                   // shell drops the write end; child holds it
    _log("shell: spawn "); _log(cast(*u8, &path[0])); _log(" len="); _lognum(img_len); _log(" pid="); _lognum(pid); _log("\n");
    if (pid < 0) { puts(t, "spawn failed\n"); sys.close(fds[0]); return; }

    // pump the child's stdout to the screen until it closes (EOF) / exits. Also
    // tee to serial so a screenless boot can see the program's actual output
    // (the framebuffer isn't visible with -display none).
    _log("shell: pump\n");
    let is [256]u8 as pbuf;
    let is i64 as n with mut = sys.read(fds[0], cast(*u8, &pbuf[0]), 256);
    _log("shell: read n="); _lognum(n); _log("\n");
    while (n > 0) {
        term.puts(t, cast(*u8, &pbuf[0]), n);
        term.flush(t);
        sys.write_serial(cast(*u8, &pbuf[0]), n);
        n = sys.read(fds[0], cast(*u8, &pbuf[0]), 256);
        _log("shell: read n="); _lognum(n); _log("\n");
    }
    _log("shell: pumped\n");
    sys.close(fds[0]);
    let is i64 as status with mut = 0;
    _log("shell: waiting\n");
    sys.wait(pid, &status);
    _log("shell: exit="); _lognum(status); _log("\n");
}

// Tokenise `line` (len bytes) in place: NUL-terminate each token, fill argv_ptr/
// argv_len, return argc. Splits on spaces; collapses runs.
fn parse(line as *u8, len as i64, argv_ptr as *i64, argv_len as *i64) as i64 {
    let is i64 as argc with mut = 0;
    let is i64 as i with mut = 0;
    while (i < len && argc < MAX_ARGS) {
        while (i < len && line[i] == 32) { i = i + 1; }   // skip spaces
        if (i >= len) { break; }
        let is i64 as start = i;
        while (i < len && line[i] != 32) { i = i + 1; }
        argv_ptr[argc] = cast(i64, line) + start;
        argv_len[argc] = i - start;
        argc = argc + 1;
    }
    return argc;
}

fn streq(a as *u8, alen as i64, lit as *u8) as i64 {
    let is i64 as ll = slen(lit);
    if (alen != ll) { return 0; }
    let is i64 as i with mut = 0;
    while (i < ll) { if (a[i] != lit[i]) { return 0; } i = i + 1; }
    return 1;
}

fn run_line(t as *term.Term, line as *u8, len as i64) as void {
    let is [16]i64 as argv_ptr;
    let is [16]i64 as argv_len;
    let is i64 as argc = parse(line, len, cast(*i64, &argv_ptr[0]), cast(*i64, &argv_len[0]));
    if (argc == 0) { return; }
    let is *u8 as cmd = cast(*u8, argv_ptr[0]);
    let is i64 as cl = argv_len[0];
    if (streq(cmd, cl, "help") == 1) {
        puts(t, "builtin: help. programs on disk: echo cat ls uptime sysinfo\n");
        return;
    }
    run_program(t, cast(*i64, &argv_ptr[0]), cast(*i64, &argv_len[0]), argc);
}

fn main() as i32 {
    let is gfx.Framebuffer as fb = gfx.open();
    if (fb.ok == 0) { sys.write_serial("shell: NO FB\n", 13); sys.exit(cast(i32, 1)); }
    let is term.Term as t = term.init(fb.base, fb.fd, fb.width, fb.height, fb.pitch, fb.bpp);
    term.set_color(&t, 0x0040ff80, 0x00101018);
    puts(&t, "CausticOS shell v0\n");
    term.set_color(&t, 0x00c8c8c8, 0x00101018);
    puts(&t, "type 'help'. programs run from /<cmd>.cse with args + a console channel.\n\n");
    sys.write_serial("shell: ready\n", 13);

    let is i64 as kfd = input.open_keyboard();
    if (kfd < 0) { sys.write_serial("shell: NO KBD\n", 14); sys.exit(cast(i32, 2)); }

    // headless self-test: spawn two programs with args end-to-end (no keyboard
    // needed) so a screenless boot proves argv + console-channel + pump. A real
    // session past this point is driven by the keyboard loop below.
    _log("shell: demo begin\n");
    puts(&t, "$ sysinfo\n");        run_line(&t, "sysinfo", 7);
    puts(&t, "$ echo hello world\n"); run_line(&t, "echo hello world", 16);
    _log("shell: demo end\n");

    let is [256]u8 as line;
    let is i64 as llen with mut = 0;
    let is i64 as shift with mut = 0;
    let is input.KeyEvent as ev;
    puts(&t, "$ ");
    term.flush(&t);
    while (1 == 1) {
        if (input.read_event(kfd, &ev) == 1) {
            if (input.is_shift(ev.scancode) == 1) { shift = ev.pressed; }
            else if (ev.pressed == 1) {
                let is i64 as c = input.scancode_to_ascii(ev.scancode, shift);
                if (c == 0x0A) {
                    term.putc(&t, 0x0A); term.flush(&t);
                    run_line(&t, cast(*u8, &line[0]), llen);
                    llen = 0;
                    puts(&t, "$ "); term.flush(&t);
                } else if (c == 0x08) {
                    if (llen > 0) { llen = llen - 1; term.putc(&t, 0x08); term.flush(&t); }
                } else if (c != 0) {
                    if (llen < LINE_CAP - 1) { line[llen] = cast(u8, c); llen = llen + 1; term.putc(&t, c); term.flush(&t); }
                }
            }
        }
    }
    return 0;
}
