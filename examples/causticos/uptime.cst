// uptime — monotonic time since boot. `uptime`. Reads SYS_TIME_NOW_NS.
use "../../std/causticos/prog.cst" as prog;
use "../../std/os/causticos.cst" as sys;

fn main(argc as i64, argv as *u8) as i32 {
    let is i64 as ns = sys.time_ns();
    prog.outs("up ");
    prog.out_num(ns / 1000000000);
    prog.outs(" s (");
    prog.out_num(ns / 1000000);
    prog.outs(" ms since boot)\n");
    return 0;
}
