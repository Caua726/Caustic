// File I/O — read and write files using raw syscalls
//
// Creates a file, writes to it, reads it back, and cleans up.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;

fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_str(s as str.String) as void {
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    print_str(s);
    str.string_free(s);
}

// Write a string to a file (create/truncate). Returns bytes written or -1.
fn write_file(path as *u8, content as *u8, len as i64) as i64 {
    // O_WRONLY | O_CREAT | O_TRUNC = 577, mode 0644 = 420
    let is i64 as fd = linux.open(path, 577, 420);
    if (fd < 0) {
        return fd;
    }
    let is i64 as written = linux.write(fd, content, len);
    linux.close(fd);
    return written;
}

// Read entire file into a heap buffer. Returns String (len=0 on error).
fn read_file(path as *u8) as str.String {
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    if (fd < 0) {
        return str.String("");
    }

    // Get file size via lseek
    let is i64 as size = linux.lseek(fd, 0, linux.SEEK_END);
    linux.lseek(fd, 0, linux.SEEK_SET);

    let is str.String as s;
    if (size > 0) {
        s.ptr = mem.galloc(size + 1);
        linux.read(fd, s.ptr, size);
        s.ptr[size] = cast(u8, 0);
        s.len = cast(i32, size);
        s.cap = cast(i32, size);
    } else {
        s.ptr = cast(*u8, 0);
        s.len = 0;
        s.cap = 0;
    }

    linux.close(fd);
    return s;
}

// Append to a file. Returns bytes written or -1.
fn append_file(path as *u8, content as *u8, len as i64) as i64 {
    // O_WRONLY | O_CREAT | O_APPEND = 1089, mode 0644 = 420
    let is i64 as fd = linux.open(path, 1089, 420);
    if (fd < 0) {
        return fd;
    }
    let is i64 as written = linux.write(fd, content, len);
    linux.close(fd);
    return written;
}

fn main() as i32 {
    mem.gheapinit(1048576);

    let is *u8 as path = "/tmp/caustic_example.txt";

    // Write a file
    print("--- Write File ---\n");
    let is *u8 as content = "Hello from Caustic!\nThis is line 2.\n";
    let is i64 as written = write_file(path, content, 36);
    print("  wrote ");
    print_num(written);
    print(" bytes to ");
    print(path);
    print("\n");

    // Read it back
    print("\n--- Read File ---\n");
    let is str.String as data = read_file(path);
    print("  read ");
    print_num(cast(i64, data.len));
    print(" bytes:\n");
    print_str(data);
    str.string_free(data);

    // Append to the file
    print("--- Append ---\n");
    let is *u8 as extra = "This line was appended.\n";
    append_file(path, extra, 24);
    print("  appended 24 bytes\n");

    // Read again to verify
    print("\n--- Read After Append ---\n");
    let is str.String as data2 = read_file(path);
    print_str(data2);
    str.string_free(data2);

    // Check file exists
    print("--- File Exists ---\n");
    let is i64 as fd = linux.open(path, linux.O_RDONLY, 0);
    if (fd >= 0) {
        print("  ");
        print(path);
        print(" exists\n");
        linux.close(fd);
    }

    // Clean up
    // unlink syscall = 87
    syscall(87, path);
    print("  cleaned up temp file\n");

    return 0;
}
