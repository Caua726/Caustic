// Hello World — two ways to print in Caustic
//
// 1. Direct syscall (no dependencies)
// 2. linux.write wrapper

use "../std/linux.cst" as linux;

fn main() as i32 {
    // Method 1: raw syscall(write, stdout, ptr, len)
    syscall(1, 1, "1. Hello via syscall!\n", 22);

    // Method 2: linux.write wrapper
    linux.write(linux.STDOUT, "2. Hello via linux.write!\n", 26);

    return 0;
}
