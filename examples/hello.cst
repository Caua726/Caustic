use "../std/io.cst" as io;
// Hello World — two ways to print in Caustic
//
// 1. Direct syscall (no dependencies)
// 2. linux.write wrapper

use "../std/os/linux.cst" as linux;

fn main() as i32 {
    // Method 1: raw syscall(write, stdout, ptr, len)
    io._write_fd(io.STDOUT, "1. Hello via portable io!\n", 27);

    // Method 2: linux.write wrapper
    io._write_fd(io.STDOUT, "2. Hello via linux.write!\n", 26);

    return 0;
}
