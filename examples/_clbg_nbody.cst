// CLBG n-body — uses hardware sqrt via __builtin_sqrt
use "../std/math.cst" as math;

fn write_str_lit(s as *u8, n as i64) as void { syscall(1, 1, s, n); }
fn write_int(n as i64) as void {
    if (n == 0) { let is [1]u8 as z; z[0] = cast(u8, 48); syscall(1, 1, &z, 1); return; }
    let is [24]u8 as buf;
    let is i64 as val with mut = n;
    let is i32 as neg with mut = 0;
    if (val < 0) { neg = 1; val = 0 - val; }
    let is i32 as pos with mut = 23;
    while (val > 0) { buf[pos] = cast(u8, (val % 10) + 48); val = val / 10; pos = pos - 1; }
    if (neg == 1) { buf[pos] = cast(u8, 45); pos = pos - 1; }
    let is i64 as start = cast(i64, pos) + 1;
    syscall(1, 1, cast(*u8, cast(i64, &buf) + start), 24 - start);
}

let is f64 as PI with imut = 3.141592653589793;
let is f64 as SOLAR_MASS with imut = 39.47841760435743;
let is f64 as DAYS_PER_YEAR with imut = 365.24;
let is i32 as NB with imut = 5;

// Layout: 7 doubles per body — x, y, z, vx, vy, vz, mass
// 5 bodies × 7 = 35 doubles
let is [35]f64 as bodies with mut;

fn init_bodies() as void {
    // Sun
    bodies[0] = 0.0;  bodies[1] = 0.0;  bodies[2] = 0.0;
    bodies[3] = 0.0;  bodies[4] = 0.0;  bodies[5] = 0.0;
    bodies[6] = SOLAR_MASS;
    // Jupiter
    bodies[7]  =  4.84143144246472090;
    bodies[8]  = -1.16032004402742839;
    bodies[9]  = -0.103622044471123109;
    bodies[10] =  0.00166007664274403694 * DAYS_PER_YEAR;
    bodies[11] =  0.00769901118419740425 * DAYS_PER_YEAR;
    bodies[12] = -0.0000690460016972063023 * DAYS_PER_YEAR;
    bodies[13] =  0.000954791938424326609 * SOLAR_MASS;
    // Saturn
    bodies[14] =  8.34336671824457987;
    bodies[15] =  4.12479856412430479;
    bodies[16] = -0.403523417114321381;
    bodies[17] = -0.00276742510726862411 * DAYS_PER_YEAR;
    bodies[18] =  0.00499852801234917238 * DAYS_PER_YEAR;
    bodies[19] =  0.0000230417297573763929 * DAYS_PER_YEAR;
    bodies[20] =  0.000285885980666130812 * SOLAR_MASS;
    // Uranus
    bodies[21] =  12.8943695621391310;
    bodies[22] = -15.1111514016986312;
    bodies[23] = -0.223307578892655734;
    bodies[24] =  0.00296460137564761618 * DAYS_PER_YEAR;
    bodies[25] =  0.0023784717395948095 * DAYS_PER_YEAR;
    bodies[26] = -0.0000296589568540237556 * DAYS_PER_YEAR;
    bodies[27] =  0.0000436624404335156298 * SOLAR_MASS;
    // Neptune
    bodies[28] =  15.3796971148509165;
    bodies[29] = -25.9193146099879641;
    bodies[30] =  0.179258772950371181;
    bodies[31] =  0.00268067772490389322 * DAYS_PER_YEAR;
    bodies[32] =  0.00162824170038242295 * DAYS_PER_YEAR;
    bodies[33] = -0.0000951592254519715870 * DAYS_PER_YEAR;
    bodies[34] =  0.0000515138902046611451 * SOLAR_MASS;
}

// sqrt — hardware sqrtsd via std/math
fn sqrt(x as f64) as f64 { return math.sqrt(x); }

fn advance(dt as f64) as void {
    let is i32 as i with mut = 0;
    while (i < NB) {
        let is i32 as j with mut = i + 1;
        while (j < NB) {
            let is f64 as dx = bodies[i*7+0] - bodies[j*7+0];
            let is f64 as dy = bodies[i*7+1] - bodies[j*7+1];
            let is f64 as dz = bodies[i*7+2] - bodies[j*7+2];
            let is f64 as d2 = dx*dx + dy*dy + dz*dz;
            let is f64 as mag = dt / (d2 * sqrt(d2));
            let is f64 as mj = bodies[j*7+6];
            let is f64 as mi = bodies[i*7+6];
            bodies[i*7+3] = bodies[i*7+3] - dx * mj * mag;
            bodies[i*7+4] = bodies[i*7+4] - dy * mj * mag;
            bodies[i*7+5] = bodies[i*7+5] - dz * mj * mag;
            bodies[j*7+3] = bodies[j*7+3] + dx * mi * mag;
            bodies[j*7+4] = bodies[j*7+4] + dy * mi * mag;
            bodies[j*7+5] = bodies[j*7+5] + dz * mi * mag;
            j = j + 1;
        }
        i = i + 1;
    }
    i = 0;
    while (i < NB) {
        bodies[i*7+0] = bodies[i*7+0] + dt * bodies[i*7+3];
        bodies[i*7+1] = bodies[i*7+1] + dt * bodies[i*7+4];
        bodies[i*7+2] = bodies[i*7+2] + dt * bodies[i*7+5];
        i = i + 1;
    }
}

fn energy() as f64 {
    let is f64 as e with mut = 0.0;
    let is i32 as i with mut = 0;
    while (i < NB) {
        let is f64 as vx = bodies[i*7+3];
        let is f64 as vy = bodies[i*7+4];
        let is f64 as vz = bodies[i*7+5];
        let is f64 as mi = bodies[i*7+6];
        e = e + 0.5 * mi * (vx*vx + vy*vy + vz*vz);
        let is i32 as j with mut = i + 1;
        while (j < NB) {
            let is f64 as dx = bodies[i*7+0] - bodies[j*7+0];
            let is f64 as dy = bodies[i*7+1] - bodies[j*7+1];
            let is f64 as dz = bodies[i*7+2] - bodies[j*7+2];
            let is f64 as d = sqrt(dx*dx + dy*dy + dz*dz);
            e = e - (mi * bodies[j*7+6]) / d;
            j = j + 1;
        }
        i = i + 1;
    }
    return e;
}

fn offset_momentum() as void {
    let is f64 as px with mut = 0.0;
    let is f64 as py with mut = 0.0;
    let is f64 as pz with mut = 0.0;
    let is i32 as i with mut = 0;
    while (i < NB) {
        px = px + bodies[i*7+3] * bodies[i*7+6];
        py = py + bodies[i*7+4] * bodies[i*7+6];
        pz = pz + bodies[i*7+5] * bodies[i*7+6];
        i = i + 1;
    }
    bodies[3] = -px / SOLAR_MASS;
    bodies[4] = -py / SOLAR_MASS;
    bodies[5] = -pz / SOLAR_MASS;
}

// Print f64 with 9 decimal digits, e.g. "-0.169075164\n".
fn print_f64_9d(v as f64) as void {
    let is f64 as x with mut = v;
    if (x < 0.0) {
        write_str_lit("-", 1);
        x = 0.0 - x;
    }
    let is i64 as as_int with mut = cast(i64, x * 1000000000.0);
    let is i64 as int_part = as_int / 1000000000;
    let is i64 as frac_part = as_int - int_part * 1000000000;
    write_int(int_part);
    write_str_lit(".", 1);
    let is i64 as divisor with mut = 100000000;
    let is i64 as fr with mut = frac_part;
    while (divisor > 0) {
        let is i64 as d = fr / divisor;
        let is [1]u8 as digit;
        digit[0] = cast(u8, d + 48);
        syscall(1, 1, cast(*u8, &digit), 1);
        fr = fr - d * divisor;
        divisor = divisor / 10;
    }
    write_str_lit("\n", 1);
}

fn main() as i32 {
    let is i32 as N = 5000000;
    init_bodies();
    offset_momentum();
    print_f64_9d(energy());
    let is i32 as i with mut = 0;
    while (i < N) { advance(0.01); i = i + 1; }
    print_f64_9d(energy());
    return 0;
}
