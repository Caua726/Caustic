// Structs — definitions, impl blocks, methods, constructors
//
// Demonstrates struct types with associated functions and methods.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
let is mem.bins.Bins as _heap with mut;
use "../std/string.cst" as str;


fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
    str.string_free(s);
}

// --- Point struct with impl block ---

struct Point {
    x as i32;
    y as i32;
}

impl Point {
    // Associated function (constructor)
    fn new(x as i32, y as i32) as Point {
        let is Point as p;
        p.x = x;
        p.y = y;
        return p;
    }

    fn origin() as Point {
        return Point.new(0, 0);
    }

    // Methods (take self as *Point)
    fn sum(self as *Point) as i32 {
        return self.x + self.y;
    }

    fn scale(self as *Point, factor as i32) as void {
        self.x = self.x * factor;
        self.y = self.y * factor;
    }

    fn print(self as *Point) as void {
        print("(");
        print_num(cast(i64, self.x));
        print(", ");
        print_num(cast(i64, self.y));
        print(")");
    }
}

// --- Rectangle struct ---

struct Rect {
    origin as Point;
    width as i32;
    height as i32;
}

impl Rect {
    fn new(x as i32, y as i32, w as i32, h as i32) as Rect {
        let is Rect as r;
        r.origin = Point.new(x, y);
        r.width = w;
        r.height = h;
        return r;
    }

    fn area(self as *Rect) as i32 {
        return self.width * self.height;
    }

    fn print(self as *Rect) as void {
        print("Rect { origin: ");
        let is *Point as orig = &self.origin;
        orig.print();
        print(", width: ");
        print_num(cast(i64, self.width));
        print(", height: ");
        print_num(cast(i64, self.height));
        print(" }");
    }
}

fn main() as i32 {
    _heap = mem.bins.bins_new(1048576);

    // Constructor
    print("--- Constructors ---\n");
    let is Point as p = Point.new(3, 4);
    print("  p = ");
    p.print();
    print("\n");

    let is Point as o = Point.origin();
    print("  origin = ");
    o.print();
    print("\n");

    // Methods
    print("\n--- Methods ---\n");
    print("  p.sum() = ");
    print_num(cast(i64, p.sum()));
    print("\n");

    p.scale(10);
    print("  after p.scale(10): ");
    p.print();
    print("\n");

    // Nested struct
    print("\n--- Nested Struct ---\n");
    let is Rect as r = Rect.new(5, 10, 100, 50);
    print("  r = ");
    r.print();
    print("\n");
    print("  r.area() = ");
    print_num(cast(i64, r.area()));
    print("\n");

    // sizeof
    print("\n--- Sizes ---\n");
    print("  sizeof(Point) = ");
    print_num(sizeof(Point));
    print("\n");
    print("  sizeof(Rect) = ");
    print_num(sizeof(Rect));
    print("\n");

    return 0;
}
