// String operations — create, concat, find, compare
//
// Demonstrates the std/string.cst module.

use "../std/linux.cst" as linux;
use "../std/mem.cst" as mem;
use "../std/string.cst" as str;

fn print(s as *u8) as void {
    linux.write(linux.STDOUT, s, str.strlen(s));
}

fn print_str(s as str.String) as void {
    linux.write(linux.STDOUT, s.ptr, cast(i64, s.len));
}

fn print_num(n as i64) as void {
    let is str.String as s = str.int_to_string(n);
    print_str(s);
    str.string_free(s);
}

fn print_bool(v as i32) as void {
    if (v != 0) {
        print("true");
    } else {
        print("false");
    }
}

fn main() as i32 {
    mem.gheapinit(1048576);

    // Create strings
    let is str.String as hello = str.String("Hello");
    let is str.String as world = str.String("World");
    let is str.String as space = str.String(", ");

    // Concatenation
    print("--- Concatenation ---\n");
    let is str.String as hw = str.concat(hello, space);
    let is str.String as greeting = str.concat(hw, world);
    print("  ");
    print_str(greeting);
    print("\n");

    // Length
    print("\n--- Length ---\n");
    print("  \"Hello\" length: ");
    print_num(cast(i64, hello.len));
    print("\n");

    // Find
    print("\n--- Find ---\n");
    let is str.String as haystack = str.String("The quick brown fox");
    let is str.String as needle = str.String("brown");
    let is i32 as pos = str.find(haystack, needle);
    print("  \"brown\" in \"The quick brown fox\" at index: ");
    print_num(cast(i64, pos));
    print("\n");

    let is str.String as missing = str.String("zebra");
    let is i32 as pos2 = str.find(haystack, missing);
    print("  \"zebra\" in \"The quick brown fox\" at index: ");
    print_num(cast(i64, pos2));
    print(" (not found)\n");

    // Comparison
    print("\n--- Comparison ---\n");
    let is str.String as a = str.String("abc");
    let is str.String as b = str.String("abc");
    let is str.String as c = str.String("xyz");
    print("  \"abc\" == \"abc\": ");
    print_bool(str.eq(a, b));
    print("\n");
    print("  \"abc\" == \"xyz\": ");
    print_bool(str.eq(a, c));
    print("\n");

    // Starts/ends with
    print("\n--- Prefix / Suffix ---\n");
    let is str.String as prefix = str.String("The");
    let is str.String as suffix = str.String("fox");
    print("  \"The quick brown fox\" starts with \"The\": ");
    print_bool(str.starts_with(haystack, prefix));
    print("\n");
    print("  \"The quick brown fox\" ends with \"fox\": ");
    print_bool(str.ends_with(haystack, suffix));
    print("\n");

    // Contains
    print("\n--- Contains ---\n");
    print("  \"The quick brown fox\" contains \"quick\": ");
    let is str.String as q = str.String("quick");
    print_bool(str.contains(haystack, q));
    print("\n");

    // Parse int
    print("\n--- Parse Int ---\n");
    let is str.String as numstr = str.String("12345");
    let is i64 as n = str.parse_int(numstr);
    print("  parse_int(\"12345\") = ");
    print_num(n);
    print("\n");

    // Int to string
    print("\n--- Int to String ---\n");
    let is str.String as s = str.int_to_string(42);
    print("  int_to_string(42) = \"");
    print_str(s);
    print("\"\n");
    str.string_free(s);

    return 0;
}
