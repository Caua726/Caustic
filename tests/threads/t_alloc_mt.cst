// 4 threads alloc+free from a SHARED bins allocator (lazy-locked via mem.set_mt,
// activated by thread.spawn). Exit 0 iff no corruption / null returns.
use "../../std/thread.cst" as thread;
use "../../std/mem.cst" only bins as mem;
let is mem.Bins as shared_bins with mut;
fn worker(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < 20000) {
        let is *u8 as p = mem.bins.bins_alloc(&shared_bins, 64);
        if (cast(i64, p) == 0) { return 1; }
        p[0] = cast(u8, 7);
        if (p[0] != 7) { return 2; }
        mem.bins.bins_free(&shared_bins, p);
        i = i + 1;
    }
    return 0;
}
fn main() as i64 {
    shared_bins = mem.bins.bins_new(65536);
    let is [4]thread.Thread as ts;
    let is i32 as i with mut = 0;
    while (i < 4) { thread.spawn(&ts[i], fn_ptr(worker), 0); i = i + 1; }
    let is i64 as bad with mut = 0;
    i = 0;
    while (i < 4) { bad = bad + thread.join(&ts[i]); i = i + 1; }
    return bad;
}
