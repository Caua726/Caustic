// spawn one thread that writes a global and returns a value; join reads both.
use "../../std/thread.cst" as thread;
let is i64 as g with mut = 0;
fn worker(arg as i64) as i64 { g = arg + 2; return 7; }
fn main() as i64 {
    let is thread.Thread as t with mut;
    if (thread.spawn(&t, fn_ptr(worker), 40) != 0) { return 1; }
    if (thread.join(&t) != 7) { return 2; }   // worker return value
    return g - 42;                            // 0 iff worker set g = 42
}
