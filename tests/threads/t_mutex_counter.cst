// 4 threads x 50000 increments of a NON-atomic counter under a Mutex == 200000.
// Without correct mutual exclusion this loses updates.
use "../../std/thread.cst" as thread;
use "../../std/sync.cst" as sync;
let is sync.Mutex as m with mut;
let is i64 as counter with mut = 0;
fn worker(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < 50000) {
        sync.mutex_lock(&m);
        counter = counter + 1;
        sync.mutex_unlock(&m);
        i = i + 1;
    }
    return 0;
}
fn main() as i64 {
    let is [4]thread.Thread as ts;
    let is i32 as i with mut = 0;
    while (i < 4) { thread.spawn(&ts[i], fn_ptr(worker), 0); i = i + 1; }
    i = 0;
    while (i < 4) { thread.join(&ts[i]); i = i + 1; }
    if (counter == 200000) { return 0; }
    return 1;
}
