// Single-threaded atomic semantics: add/load/store/xchg/cas (hit+miss), 32-bit.
let is i64 as g with mut = 0;
let is i32 as g32 with mut = 0;

fn main() as i64 {
    g = 10;
    if (atomic_add(&g, 5) != 10) { return 1; }       // returns OLD
    if (atomic_load(&g) != 15) { return 2; }
    atomic_store(&g, 100);
    if (atomic_load(&g) != 100) { return 3; }
    if (atomic_xchg(&g, 7) != 100) { return 4; }      // returns OLD
    if (atomic_load(&g) != 7) { return 5; }
    if (atomic_cas(&g, 7, 99) != 7) { return 6; }      // hit: returns OLD
    if (atomic_load(&g) != 99) { return 7; }
    if (atomic_cas(&g, 50, 123) != 99) { return 8; }   // miss: returns OLD, no swap
    if (atomic_load(&g) != 99) { return 9; }
    g32 = 1000;
    if (atomic_add(&g32, 1) != 1000) { return 10; }
    if (atomic_load(&g32) != 1001) { return 11; }
    fence();
    return 0;
}
