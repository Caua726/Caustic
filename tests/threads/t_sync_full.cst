// Exercises Channel (Mutex+Cond), WaitGroup, RwLock, and Once together.
use "../../std/thread.cst" as thread;
use "../../std/sync.cst" as sync;

let is sync.Channel as ch with mut;
let is sync.WaitGroup as prod_wg with mut;
let is i64 as recv_sum with mut = 0;
fn producer(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < 1000) { let is i64 as v = 1; sync.chan_send(&ch, cast(*u8, &v)); i = i + 1; }
    sync.wg_done(&prod_wg);
    return 0;
}
fn consumer(arg as i64) as i64 {
    let is i64 as v with mut = 0;
    while (sync.chan_recv(&ch, cast(*u8, &v)) == 0) { recv_sum = recv_sum + v; }
    return 0;
}

let is sync.RwLock as rw with mut;
let is i64 as shared with mut = 100;
fn reader(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    let is i64 as bad with mut = 0;
    while (i < 30000) {
        sync.rw_read_lock(&rw);
        let is i64 as v = shared;
        if (v != 100 && v != 200) { bad = bad + 1; }
        sync.rw_read_unlock(&rw);
        i = i + 1;
    }
    return bad;
}
fn writer(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < 1000) {
        sync.rw_write_lock(&rw);
        shared = 200;
        shared = 100;
        sync.rw_write_unlock(&rw);
        i = i + 1;
    }
    return 0;
}

let is sync.Once as once with mut;
let is i64 as init_count with mut = 0;
fn do_init() as void { init_count = init_count + 1; }
fn once_worker(arg as i64) as i64 { sync.once_run(&once, fn_ptr(do_init)); return 0; }

fn main() as i64 {
    // Channel + WaitGroup: 3 producers x1000, 1 consumer sums -> 3000.
    if (sync.chan_init(&ch, 64, 8) != 0) { return 10; }
    sync.wg_add(&prod_wg, 3);
    let is [3]thread.Thread as prods;
    let is thread.Thread as cons;
    thread.spawn(&cons, fn_ptr(consumer), 0);
    let is i32 as i with mut = 0;
    while (i < 3) { thread.spawn(&prods[i], fn_ptr(producer), 0); i = i + 1; }
    sync.wg_wait(&prod_wg);
    sync.chan_close(&ch);
    thread.join(&cons);
    i = 0; while (i < 3) { thread.join(&prods[i]); i = i + 1; }
    if (recv_sum != 3000) { return 1; }

    // RwLock: readers must never observe a torn value.
    let is [3]thread.Thread as rs;
    let is thread.Thread as ws;
    thread.spawn(&ws, fn_ptr(writer), 0);
    i = 0; while (i < 3) { thread.spawn(&rs[i], fn_ptr(reader), 0); i = i + 1; }
    thread.join(&ws);
    let is i64 as total_bad with mut = 0;
    i = 0; while (i < 3) { total_bad = total_bad + thread.join(&rs[i]); i = i + 1; }
    if (total_bad != 0) { return 2; }

    // Once: 8 threads, init runs exactly once.
    let is [8]thread.Thread as os;
    i = 0; while (i < 8) { thread.spawn(&os[i], fn_ptr(once_worker), 0); i = i + 1; }
    i = 0; while (i < 8) { thread.join(&os[i]); i = i + 1; }
    if (init_count != 1) { return 3; }

    return 0;
}
