// 200 sequential spawn+join cycles: stress stack mmap/reclaim and the tid
// (PARENT_SETTID / CHILD_CLEARTID) join race over many iterations.
use "../../std/thread.cst" as thread;
fn worker(arg as i64) as i64 { return arg + 1; }
fn main() as i64 {
    let is i64 as i with mut = 0;
    while (i < 200) {
        let is thread.Thread as t with mut;
        if (thread.spawn(&t, fn_ptr(worker), i) != 0) { return 1; }
        if (thread.join(&t) != i + 1) { return 2; }
        i = i + 1;
    }
    return 0;
}
