// 4 threads x 50000 atomic_add on a shared counter == 200000 (no lost updates).
use "../../std/thread.cst" as thread;
let is i64 as counter with mut = 0;
fn worker(arg as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < 50000) { atomic_add(&counter, 1); i = i + 1; }
    return 0;
}
fn main() as i64 {
    let is [4]thread.Thread as ts;
    let is i32 as i with mut = 0;
    while (i < 4) { thread.spawn(&ts[i], fn_ptr(worker), 0); i = i + 1; }
    i = 0;
    while (i < 4) { thread.join(&ts[i]); i = i + 1; }
    if (atomic_load(&counter) == 200000) { return 0; }
    return 1;
}
