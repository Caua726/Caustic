use "../../std/io.cst" as io;

fn add(a as i64, b as i64) as i64 { return a + b; }
fn mul(a as i64, b as i64) as i64 { return a * b; }
fn sub(a as i64, b as i64) as i64 { return a - b; }

fn apply(f as *u8, x as i64, y as i64) as i64 {
    return call(f, x, y);
}

fn main() as i32 {
    let is *u8 as fadd = fn_ptr(add);
    let is *u8 as fmul = fn_ptr(mul);
    let is *u8 as fsub = fn_ptr(sub);
    io.printf("add(6,7)=%d mul(6,7)=%d sub(6,7)=%d\n",
              apply(fadd, 6, 7), apply(fmul, 6, 7), apply(fsub, 6, 7));

    // dispatch table
    let is [3]*u8 as ops;
    ops[0] = fadd; ops[1] = fmul; ops[2] = fsub;
    let is i64 as i with mut = 0;
    while (i < 3) {
        io.printf("ops[%d](10,3) = %d\n", i, call(ops[i], 10, 3));
        i = i + 1;
    }
    return cast(i32, apply(fadd, 40, 2));
}
