use "../../std/io.cst" as io;

struct Vec2 { x as i64; y as i64; }

fn dot(a as *Vec2, b as *Vec2) as i64 {
    return a.x * b.x + a.y * b.y;
}

fn fib(n as i64) as i64 {
    if (n < 2) { return n; }
    return fib(n - 1) + fib(n - 2);
}

fn is_prime(n as i64) as i64 {
    if (n < 2) { return 0; }
    let is i64 as d with mut = 2;
    while (d * d <= n) {
        if (n % d == 0) { return 0; }
        d = d + 1;
    }
    return 1;
}

fn main() as i32 {
    io.write_str(io.STDOUT, "=== Caustic -> WASM demo ===\n");

    // recursion
    io.write_str(io.STDOUT, "fib(15) = ");
    io.write_int(io.STDOUT, fib(15));
    io.write_str(io.STDOUT, "\n");

    // structs by pointer
    let is Vec2 as a; a.x = 3; a.y = 4;
    let is Vec2 as b; b.x = 5; b.y = 6;
    io.write_str(io.STDOUT, "dot((3,4),(5,6)) = ");
    io.write_int(io.STDOUT, dot(&a, &b));
    io.write_str(io.STDOUT, "\n");

    // loop + array + branching
    let is [20]i64 as sieve;
    io.write_str(io.STDOUT, "primes < 20: ");
    let is i64 as i with mut = 0;
    let is i64 as count with mut = 0;
    while (i < 20) {
        if (is_prime(i) == 1) {
            io.write_int(io.STDOUT, i);
            io.write_str(io.STDOUT, " ");
            count = count + 1;
        }
        i = i + 1;
    }
    io.write_str(io.STDOUT, "\n");

    io.write_str(io.STDOUT, "prime count = ");
    io.write_int(io.STDOUT, count);
    io.write_str(io.STDOUT, "\n=== done ===\n");
    return cast(i32, count);   // exit code = 8
}
