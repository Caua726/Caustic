// Custom (non-WASI) host imports: extern "<module>" fn ... becomes a wasm import
// from that module, provided by the host at instantiation. Args/results are i64
// (pointers arrive as linear-memory offsets; the host reads the module's memory).
//
// Run e.g. under Node by supplying the "env" module:
//   const imp = { env: { host_add:(a,b)=>a+b, host_log:(x)=>console.log(x) }, ... };
//   const { instance } = await WebAssembly.instantiate(bytes, imp);
extern "env" fn host_add(a as i64, b as i64) as i64;
extern "env" fn host_log(x as i64) as void;

fn main() as i32 {
    host_log(99);
    return cast(i32, host_add(40, 2));
}
