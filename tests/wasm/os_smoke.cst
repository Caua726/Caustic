use "../../std/io.cst" as io;
use "../../std/time.cst" as time;
use "../../std/random.cst" as rng;
use "../../std/env.cst" as env;

fn yn(cond as i32) as *u8 { if (cond != 0) { return "yes"; } return "NO"; }

fn main(argc as i64, argv as i64) as i32 {
    env.init(argc, cast(*u8, argv));

    io.write_str(io.STDOUT, "== filesystem ==\n");
    io.mkdir("/tdir");
    let is i64 as fd = io._open_write("/tdir/f.txt");
    io._write_fd(fd, "hello fs\n", 9);
    io._close_fd(fd);
    io.write_str(io.STDOUT, "mtime>0:      "); io.write_str(io.STDOUT, yn(cast(i32, io.mtime("/tdir/f.txt") > 0))); io.write_str(io.STDOUT, "\n");
    io.rename("/tdir/f.txt", "/tdir/g.txt");
    io.write_str(io.STDOUT, "renamed:      "); io.write_str(io.STDOUT, yn(io.exists("/tdir/g.txt"))); io.write_str(io.STDOUT, "\n");
    io.write_str(io.STDOUT, "old gone:     "); io.write_str(io.STDOUT, yn(cast(i32, io.exists("/tdir/f.txt") == 0))); io.write_str(io.STDOUT, "\n");
    io.unlink("/tdir/g.txt");
    io.write_str(io.STDOUT, "unlinked:     "); io.write_str(io.STDOUT, yn(cast(i32, io.exists("/tdir/g.txt") == 0))); io.write_str(io.STDOUT, "\n");

    io.write_str(io.STDOUT, "== time ==\n");
    let is i64 as t0 = time.now_ns();
    time.sleep_ms(3);
    io.write_str(io.STDOUT, "monotonic++:  "); io.write_str(io.STDOUT, yn(cast(i32, time.now_ns() > t0))); io.write_str(io.STDOUT, "\n");
    io.write_str(io.STDOUT, "wall clock:   "); io.write_str(io.STDOUT, yn(cast(i32, time.unix_time() > 1000000000))); io.write_str(io.STDOUT, "\n");

    io.write_str(io.STDOUT, "== random ==\n");
    rng.seed();
    let is i64 as a = rng.range(0, 1000000);
    let is i64 as b = rng.range(0, 1000000);
    io.write_str(io.STDOUT, "two differ:   "); io.write_str(io.STDOUT, yn(cast(i32, a != b))); io.write_str(io.STDOUT, "\n");
    io.write_str(io.STDOUT, "in range:     "); io.write_str(io.STDOUT, yn(cast(i32, a >= 0 && a < 1000000))); io.write_str(io.STDOUT, "\n");

    io.write_str(io.STDOUT, "== env ==\n");
    let is *u8 as v = env.getenv("CAUSTIC_TEST");
    io.write_str(io.STDOUT, "CAUSTIC_TEST="); 
    if (cast(i64, v) != 0) { io.write_str(io.STDOUT, v); } else { io.write_str(io.STDOUT, "(null)"); }
    io.write_str(io.STDOUT, "\n");
    return 0;
}
