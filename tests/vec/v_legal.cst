fn add3(c as *i32, a as *i32, b as *i32, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) { c[i] = a[i] + b[i]; i = i + 1; }      // VECTORIZABLE rt=1 (distinct bases)
}
fn rec(a as *i32, n as i64) as void {
    let is i64 as i with mut = 1;
    while (i < n) { a[i] = a[i-1] + 1; i = i + 1; }        // MISSED unsafe (backward dist 1)
}
fn evenodd(a as *i32, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) { a[2*i] = a[2*i+1] + 1; i = i + 1; }    // NODEP (even vs odd) -> vectorizable
}
fn search(a as *i32) as i64 {
    let is i64 as i with mut = 0;
    while (a[i] != 0) { i = i + 1; }                        // MISSED not-countable (data exit)
    return i;
}
fn main() as i32 { return 0; }
