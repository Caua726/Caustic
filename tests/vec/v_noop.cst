// M0/C1 scaffold test: with vec_use_v2=0 the legacy pass handles this reduction.
fn main() as i32 {
    let is [8]i32 as a; let is i64 as i with mut = 0;
    while (i < 8) { a[i] = cast(i32, i); i = i + 1; }
    let is i32 as s with mut = 0; i = 0;
    while (i < 8) { s = s + a[i]; i = i + 1; }
    return s;   // 0+1+..+7 = 28
}
