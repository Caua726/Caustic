// Build a tiny canonical CSIF in memory and exercise the strict container parser.
use "../std/causticos/img/csif.cst" as csif;

fn u16(p as *u8, o as i64, v as i64) as void {
    p[o] = cast(u8, v); p[o + 1] = cast(u8, v >> 8);
}

fn u32(p as *u8, o as i64, v as i64) as void {
    p[o] = cast(u8, v); p[o + 1] = cast(u8, v >> 8);
    p[o + 2] = cast(u8, v >> 16); p[o + 3] = cast(u8, v >> 24);
}

fn u64(p as *u8, o as i64, v as i64) as void {
    u32(p, o, v); u32(p, o + 4, v >> 32);
}

fn typ(p as *u8, o as i64, a as i64, b as i64, c as i64, d as i64) as void {
    p[o] = cast(u8, a); p[o + 1] = cast(u8, b);
    p[o + 2] = cast(u8, c); p[o + 3] = cast(u8, d);
}

fn chunk_head(p as *u8, off as i64, a as i64, b as i64, c as i64, d as i64,
              flags as i64, plen as i64) as void {
    typ(p, off, a, b, c, d); u32(p, off + 4, flags); u64(p, off + 8, plen);
}

fn chunk_crc(p as *u8, off as i64, plen as i64) as void {
    u32(p, off + 16 + plen, csif.crc32(p, off, 16 + plen));
}

fn dir_rec(p as *u8, rec as i64, a as i64, b as i64, c as i64, d as i64,
           flags as i64, off as i64, total as i64, seq as i64) as void {
    typ(p, rec, a, b, c, d); u32(p, rec + 4, flags);
    u64(p, rec + 8, off); u64(p, rec + 16, total);
    u32(p, rec + 24, seq); u32(p, rec + 28, 0);
}

fn build_fixture(p as *u8) as void {
    let is i64 as z with mut = 0;
    while (z < 784) { p[z] = cast(u8, 0); z = z + 1; }

    // Header: BASELINE level 1, random layout, CRC32-IEEE, six chunks.
    typ(p, 0, 67, 83, 73, 70);
    p[4]=cast(u8,0x89); p[5]=cast(u8,0x0D); p[6]=cast(u8,0x0A);
    p[7]=cast(u8,0x1A); p[8]=cast(u8,0x0A); p[9]=cast(u8,0);
    u16(p, 0x0A, 1); p[0x0C]=cast(u8,0); p[0x0D]=cast(u8,1);
    p[0x0E]=cast(u8,0); p[0x0F]=cast(u8,1);
    p[0x10]=cast(u8,0); p[0x11]=cast(u8,1); u16(p,0x12,0);
    u32(p,0x14,6); u64(p,0x18,64); u64(p,0x20,784);
    u64(p,0x28,0); u64(p,0x30,0);

    // Directory and canonical chunk layout.
    dir_rec(p,64,  73,76,73,77, 11,256,204,0);  // ILIM
    dir_rec(p,96,  73,72,68,82, 27,464,96,1);   // IHDR
    dir_rec(p,128, 73,67,79,76, 27,560,36,2);   // ICOL
    dir_rec(p,160, 73,67,79,68, 27,600,80,3);   // ICOD
    dir_rec(p,192, 73,68,65,84, 51,680,55,4);   // IDAT
    dir_rec(p,224, 73,69,78,68, 11,736,44,5);   // IEND

    // ILIM, matching the reference encoder's level-1 ceilings.
    chunk_head(p,256,73,76,73,77,11,184);
    let is [23]i64 as lim;
    lim[0]=65536; lim[1]=65536; lim[2]=1073741824; lim[3]=16777216;
    lim[4]=1073741824; lim[5]=16; lim[6]=16; lim[7]=1073741824;
    lim[8]=4096; lim[9]=1048576; lim[10]=16; lim[11]=65536;
    lim[12]=16; lim[13]=16; lim[14]=16; lim[15]=65536;
    lim[16]=1048576; lim[17]=65536; lim[18]=65536; lim[19]=65536;
    lim[20]=1048576; lim[21]=16777216; lim[22]=256;
    let is i64 as i with mut = 0;
    while (i < 23) { u64(p, 272 + i * 8, lim[i]); i = i + 1; }
    chunk_crc(p,256,184);

    // IHDR: one 1x1 RGB8 pixel.
    chunk_head(p,464,73,72,68,82,27,76);
    u64(p,480,0); u32(p,488,1); u32(p,492,1); u32(p,496,1);
    p[500]=cast(u8,0); p[501]=cast(u8,0); p[502]=cast(u8,8); p[503]=cast(u8,0);
    p[504]=cast(u8,2); p[505]=cast(u8,3); p[506]=cast(u8,1); p[507]=cast(u8,1);
    p[508]=cast(u8,0); p[509]=cast(u8,0); p[510]=cast(u8,0); p[511]=cast(u8,0);
    u32(p,512,0); u32(p,516,0); u32(p,520,1); u32(p,524,1);
    u32(p,528,0); u32(p,532,0); u32(p,536,1); u32(p,540,1);
    u32(p,544,1); u32(p,548,1); u32(p,552,0);
    chunk_crc(p,464,76);

    // ICOL: sRGB/BT.709, identity matrix, full range.
    chunk_head(p,560,73,67,79,76,27,16);
    u64(p,576,0); p[584]=cast(u8,0); p[585]=cast(u8,1);
    p[586]=cast(u8,13); p[587]=cast(u8,0); p[588]=cast(u8,1);
    p[589]=cast(u8,0); p[590]=cast(u8,1); p[591]=cast(u8,1);
    chunk_crc(p,560,16);

    // ICOD: RAW v1, one untiled whole-image stream, 8-byte RAW params.
    chunk_head(p,600,73,67,79,68,27,60);
    u64(p,616,0); u16(p,624,0); u16(p,626,1);
    p[628]=cast(u8,1); p[629]=cast(u8,0); p[630]=cast(u8,0); p[631]=cast(u8,0);
    u32(p,632,0); u32(p,636,0); u32(p,640,1); u32(p,644,1);
    u32(p,648,1); u32(p,652,1); u32(p,656,0); u16(p,660,3);
    p[662]=cast(u8,0); p[663]=cast(u8,0); u32(p,664,8);
    p[668]=cast(u8,1); p[669]=cast(u8,0); p[670]=cast(u8,1);
    chunk_crc(p,600,60);

    // IDAT: item 0, whole image, pixel {17,34,51}.
    chunk_head(p,680,73,68,65,84,51,35);
    u64(p,696,0); u32(p,704,0); u32(p,708,0);
    u32(p,712,0); u32(p,716,0); u32(p,720,0); u32(p,724,0);
    p[728]=cast(u8,17); p[729]=cast(u8,34); p[730]=cast(u8,51);
    chunk_crc(p,680,35);

    // IEND: terminal marker. Whole-file checksum is informational in BASELINE.
    chunk_head(p,736,73,69,78,68,11,24);
    chunk_crc(p,736,24);
    u64(p,0x38,csif.crc32(p,0,0x38));
}

fn main() as i32 {
    let is [784]u8 as file;
    let is [3]u8 as out;
    build_fixture(cast(*u8, &file[0]));

    let is csif.Image as im = csif.decode_into(
        cast(*u8, &file[0]), 784, cast(*u8, &out[0]), 3);
    if (im.ok == 0 || im.width != 1 || im.height != 1 || im.nchan != 3) { return 1; }
    if (out[0]!=cast(u8,17) || out[1]!=cast(u8,34) || out[2]!=cast(u8,51)) { return 2; }

    let is csif.Image as small = csif.decode_into(
        cast(*u8, &file[0]), 784, cast(*u8, &out[0]), 2);
    if (small.ok != 0 || small.err != csif.ERR_OUTPUT) { return 3; }

    // Directory/header flag mismatch is rejected before codec dispatch.
    file[68] = file[68] ^ cast(u8, 1);
    let is csif.Image as flags = csif.decode_into(
        cast(*u8, &file[0]), 784, cast(*u8, &out[0]), 3);
    if (flags.ok != 0 || flags.err != csif.ERR_FLAG_MISMATCH) { return 4; }
    file[68] = file[68] ^ cast(u8, 1);

    // CRC-covered payload corruption is rejected before codec dispatch.
    file[728] = file[728] ^ cast(u8, 1);
    let is csif.Image as crc = csif.decode_into(
        cast(*u8, &file[0]), 784, cast(*u8, &out[0]), 3);
    if (crc.ok != 0 || crc.err != csif.ERR_CRC_CRITICAL) { return 5; }
    file[728] = file[728] ^ cast(u8, 1);

    // Dimension above the declared/hard ceiling, with a valid chunk CRC.
    u32(cast(*u8,&file[0]),488,70000); chunk_crc(cast(*u8,&file[0]),464,76);
    let is csif.Image as dims = csif.decode_into(
        cast(*u8, &file[0]), 784, cast(*u8, &out[0]), 3);
    if (dims.ok != 0 || dims.err != csif.ERR_DIMS) { return 6; }
    return 0;
}
