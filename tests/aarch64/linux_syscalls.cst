use "../../std/os/linux.cst" as linux;

fn main() as i32 {
    let is *u8 as path = "/tmp/caustic-aarch64-syscalls.tmp";
    let is i64 as fd = linux.open(path, linux.O_WRONLY + linux.O_CREAT + linux.O_TRUNC, linux.PERM_600);
    if (fd < 0) { return 1; }
    if (linux.write(fd, "abc", 3) != 3) { return 2; }
    if (linux.close(fd) != 0) { return 3; }

    let is [144]u8 as st;
    if (linux.stat(path, &st) != 0) { return 4; }

    let is i64 as rd = linux.open(path, linux.O_RDONLY, 0);
    if (rd < 0) { return 5; }
    let is [4]u8 as data;
    if (linux.read(rd, &data, 3) != 3) { return 6; }
    linux.close(rd);
    if (data[0] != 97 || data[1] != 98 || data[2] != 99) { return 7; }

    let is *u8 as page = linux.mmap(cast(*u8, 0), 4096,
        linux.PROT_READ + linux.PROT_WRITE,
        linux.MAP_PRIVATE + linux.MAP_ANONYMOUS, 0 - 1, 0);
    if (cast(i64, page) == linux.MAP_FAILED || cast(i64, page) == 0) { return 8; }
    page[0] = 42;
    if (page[0] != 42 || linux.munmap(page, 4096) != 0) { return 9; }

    let is [2]i64 as ts;
    if (linux.clock_gettime(linux.CLOCK_MONOTONIC, &ts) != 0) { return 10; }
    let is [8]u8 as random;
    if (linux.getrandom(&random, 8, 0) != 8) { return 11; }
    if (linux.getpid() <= 0 || linux.gettid() <= 0) { return 12; }

    let is i64 as sock = linux.socket(linux.AF_INET, linux.SOCK_STREAM, 0);
    // Sandboxes may deny socket() with EPERM; a successful descriptor is
    // still closed, while filesystem/memory/time syscalls remain strict.
    if (sock >= 0) { linux.close(sock); }

    if (linux.unlink(path) != 0) { return 13; }
    let is *u8 as dir = "/tmp/caustic-aarch64-dir";
    linux.rmdir(dir);
    if (linux.mkdir(dir, linux.PERM_700) != 0) { return 14; }
    if (linux.rmdir(dir) != 0) { return 15; }
    return 0;
}
