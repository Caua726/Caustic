// Test: with section attribute on global variables

let is i64 as normal_var with mut = 42;

let is i64 as driver_entry with section(".drivers_init") = 99;

let is i64 as another_entry with mut with section(".drivers_init") = 100;

fn main() as i32 {
    // Just verify the globals are accessible
    if (driver_entry != 99) { return 1; }
    if (another_entry != 100) { return 2; }
    if (normal_var != 42) { return 3; }
    return 0;
}
