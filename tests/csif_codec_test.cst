// Portable conformance checks for the CSIF BASELINE RAW and QOI decoders.
use "../std/causticos/img/codec_raw.cst" as raw;
use "../std/causticos/img/codec_qoi.cst" as qoi;

fn test_raw() as i32 {
    let is [7]u8 as src;
    src[0] = cast(u8, 1); src[1] = cast(u8, 2); src[2] = cast(u8, 3);
    src[3] = cast(u8, 4); src[4] = cast(u8, 5); src[5] = cast(u8, 6);
    src[6] = cast(u8, 99);
    let is [6]u8 as out;

    if (raw.decode(cast(*u8, &src[0]), 6, cast(*u8, &out[0]), 2, 1, 3) != 0) { return 1; }
    let is i64 as i with mut = 0;
    while (i < 6) {
        if (out[i] != src[i]) { return 2; }
        i = i + 1;
    }
    if (raw.decode(cast(*u8, &src[0]), 5, cast(*u8, &out[0]), 2, 1, 3) != 0 - 1) { return 3; }
    if (raw.decode(cast(*u8, &src[0]), 7, cast(*u8, &out[0]), 2, 1, 3) != 0 - 2) { return 4; }
    if (raw.decode(cast(*u8, &src[0]), 0, cast(*u8, &out[0]), 0, 1, 3) != 0 - 3) { return 5; }
    return 0;
}

fn test_qoi_rgb() as i32 {
    // RGB(10,20,30), INDEX(hash=9), RUN(1), DIFF(+1,-1,0),
    // LUMA(dg=+2, dr-dg=+1, db-dg=-1).
    let is [9]u8 as src;
    src[0] = cast(u8, 0xFE);
    src[1] = cast(u8, 10); src[2] = cast(u8, 20); src[3] = cast(u8, 30);
    src[4] = cast(u8, 9);
    src[5] = cast(u8, 0xC0);
    src[6] = cast(u8, 0x76);
    src[7] = cast(u8, 0xA2); src[8] = cast(u8, 0x97);

    let is [15]u8 as out;
    if (qoi.decode(cast(*u8, &src[0]), 9, cast(*u8, &out[0]), 5, 1, 3) != 0) { return 10; }
    let is [15]u8 as want;
    want[0]=cast(u8,10); want[1]=cast(u8,20); want[2]=cast(u8,30);
    want[3]=cast(u8,10); want[4]=cast(u8,20); want[5]=cast(u8,30);
    want[6]=cast(u8,10); want[7]=cast(u8,20); want[8]=cast(u8,30);
    want[9]=cast(u8,11); want[10]=cast(u8,19); want[11]=cast(u8,30);
    want[12]=cast(u8,14); want[13]=cast(u8,21); want[14]=cast(u8,31);
    let is i64 as i with mut = 0;
    while (i < 15) {
        if (out[i] != want[i]) { return 11; }
        i = i + 1;
    }
    return 0;
}

fn test_qoi_rgba_and_errors() as i32 {
    let is [6]u8 as rgba;
    rgba[0]=cast(u8,0xFF); rgba[1]=cast(u8,1); rgba[2]=cast(u8,2);
    rgba[3]=cast(u8,3); rgba[4]=cast(u8,4); rgba[5]=cast(u8,99);
    let is [4]u8 as out;
    if (qoi.decode(cast(*u8, &rgba[0]), 5, cast(*u8, &out[0]), 1, 1, 4) != 0) { return 20; }
    if (out[0]!=cast(u8,1) || out[1]!=cast(u8,2)
        || out[2]!=cast(u8,3) || out[3]!=cast(u8,4)) { return 21; }
    if (qoi.decode(cast(*u8, &rgba[0]), 4, cast(*u8, &out[0]), 1, 1, 4) != 0 - 1) { return 22; }
    if (qoi.decode(cast(*u8, &rgba[0]), 6, cast(*u8, &out[0]), 1, 1, 4) != 0 - 3) { return 23; }

    let is [1]u8 as run;
    run[0] = cast(u8, 0xC1); // two pixels into a one-pixel output
    if (qoi.decode(cast(*u8, &run[0]), 1, cast(*u8, &out[0]), 1, 1, 4) != 0 - 2) { return 24; }
    if (qoi.decode(cast(*u8, &run[0]), 1, cast(*u8, &out[0]), 0, 1, 4) != 0 - 4) { return 25; }
    return 0;
}

fn main() as i32 {
    let is i32 as rc with mut = test_raw();
    if (rc != 0) { return rc; }
    rc = test_qoi_rgb();
    if (rc != 0) { return rc; }
    return test_qoi_rgba_and_errors();
}
