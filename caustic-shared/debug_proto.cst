// Shared protocol constants for the Caustic-internal debug-info pipeline.
//
// The assembler writes a `.cstdebug` custom section per .obj; the linker
// reads it back to synthesize CodeView records into the PDB module stream.
// Both endpoints must agree on the leading magic; drift here silently
// drops all debug info. Centralized here so changes propagate atomically.

let is i64 as CSTDEBUG_MAGIC with imut = 3313585073;     // 0xC57DBCB1
